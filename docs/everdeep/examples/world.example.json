    "e_s5oh9z7uunjy01": {
      "id": "e_s5oh9z7uunjy01",
      "kind": "note",
      "name": "The feud on the square",
      "fields": {},
      "body": [
        {
          "type": "paragraph",
          "id": "b_283qxtxh",
          "text": "{@e e_o3cy312s62w7ju|The Animals Shop} and {@e e_sgwqh8oj6hubcy|The Religious Goods Shop} have not shared a civil word in years. {@e e_wglfninzb99rwy|Floriana} and {@e e_uokmrydv3og5u8|Oy Xiaong} each swear the other started it; {@e e_c7peu63ugg2bmw|Fendothek Gemzirgeno} and {@e e_xblfpc229gnvqw|Alupisys} take different sides at every family supper."
        }
      ],
      "rev": 1,
      "created": "2026-07-13T00:43:48.158Z",
      "updated": "2026-07-13T00:43:48.158Z",
      "parentId": "e_townbramhollow",
      "tags": [
        "life",
        "rumor"
      ]
    },
    "e_zgxch7kd77ximc": {
      "id": "e_zgxch7kd77ximc",
      "kind": "person",
      "name": "Yorkas",
      "fields": {
        "vocation": "Hand behind the sickness"
      },
      "body": [
        {
          "type": "statblock",
          "name": "Yorkas",
          "meta": "Half-Elf (male) · Ranger",
          "sections": [
            {
              "type": "paragraph",
              "label": "Appearance",
              "text": "Height: Unusually short · Jewelry: A pair of earrings with glowing moonstone orbs made of platinum."
            },
            {
              "type": "keyValue",
              "pairs": [
                {
                  "key": "Demeanor",
                  "value": "When calm: Dour When stressed: Withdrawn"
                },
                {
                  "key": "Right Now",
                  "value": "Suspicious."
                },
                {
                  "key": "Wants",
                  "value": "Retrieve a legendary weapon to defend their homeland."
                },
                {
                  "key": "Flaw",
                  "value": "Prejudice — Racist: specifically toward halflings"
                },
                {
                  "key": "Quirk",
                  "value": "They often say: “The offspring of a dwarf and a hill giant.”"
                },
                {
                  "key": "Faith",
                  "value": "Broken heretic."
                },
                {
                  "key": "Keepsake",
                  "value": "A large conch shell that, when put to the ear, makes the wielder hear the sounds of the ocean. If you close your eyes while doing so, you’ ll see visions of infinite horizons and calming ocean waves. A gift from a pirate lord to his estranged, landlocked son to give him at least a glance as to why he left."
                }
              ]
            },
            {
              "type": "paragraph",
              "label": "Racial Note",
              "text": "The half-elf has a rather prominent underbite."
            },
            {
              "type": "paragraph",
              "label": "Backstory",
              "text": "Charlatan: Betting and losing a deed that wasn’t theirs to bet."
            }
          ],
          "id": "b_ghbmbah5"
        }
      ],
      "rev": 1,
      "created": "2026-07-13T00:43:48.171Z",
