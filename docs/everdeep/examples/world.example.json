    "e_sgwqh8oj6hubcy": {
      "id": "e_sgwqh8oj6hubcy",
      "kind": "building",
      "name": "The Religious Goods Shop",
      "fields": {
        "keeper": {
          "ref": "e_uokmrydv3og5u8"
        }
      },
      "body": [
        {
          "type": "statblock",
          "name": "The Religious Goods Shop",
          "meta": "Religious Goods merchant",
          "sections": [
            {
              "type": "paragraph",
              "label": "The Premises",
              "text": "A Halfling Artificer and Tinker, with a broad smile and gregarious nature. He produces intricate, ingenious mechanical devices for adventurers. The shop he operates out of is built-to-halfling-scale, though. To broaden his customer base, he has fitted every shelf, display, and even the front wall of the building with a complex system of rails and slides, allowing him to do business with anyone, and display anything, all at the customer’s eye level."
            },
            {
              "type": "list",
              "label": "On the Shelves",
              "items": [
                "Staff of the Python (500gp) stock: Only 1, ever | DMG 204",
                "Spell: Raise dead (1,250gp) stock: 3 spells/day | PHB 270 Returns a dead corpse to life",
                "Dagger, ritual (2gp) stock: 2 | PHB 148 Has an oddly curved design",
                "Candle (1cp) stock: 1 | PHB 150 Comes in a variety of colors",
                "Chalk (1cp/piece) stock: 14 pieces | PHB 150 Comes in a variety of colors",
                "Keoghtom's ointment (250gp) stock: 3 | PHB 179"
              ]
            },
            {
              "type": "keyValue",
              "pairs": [
                {
                  "key": "Keeper Personality",
                  "value": "I'm convinced my natural showmanship is what earns me customers."
                },
                {
                  "key": "Ideal",
                  "value": "Monopoly. Undercutting my rivals and price gouging are the only ways to get ahead. (Evil)"
                },
                {
                  "key": "Bond",
                  "value": "I'm counting down the days to a peaceful retirement with my spouse or loved ones."
                },
                {
                  "key": "Flaw",
                  "value": "It's hard for me to respect someone who doesn't know everything about what I'm selling."
                }
              ]
            }
          ],
          "id": "b_tsp11zu8"
        }
      ],
