    "e_xblfpc229gnvqw": {
      "id": "e_xblfpc229gnvqw",
      "kind": "person",
      "name": "Alupisys",
      "fields": {},
      "body": [
        {
          "type": "statblock",
          "name": "Alupisys",
          "meta": "Half-Elf (female) · Monk",
          "sections": [
            {
              "type": "paragraph",
              "label": "Appearance",
              "text": "Eyes: Haunted · Markings: a figure tattoo (Clearly homemade work) depicting: ranger — on the chest."
            },
            {
              "type": "keyValue",
              "pairs": [
                {
                  "key": "Demeanor",
                  "value": "When calm: Dour When stressed: Courageous"
                },
                {
                  "key": "Right Now",
                  "value": "Agitated."
                },
                {
                  "key": "Fears",
                  "value": "facing the embodiment of their worst nightmares"
                },
                {
                  "key": "Flaw",
                  "value": "Prejudice — Racist: specifically toward elves"
                },
                {
                  "key": "Quirk",
                  "value": "Favorite phrase: “What in the Holy Light of the Morninglord is going on here?!”"
                },
                {
                  "key": "Faith",
                  "value": "Critical student."
                },
                {
                  "key": "Keepsake",
                  "value": "A tiny stuffed animal made to look like a pitch black leopard. Its eyes glow in the dark."
                }
              ]
            },
            {
              "type": "paragraph",
              "label": "Racial Note",
              "text": "The half-elf wears their long hair in a complex braid."
            },
            {
              "type": "paragraph",
              "label": "Backstory",
              "text": "Was a weapons instructor for the city militia"
            }
          ],
          "id": "b_nd9ann6c"
        }
      ],
      "rev": 1,
