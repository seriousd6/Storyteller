    "e_m2zon2fc39pebs": {
      "id": "e_m2zon2fc39pebs",
      "kind": "landmark",
      "name": "Tower Watch",
      "fields": {},
      "body": [
        {
          "type": "statblock",
          "name": "Tower Watch",
          "meta": "Landmark",
          "sections": [
            {
              "type": "paragraph",
              "label": "The Site",
              "text": "A small pool of water at the roots of a gnarled old tree. The water contains a psychoactive substance which causes vivid, but not traumatic, dreams/hallucinations. Buried within the visions are directions to an abandoned bandit hideout nearby."
            },
            {
              "type": "paragraph",
              "label": "Within",
              "text": "The party finds an gold vein that has been roughly ‘mined out’. If they follow it, they find a hive of rust monsters eating the ore. If disturbed the RMs with spill out into the dungeon and eventually the surface (maybe destroying a nearby village)."
            },
            {
              "type": "keyValue",
              "pairs": [
                {
                  "key": "Hazard",
                  "value": "A stone bridge over a section of an otherwise normal river, the “water” under which is actually a grouping of gelatinous cubes in wait to surround any passers, running water hiding their already transparent bodies."
                },
                {
                  "key": "Scrawled Here",
                  "value": "On the ceiling, ‘Beware of Trappers’"
                }
              ]
            }
          ],
          "id": "b_2famflgk"
        }
      ],
      "rev": 1,
      "created": "2026-07-13T00:43:48.174Z",
      "updated": "2026-07-13T00:43:48.174Z",
