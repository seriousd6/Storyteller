<style is:global>
  /* Block internals are rendered at runtime — global styles, scoped by .sheet */
  .sheet .block {
    position: relative;
    padding-right: 7.5rem;
    margin-block: var(--space-3);
  }

  .sheet .block h2 {
    font-size: var(--text-xl);
    color: var(--color-statblock);
    border-bottom: 1px solid var(--color-statblock-rule);
    padding-bottom: 2px;
    outline: none;
  }

  .sheet .block h3 {
    font-size: var(--text-lg);
    color: var(--color-statblock);
  }

  .sheet .block-label {
    font-style: italic;
    color: var(--color-statblock);
  }

  .sheet .block [contenteditable]:focus-visible {
    outline: 1px dashed var(--color-accent);
    outline-offset: 2px;
  }

  /* Page view (PLAN.md §10): REAL letter-sized boxes, built at runtime so
     they live in the GLOBAL block. 0.5in margins leave 7.5in × 10in of
     content — the same numbers print gets, so a measured spill here is a
     real spill there. */
  .page-view {
    display: grid;
    gap: var(--space-6);
    justify-content: center;
  }

  .page-view[hidden] {
    display: none;
  }

  .page {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow);
    padding: 0.5in;
  }

  .page-inner {
    width: 7.5in;
    height: 10in;
    overflow: hidden;
  }

  .page-num {
    position: absolute;
    bottom: 0.15in;
    left: 0;
    right: 0;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  .page-warn {
    position: absolute;
    top: 0.1in;
    left: 0.5in;
    right: 0.5in;
    margin: 0;
    padding: var(--space-1) var(--space-2);
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fca5a5;
    border-radius: var(--radius);
    font-size: var(--text-sm);
    z-index: 1;
