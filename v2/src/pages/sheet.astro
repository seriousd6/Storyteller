---
import Base from '../layouts/Base.astro';
---

<Base title="Sheet Builder" description="Compose pinned results into a printable, statblock-style prep sheet." hideTray>
  <div class="sheet-page">
    <div class="sheet-toolbar no-print">
      <select data-sheet-select aria-label="Active sheet"></select>
      <button class="btn" data-new type="button">＋ New sheet</button>
      <button class="btn" data-rename type="button">Rename</button>
      <button class="btn" data-delete type="button">Delete</button>
      <span class="toolbar-gap"></span>
      <button class="btn" data-add-title type="button">＋ Heading</button>
      <button class="btn" data-add-note type="button">＋ Note</button>
      <span class="toolbar-gap"></span>
      <button class="btn" data-export type="button">⬇ Markdown</button>
      <button class="btn btn-primary" data-print type="button">🖨 Print</button>
      <span class="toolbar-gap"></span>
      <span class="drive-chip" data-drive-chip>☁ Drive: not connected</span>
      <button class="btn" data-drive-save type="button" title="Back up all sheets to your Google Drive">☁ Save to Drive</button>
      <button class="btn" data-drive-load type="button" title="Restore sheets from your Google Drive backup">☁ Load</button>
      <button class="btn" data-drive-disconnect type="button" hidden title="Revoke this site's Drive access and forget the link on this device">Disconnect</button>
      <span class="drive-status" data-drive-status aria-live="polite"></span>
    </div>
    <p class="drive-hint no-print">
      Drive backup sends <strong>only the documents you create on this site</strong> —
      today that's your sheets; maps, stat blocks, and trackers will join the same backup
      as they arrive — to a single file (<code>storyteller-toolbox-data.json</code>) in
      <strong>your own Google Drive</strong>, so you can pick up where you left off on any
      device. Nothing else is sent, read, or shared, and this site has no server that
      could keep a copy. <a href="/privacy/">Privacy&nbsp;policy</a>
    </p>

    <article class="sheet" data-sheet>
      <h1 class="sheet-name" data-sheet-name contenteditable="true" spellcheck="false"></h1>
      <div class="sheet-rule"></div>
      <div data-blocks></div>
      <p class="sheet-empty no-print" data-empty hidden>
        This sheet is empty. Pin 📌 results from any generator — or add a
        heading or note above — then arrange, edit, and print.
      </p>
    </article>
  </div>
</Base>

<script>
  import { loadStore, saveStore, getActive, createSheet, deleteSheet, sheetToMarkdown, newId, SHEET_EVENT } from '../engine/sheetStore';
  import type { Sheet, SheetStore } from '../engine/sheetStore';
  import type { Block, ParagraphBlock, TitleBlock } from '../engine/types';
  import { enableDragReorder, moveItem } from '../engine/dragList';
  import { saveToDrive, loadFromDrive, disconnect, isConnected, isLinked, DRIVE_EVENT } from '../engine/drive';

  const SOURCE = 'sheet-page';
  let store = loadStore();

  const $ = <T extends HTMLElement = HTMLElement>(sel: string) => document.querySelector<T>(sel)!;
  const blocksEl = $('[data-blocks]');
  const selectEl = $<HTMLSelectElement>('[data-sheet-select]');
  const nameEl = $('[data-sheet-name]');
  const emptyEl = $('[data-empty]');

  const save = () => saveStore(store, SOURCE);

  function editable(el: HTMLElement, get: () => string, set: (v: string) => void) {
    el.contentEditable = 'true';
    el.spellcheck = false;
    el.textContent = get();
    el.addEventListener('input', () => {
      set(el.textContent ?? '');
      save();
    });
  }

  /** A small inline control (add/remove), hidden until the block is hovered. */
  function mini(glyph: string, label: string, fn: () => void): HTMLButtonElement {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'mini no-print';
    btn.textContent = glyph;
    btn.title = label;
    btn.setAttribute('aria-label', label);
    btn.addEventListener('click', fn);
    return btn;
  }

  /** Editable rendering for every block type. Text edits save in place;
   *  structural edits (add/remove item, field, row, section) rerender. */
  function renderEditable(block: Block, rerender: () => void): HTMLElement {
    const el = document.createElement('div');
    el.className = `b b-${block.type}`;
    const commit = () => {
      save();
      rerender();
    };

    if (block.type === 'title') {
      const h = document.createElement('h2');
      editable(h, () => block.text, (v) => (block.text = v));
      el.appendChild(h);
    } else if (block.type === 'paragraph') {
      const p = document.createElement('p');
      if (block.label !== undefined) {
        const b = document.createElement('b');
        b.className = 'block-label';
        editable(b, () => block.label ?? '', (v) => (block.label = v));
        p.append(b, ' ');
      }
      const span = document.createElement('span');
      editable(span, () => block.text, (v) => (block.text = v));
      p.appendChild(span);
      el.appendChild(p);
    } else if (block.type === 'keyValue') {
      block.pairs.forEach((pair, i) => {
        const p = document.createElement('p');
        const b = document.createElement('b');
        b.className = 'block-label';
        editable(b, () => pair.key, (v) => (pair.key = v));
        const span = document.createElement('span');
        editable(span, () => pair.value, (v) => (pair.value = v));
        p.append(b, '. ', span, mini('✕', 'Remove field', () => {
          block.pairs.splice(i, 1);
          commit();
        }));
        el.appendChild(p);
      });
      el.appendChild(mini('＋ field', 'Add field', () => {
        block.pairs.push({ key: 'Field', value: '…' });
        commit();
      }));
    } else if (block.type === 'list') {
      if (block.label !== undefined) {
        const b = document.createElement('b');
        b.className = 'block-label';
        editable(b, () => block.label ?? '', (v) => (block.label = v));
        el.appendChild(b);
      }
      const list = document.createElement(block.ordered ? 'ol' : 'ul');
      block.items.forEach((_, i) => {
        const li = document.createElement('li');
        const span = document.createElement('span');
        editable(span, () => block.items[i] ?? '', (v) => (block.items[i] = v));
        li.append(span, mini('✕', 'Remove item', () => {
          block.items.splice(i, 1);
          commit();
        }));
        list.appendChild(li);
      });
      el.appendChild(list);
      el.appendChild(mini('＋ item', 'Add item', () => {
        block.items.push('…');
        commit();
      }));
    } else if (block.type === 'table') {
      const table = document.createElement('table');
      const head = document.createElement('tr');
      block.columns.forEach((_, i) => {
        const th = document.createElement('th');
        editable(th, () => block.columns[i] ?? '', (v) => (block.columns[i] = v));
        head.appendChild(th);
      });
      const headTools = document.createElement('th');
      headTools.className = 'row-tools no-print';
      head.appendChild(headTools);
      table.appendChild(head);
      block.rows.forEach((row, r) => {
        const tr = document.createElement('tr');
        row.forEach((_, i) => {
          const td = document.createElement('td');
          editable(td, () => row[i] ?? '', (v) => (row[i] = v));
          tr.appendChild(td);
        });
        const tools = document.createElement('td');
        tools.className = 'row-tools no-print';
        tools.appendChild(mini('✕', 'Remove row', () => {
          block.rows.splice(r, 1);
          commit();
        }));
        tr.appendChild(tools);
        table.appendChild(tr);
      });
      el.appendChild(table);
      el.appendChild(mini('＋ row', 'Add row', () => {
        block.rows.push(block.columns.map(() => '…'));
        commit();
      }));
    } else {
      const h = document.createElement('h3');
      editable(h, () => block.name, (v) => (block.name = v));
      el.appendChild(h);
      if (block.meta !== undefined) {
        const i = document.createElement('i');
        editable(i, () => block.meta ?? '', (v) => (block.meta = v));
        el.appendChild(i);
      }
      const rule = document.createElement('div');
      rule.className = 'b-rule';
      el.appendChild(rule);
      block.sections.forEach((section, i) => {
        const sub = document.createElement('div');
        sub.className = 'sub';
        sub.append(renderEditable(section, rerender), mini('✕', 'Remove section', () => {
          block.sections.splice(i, 1);
          commit();
        }));
        el.appendChild(sub);
      });
      el.appendChild(mini('＋ note', 'Add a note section', () => {
        block.sections.push({ type: 'paragraph', label: 'Note', text: 'Write here…' });
        commit();
      }));
    }
    return el;
  }

  function renderBlock(sheet: Sheet, block: Block, index: number): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = `block block-${block.type}`;
    wrap.appendChild(renderEditable(block, renderBlocks));

    const controls = document.createElement('div');
    controls.className = 'block-controls no-print';

    // Drag handle: the block becomes draggable only while grabbed by the
    // handle, so text selection in contenteditable regions still works.
    const handle = document.createElement('button');
    handle.type = 'button';
    handle.className = 'btn block-grip';
    handle.textContent = '⠿';
    handle.title = 'Drag to reorder';
    handle.setAttribute('aria-label', 'Drag to reorder');
    handle.addEventListener('pointerdown', () => (wrap.draggable = true));
    handle.addEventListener('pointerup', () => (wrap.draggable = false));
    wrap.addEventListener('dragend', () => (wrap.draggable = false));
    controls.appendChild(handle);

    const actions: [string, string, () => void][] = [
      ['↑', 'Move up', () => move(sheet, index, -1)],
      ['↓', 'Move down', () => move(sheet, index, 1)],
      ['⧉', 'Duplicate', () => duplicate(sheet, index)],
      ['✕', 'Remove', () => remove(sheet, index)],
    ];
    for (const [glyph, label, fn] of actions) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'btn';
      btn.textContent = glyph;
      btn.title = label;
      btn.setAttribute('aria-label', label);
      btn.addEventListener('click', fn);
      controls.appendChild(btn);
    }
    wrap.appendChild(controls);
    return wrap;
  }

  function move(sheet: Sheet, index: number, delta: number) {
    const target = index + delta;
    if (target < 0 || target >= sheet.blocks.length) return;
    const [block] = sheet.blocks.splice(index, 1);
    sheet.blocks.splice(target, 0, block!);
    save();
    renderBlocks();
  }

  function duplicate(sheet: Sheet, index: number) {
    const copy: Block = structuredClone(sheet.blocks[index]!);
    copy.id = `pin-${newId()}`;
    sheet.blocks.splice(index + 1, 0, copy);
    save();
    renderBlocks();
  }

  function remove(sheet: Sheet, index: number) {
    sheet.blocks.splice(index, 1);
    save();
    renderBlocks();
  }

  function renderBlocks() {
    const sheet = getActive(store);
    blocksEl.replaceChildren(...sheet.blocks.map((b, i) => renderBlock(sheet, b, i)));
    emptyEl.hidden = sheet.blocks.length > 0;
  }

  function renderAll() {
    const sheet = getActive(store);
    selectEl.replaceChildren(
      ...store.sheets.map((s) => {
        const opt = document.createElement('option');
        opt.value = s.id;
        opt.textContent = s.name;
        opt.selected = s.id === store.activeId;
        return opt;
      }),
    );
    nameEl.textContent = sheet.name;
    renderBlocks();
  }

  nameEl.addEventListener('input', () => {
    const sheet = getActive(store);
    sheet.name = nameEl.textContent ?? 'Untitled';
    save();
    const opt = selectEl.querySelector<HTMLOptionElement>(`option[value="${sheet.id}"]`);
    if (opt) opt.textContent = sheet.name;
  });

  selectEl.addEventListener('change', () => {
    store.activeId = selectEl.value;
    save();
    renderAll();
  });

  $('[data-new]').addEventListener('click', () => {
    const name = prompt('Name the new sheet:', `Session ${store.sheets.length + 1}`);
    if (!name) return;
    createSheet(store, name.trim() || 'Untitled');
    renderAll();
  });

  $('[data-rename]').addEventListener('click', () => {
    const sheet = getActive(store);
    const name = prompt('Rename sheet:', sheet.name);
    if (!name) return;
    sheet.name = name.trim() || sheet.name;
    save();
    renderAll();
  });

  $('[data-delete]').addEventListener('click', () => {
    const sheet = getActive(store);
    if (!confirm(`Delete "${sheet.name}" and its ${sheet.blocks.length} block(s)?`)) return;
    deleteSheet(store, sheet.id);
    renderAll();
  });

  $('[data-add-title]').addEventListener('click', () => {
    const block: TitleBlock = { type: 'title', text: 'New heading', id: `pin-${newId()}` };
    getActive(store).blocks.push(block);
    save();
    renderBlocks();
  });

  $('[data-add-note]').addEventListener('click', () => {
    const block: ParagraphBlock = { type: 'paragraph', label: 'Note', text: 'Write here…', id: `pin-${newId()}` };
    getActive(store).blocks.push(block);
    save();
    renderBlocks();
  });

  $('[data-export]').addEventListener('click', () => {
    const sheet = getActive(store);
    const blob = new Blob([sheetToMarkdown(sheet)], { type: 'text/markdown' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `${sheet.name.replace(/[^\w-]+/g, '-').toLowerCase() || 'sheet'}.md`;
    a.click();
    URL.revokeObjectURL(a.href);
  });

  $('[data-print]').addEventListener('click', () => window.print());

  // Google Drive backup: one JSON file in the user's own Drive holding every
  // sheet. Save overwrites it (Drive keeps ~30 days of revisions); Load
  // replaces the local store after an explicit confirm.
  const driveStatus = $('[data-drive-status]');
  const setDriveStatus = (msg: string) => (driveStatus.textContent = msg);
  const driveError = (err: unknown, fallback: string) =>
    setDriveStatus(err instanceof Error ? err.message : fallback);

  // Connection chip: live token > linked-before > never connected.
  const driveChip = $('[data-drive-chip]');
  const disconnectBtn = $<HTMLButtonElement>('[data-drive-disconnect]');
  function renderDrive() {
    if (isConnected()) {
      driveChip.textContent = '☁ Drive: connected ●';
      driveChip.dataset.state = 'on';
      driveChip.title = 'This session is authorized — Save and Load work without another popup.';
    } else if (isLinked()) {
      driveChip.textContent = '☁ Drive: linked';
      driveChip.dataset.state = 'linked';
      driveChip.title = 'Drive was linked on this device — the next Save or Load reconnects automatically.';
    } else {
      driveChip.textContent = '☁ Drive: not connected';
      driveChip.dataset.state = 'off';
      driveChip.title = 'Click Save to Drive to connect your Google Drive.';
    }
    disconnectBtn.hidden = !isConnected() && !isLinked();
  }
  window.addEventListener(DRIVE_EVENT, renderDrive);
  renderDrive();

  disconnectBtn.addEventListener('click', async () => {
    await disconnect();
    setDriveStatus('Drive access revoked. Your backup file stays in your Drive.');
  });

  // Versioned envelope so future document types (maps, stat blocks,
  // initiative trackers) can join the same backup file without breaking
  // older backups. version 1 payload: { sheets: SheetStore }.
  const BACKUP_FORMAT = 'storyteller-toolbox-backup';
  interface Backup {
    format: typeof BACKUP_FORMAT;
    version: number;
    savedAt: string;
    sheets: SheetStore;
  }
  const unwrapBackup = (raw: string): SheetStore => {
    const parsed = JSON.parse(raw);
    // Envelope, or a bare SheetStore from the very first builds.
    return parsed?.format === BACKUP_FORMAT ? parsed.sheets : parsed;
  };

  $('[data-drive-save]').addEventListener('click', async () => {
    try {
      setDriveStatus('Saving to Drive…');
      const backup: Backup = {
        format: BACKUP_FORMAT,
        version: 1,
        savedAt: new Date().toISOString(),
        sheets: store,
      };
      const result = await saveToDrive(JSON.stringify(backup));
      const total = store.sheets.reduce((n, s) => n + s.blocks.length, 0);
      setDriveStatus(
        `✓ Backed up ${store.sheets.length} sheet(s), ${total} block(s) · ${new Date(result.modifiedTime).toLocaleTimeString()}`,
      );
    } catch (err) {
      driveError(err, 'Drive save failed.');
    }
  });

  $('[data-drive-load]').addEventListener('click', async () => {
    try {
      setDriveStatus('Checking Drive…');
      const backup = await loadFromDrive();
      if (!backup) {
        setDriveStatus('No Drive backup yet — use ☁ Save to Drive first.');
        return;
      }
      const incoming = unwrapBackup(backup.json);
      if (!incoming || !Array.isArray(incoming.sheets)) throw new Error('The Drive file is not a Storyteller Toolbox backup.');
      const when = new Date(backup.modifiedTime).toLocaleString();
      if (
        !confirm(
          `Replace the ${store.sheets.length} sheet(s) on this device with the Drive backup? ` +
            `(${incoming.sheets.length} sheet(s), saved ${when})`,
        )
      ) {
        setDriveStatus('');
        return;
      }
      store = incoming;
      save();
      store = loadStore(); // normalizes activeId and empty stores
      renderAll();
      setDriveStatus(`✓ Restored from Drive (saved ${when}).`);
    } catch (err) {
      driveError(err, 'Drive load failed.');
    }
  });

  enableDragReorder(blocksEl, '.block', (from, to) => {
    const sheet = getActive(store);
    moveItem(sheet.blocks, from, to);
    save();
    renderBlocks();
  });

  // Live-sync with pins and the tray; ignore our own writes so typing
  // in a contenteditable block never re-renders out from under the caret.
  window.addEventListener(SHEET_EVENT, ((e: CustomEvent) => {
    if (e.detail?.source === SOURCE) return;
    store = loadStore();
    renderAll();
  }) as EventListener);

  renderAll();
</script>

<style>
  .sheet-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .sheet-toolbar select {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    max-width: 14rem;
  }

  .toolbar-gap {
    flex: 0 0 var(--space-4);
  }

  .drive-status {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  .drive-chip {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-1) var(--space-2);
    white-space: nowrap;
  }

  .drive-chip[data-state='on'] {
    color: #15803d;
    border-color: #15803d;
  }

  :root[data-theme='dark'] .drive-chip[data-state='on'] {
    color: #4ade80;
    border-color: #4ade80;
  }

  .drive-chip[data-state='linked'] {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .drive-hint {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    max-width: 46rem;
    margin-bottom: var(--space-6);
  }

  .sheet {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: var(--space-8);
    max-width: 50rem;
    margin-inline: auto;
  }

  .sheet-name {
    font-size: var(--text-2xl);
    color: var(--color-statblock);
    outline: none;
  }

  .sheet-rule {
    height: 3px;
    background: var(--color-statblock-rule);
    clip-path: polygon(0 0, 100% 0, 99% 100%, 1% 100%);
    margin-block: var(--space-2) var(--space-6);
  }

  .sheet-empty {
    color: var(--color-ink-muted);
  }

  @media print {
    .sheet {
      border: none;
      box-shadow: none;
      padding: 0;
      max-width: none;
    }
  }
</style>

<style is:global>
  /* Block internals are rendered at runtime — global styles, scoped by .sheet */
  .sheet .block {
    position: relative;
    padding-right: 7.5rem;
    margin-block: var(--space-3);
  }

  .sheet .block h2 {
    font-size: var(--text-xl);
    color: var(--color-statblock);
    border-bottom: 1px solid var(--color-statblock-rule);
    padding-bottom: 2px;
    outline: none;
  }

  .sheet .block h3 {
    font-size: var(--text-lg);
    color: var(--color-statblock);
  }

  .sheet .block-label {
    font-style: italic;
    color: var(--color-statblock);
  }

  .sheet .block [contenteditable]:focus-visible {
    outline: 1px dashed var(--color-accent);
    outline-offset: 2px;
  }

  .sheet .block.dragging {
    opacity: 0.5;
    outline: 1px dashed var(--color-accent);
    outline-offset: 4px;
  }

  .sheet .block-grip {
    cursor: grab;
  }

  .sheet .block-controls {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    gap: 2px;
    opacity: 0;
    transition: opacity 120ms;
  }

  .sheet .block:hover .block-controls,
  .sheet .block:focus-within .block-controls {
    opacity: 1;
  }

  .sheet .block-controls .btn {
    padding: 0 var(--space-2);
    font-size: var(--text-sm);
  }

  .sheet .block table {
    border-collapse: collapse;
  }

  .sheet .block th,
  .sheet .block td {
    border: 1px solid var(--color-border);
    padding: var(--space-1) var(--space-2);
    text-align: left;
  }

  .sheet .block th.row-tools,
  .sheet .block td.row-tools {
    border: none;
    padding: 0 0 0 var(--space-1);
  }

  .sheet .block .b-rule {
    height: 3px;
    background: var(--color-statblock-rule);
    clip-path: polygon(0 0, 100% 0, 99% 100%, 1% 100%);
    margin-block: var(--space-1) var(--space-2);
  }

  .sheet .block i {
    color: var(--color-ink-muted);
  }

  .sheet .block .sub {
    position: relative;
    padding-right: 1.75rem;
    margin-block: var(--space-2);
  }

  .sheet .block .sub > .mini {
    position: absolute;
    top: 0;
    right: 0;
  }

  .sheet .mini {
    border: none;
    background: none;
    color: var(--color-ink-muted);
    cursor: pointer;
    font-size: var(--text-sm);
    padding: 0 var(--space-1);
    border-radius: var(--radius);
    opacity: 0;
    transition: opacity 120ms;
  }

  .sheet .block:hover .mini,
  .sheet .block:focus-within .mini {
    opacity: 0.7;
  }

  .sheet .mini:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  @media print {
    .sheet .block {
      break-inside: avoid;
      padding-right: 0;
    }

    .sheet .block .sub {
      padding-right: 0;
    }
  }
</style>
