---
import Base from '../layouts/Base.astro';
import BrewPanel from '../components/BrewPanel.astro';
import DicePanel from '../components/DicePanel.astro';
---

<Base title="Sheet Builder" description="Compose pinned results into a printable, statblock-style prep sheet." hideTray appShell>
  <div class="sheet-page">
    <!-- The command bar (workspace overhaul, owner ask 2026-07-18): ONE
         sticky row, like a document editor — the daily verbs stay visible,
         everything occasional folds into the Sheet ▾ and ☁ menus. -->
    <div class="command-bar no-print">
      <select data-sheet-select aria-label="Active sheet"></select>
      <button class="btn" data-insert-open type="button" title="Insert a block — text, tables, trackers, live roll tables and more">＋ Insert</button>
      <button class="btn" data-mode-toggle type="button" title="Play: tokens roll, text locks. Edit: full editing.">▶ Play</button>
      <button class="btn" data-dice-open type="button" title="Roll dice — pick how many of each kind and tumble them on the table">🎲 Dice</button>
      <button class="btn" data-undo type="button" disabled title="Undo (Ctrl+Z)" aria-label="Undo">↶</button>
      <button class="btn" data-redo type="button" disabled title="Redo (Ctrl+Shift+Z)" aria-label="Redo">↷</button>
      <span class="bar-spacer"></span>
      <details class="tool-menu" data-file-menu>
        <summary class="btn" title="Everything about this sheet — create, rename, share, export">Sheet ▾</summary>
        <div class="tool-menu-panel">
          <button class="btn" data-new type="button">＋ New sheet</button>
          <button class="btn" data-from-template type="button" title="Start from a boilerplate page that fills itself by rolling">✦ From template…</button>
          <button class="btn" data-rename type="button">✎ Rename</button>
          <button class="btn" data-delete type="button">🗑 Delete</button>
          <hr />
          <button class="btn" data-promote type="button" title="Save this sheet into a world as an entity — the sheet then shows the world's copy, live">🌍 Save to world</button>
          <button class="btn" data-pages-toggle type="button" aria-pressed="false" title="Preview real pages — see exactly where content lands and where it spills">⧉ Pages</button>
          <button class="btn" data-export type="button">⬇ Markdown</button>
          <button class="btn" data-share-open type="button" title="Share this sheet — a link that carries the whole sheet in the URL, or a small file">⤴ Share…</button>
          <hr />
          <label class="menu-row">
            Genre
            <select data-genre-pin aria-label="Sheet genre" title="Pin a genre to THIS sheet — it keeps the look on screen and in print, whatever the site is set to">
              <option value="">site</option>
              <option value="fantasy">Fantasy</option>
              <option value="scifi">Sci-fi</option>
              <option value="horror">Horror</option>
            </select>
          </label>
        </div>
      </details>
      <details class="tool-menu" data-drive-menu>
        <summary class="btn" title="Back up and sync to your own Google Drive"><span class="drive-chip" data-drive-chip>☁ Drive: not connected</span></summary>
        <div class="tool-menu-panel tool-menu-panel-end">
          <button class="btn" data-drive-save type="button" title="Back up all sheets to your Google Drive">☁ Save to Drive</button>
          <button class="btn" data-drive-load type="button" title="Restore sheets from your Google Drive backup">☁ Load backup</button>
          <button class="btn" data-sync-pill type="button" title="Automatic background backup of every document to your own Drive">⇅ Auto-sync: off</button>
          <button class="btn" data-drive-disconnect type="button" hidden title="Revoke this site's Drive access and forget the link on this device">Disconnect</button>
          <p class="drive-status" data-drive-status aria-live="polite"></p>
          <p class="drive-hint">
            Backups go to <strong>your own Google Drive</strong> and carry
            <strong>only the documents you create here</strong> — ⇅&nbsp;Auto-sync keeps each
            sheet, world, brew, and dice skin as its own file in a
            <code>Storyteller&nbsp;Toolbox</code> folder; ☁&nbsp;Save writes a single archive
            you can restore anywhere. Nothing else is sent, read, or shared, and this site
            has no server that could keep a copy. <a href="/privacy/">Privacy&nbsp;policy</a>
          </p>
        </div>
      </details>
      <button class="btn btn-primary" data-print type="button">🖨 Print</button>
    </div>

    <!-- The workspace: a neutral desk, the paper on it, tools in a rail. -->
    <div class="workspace">
      <aside class="workspace-rail no-print">
        <details class="roll-log" data-roll-log>
          <summary>🎲 Roll log</summary>
          <ol data-roll-entries></ol>
        </details>

        <DicePanel />

        <BrewPanel />

        <details class="trash-panel" data-trash-panel>
          <summary>🗑 Trash <span data-trash-count></span></summary>
          <div data-trash-list></div>
        </details>
      </aside>

      <div class="doc-col">
        <article class="sheet" data-sheet>
          <h1 class="sheet-name" data-sheet-name contenteditable="true" spellcheck="false"></h1>
          <div class="sheet-rule"></div>
          <div data-blocks></div>
          <button class="btn sheet-add no-print" data-sheet-add type="button" hidden>＋ Add a block</button>
          <p class="sheet-empty no-print" data-empty hidden>
            This sheet is empty. Pin 📌 results from any generator, start
            <button class="btn" data-from-template-empty type="button">✦ from a template</button>,
            or <button class="btn" data-insert-empty type="button">＋ insert a block</button> —
            then arrange, edit, and print.
          </p>
        </article>

        <div class="page-view no-print" data-page-view hidden></div>
      </div>
    </div>

    <dialog class="template-gallery" data-template-dialog>
      <h2>New sheet from a template</h2>
      <p class="gallery-hint">Templates arrive already rolled — every blank filled by the site's tables. Every generator is here too, as a full page you can trim and reroll. Reroll anything you don't like.</p>
      <div data-template-list></div>
      <button class="btn" data-template-close type="button">Close</button>
    </dialog>

    <!-- The dice roller (owner ask 2026-07-19): a tooltip off 🎲 Dice — pick
         how many of each kind, and the whole pool tumbles on the 3D stage.
         Works in edit AND play; every roll lands in the roll log. -->
    <div class="dice-pop no-print" data-dice-pop hidden>
      <div class="dice-pop-kinds" data-dice-kinds></div>
      <p class="dice-pop-formula"><output data-dice-formula aria-live="polite">pick some dice…</output></p>
      <div class="dice-pop-actions">
        <button class="btn btn-primary" data-dice-roll type="button" disabled>🎲 Roll</button>
        <button class="btn" data-dice-clear type="button">✕ Clear</button>
      </div>
    </div>

    <div class="insert-menu no-print" data-insert-menu hidden>
      <p class="insert-group">Text</p>
      <button class="btn" data-add-title type="button">Heading</button>
      <button class="btn" data-add-note type="button">Note</button>
      <button class="btn" data-add-list type="button">List</button>
      <button class="btn" data-add-table type="button">Table</button>
      <button class="btn" data-add-keyvalue type="button" title="Label · value pairs — AC, Speed, anything">Key–value</button>
      <p class="insert-group">Game</p>
      <button class="btn" data-add-rolltable type="button" title="Embed any of the site's tables — or your own — as a live rolling widget">Roll table…</button>
      <button class="btn" data-add-statgrid type="button" title="The classic six-box stat strip; tap a box in Play to roll a check">Stat grid</button>
      <button class="btn" data-add-tracker type="button" title="HP, rations, uses — tick it down in Play">Tracker</button>
      <button class="btn" data-add-actions type="button" title="Attack / ability rows with one-tap rolls">Actions</button>
      <button class="btn" data-add-choice type="button" title="A labelled dropdown — pick from a list, or add your own options">Choice</button>
      <button class="btn" data-add-choicelist type="button" title="A group of dropdowns over one list — a spellbook, known invocations, anything picked-from-a-pool">Choices…</button>
      <button class="btn" data-add-profgrid type="button" title="Saves/skills as clickable cards with proficiency & expertise checkboxes; each card rolls its check in Play">Skills grid</button>
      <button class="btn" data-add-statblock type="button">Statblock</button>
      <button class="btn" data-add-entityref type="button" title="Embed a world entity LIVE — the sheet and the world wiki edit the same data">World entity…</button>
      <p class="insert-group">Layout</p>
      <button class="btn" data-add-image type="button" title="Upload a portrait or handout image">Image</button>
      <button class="btn" data-add-pagebreak type="button">Page break</button>
      <button class="btn" data-add-columns type="button" title="Wrap the last two blocks into side-by-side columns">Columns</button>
    </div>

    <dialog class="table-picker" data-table-picker>
      <h2>Embed a roll table</h2>
      <input type="search" data-picker-search placeholder="Search tables…" aria-label="Search tables" autocomplete="off" />
      <div class="picker-list" data-picker-list></div>
      <button class="btn" data-picker-close type="button">Close</button>
    </dialog>

    <dialog class="table-picker" data-entity-picker>
      <h2 data-entity-picker-title>Embed a world entity</h2>
      <p class="gallery-hint" data-entity-picker-hint>Live, not a copy: edits here land in the world; world edits appear here.</p>
      <input type="search" data-entity-search placeholder="Search entities…" aria-label="Search entities" autocomplete="off" />
      <div class="picker-list" data-entity-list></div>
      <button class="btn" data-entity-close type="button">Close</button>
    </dialog>

    <dialog class="table-picker" data-import-dialog>
      <h2>Import a brew or a sheet file</h2>
      <p class="gallery-hint">
        Homebrewery markdown in, living blocks out — headings, tables,
        statblocks, key–value lines, lists, <code>\page</code> breaks (images
        and column layout don't survive the trip). A <code>.json</code> sheet
        file from ⤴&nbsp;Share imports exactly as exported.
      </p>
      <textarea class="import-text" data-import-text rows="12" placeholder="# My Brew&#10;Paste markdown or a sheet file here…" spellcheck="false"></textarea>
      <label class="import-file-row">Or pick a file:
        <input type="file" data-import-file accept=".json,.md,.txt,text/markdown,application/json" />
      </label>
      <p class="picker-more" data-import-status hidden></p>
      <div class="brew-actions">
        <button class="btn btn-primary" data-import-go type="button">Import as a new sheet</button>
        <button class="btn" data-import-close type="button">Close</button>
      </div>
    </dialog>

    <dialog class="table-picker" data-share-dialog>
      <h2>Share “<span data-share-name></span>”</h2>
      <p class="gallery-hint">
        The link carries the whole sheet inside the URL — no server, nothing
        uploaded; whoever opens it gets their own editable copy. Embedded world
        entities travel as snapshots, and their GM-secret blocks stay home.
      </p>
      <div class="share-row">
        <input type="text" data-share-url readonly aria-label="Share link" spellcheck="false" />
        <button class="btn btn-primary" data-share-copy type="button">Copy link</button>
      </div>
      <p class="picker-more" data-share-hint hidden>
        That's a long link — some chat apps truncate long URLs. The file below
        survives anything.
      </p>
      <div class="brew-actions">
        <button class="btn" data-share-json type="button" title="A small .json file — send it, back it up, or import it on the other side">⬇ Sheet file (.json)</button>
        <button class="btn" data-share-close type="button">Close</button>
      </div>
    </dialog>
  </div>
</Base>

<script>
  import { initSheetStore, loadStore, saveStore, getActive, activeSheets, trashedSheets, createSheet, deleteSheet, restoreSheet, purgeSheet, sheetToMarkdown, newId, SHEET_EVENT } from '../engine/sheetStore';
  import type { Sheet } from '../engine/sheetStore';
  import type { Block, RollTableBlock, GeneratorConfig } from '../engine/types';
  import { generatorTemplate } from '../engine/generatorTemplate';
  import { isComposite, runComposite } from '../engine/compositeInstance';
  import { renderBlockEditable, renderBlockPlay, renderBlockStatic, type EditCtx } from '../engine/blockKit';
  import { columnsOf } from '../engine/blocks/columns';
  import { CommandBus } from '../engine/commands';
  import { enableDragReorder, moveItem } from '../engine/dragList';
  import { saveToDrive, loadFromDrive, disconnect, isConnected, isLinked, DRIVE_EVENT } from '../engine/drive';
  import { buildBackup, parseBackup, restoreWorlds, restoreBrews, restoreAssets, restoreSkins } from '../engine/backup.ts';
  import { referencedTables, renderTemplate } from '../engine/roll';
  import { loadClosure, listSiteTables } from '../engine/tableLoader';
  import { getUserTables } from '../engine/brewStore';
  import { randomSeed, makeRng } from '../engine/rng';
  import { defaultRecipe, serializeRecipe, type Race } from '../everdeep/portraits';

  // the faces a template's portrait:'random' draws from — the SRD race set
  const SRD_PORTRAIT_RACES: Race[] = ['human', 'dwarf', 'elf', 'halfling', 'gnome', 'dragonborn', 'half-elf', 'half-orc', 'tiefling'];
  import { getRollLog, pushRoll, ROLL_LOG_EVENT } from '../engine/rollLog';
  import { collectVars } from '../engine/vars';
  import { getAllWorlds, getWorld, newEntity, putWorld, WORLD_EVENT } from '../engine/worldStore';
  import type { WorldDoc } from '../engine/worldStore';
  import { isSelfPersist, peekEntity } from '../engine/blocks/entityRef';
  import { importHomebrew, importedName } from '../engine/homebrewImport';
  import { packSheet, unpackSheet, encodeShare, decodeShare } from '../engine/sheetShare';
  import { SYNC_EVENT, syncStatus, autoSyncEnabled, enableAutoSync, disableAutoSync, resumeSync } from '../engine/sync';

  // Boilerplate pages (PLAN.md §9): small JSON docs of blocks whose text may
  // carry {table:} tokens — instantiation rolls them all with one seed.
  interface SheetTemplate {
    id: string;
    title: string;
    kind?: string;
    description?: string;
    blocks: Block[];
  }
  const TEMPLATES: SheetTemplate[] = Object.values(
    import.meta.glob('../sheets/templates/*.json', { eager: true }),
  ).map((m) => (m as { default: SheetTemplate }).default);

  // Every slot generator is ALSO a self-filling one-pager
  // (docs/sheets/GENERATORS-AS-ONEPAGERS.md): its slots ARE the sections and
  // the tokens are its own, so generatorTemplate() derives a drop-in
  // SheetTemplate that instantiate() fills exactly like a hand-authored one —
  // one definition per topic, no duplicated tables. A curated page that
  // already owns a topic wins, so its generator twin is suppressed here; the
  // rest register for free ("every generator becomes a one-pager").
  const DERIVED_TEMPLATES: SheetTemplate[] = Object.values(
    import.meta.glob('../generators/*.json', { eager: true }),
  )
    .map((m) => generatorTemplate((m as { default: GeneratorConfig }).default))
    .sort((a, b) => a.title.localeCompare(b.title));
  // The gallery hides a generator whose topic a curated page already owns
  // (npc-one-pager, shop-catalog) so no topic shows twice — but a direct deep
  // link to that generator id still resolves against DERIVED_TEMPLATES below,
  // because the slot page's own content IS the full generator, not the cousin.
  const CURATED_TOPICS = new Set(['gm/npc', 'gm/shop']); // owned by npc-one-pager, shop-catalog
  const curatedIds = new Set(TEMPLATES.map((t) => t.id));
  const GENERATOR_TEMPLATES = DERIVED_TEMPLATES.filter(
    (t) => !CURATED_TOPICS.has(t.id) && !curatedIds.has(t.id),
  );
  // Deep-link resolution (§3.3): every template addressable by id, hidden or not.
  const TEMPLATES_BY_ID = new Map([...TEMPLATES, ...DERIVED_TEMPLATES].map((t) => [t.id, t]));

  const SOURCE = 'sheet-page';
  await initSheetStore(); // IndexedDB-backed since PLAN.md §8
  let store = loadStore();

  const $ = <T extends HTMLElement = HTMLElement>(sel: string) => document.querySelector<T>(sel)!;
  const blocksEl = $('[data-blocks]');
  const selectEl = $<HTMLSelectElement>('[data-sheet-select]');
  const nameEl = $('[data-sheet-name]');
  const emptyEl = $('[data-empty]');
  const addRowEl = $('[data-sheet-add]');
  const insertOpenBtn = $('[data-insert-open]');
  const pageEl = $('.sheet-page');
  const undoBtn = $<HTMLButtonElement>('[data-undo]');
  const redoBtn = $<HTMLButtonElement>('[data-redo]');

  function updateUndoButtons(): void {
    undoBtn.disabled = !bus.canUndo;
    redoBtn.disabled = !bus.canRedo;
  }

  const save = () => saveStore(store, SOURCE);

  // Per-type rendering lives in the Block Kit (engine/blocks/*); this page
  // supplies the ctx: persistence (save), and the undo bus. Every structural
  // edit — here or inside a block def — is a Command, so ctrl+Z works.
  const bus = new CommandBus(() => {
    save();
    renderBlocks();
    updateUndoButtons();
  });
  const editCtx: EditCtx = {
    mode: 'edit',
    renderChild: (b) => renderBlockEditable(b, editCtx),
    save,
    execute: (cmd) => bus.execute(cmd),
    // record() deliberately skips onChange (re-rendering on blur would eat
    // the click target) — but the undo button still needs to light up
    record: (cmd) => {
      bus.record(cmd);
      updateUndoButtons();
    },
    // read at CLICK time by dice chips / stat boxes / action rows — a raised
    // STR reaches every later roll without re-rendering anything
    vars: () => collectVars(getActive(store).blocks),
  };

  function renderBlock(sheet: Sheet, block: Block, index: number): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = `block block-${block.type}`;
    wrap.appendChild(renderBlockEditable(block, editCtx));

    // Insertion point (workspace audit): a ＋ on the block's top-left edge,
    // shown on hover/focus — insert exactly where you're looking, not at
    // the end of the document.
    const insertBtn = document.createElement('button');
    insertBtn.type = 'button';
    insertBtn.className = 'btn block-insert no-print';
    insertBtn.textContent = '＋';
    insertBtn.title = 'Insert a block here';
    insertBtn.setAttribute('aria-label', 'Insert a block here');
    insertBtn.addEventListener('click', () => openInsertMenu(insertBtn, index));
    wrap.appendChild(insertBtn);

    const controls = document.createElement('div');
    controls.className = 'block-controls no-print';

    // Drag handle: the block becomes draggable only while grabbed by the
    // handle, so text selection in contenteditable regions still works.
    const handle = document.createElement('button');
    handle.type = 'button';
    handle.className = 'btn block-grip';
    handle.textContent = '⠿';
    handle.title = 'Drag to reorder';
    handle.setAttribute('aria-label', 'Drag to reorder');
    handle.addEventListener('pointerdown', () => (wrap.draggable = true));
    handle.addEventListener('pointerup', () => (wrap.draggable = false));
    wrap.addEventListener('dragend', () => (wrap.draggable = false));
    controls.appendChild(handle);

    const actions: [string, string, () => void][] = [
      ['↑', 'Move up', () => move(sheet, index, -1)],
      ['↓', 'Move down', () => move(sheet, index, 1)],
      ['⧉', 'Duplicate', () => duplicate(sheet, index)],
      ['✕', 'Remove', () => remove(sheet, index)],
    ];
    for (const [glyph, label, fn] of actions) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'btn';
      btn.textContent = glyph;
      btn.title = label;
      btn.setAttribute('aria-label', label);
      btn.addEventListener('click', fn);
      controls.appendChild(btn);
    }
    wrap.appendChild(controls);
    return wrap;
  }

  function move(sheet: Sheet, index: number, delta: number) {
    const target = index + delta;
    if (target < 0 || target >= sheet.blocks.length) return;
    bus.execute({
      label: 'move block',
      apply: () => moveItem(sheet.blocks, index, target),
      revert: () => moveItem(sheet.blocks, target, index),
    });
  }

  function duplicate(sheet: Sheet, index: number) {
    const copy: Block = structuredClone(sheet.blocks[index]!);
    copy.id = `pin-${newId()}`;
    // a statblock's sections carry ids too — a clone sharing them with the
    // original is a latent duplicate-id bug for anything that addresses
    // blocks by id (per-block overrides, sync)
    if (copy.type === 'statblock') {
      for (const s of copy.sections as Array<{ id?: string }>) {
        if (s.id) s.id = `pin-${newId()}`;
      }
    }
    bus.execute({
      label: 'duplicate block',
      apply: () => sheet.blocks.splice(index + 1, 0, copy),
      revert: () => {
        const at = sheet.blocks.indexOf(copy);
        if (at >= 0) sheet.blocks.splice(at, 1);
      },
    });
  }

  function remove(sheet: Sheet, index: number) {
    const block = sheet.blocks[index]!;
    bus.execute({
      label: 'remove block',
      apply: () => {
        const at = sheet.blocks.indexOf(block);
        if (at >= 0) sheet.blocks.splice(at, 1);
      },
      revert: () => sheet.blocks.splice(index, 0, block),
    });
  }

  // Play mode (PLAN.md §16): tokens live, text locked, structure chrome
  // hidden. Remembered per sheet.
  const modeBtn = $('[data-mode-toggle]');
  const playing = () => getActive(store).mode === 'play';

  function renderBlocks() {
    // A full rebuild empties the container for a beat — without this guard the
    // page height collapses and the browser clamps scroll to the top, so a
    // click deep in a long sheet (a spell slot, a tracker) teleports the
    // reader (owner review 2026-07-18). Restore the exact position after.
    const scrollY = window.scrollY;
    const sheet = getActive(store);
    if (playing()) {
      // same bus/save/vars, but mode 'play' — widgets must not show edit
      // chrome (result ✕ minis, editable refs) at the table
      const playCtx: EditCtx = { ...editCtx, mode: 'play' };
      blocksEl.replaceChildren(
        ...sheet.blocks.map((b) => {
          const wrap = document.createElement('div');
          wrap.className = `block block-${b.type} block-play`;
          wrap.appendChild(renderBlockPlay(b, playCtx));
          return wrap;
        }),
      );
    } else {
      blocksEl.replaceChildren(...sheet.blocks.map((b, i) => renderBlock(sheet, b, i)));
    }
    emptyEl.hidden = sheet.blocks.length > 0;
    // the trailing ＋ Add a block ghost: edit mode only, and the empty hint
    // already offers the menu when there are no blocks at all
    addRowEl.hidden = playing() || sheet.blocks.length === 0;
    if (Math.abs(window.scrollY - scrollY) > 1) window.scrollTo(0, scrollY);
  }

  function renderAll() {
    const sheet = getActive(store);
    selectEl.replaceChildren(
      ...activeSheets(store).map((s) => {
        const opt = document.createElement('option');
        opt.value = s.id;
        opt.textContent = s.name;
        opt.selected = s.id === store.activeId;
        return opt;
      }),
    );
    renderTrash();
    nameEl.textContent = sheet.name;
    nameEl.contentEditable = playing() ? 'false' : 'true';
    modeBtn.textContent = playing() ? '✎ Edit' : '▶ Play';
    modeBtn.setAttribute('aria-pressed', playing() ? 'true' : 'false');
    // play edits values, not structure (§16) — no inserting at the table,
    // and the whole authoring frame folds away (CSS keys off this attribute:
    // New/Rename/Delete, templates, pages, export, Drive, brews, trash)
    pageEl.toggleAttribute('data-playing', playing());
    insertOpenBtn.hidden = playing();
    if (playing()) closeInsertMenu();
    updateUndoButtons();
    // genre pin (PLAN.md §15): the attribute on the sheet surface makes the
    // pack's tokens win inside it — on screen and in print
    genrePinEl.value = sheet.genre ?? '';
    if (sheet.genre) sheetEl.dataset.genre = sheet.genre;
    else delete sheetEl.dataset.genre;
    // dice-skin pin (PLAN.md §17): the stage reads this attribute per roll
    if (sheet.diceSkin) sheetEl.dataset.diceSkin = sheet.diceSkin;
    else delete sheetEl.dataset.diceSkin;
    renderBlocks();
    if (pagesOn) void renderPages(); // the preview tracks live edits
  }

  modeBtn.addEventListener('click', () => {
    const sheet = getActive(store);
    sheet.mode = playing() ? 'edit' : 'play';
    save();
    renderAll();
  });

  undoBtn.addEventListener('click', () => bus.undo());
  redoBtn.addEventListener('click', () => bus.redo());

  // Page view (PLAN.md §10): REAL fixed-size pages with measured overflow —
  // a CSS-only preview lies at the printer, so this one measures and warns.
  const pageViewEl = $('[data-page-view]');
  const pagesBtn = $('[data-pages-toggle]');
  let pagesOn = false;

  function addPage(): HTMLElement {
    const p = document.createElement('div');
    p.className = 'page';
    const inner = document.createElement('div');
    inner.className = 'page-inner';
    p.appendChild(inner);
    pageViewEl.appendChild(p);
    return inner;
  }

  /** Wait until every image in the preview has bytes and a decoded size —
   *  measuring before that undercounts and the warning would lie. */
  async function settleImages(host: HTMLElement): Promise<void> {
    for (let i = 0; i < 20; i++) {
      const imgs = [...host.querySelectorAll('img')];
      if (imgs.every((im) => im.src)) {
        await Promise.all(imgs.map((im) => im.decode().catch(() => {})));
        return;
      }
      await new Promise((r) => setTimeout(r, 25));
    }
  }

  const overflowing = (inner: HTMLElement) => inner.scrollHeight > inner.clientHeight + 1;

  async function renderPages(): Promise<void> {
    const sheet = getActive(store);
    pageViewEl.replaceChildren();
    if (sheet.genre) pageViewEl.dataset.genre = sheet.genre;
    else delete pageViewEl.dataset.genre;

    // build every block once, at page width, and let images settle BEFORE
    // any measurement — then deal the elements onto pages
    const staging = addPage();
    const items: (HTMLElement | 'break')[] = [];
    for (const block of sheet.blocks) {
      if (block.type === 'pageBreak') {
        items.push('break');
        continue;
      }
      const el = renderBlockStatic(block);
      staging.appendChild(el);
      items.push(el);
    }
    await settleImages(pageViewEl);
    pageViewEl.replaceChildren();

    let inner = addPage();
    for (const item of items) {
      if (item === 'break') {
        inner = addPage();
        continue;
      }
      inner.appendChild(item);
      if (overflowing(inner) && inner.children.length > 1) {
        inner = addPage();
        inner.appendChild(item);
      }
      if (overflowing(inner)) inner.parentElement!.classList.add('page-overflow');
    }

    const pages = [...pageViewEl.querySelectorAll<HTMLElement>('.page')];
    pages.forEach((p, i) => {
      const num = document.createElement('span');
      num.className = 'page-num';
      num.textContent = `page ${i + 1} of ${pages.length}`;
      p.appendChild(num);
      if (p.classList.contains('page-overflow')) {
        const warn = document.createElement('p');
        warn.className = 'page-warn';
        warn.textContent = `⚠ content spills page ${i + 1} — the printer will clip it`;
        p.prepend(warn);
      }
    });
  }

  pagesBtn.addEventListener('click', () => {
    pagesOn = !pagesOn;
    pagesBtn.setAttribute('aria-pressed', String(pagesOn));
    sheetEl.hidden = pagesOn;
    pageViewEl.hidden = !pagesOn;
    if (pagesOn) void renderPages();
  });

  const sheetEl = $('[data-sheet]');
  const genrePinEl = $<HTMLSelectElement>('[data-genre-pin]');
  genrePinEl.addEventListener('change', () => {
    const sheet = getActive(store);
    const v = genrePinEl.value;
    sheet.genre = v === 'fantasy' || v === 'scifi' || v === 'horror' ? v : undefined;
    save();
    renderAll();
  });

  nameEl.addEventListener('input', () => {
    const sheet = getActive(store);
    sheet.name = nameEl.textContent ?? 'Untitled';
    save();
    const opt = selectEl.querySelector<HTMLOptionElement>(`option[value="${sheet.id}"]`);
    if (opt) opt.textContent = sheet.name;
  });

  selectEl.addEventListener('change', () => {
    store.activeId = selectEl.value;
    bus.clear(); // the undo stack is per-sheet — history doesn't cross sheets
    save();
    renderAll();
  });

  $('[data-new]').addEventListener('click', () => {
    const name = prompt('Name the new sheet:', `Session ${store.sheets.length + 1}`);
    if (!name) return;
    createSheet(store, name.trim() || 'Untitled');
    bus.clear();
    renderAll();
  });

  $('[data-rename]').addEventListener('click', () => {
    const sheet = getActive(store);
    const name = prompt('Rename sheet:', sheet.name);
    if (!name) return;
    sheet.name = name.trim() || sheet.name;
    save();
    renderAll();
  });

  $('[data-delete]').addEventListener('click', () => {
    const sheet = getActive(store);
    if (!confirm(`Move "${sheet.name}" (${sheet.blocks.length} block(s)) to the trash? It stays restorable for 30 days.`)) return;
    deleteSheet(store, sheet.id);
    bus.clear();
    renderAll();
  });

  // --- Trash (PLAN.md §12/§19.3): soft delete, 30-day retention.
  const trashList = $('[data-trash-list]');
  const trashCount = $('[data-trash-count]');
  function renderTrash() {
    const trashed = trashedSheets(store);
    trashCount.textContent = trashed.length ? `(${trashed.length})` : '';
    trashList.replaceChildren(
      ...trashed.map((s) => {
        const row = document.createElement('p');
        const name = document.createElement('b');
        name.textContent = s.name;
        const when = document.createElement('span');
        when.className = 'trash-when';
        when.textContent = ` ${s.blocks.length} block(s), deleted ${new Date(s.deletedAt!).toLocaleDateString()} `;
        const restoreBtn = document.createElement('button');
        restoreBtn.type = 'button';
        restoreBtn.className = 'btn';
        restoreBtn.textContent = '↩ Restore';
        restoreBtn.addEventListener('click', () => {
          restoreSheet(store, s.id);
          bus.clear();
          renderAll();
        });
        const purgeBtn = document.createElement('button');
        purgeBtn.type = 'button';
        purgeBtn.className = 'btn';
        purgeBtn.textContent = '✕ Delete forever';
        purgeBtn.addEventListener('click', () => {
          if (!confirm(`Permanently delete "${s.name}"? This cannot be undone.`)) return;
          purgeSheet(store, s.id);
          renderAll();
        });
        row.append(name, when, restoreBtn, ' ', purgeBtn);
        return row;
      }),
    );
  }

  function addBlock(block: Block, label: string, at?: number) {
    const sheet = getActive(store);
    const index = Math.min(at ?? sheet.blocks.length, sheet.blocks.length);
    bus.execute({
      label,
      apply: () => sheet.blocks.splice(index, 0, block),
      revert: () => {
        const i = sheet.blocks.indexOf(block);
        if (i >= 0) sheet.blocks.splice(i, 1);
      },
    });
  }

  // ---- ＋ Insert: ONE menu, every block type. Opened from the toolbar
  // (appends), from a block's edge ＋ (inserts there), or from the empty
  // hint. Until this menu, seven of the kit's block types could only
  // arrive via pins or templates — never be added by hand.
  const insertMenu = $('[data-insert-menu]');
  let insertAt: number | undefined; // undefined = append at the end

  function openInsertMenu(anchor: HTMLElement, at?: number): void {
    insertAt = at;
    insertMenu.hidden = false;
    const r = anchor.getBoundingClientRect();
    insertMenu.style.top = `${Math.max(8, Math.min(r.bottom + 4, innerHeight - insertMenu.offsetHeight - 8))}px`;
    insertMenu.style.left = `${Math.max(8, Math.min(r.left, innerWidth - insertMenu.offsetWidth - 8))}px`;
    insertMenu.querySelector<HTMLButtonElement>('button')?.focus();
  }
  function closeInsertMenu(): void {
    insertMenu.hidden = true;
    insertAt = undefined;
  }

  // Openers toggle; outside pointerdown closes. The opener check keeps
  // pointerdown-close and click-open from fighting over the same press.
  document.addEventListener('pointerdown', (e) => {
    if (insertMenu.hidden) return;
    const t = e.target as HTMLElement;
    if (insertMenu.contains(t) || t.closest('[data-insert-open],[data-insert-empty],.block-insert')) return;
    closeInsertMenu();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !insertMenu.hidden) closeInsertMenu();
  });
  $('[data-insert-open]').addEventListener('click', (e) => {
    if (!insertMenu.hidden) closeInsertMenu();
    else openInsertMenu(e.currentTarget as HTMLElement);
  });
  $('[data-insert-empty]').addEventListener('click', (e) => openInsertMenu(e.currentTarget as HTMLElement));
  $('[data-sheet-add]').addEventListener('click', (e) => openInsertMenu(e.currentTarget as HTMLElement));

  function menuAdd(sel: string, label: string, make: () => Block): void {
    insertMenu.querySelector<HTMLButtonElement>(sel)!.addEventListener('click', () => {
      const at = insertAt;
      closeInsertMenu();
      addBlock(make(), label, at);
    });
  }
  menuAdd('[data-add-title]', 'add heading', () => ({ type: 'title', text: 'New heading', id: `pin-${newId()}` }));
  menuAdd('[data-add-note]', 'add note', () => ({ type: 'paragraph', label: 'Note', text: 'Write here…', id: `pin-${newId()}` }));
  menuAdd('[data-add-list]', 'add list', () => ({ type: 'list', items: ['First item', 'Second item'], id: `pin-${newId()}` }));
  menuAdd('[data-add-table]', 'add table', () => ({
    type: 'table',
    columns: ['Item', 'Notes'],
    rows: [['', ''], ['', '']],
    id: `pin-${newId()}`,
  }));
  menuAdd('[data-add-keyvalue]', 'add key–value', () => ({
    type: 'keyValue',
    pairs: [{ key: 'Label', value: 'Value' }],
    id: `pin-${newId()}`,
  }));
  menuAdd('[data-add-statgrid]', 'add stat grid', () => ({
    type: 'statGrid',
