  }

  .sheet .block-controls {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    gap: 2px;
    opacity: 0;
    transition: opacity 120ms;
  }

  .sheet .block:hover .block-controls,
  .sheet .block:focus-within .block-controls {
    opacity: 1;
  }

  .sheet .block-controls .btn {
    padding: 0 var(--space-2);
    font-size: var(--text-sm);
  }

  /* An [hidden] that actually hides: global.css's `.btn { display:inline-flex }`
     otherwise defeats the attribute (the always-visible Disconnect bug). */
  .sheet-page [hidden] {
    display: none !important;
  }

  /* Play mode (§16): the authoring frame folds away — a player at the table
     sees the sheet, the sheet picker, Edit, Print, the roll log, and their
     dice. No Delete under a thumb, no Drive plumbing, no template gallery. */
  .sheet-page[data-playing] :is(
    [data-new], [data-from-template], [data-rename], [data-delete],
    [data-genre-pin], [data-pages-toggle], [data-export],
    [data-drive-chip], [data-drive-save], [data-drive-load],
    [data-drive-disconnect], [data-sync-pill], [data-drive-status],
    .drive-hint, .brew-panel, .trash-panel
  ) {
    display: none !important;
  }

  /* No control strip in play mode — give the reserved gutter back to the
     content (a third of a phone's width). */
  .sheet .block.block-play {
    padding-right: 0;
  }

  /* The ＋ on every block's top-left edge — insert exactly here. */
  .sheet .block-insert {
    position: absolute;
    top: -0.7rem;
    left: -2.4rem;
    padding: 0 var(--space-2);
    font-size: var(--text-sm);
    opacity: 0;
    transition: opacity 120ms;
  }

  .sheet .block:hover .block-insert,
  .sheet .block:focus-within .block-insert,
