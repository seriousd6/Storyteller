---
import Base from '../layouts/Base.astro';
---

<Base title="Sheet Builder" description="Compose pinned results into a printable, statblock-style prep sheet." hideTray>
  <div class="sheet-page">
    <div class="sheet-toolbar no-print">
      <select data-sheet-select aria-label="Active sheet"></select>
      <button class="btn" data-new type="button">＋ New sheet</button>
      <button class="btn" data-from-template type="button" title="Start from a boilerplate page that fills itself by rolling">✦ From template</button>
      <button class="btn" data-rename type="button">Rename</button>
      <button class="btn" data-delete type="button">Delete</button>
      <span class="toolbar-gap"></span>
      <button class="btn" data-mode-toggle type="button" title="Play: tokens roll, text locks. Edit: full editing.">▶ Play</button>
      <span class="toolbar-gap"></span>
      <button class="btn" data-add-title type="button">＋ Heading</button>
      <button class="btn" data-add-note type="button">＋ Note</button>
      <button class="btn" data-add-rolltable type="button" title="Embed a live roll table">＋ Roll table</button>
      <button class="btn" data-add-pagebreak type="button">＋ Page break</button>
      <span class="toolbar-gap"></span>
      <button class="btn" data-export type="button">⬇ Markdown</button>
      <button class="btn btn-primary" data-print type="button">🖨 Print</button>
      <span class="toolbar-gap"></span>
      <span class="drive-chip" data-drive-chip>☁ Drive: not connected</span>
      <button class="btn" data-drive-save type="button" title="Back up all sheets to your Google Drive">☁ Save to Drive</button>
      <button class="btn" data-drive-load type="button" title="Restore sheets from your Google Drive backup">☁ Load</button>
      <button class="btn" data-drive-disconnect type="button" hidden title="Revoke this site's Drive access and forget the link on this device">Disconnect</button>
      <span class="drive-status" data-drive-status aria-live="polite"></span>
    </div>
    <p class="drive-hint no-print">
      Drive backup sends <strong>only the documents you create on this site</strong> —
      today that's your sheets; maps, stat blocks, and trackers will join the same backup
      as they arrive — to a single file (<code>storyteller-toolbox-data.json</code>) in
      <strong>your own Google Drive</strong>, so you can pick up where you left off on any
      device. Nothing else is sent, read, or shared, and this site has no server that
      could keep a copy. <a href="/privacy/">Privacy&nbsp;policy</a>
    </p>

    <details class="roll-log no-print" data-roll-log>
      <summary>🎲 Roll log</summary>
      <ol data-roll-entries></ol>
    </details>

    <article class="sheet" data-sheet>
      <h1 class="sheet-name" data-sheet-name contenteditable="true" spellcheck="false"></h1>
      <div class="sheet-rule"></div>
      <div data-blocks></div>
      <p class="sheet-empty no-print" data-empty hidden>
        This sheet is empty. Pin 📌 results from any generator, start
        <button class="btn" data-from-template-empty type="button">✦ from a template</button>,
        or add a heading or note above — then arrange, edit, and print.
      </p>
    </article>

    <dialog class="template-gallery" data-template-dialog>
      <h2>New sheet from a template</h2>
      <p class="gallery-hint">Templates arrive already rolled — every blank filled by the site's tables. Reroll anything you don't like.</p>
      <div data-template-list></div>
      <button class="btn" data-template-close type="button">Close</button>
    </dialog>
  </div>
</Base>

<script>
  import { loadStore, saveStore, getActive, createSheet, deleteSheet, sheetToMarkdown, newId, SHEET_EVENT } from '../engine/sheetStore';
  import type { Sheet } from '../engine/sheetStore';
  import type { Block, ParagraphBlock, RollTableBlock, TitleBlock } from '../engine/types';
  import { renderBlockEditable, renderBlockPlay, type EditCtx } from '../engine/blockKit';
  import { CommandBus } from '../engine/commands';
  import { enableDragReorder, moveItem } from '../engine/dragList';
  import { saveToDrive, loadFromDrive, disconnect, isConnected, isLinked, DRIVE_EVENT } from '../engine/drive';
  import { buildBackup, parseBackup, restoreWorlds } from '../engine/backup.ts';
  import { referencedTables, renderTemplate } from '../engine/roll';
  import { loadClosure } from '../engine/tableLoader';
  import { randomSeed } from '../engine/rng';
  import { getRollLog, ROLL_LOG_EVENT } from '../engine/rollLog';
  import { collectVars } from '../engine/vars';

  // Boilerplate pages (PLAN.md §9): small JSON docs of blocks whose text may
  // carry {table:} tokens — instantiation rolls them all with one seed.
  interface SheetTemplate {
    id: string;
    title: string;
    kind?: string;
    description?: string;
    blocks: Block[];
  }
  const TEMPLATES: SheetTemplate[] = Object.values(
    import.meta.glob('../sheets/templates/*.json', { eager: true }),
  ).map((m) => (m as { default: SheetTemplate }).default);

  const SOURCE = 'sheet-page';
  let store = loadStore();

  const $ = <T extends HTMLElement = HTMLElement>(sel: string) => document.querySelector<T>(sel)!;
  const blocksEl = $('[data-blocks]');
  const selectEl = $<HTMLSelectElement>('[data-sheet-select]');
  const nameEl = $('[data-sheet-name]');
  const emptyEl = $('[data-empty]');

  const save = () => saveStore(store, SOURCE);

  // Per-type rendering lives in the Block Kit (engine/blocks/*); this page
  // supplies the ctx: persistence (save), and the undo bus. Every structural
  // edit — here or inside a block def — is a Command, so ctrl+Z works.
  const bus = new CommandBus(() => {
    save();
    renderBlocks();
  });
  const editCtx: EditCtx = {
    mode: 'edit',
    renderChild: (b) => renderBlockEditable(b, editCtx),
    save,
    execute: (cmd) => bus.execute(cmd),
    record: (cmd) => bus.record(cmd),
    // read at CLICK time by dice chips / stat boxes / action rows — a raised
    // STR reaches every later roll without re-rendering anything
    vars: () => collectVars(getActive(store).blocks),
  };

  function renderBlock(sheet: Sheet, block: Block, index: number): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = `block block-${block.type}`;
    wrap.appendChild(renderBlockEditable(block, editCtx));

    const controls = document.createElement('div');
    controls.className = 'block-controls no-print';

    // Drag handle: the block becomes draggable only while grabbed by the
    // handle, so text selection in contenteditable regions still works.
    const handle = document.createElement('button');
    handle.type = 'button';
    handle.className = 'btn block-grip';
    handle.textContent = '⠿';
    handle.title = 'Drag to reorder';
    handle.setAttribute('aria-label', 'Drag to reorder');
    handle.addEventListener('pointerdown', () => (wrap.draggable = true));
    handle.addEventListener('pointerup', () => (wrap.draggable = false));
    wrap.addEventListener('dragend', () => (wrap.draggable = false));
    controls.appendChild(handle);

    const actions: [string, string, () => void][] = [
      ['↑', 'Move up', () => move(sheet, index, -1)],
      ['↓', 'Move down', () => move(sheet, index, 1)],
      ['⧉', 'Duplicate', () => duplicate(sheet, index)],
      ['✕', 'Remove', () => remove(sheet, index)],
    ];
    for (const [glyph, label, fn] of actions) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'btn';
      btn.textContent = glyph;
      btn.title = label;
      btn.setAttribute('aria-label', label);
      btn.addEventListener('click', fn);
      controls.appendChild(btn);
    }
    wrap.appendChild(controls);
    return wrap;
  }

  function move(sheet: Sheet, index: number, delta: number) {
    const target = index + delta;
    if (target < 0 || target >= sheet.blocks.length) return;
    bus.execute({
      label: 'move block',
      apply: () => moveItem(sheet.blocks, index, target),
      revert: () => moveItem(sheet.blocks, target, index),
    });
  }

  function duplicate(sheet: Sheet, index: number) {
    const copy: Block = structuredClone(sheet.blocks[index]!);
    copy.id = `pin-${newId()}`;
    // a statblock's sections carry ids too — a clone sharing them with the
    // original is a latent duplicate-id bug for anything that addresses
    // blocks by id (per-block overrides, sync)
    if (copy.type === 'statblock') {
      for (const s of copy.sections as Array<{ id?: string }>) {
        if (s.id) s.id = `pin-${newId()}`;
      }
    }
    bus.execute({
      label: 'duplicate block',
      apply: () => sheet.blocks.splice(index + 1, 0, copy),
      revert: () => {
        const at = sheet.blocks.indexOf(copy);
        if (at >= 0) sheet.blocks.splice(at, 1);
      },
    });
  }

  function remove(sheet: Sheet, index: number) {
    const block = sheet.blocks[index]!;
    bus.execute({
      label: 'remove block',
      apply: () => {
        const at = sheet.blocks.indexOf(block);
        if (at >= 0) sheet.blocks.splice(at, 1);
      },
      revert: () => sheet.blocks.splice(index, 0, block),
    });
  }

  // Play mode (PLAN.md §16): tokens live, text locked, structure chrome
  // hidden. Remembered per sheet.
  const modeBtn = $('[data-mode-toggle]');
  const playing = () => getActive(store).mode === 'play';

  function renderBlocks() {
    const sheet = getActive(store);
    if (playing()) {
      blocksEl.replaceChildren(
        ...sheet.blocks.map((b) => {
          const wrap = document.createElement('div');
          wrap.className = `block block-${b.type} block-play`;
          wrap.appendChild(renderBlockPlay(b, editCtx));
          return wrap;
        }),
      );
    } else {
      blocksEl.replaceChildren(...sheet.blocks.map((b, i) => renderBlock(sheet, b, i)));
    }
    emptyEl.hidden = sheet.blocks.length > 0;
  }

  function renderAll() {
    const sheet = getActive(store);
    selectEl.replaceChildren(
      ...store.sheets.map((s) => {
        const opt = document.createElement('option');
        opt.value = s.id;
        opt.textContent = s.name;
        opt.selected = s.id === store.activeId;
        return opt;
      }),
    );
    nameEl.textContent = sheet.name;
    nameEl.contentEditable = playing() ? 'false' : 'true';
    modeBtn.textContent = playing() ? '✎ Edit' : '▶ Play';
    modeBtn.setAttribute('aria-pressed', playing() ? 'true' : 'false');
    renderBlocks();
  }

  modeBtn.addEventListener('click', () => {
    const sheet = getActive(store);
    sheet.mode = playing() ? 'edit' : 'play';
    save();
    renderAll();
  });

  nameEl.addEventListener('input', () => {
    const sheet = getActive(store);
    sheet.name = nameEl.textContent ?? 'Untitled';
    save();
    const opt = selectEl.querySelector<HTMLOptionElement>(`option[value="${sheet.id}"]`);
    if (opt) opt.textContent = sheet.name;
  });

  selectEl.addEventListener('change', () => {
    store.activeId = selectEl.value;
    bus.clear(); // the undo stack is per-sheet — history doesn't cross sheets
    save();
    renderAll();
  });

  $('[data-new]').addEventListener('click', () => {
    const name = prompt('Name the new sheet:', `Session ${store.sheets.length + 1}`);
    if (!name) return;
    createSheet(store, name.trim() || 'Untitled');
    bus.clear();
    renderAll();
  });

  $('[data-rename]').addEventListener('click', () => {
    const sheet = getActive(store);
    const name = prompt('Rename sheet:', sheet.name);
    if (!name) return;
    sheet.name = name.trim() || sheet.name;
    save();
    renderAll();
  });

  $('[data-delete]').addEventListener('click', () => {
    const sheet = getActive(store);
    if (!confirm(`Delete "${sheet.name}" and its ${sheet.blocks.length} block(s)?`)) return;
    deleteSheet(store, sheet.id);
    bus.clear();
    renderAll();
  });

  function addBlock(block: Block, label: string) {
    const sheet = getActive(store);
    bus.execute({
      label,
      apply: () => sheet.blocks.push(block),
      revert: () => {
        const at = sheet.blocks.indexOf(block);
        if (at >= 0) sheet.blocks.splice(at, 1);
      },
    });
  }

  $('[data-add-title]').addEventListener('click', () => {
    const block: TitleBlock = { type: 'title', text: 'New heading', id: `pin-${newId()}` };
    addBlock(block, 'add heading');
  });

  $('[data-add-note]').addEventListener('click', () => {
    const block: ParagraphBlock = { type: 'paragraph', label: 'Note', text: 'Write here…', id: `pin-${newId()}` };
    addBlock(block, 'add note');
  });

  $('[data-add-rolltable]').addEventListener('click', () => {
    const ref = prompt('Table id to embed (e.g. gm/tavern/rumor):', 'gm/tavern/rumor');
    if (!ref) return;
    const block: RollTableBlock = { type: 'rollTable', ref: ref.trim(), id: `pin-${newId()}` };
    addBlock(block, 'add roll table');
  });

  $('[data-add-pagebreak]').addEventListener('click', () => {
    addBlock({ type: 'pageBreak', id: `pin-${newId()}` }, 'add page break');
  });

  // --- Template gallery (PLAN.md §9): instantiate = roll every {table:}
  // token with one seed; each block records {template, seed} provenance.
  const dialog = $<HTMLDialogElement>('[data-template-dialog]');
  const templateList = $('[data-template-list]');

  function textsOf(block: Block): string[] {
    switch (block.type) {
      case 'title':
        return [block.text, block.subtitle ?? ''];
      case 'paragraph':
        return [block.text];
      case 'keyValue':
        return block.pairs.flatMap((p) => [p.key, p.value]);
      case 'list':
        return block.items;
      case 'table':
        return [...block.columns, ...block.rows.flat()];
      case 'statblock':
        return [block.name, block.meta ?? '', ...block.sections.flatMap(textsOf)];
      case 'rollTable':
        return [`{table:${block.ref}}`]; // pulls the widget's closure too
      case 'pageBreak':
      case 'tracker':
      case 'statGrid':
      case 'actions':
        return []; // no {table:} tokens live in these
    }
  }

  function fillText(text: string, tables: Awaited<ReturnType<typeof loadClosure>>, seed: string): string {
    return referencedTables(text).length || /\{(count|num|pick|var):/.test(text)
      ? renderTemplate(text, tables, seed)
      : text;
  }

  async function instantiate(template: SheetTemplate): Promise<void> {
    const refs = template.blocks.flatMap(textsOf).flatMap(referencedTables);
    const tables = await loadClosure([...new Set(refs)]);
    const seed = randomSeed();
    let n = 0;
    const next = () => `${seed}:${n++}`;
    const fill = (block: Block): Block => {
      const b: Block = structuredClone(block);
      b.id = `pin-${newId()}`;
      b.source = { generator: `template:${template.id}`, seed };
      switch (b.type) {
        case 'title':
          b.text = fillText(b.text, tables, next());
          if (b.subtitle) b.subtitle = fillText(b.subtitle, tables, next());
          break;
        case 'paragraph':
          b.text = fillText(b.text, tables, next());
          break;
        case 'keyValue':
          for (const p of b.pairs) p.value = fillText(p.value, tables, next());
          break;
        case 'list':
          b.items = b.items.map((i) => fillText(i, tables, next()));
          break;
        case 'table':
          b.rows = b.rows.map((r) => r.map((c) => fillText(c, tables, next())));
          break;
        case 'statblock':
          b.name = fillText(b.name, tables, next());
          if (b.meta) b.meta = fillText(b.meta, tables, next());
          b.sections = b.sections.map(fill);
          break;
      }
      return b;
    };
    // Build the sheet fully BEFORE saving: createSheet() saves eagerly, and
    // its SHEET_EVENT makes this page reload the store mid-flight — blocks
    // written onto the stale sheet object afterwards would be lost.
    const sheet: Sheet = { id: newId(), name: template.title, blocks: template.blocks.map(fill) };
    store.sheets.push(sheet);
    store.activeId = sheet.id;
    save();
    bus.clear();
    dialog.close();
    renderAll();
  }

  function openGallery(): void {
    templateList.replaceChildren(
      ...TEMPLATES.map((t) => {
        const card = document.createElement('button');
        card.type = 'button';
        card.className = 'template-card';
        card.setAttribute('data-template-id', t.id);
        const h = document.createElement('b');
        h.textContent = t.title;
        const p = document.createElement('span');
        p.textContent = t.description ?? '';
        card.append(h, p);
        card.addEventListener('click', () => {
          card.disabled = true;
          instantiate(t).catch((err) => {
            card.disabled = false;
            alert(err instanceof Error ? err.message : 'template failed to load');
          });
        });
        return card;
      }),
    );
    dialog.showModal();
  }
  $('[data-from-template]').addEventListener('click', openGallery);
  $('[data-from-template-empty]').addEventListener('click', openGallery);
  $('[data-template-close]').addEventListener('click', () => dialog.close());

  // --- Roll log (PLAN.md §16): last rolls, newest first, session-scoped.
  const rollEntries = $('[data-roll-entries]');
  function renderRollLog(): void {
    rollEntries.replaceChildren(
      ...getRollLog()
        .slice(0, 10)
        .map((e) => {
          const li = document.createElement('li');
          const b = document.createElement('b');
          b.textContent = e.label;
          li.append(b, ` ${e.detail}`);
          return li;
        }),
    );
  }
  window.addEventListener(ROLL_LOG_EVENT, renderRollLog);
  renderRollLog();

  $('[data-export]').addEventListener('click', () => {
    const sheet = getActive(store);
    const blob = new Blob([sheetToMarkdown(sheet)], { type: 'text/markdown' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `${sheet.name.replace(/[^\w-]+/g, '-').toLowerCase() || 'sheet'}.md`;
    a.click();
    URL.revokeObjectURL(a.href);
  });

  $('[data-print]').addEventListener('click', () => window.print());

  // Google Drive backup: one JSON file in the user's own Drive holding every
  // sheet. Save overwrites it (Drive keeps ~30 days of revisions); Load
  // replaces the local store after an explicit confirm.
  const driveStatus = $('[data-drive-status]');
  const setDriveStatus = (msg: string) => (driveStatus.textContent = msg);
  const driveError = (err: unknown, fallback: string) =>
    setDriveStatus(err instanceof Error ? err.message : fallback);

  // Connection chip: live token > linked-before > never connected.
  const driveChip = $('[data-drive-chip]');
  const disconnectBtn = $<HTMLButtonElement>('[data-drive-disconnect]');
  function renderDrive() {
    if (isConnected()) {
      driveChip.textContent = '☁ Drive: connected ●';
      driveChip.dataset.state = 'on';
      driveChip.title = 'This session is authorized — Save and Load work without another popup.';
    } else if (isLinked()) {
      driveChip.textContent = '☁ Drive: linked';
      driveChip.dataset.state = 'linked';
      driveChip.title = 'Drive was linked on this device — the next Save or Load reconnects automatically.';
    } else {
      driveChip.textContent = '☁ Drive: not connected';
      driveChip.dataset.state = 'off';
      driveChip.title = 'Click Save to Drive to connect your Google Drive.';
    }
    disconnectBtn.hidden = !isConnected() && !isLinked();
  }
  window.addEventListener(DRIVE_EVENT, renderDrive);
  renderDrive();

  disconnectBtn.addEventListener('click', async () => {
    await disconnect();
    setDriveStatus('Drive access revoked. Your backup file stays in your Drive.');
  });

  // Versioned envelope shared with /world/ (engine/backup.ts): v2 carries
  // { sheets, worlds }, so saving from this page never drops worlds and
  // vice versa. Older v1/bare backups still load.

  $('[data-drive-save]').addEventListener('click', async () => {
    try {
      setDriveStatus('Saving to Drive…');
      const result = await saveToDrive(await buildBackup(store));
      const total = store.sheets.reduce((n, s) => n + s.blocks.length, 0);
      setDriveStatus(
        `✓ Backed up ${store.sheets.length} sheet(s), ${total} block(s) + your worlds · ${new Date(result.modifiedTime).toLocaleTimeString()}`,
      );
    } catch (err) {
      driveError(err, 'Drive save failed.');
    }
  });

  $('[data-drive-load]').addEventListener('click', async () => {
    try {
      setDriveStatus('Checking Drive…');
      const backup = await loadFromDrive();
      if (!backup) {
        setDriveStatus('No Drive backup yet — use ☁ Save to Drive first.');
        return;
      }
      const incoming = parseBackup(backup.json);
      if (!incoming.sheets || !Array.isArray(incoming.sheets.sheets)) throw new Error('The Drive file is not a Storyteller Toolbox backup.');
      const when = new Date(backup.modifiedTime).toLocaleString();
      if (
        !confirm(
          `Replace the ${store.sheets.length} sheet(s) on this device with the Drive backup? ` +
            `(${incoming.sheets.sheets.length} sheet(s), saved ${when})`,
        )
      ) {
        setDriveStatus('');
        return;
      }
      store = incoming.sheets;
      save();
      store = loadStore(); // normalizes activeId and empty stores
      bus.clear(); // every block object was just replaced — old commands are stale
      renderAll();
      const worlds = await restoreWorlds(incoming.worlds);
      setDriveStatus(
        `✓ Restored from Drive (saved ${when})` +
          (worlds.restored ? ` · ${worlds.restored} world(s) restored` : '') +
          (worlds.skippedOlder ? ` · ${worlds.skippedOlder} world(s) kept (local copy newer)` : '') + '.',
      );
    } catch (err) {
      driveError(err, 'Drive load failed.');
    }
  });

  enableDragReorder(blocksEl, '.block', (from, to) => {
    const sheet = getActive(store);
    bus.execute({
      label: 'reorder blocks',
      apply: () => moveItem(sheet.blocks, from, to),
      revert: () => moveItem(sheet.blocks, to, from),
    });
  });

  // Undo/redo. Inside a contenteditable field the browser's native text undo
  // handles ctrl+Z (its input events run set(), keeping the model in sync);
  // everywhere else the command bus does.
  document.addEventListener('keydown', (e) => {
    if (!(e.ctrlKey || e.metaKey)) return;
    const key = e.key.toLowerCase();
    if (key !== 'z' && key !== 'y') return;
    if (e.target instanceof HTMLElement && e.target.isContentEditable) return;
    const redo = key === 'y' || (key === 'z' && e.shiftKey);
    if (redo ? bus.redo() : bus.undo()) e.preventDefault();
  });

  // Live-sync with pins and the tray; ignore our own writes so typing
  // in a contenteditable block never re-renders out from under the caret.
  window.addEventListener(SHEET_EVENT, ((e: CustomEvent) => {
    if (e.detail?.source === SOURCE) return;
    store = loadStore();
    bus.clear(); // fresh objects from storage — undo history would mutate stale ones
    renderAll();
  }) as EventListener);

  renderAll();
</script>

<style>
  .sheet-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .sheet-toolbar select {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    max-width: 14rem;
  }

  .toolbar-gap {
    flex: 0 0 var(--space-4);
  }

  .drive-status {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  .drive-chip {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-1) var(--space-2);
    white-space: nowrap;
  }

  .drive-chip[data-state='on'] {
    color: #15803d;
    border-color: #15803d;
  }

  :root[data-theme='dark'] .drive-chip[data-state='on'] {
    color: #4ade80;
    border-color: #4ade80;
  }

  .drive-chip[data-state='linked'] {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .drive-hint {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    max-width: 46rem;
    margin-bottom: var(--space-6);
  }

  .sheet {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: var(--space-8);
    max-width: 50rem;
    margin-inline: auto;
  }

  .sheet-name {
    font-size: var(--text-2xl);
    color: var(--color-statblock);
    outline: none;
