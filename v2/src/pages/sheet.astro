    ],
    id: `pin-${newId()}`,
  }));
  menuAdd('[data-add-statblock]', 'add statblock', () => ({
    type: 'statblock',
    name: 'New creature',
    sections: [{ type: 'paragraph', text: 'Describe it…', id: `pin-${newId()}` }],
    id: `pin-${newId()}`,
  }));
  menuAdd('[data-add-image]', 'add image', () => ({ type: 'image', layout: 'float-right', id: `pin-${newId()}` }));
  menuAdd('[data-add-pagebreak]', 'add page break', () => ({ type: 'pageBreak', id: `pin-${newId()}` }));

  // ＋ Columns (PLAN.md §10): wrap the last blocks on the page into a
  // side-by-side pair — the fast path from "linear notes" to "book page".
  insertMenu.querySelector<HTMLButtonElement>('[data-add-columns]')!.addEventListener('click', () => {
    closeInsertMenu();
    const sheet = getActive(store);
    const take = Math.min(2, sheet.blocks.length);
    const taken = sheet.blocks.slice(sheet.blocks.length - take);
    const cols = columnsOf(taken);
    bus.execute({
      label: 'make columns',
      apply: () => sheet.blocks.splice(sheet.blocks.length - take, take, cols),
      revert: () => {
        const at = sheet.blocks.indexOf(cols);
        if (at >= 0) sheet.blocks.splice(at, 1, ...taken);
      },
    });
  });

  // ---- 🎲 Dice roller (owner ask 2026-07-19): a command-bar tooltip — build
  // a pool (3×d6 + 1×d20…), Roll tumbles every die on the 3D stage and files
  // it in the roll log. Works in edit AND play; the pool survives the roll
  // so a repeat is one click.
  const dicePop = $('[data-dice-pop]');
  const diceKindsEl = $('[data-dice-kinds]');
  const diceFormulaEl = $('[data-dice-formula]');
  const diceRollBtn = $<HTMLButtonElement>('[data-dice-roll]');
  const diceOpenBtn = $('[data-dice-open]');
  const DICE_KINDS = [4, 6, 8, 10, 12, 20, 100];
  const dicePool = new Map<number, number>();

  const dicePoolFormula = (): string =>
    DICE_KINDS.filter((k) => (dicePool.get(k) ?? 0) > 0)
      .map((k) => `${dicePool.get(k)}d${k}`)
      .join('+');

  function renderDicePool(): void {
    const formula = dicePoolFormula();
    diceFormulaEl.textContent = formula ? formula.replaceAll('+', ' + ') : 'pick some dice…';
    diceRollBtn.disabled = !formula;
    for (const count of diceKindsEl.querySelectorAll<HTMLElement>('[data-die-count]')) {
      const k = Number(count.dataset.dieCount);
      count.textContent = String(dicePool.get(k) ?? 0);
    }
  }

  for (const k of DICE_KINDS) {
    const row = document.createElement('div');
    row.className = 'dice-kind';
    const add = document.createElement('button');
    add.type = 'button';
    add.className = 'btn dice-kind-add';
    add.textContent = `d${k}`;
    add.title = `Add a d${k} to the pool`;
    add.addEventListener('click', () => {
      dicePool.set(k, Math.min(20, (dicePool.get(k) ?? 0) + 1));
      renderDicePool();
    });
    const count = document.createElement('b');
    count.dataset.dieCount = String(k);
    count.textContent = '0';
    const minus = document.createElement('button');
    minus.type = 'button';
    minus.className = 'btn dice-kind-minus';
    minus.textContent = '−';
    minus.setAttribute('aria-label', `One fewer d${k}`);
    minus.addEventListener('click', () => {
      dicePool.set(k, Math.max(0, (dicePool.get(k) ?? 0) - 1));
      renderDicePool();
    });
    row.append(add, count, minus);
    diceKindsEl.appendChild(row);
  }

  function closeDicePop(): void {
    dicePop.hidden = true;
  }
  diceOpenBtn.addEventListener('click', () => {
    if (!dicePop.hidden) {
      closeDicePop();
      return;
    }
    renderDicePool();
    dicePop.hidden = false;
    const r = diceOpenBtn.getBoundingClientRect();
    dicePop.style.top = `${Math.max(8, Math.min(r.bottom + 4, innerHeight - dicePop.offsetHeight - 8))}px`;
    dicePop.style.left = `${Math.max(8, Math.min(r.left, innerWidth - dicePop.offsetWidth - 8))}px`;
  });
  document.addEventListener('pointerdown', (e) => {
    if (dicePop.hidden) return;
    const t = e.target as HTMLElement;
    if (dicePop.contains(t) || t.closest('[data-dice-open]')) return;
    closeDicePop();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !dicePop.hidden) closeDicePop();
  });
  $('[data-dice-clear]').addEventListener('click', () => {
    dicePool.clear();
    renderDicePool();
  });
  diceRollBtn.addEventListener('click', () => {
    const formula = dicePoolFormula();
    if (!formula) return;
    void (async () => {
      const [{ roll: rollDice }, { showRoll }] = await Promise.all([
        import('../engine/dice'),
        import('../engine/diceStage'),
      ]);
      const result = rollDice(formula, randomSeed());
      await showRoll(result);
      pushRoll({ label: formula, detail: result.breakdown, total: result.total });
    })();
  });

  // ---- Table picker: the site's whole table forest, searchable, plus the
  // user's brews — replaces the prompt() that demanded a memorized id.
  const pickerDialog = $<HTMLDialogElement>('[data-table-picker]');
  const pickerSearch = $<HTMLInputElement>('[data-picker-search]');
  const pickerList = $('[data-picker-list]');
  let pickerAt: number | undefined;
  const PICKER_CAP = 200;

  function prettyTable(id: string): string {
    const name = id.split('/').pop()!.replace(/-/g, ' ');
    return name.charAt(0).toUpperCase() + name.slice(1);
  }

  function embedTable(ref: string): void {
    const at = pickerAt;
    pickerDialog.close();
    const block: RollTableBlock = { type: 'rollTable', ref, title: prettyTable(ref), id: `pin-${newId()}` };
    addBlock(block, 'add roll table', at);
  }

  async function openTablePicker(at?: number): Promise<void> {
    pickerAt = at;
    const brews = (await getUserTables()).map((t) => t.id);
    const all = [...brews, ...listSiteTables()];
    pickerSearch.placeholder = `Search ${all.length} tables…`;
    const render = () => {
      const q = pickerSearch.value.trim().toLowerCase();
      const hits = q
        ? all.filter((id) => id.toLowerCase().includes(q) || prettyTable(id).toLowerCase().includes(q))
        : all;
      pickerList.replaceChildren(
        ...hits.slice(0, PICKER_CAP).map((id) => {
          const row = document.createElement('button');
          row.type = 'button';
          row.className = 'picker-row';
          row.setAttribute('data-ref', id);
          const b = document.createElement('b');
          b.textContent = prettyTable(id);
          const code = document.createElement('code');
          code.textContent = id;
          row.append(b, code);
          row.addEventListener('click', () => embedTable(id));
          return row;
        }),
      );
      if (hits.length > PICKER_CAP) {
        const more = document.createElement('p');
        more.className = 'picker-more';
        more.textContent = `…and ${hits.length - PICKER_CAP} more — keep typing to narrow`;
        pickerList.append(more);
      } else if (hits.length === 0) {
        const none = document.createElement('p');
        none.className = 'picker-more';
        none.textContent = 'No table matches — brew your own in 🍺 My tables.';
        pickerList.append(none);
      }
    };
    pickerSearch.value = '';
    render();
    pickerSearch.oninput = render;
    pickerDialog.showModal();
    pickerSearch.focus();
  }

  pickerSearch.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    e.preventDefault();
    pickerList.querySelector<HTMLButtonElement>('.picker-row')?.click();
  });
  $('[data-picker-close]').addEventListener('click', () => pickerDialog.close());

  insertMenu.querySelector<HTMLButtonElement>('[data-add-rolltable]')!.addEventListener('click', () => {
    const at = insertAt;
    closeInsertMenu();
    void openTablePicker(at);
  });

  // ---- World entities on sheets (owner decision 2026-07-18, PLAN §21.10):
  // one copy of the data. The picker embeds a LIVE entityRef; "Save to
  // world" promotes a sheet into an entity and re-points the sheet at it.
  const entityDialog = $<HTMLDialogElement>('[data-entity-picker]');
  const entityTitle = $('[data-entity-picker-title]');
  const entityHint = $('[data-entity-picker-hint]');
  const entitySearch = $<HTMLInputElement>('[data-entity-search]');
  const entityList = $('[data-entity-list]');

  function entityRow(label: string, sub: string, pick: () => void): HTMLButtonElement {
    const row = document.createElement('button');
    row.type = 'button';
    row.className = 'picker-row';
    const b = document.createElement('b');
    b.textContent = label;
    const code = document.createElement('code');
    code.textContent = sub;
    row.append(b, code);
    row.addEventListener('click', pick);
    return row;
  }

  async function openEntityPicker(at?: number): Promise<void> {
    const worlds = await getAllWorlds();
    const all = worlds.flatMap((w) =>
      Object.values(w.entities)
        .filter((e) => !e.deleted)
        .map((e) => ({ w, e })),
    );
    if (all.length === 0) {
      alert('No world entities on this device yet — build a world on the World page first.');
      return;
    }
    entityTitle.textContent = 'Embed a world entity';
    entityHint.hidden = false;
    const render = () => {
      const q = entitySearch.value.trim().toLowerCase();
      const hits = q ? all.filter(({ e }) => `${e.name} ${e.kind}`.toLowerCase().includes(q)) : all;
      entityList.replaceChildren(
        ...hits.slice(0, PICKER_CAP).map(({ w, e }) =>
          entityRow(e.name, `${e.kind} · ${w.name}`, () => {
            entityDialog.close();
            addBlock({ type: 'entityRef', worldId: w.id, entityId: e.id, id: `pin-${newId()}` }, 'embed world entity', at);
          }),
        ),
      );
      if (hits.length > PICKER_CAP) {
        const more = document.createElement('p');
        more.className = 'picker-more';
        more.textContent = `…and ${hits.length - PICKER_CAP} more — keep typing to narrow`;
        entityList.append(more);
      }
    };
    entitySearch.value = '';
    render();
    entitySearch.oninput = render;
    entityDialog.showModal();
    entitySearch.focus();
  }

  insertMenu.querySelector<HTMLButtonElement>('[data-add-entityref]')!.addEventListener('click', () => {
    const at = insertAt;
    closeInsertMenu();
    void openEntityPicker(at);
  });
  $('[data-entity-close]').addEventListener('click', () => entityDialog.close());

  function pickWorld(worlds: WorldDoc[]): Promise<WorldDoc | null> {
    return new Promise((resolve) => {
      entityTitle.textContent = 'Save into which world?';
      entityHint.hidden = true;
      entitySearch.value = '';
      entitySearch.oninput = null;
      entityList.replaceChildren(
        ...worlds.map((w) =>
          entityRow(w.name, `${Object.keys(w.entities).length} entities`, () => {
            // resolve BEFORE close(): the close event fires synchronously and
            // its once-listener would otherwise settle the promise with null
            resolve(w);
            entityDialog.close();
          }),
        ),
      );
      entityDialog.addEventListener('close', () => resolve(null), { once: true });
      entityDialog.showModal();
    });
  }

  $('[data-promote]').addEventListener('click', async () => {
    const sheet = getActive(store);
    if (sheet.blocks.length === 0) {
      alert('Nothing to save — the sheet is empty.');
      return;
    }
    if (sheet.blocks.every((b) => b.type === 'entityRef')) {
      alert('This sheet already lives in a world — its content IS the entity.');
      return;
    }
    const worlds = await getAllWorlds();
    if (worlds.length === 0) {
      alert('No worlds on this device yet — create one on the World page first.');
      return;
    }
    const world = worlds.length === 1 ? worlds[0]! : await pickWorld(worlds);
    if (!world) return;
    const kind =
      sheet.kind === 'character' || sheet.kind === 'npc' ? 'person'
      : sheet.kind === 'settlement' ? 'settlement'
      : 'note';
    const entity = newEntity(kind, sheet.name);
    entity.body = structuredClone(sheet.blocks).map((b) => {
      b.id = `pin-${newId()}`;
      return b;
    }) as typeof entity.body;
    world.entities[entity.id] = entity;
    await putWorld(world);
    // the sheet now SHOWS the world's copy — undo detaches the sheet again
    // (the entity stays in the world; delete it there if unwanted)
    const oldBlocks = sheet.blocks.slice();
    const ref: Block = { type: 'entityRef', worldId: world.id, entityId: entity.id, id: `pin-${newId()}` };
    bus.execute({
      label: 'save to world',
      apply: () => {
        sheet.blocks.length = 0;
        sheet.blocks.push(ref);
      },
      revert: () => {
        sheet.blocks.length = 0;
        sheet.blocks.push(...oldBlocks);
      },
    });
  });

  // world-side edits re-render embedded entities — unless WE caused the
  // event, or the user is mid-edit inside the sheet (tearing down a focused
  // contenteditable would eat their caret)
  window.addEventListener(WORLD_EVENT, () => {
    if (isSelfPersist()) return;
    if (blocksEl.contains(document.activeElement)) return;
    renderBlocks();
  });

  // --- Template gallery (PLAN.md §9): instantiate = roll every {table:}
  // token with one seed; each block records {template, seed} provenance.
  const dialog = $<HTMLDialogElement>('[data-template-dialog]');
  const templateList = $('[data-template-list]');

  function textsOf(block: Block): string[] {
    switch (block.type) {
      case 'title':
        return [block.text, block.subtitle ?? ''];
      case 'paragraph':
        return [block.text];
      case 'keyValue':
        return block.pairs.flatMap((p) => [p.key, p.value]);
      case 'list':
        return block.items;
      case 'table':
        return [...block.columns, ...block.rows.flat()];
      case 'statblock':
        return [block.name, block.meta ?? '', ...block.sections.flatMap(textsOf)];
      case 'rollTable':
        return [`{table:${block.ref}}`]; // pulls the widget's closure too
      case 'columns':
        return block.columns.flat().flatMap(textsOf);
      case 'pageBreak':
      case 'tracker':
      case 'statGrid':
      case 'actions':
      case 'image':
      case 'entityRef':
      case 'choice':
      case 'choiceList':
      case 'profGrid':
        return []; // no {table:} tokens live in these
    }
  }

  function fillText(text: string, tables: Awaited<ReturnType<typeof loadClosure>>, seed: string): string {
    return referencedTables(text).length || /\{(count|num|pick|var):/.test(text)
      ? renderTemplate(text, tables, seed)
      : text;
  }

  async function instantiate(template: SheetTemplate, forcedSeed?: string): Promise<void> {
    const refs = template.blocks.flatMap(textsOf).flatMap(referencedTables);
    const tables = await loadClosure([...new Set(refs)]);
    const seed = forcedSeed ?? randomSeed();
    let n = 0;
    // Field order IS a contract: slotSeeds() (engine/generatorTemplate.ts)
    // mirrors this walk so generator pages roll from the same seeds and the
    // ?template=&seed= bridge reproduces them. Change the walk ⇒ change
    // slotSeeds in the same commit (the live-sheet "carries the rolls" e2e
    // is the drift alarm).
    const next = () => `${seed}:${n++}`;
    const fill = (block: Block): Block => {
      const b: Block = structuredClone(block);
      b.id = `pin-${newId()}`;
      b.source = { generator: `template:${template.id}`, seed };
      switch (b.type) {
        case 'title':
          b.text = fillText(b.text, tables, next());
          if (b.subtitle) b.subtitle = fillText(b.subtitle, tables, next());
          break;
        case 'paragraph':
          b.text = fillText(b.text, tables, next());
          break;
        case 'keyValue':
          for (const p of b.pairs) p.value = fillText(p.value, tables, next());
          break;
        case 'list':
          b.items = b.items.map((i) => fillText(i, tables, next()));
          break;
        case 'table':
          b.rows = b.rows.map((r) => r.map((c) => fillText(c, tables, next())));
          break;
        case 'statblock':
          b.name = fillText(b.name, tables, next());
          if (b.meta) b.meta = fillText(b.meta, tables, next());
          b.sections = b.sections.map(fill);
          break;
        case 'columns':
          b.columns = b.columns.map((column) => column.map(fill));
          break;
        case 'image':
          // A template may ask for a rolled starting portrait: 'random'
          // resolves to a seeded recipe over the SRD races (sex rolled too),
          // rerollable in edit like any portrait. Deliberately does NOT
          // consume next() — the text-field seed walk (the slotSeeds
          // contract) is untouched.
          if (b.portrait === 'random') {
            const rng = makeRng(`${seed}:portrait`);
            const race = SRD_PORTRAIT_RACES[Math.floor(rng() * SRD_PORTRAIT_RACES.length)]!;
            b.portrait = serializeRecipe(defaultRecipe(`${seed}:portrait`, race, null));
          }
          break;
      }
      return b;
    };
    // The sheet's name already carries the title — a leading title block
    // that merely repeats it would print the heading twice. One with a
    // subtitle is content (a rolled descriptor) and stays.
    const blocks = template.blocks.filter(
      (b, i) => !(i === 0 && b.type === 'title' && b.text === template.title && !b.subtitle),
    );
    // Build the sheet fully BEFORE saving: createSheet() saves eagerly, and
    // its SHEET_EVENT makes this page reload the store mid-flight — blocks
    // written onto the stale sheet object afterwards would be lost.
    const sheet: Sheet = { id: newId(), name: template.title, kind: template.kind, blocks: blocks.map(fill) };
    store.sheets.push(sheet);
    store.activeId = sheet.id;
    save();
    bus.clear();
    dialog.close();
    renderAll();
  }

  /** A flagged sheet used as boilerplate: its text is already resolved, so
   *  instantiation is a clean copy with fresh ids — no re-rolling. */
  function instantiateFromSheet(source: Sheet): void {
    const sheet: Sheet = {
      id: newId(),
      name: source.name,
      kind: source.kind,
      blocks: structuredClone(source.blocks),
    };
    for (const b of sheet.blocks) if (b.id) b.id = `pin-${newId()}`;
    store.sheets.push(sheet);
    store.activeId = sheet.id;
    save();
    bus.clear();
    dialog.close();
    renderAll();
  }

  // Fresh ids + provenance on a composite's freshly-built blocks, mirroring
  // instantiate()'s fill() (statblock sections carry their own ids too, so a
  // clone must re-id them — else per-block overrides address two blocks at once).
  function stampBlock(block: Block, generator: string, seed: string): Block {
    const b: Block = structuredClone(block);
    b.id = `pin-${newId()}`;
    b.source = { generator, seed };
    if (b.type === 'statblock') b.sections = b.sections.map((s) => stampBlock(s, generator, seed));
    return b;
  }

  // A composite opens as a full page by RUNNING its build() (§3.2) — the dials
  // ride in as opts. Reserved query keys aside, every param is an option value.
  async function instantiateComposite(id: string, forcedSeed: string | undefined, params: URLSearchParams): Promise<void> {
    const seed = forcedSeed ?? randomSeed();
    const opts: Record<string, string> = {};
    for (const [k, v] of params) if (k !== 'template' && k !== 'seed') opts[k] = v;
    const run = await runComposite(id, seed, opts);
    if (!run) {
      alert(`No one-pager found for “${id}”. It may have been renamed.`);
      return;
    }
    // A generated character (or scene, or shop) is named after ITSELF, not
    // its generator: the leading title block carries the rolled name.
    const lead = run.blocks[0];
    const name = lead?.type === 'title' && lead.text.trim() ? lead.text.trim() : run.title;
    const sheet: Sheet = { id: newId(), name, kind: 'custom', blocks: run.blocks.map((b) => stampBlock(b, id, seed)) };
    store.sheets.push(sheet);
    store.activeId = sheet.id;
    save();
    bus.clear();
    dialog.close();
    renderAll();
  }

  function galleryCard(title: string, description: string, onPick: (card: HTMLButtonElement) => void, id?: string): HTMLButtonElement {
    const card = document.createElement('button');
    card.type = 'button';
    card.className = 'template-card';
    if (id) card.setAttribute('data-template-id', id);
    const h = document.createElement('b');
    h.textContent = title;
    const p = document.createElement('span');
    p.textContent = description;
    card.append(h, p);
    card.addEventListener('click', () => onPick(card));
    return card;
  }

  function pickTemplate(t: SheetTemplate, card: HTMLButtonElement): void {
    card.disabled = true;
    instantiate(t).catch((err) => {
      card.disabled = false;
      alert(err instanceof Error ? err.message : 'template failed to load');
    });
  }

  function sectionHeader(text: string): HTMLParagraphElement {
    const p = document.createElement('p');
    p.className = 'gallery-section';
    p.textContent = text;
    return p;
  }

  function openGallery(): void {
    const children: Node[] = [];
    // Curated pages first: hand-authored, opinionated layouts.
    for (const t of TEMPLATES) {
      children.push(galleryCard(t.title, t.description ?? '', (card) => pickTemplate(t, card), t.id));
    }
    // Then every generator, derived into a full page you can trim and reroll.
    if (GENERATOR_TEMPLATES.length) {
      children.push(sectionHeader('Every generator, as a full page'));
      for (const t of GENERATOR_TEMPLATES) {
        children.push(galleryCard(t.title, t.description ?? '', (card) => pickTemplate(t, card), t.id));
      }
    }
    // Finally the user's own boilerplate (PLAN.md §21.5): sheets flagged ★ in the Library.
    const mine = activeSheets(store).filter((s) => s.template);
    if (mine.length) {
      children.push(sectionHeader('Your templates'));
      for (const s of mine) {
        children.push(
          galleryCard(s.name, `${s.blocks.length} block(s) — your own boilerplate`, () => instantiateFromSheet(s), `mine-${s.id}`),
        );
      }
    }
    // Bring your own (PLAN.md §21.5): years of Homebrewery brews, converted.
    children.push(sectionHeader('Bring your own'));
    children.push(
      galleryCard(
        '📋 Import — a brew or a sheet file',
        'Homebrewery markdown becomes an editable sheet — tables, statblocks, page breaks and all. A shared .json sheet file imports exactly as exported.',
        () => {
          dialog.close();
          openImportDialog();
        },
        'import-homebrew',
      ),
    );
    templateList.replaceChildren(...children);
    dialog.showModal();
  }
  $('[data-from-template]').addEventListener('click', openGallery);
  $('[data-from-template-empty]').addEventListener('click', openGallery);
  $('[data-template-close]').addEventListener('click', () => dialog.close());

  // --- Homebrewery import (PLAN.md §21.5): paste markdown, get a sheet.
  const importDialog = $<HTMLDialogElement>('[data-import-dialog]');
  const importText = $<HTMLTextAreaElement>('[data-import-text]');
  const importStatus = $('[data-import-status]');

  function openImportDialog(): void {
    importText.value = '';
    importStatus.hidden = true;
    importDialog.showModal();
    importText.focus();
  }

  // Fresh ids on anything imported: a pasted file (or a re-shared link) may
  // carry ids that collide with blocks already on this device.
  function reIdBlocks(bs: Block[]): void {
    for (const b of bs) {
      b.id = `pin-${newId()}`;
      if (b.type === 'statblock') reIdBlocks(b.sections);
      if (b.type === 'columns') b.columns.forEach(reIdBlocks);
    }
  }

  function importAsSheet(name: string, blocks: Block[]): Sheet {
    reIdBlocks(blocks);
    const sheet: Sheet = { id: newId(), name, kind: 'custom', blocks };
    store.sheets.push(sheet);
    store.activeId = sheet.id;
    save();
    bus.clear();
    renderAll();
    return sheet;
  }

  $('[data-import-close]').addEventListener('click', () => importDialog.close());
  $<HTMLInputElement>('[data-import-file]').addEventListener('change', async (e) => {
    const f = (e.target as HTMLInputElement).files?.[0];
    if (!f) return;
    importText.value = await f.text();
    importStatus.hidden = true;
  });
  $('[data-import-go]').addEventListener('click', () => {
    importStatus.hidden = false;
    // Sheet file first (unpackSheet only recognizes our own format — anything
    // else, markdown included, falls through to the Homebrewery importer).
    const file = unpackSheet(importText.value);
    if (file) {
      if (file.blocks.length === 0) {
        importStatus.textContent =
          'That sheet file has no blocks this site version recognizes — was it made on a newer version?';
        return;
      }
      const sheet = importAsSheet(file.name, file.blocks);
      importStatus.textContent =
        `Imported “${sheet.name}” — it's behind this dialog.` +
        (file.dropped ? ` ${file.dropped} block(s) from a newer version were left behind.` : '');
      return;
    }
    const { blocks, skipped } = importHomebrew(importText.value);
    if (blocks.length === 0) {
      importStatus.textContent = 'Nothing recognizable in that text — is it markdown?';
      return;
    }
    const sheet = importAsSheet(importedName(blocks), blocks);
    importStatus.textContent =
      `Imported ${blocks.length} block(s) as “${sheet.name}” — it's behind this dialog.` +
      (skipped.length ? ` Left behind: ${skipped.join('; ')}.` : '');
  });

  // --- Roll log (PLAN.md §16): last rolls, newest first, session-scoped.
  const rollEntries = $('[data-roll-entries]');
  function renderRollLog(): void {
    rollEntries.replaceChildren(
      ...getRollLog()
        .slice(0, 10)
        .map((e) => {
          const li = document.createElement('li');
          const b = document.createElement('b');
          b.textContent = e.label;
          li.append(b, ` ${e.detail}`);
          return li;
        }),
    );
  }
  window.addEventListener(ROLL_LOG_EVENT, renderRollLog);
  renderRollLog();

  // What leaves this device (PLAN.md §21.5): entityRef blocks are LIVE wires
  // into this device's world store — a recipient has neither the world nor the
  // wire. Exports flatten each one to a snapshot of the entity's public
  // blocks; GM-secret blocks never travel. `seen` is the ancestor chain, so a
  // self-referencing entity can't recurse forever but two siblings may embed
  // the same entity.
  async function exportableBlocks(blocks: Block[], seen = new Set<string>()): Promise<Block[]> {
    const out: Block[] = [];
    for (const b of structuredClone(blocks)) {
      if (b.type === 'columns') {
        b.columns = await Promise.all(b.columns.map((col) => exportableBlocks(col, seen)));
        out.push(b);
      } else if (b.type === 'entityRef') {
        const key = `${b.worldId}:${b.entityId}`;
        const world = seen.has(key) ? undefined : await getWorld(b.worldId);
        const entity = world?.entities[b.entityId];
        if (!entity || entity.deleted) {
          out.push({
            type: 'paragraph',
            text: '⚠ an embedded world entity could not travel — its world lives only on the sharer\'s device',
            id: `pin-${newId()}`,
          });
          continue;
        }
        seen.add(key);
        const pub = ((entity.body ?? []) as unknown as Block[]).filter(
          (child) => !entity.secretBlocks?.includes(child.id ?? ''),
        );
        out.push({ type: 'title', text: entity.name, id: `pin-${newId()}` });
        out.push(...(await exportableBlocks(pub, seen)));
        seen.delete(key);
      } else {
        out.push(b);
      }
    }
    return out;
  }

  // @-mention tokens reference THIS device's worlds — exports resolve them
  // to the entity's plain name. Operating on the serialized form reaches
  // every text field of every block type in one pass; the replacement is
  // JSON-escaped so exotic names can't corrupt the structure.
  async function resolveMentions(blocks: Block[]): Promise<Block[]> {
    let json = JSON.stringify(blocks);
    const tokens = [...new Set(json.match(/\[\[@[^\s:\][]+:[^\s\][]+\]\]/g) ?? [])];
    for (const token of tokens) {
      const m = /^\[\[@([^:]+):(.+)\]\]$/.exec(token)!;
      const entity = await peekEntity(m[1]!, m[2]!).catch(() => undefined);
      const name = entity?.name ?? 'an entity from another world';
      json = json.split(token).join(JSON.stringify(name).slice(1, -1));
    }
    return JSON.parse(json) as Block[];
  }

  /** The full export view: entityRef embeds flattened, mentions named. */
  async function exportView(blocks: Block[]): Promise<Block[]> {
    return resolveMentions(await exportableBlocks(blocks));
  }

  const fileSlug = (name: string) => name.replace(/[^\w-]+/g, '-').toLowerCase() || 'sheet';

  $('[data-export]').addEventListener('click', async () => {
    const sheet = getActive(store);
    const blocks = await exportView(sheet.blocks);
    const blob = new Blob([sheetToMarkdown({ ...sheet, blocks })], { type: 'text/markdown' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `${fileSlug(sheet.name)}.md`;
    a.click();
    URL.revokeObjectURL(a.href);
  });

  // --- Share (PLAN.md §21.5): the sheet leaves home. The link IS the data —
  // deflated, base64url, in the hash, so no server ever sees it; the .json
  // file is the same pack for when a URL is too clumsy to send.
  const shareDialog = $<HTMLDialogElement>('[data-share-dialog]');
  const shareUrl = $<HTMLInputElement>('[data-share-url]');
  const shareHint = $('[data-share-hint]');
  const shareCopy = $<HTMLButtonElement>('[data-share-copy]');
  const shareJson = $<HTMLButtonElement>('[data-share-json]');
  let shareBlocks: Block[] = []; // captured at open — the flattened export view

  $('[data-share-open]').addEventListener('click', async () => {
    const sheet = getActive(store);
    $('[data-share-name]').textContent = sheet.name;
    shareUrl.value = 'Preparing link…';
    shareHint.hidden = true;
    shareCopy.disabled = true;
    shareJson.disabled = true;
    shareCopy.textContent = 'Copy link';
    shareDialog.showModal();
    shareBlocks = await exportView(sheet.blocks);
    shareUrl.value = `${location.origin}/sheet/#share=${await encodeShare(sheet.name, shareBlocks)}`;
    shareHint.hidden = shareUrl.value.length < 8000;
    shareCopy.disabled = false;
    shareJson.disabled = false;
  });

  shareCopy.addEventListener('click', async () => {
    shareUrl.select();
    try {
      await navigator.clipboard.writeText(shareUrl.value);
      shareCopy.textContent = 'Copied ✓';
    } catch {
      // clipboard blocked — the text is already selected for a manual copy
      shareCopy.textContent = 'Press Ctrl+C';
    }
  });

  shareJson.addEventListener('click', () => {
    const sheet = getActive(store);
    const blob = new Blob([packSheet(sheet.name, shareBlocks)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `${fileSlug(sheet.name)}.json`;
    a.click();
    URL.revokeObjectURL(a.href);
  });

  $('[data-share-close]').addEventListener('click', () => shareDialog.close());

  $('[data-print]').addEventListener('click', () => window.print());

  // Google Drive backup: one JSON file in the user's own Drive holding every
  // sheet. Save overwrites it (Drive keeps ~30 days of revisions); Load
  // replaces the local store after an explicit confirm.
  const driveStatus = $('[data-drive-status]');
  const setDriveStatus = (msg: string) => (driveStatus.textContent = msg);
  const driveError = (err: unknown, fallback: string) =>
    setDriveStatus(err instanceof Error ? err.message : fallback);

  // Connection chip: live token > linked-before > never connected.
  const driveChip = $('[data-drive-chip]');
  const disconnectBtn = $<HTMLButtonElement>('[data-drive-disconnect]');
  function renderDrive() {
    if (isConnected()) {
      driveChip.textContent = '☁ Drive: connected ●';
      driveChip.dataset.state = 'on';
      driveChip.title = 'This session is authorized — Save and Load work without another popup.';
    } else if (isLinked()) {
      driveChip.textContent = '☁ Drive: linked';
      driveChip.dataset.state = 'linked';
      driveChip.title = 'Drive was linked on this device — the next Save or Load reconnects automatically.';
    } else {
      driveChip.textContent = '☁ Drive: not connected';
      driveChip.dataset.state = 'off';
      driveChip.title = 'Click Save to Drive to connect your Google Drive.';
    }
    disconnectBtn.hidden = !isConnected() && !isLinked();
  }
  window.addEventListener(DRIVE_EVENT, renderDrive);
  renderDrive();

  disconnectBtn.addEventListener('click', async () => {
    await disconnect();
    setDriveStatus('Drive access revoked. Your backup file stays in your Drive.');
  });

  // Auto-sync pill (PLAN.md §13): off → click enables (a real gesture, so
  // the consent popup is allowed); paused → click reconnects; on → click
  // turns it off. Paused is honest, never lossy — everything stays local.
  const syncPill = $('[data-sync-pill]');
  function renderSyncPill(): void {
    const s = syncStatus();
    const state = autoSyncEnabled() ? s.state : 'off';
    syncPill.dataset.state = state;
    syncPill.textContent =
      state === 'off' ? '⇅ Auto-sync: off'
      : state === 'paused' ? `⇅ Auto-sync: paused${s.detail ? ` — ${s.detail}` : ''}`
      : state === 'syncing' ? '⇅ Auto-sync: syncing…'
      : `⇅ Auto-sync: on${s.lastSync ? ` · ${new Date(s.lastSync).toLocaleTimeString()}` : ''}`;
  }
  syncPill.addEventListener('click', async () => {
    try {
      const state = autoSyncEnabled() ? syncStatus().state : 'off';
      if (state === 'off') await enableAutoSync();
      else if (state === 'paused') await resumeSync();
      else if (confirm('Turn off automatic Drive backup? Documents stay on this device; manual ☁ Save still works.')) disableAutoSync();
    } catch (err) {
      setDriveStatus(err instanceof Error ? err.message : 'Could not connect to Drive.');
    }
    renderSyncPill();
  });
  window.addEventListener(SYNC_EVENT, renderSyncPill);
  renderSyncPill();

  // Versioned envelope shared with /world/ (engine/backup.ts): v2 carries
  // { sheets, worlds }, so saving from this page never drops worlds and
  // vice versa. Older v1/bare backups still load.

  $('[data-drive-save]').addEventListener('click', async () => {
    try {
      setDriveStatus('Saving to Drive…');
      const result = await saveToDrive(await buildBackup(store));
      const total = store.sheets.reduce((n, s) => n + s.blocks.length, 0);
      setDriveStatus(
        `✓ Backed up ${store.sheets.length} sheet(s), ${total} block(s) + your worlds · ${new Date(result.modifiedTime).toLocaleTimeString()}`,
      );
    } catch (err) {
      driveError(err, 'Drive save failed.');
    }
  });

  $('[data-drive-load]').addEventListener('click', async () => {
    try {
      setDriveStatus('Checking Drive…');
      const backup = await loadFromDrive();
      if (!backup) {
        setDriveStatus('No Drive backup yet — use ☁ Save to Drive first.');
        return;
      }
      const incoming = parseBackup(backup.json);
      if (!incoming.sheets || !Array.isArray(incoming.sheets.sheets)) throw new Error('The Drive file is not a Storyteller Toolbox backup.');
      const when = new Date(backup.modifiedTime).toLocaleString();
      if (
        !confirm(
          `Replace the ${store.sheets.length} sheet(s) on this device with the Drive backup? ` +
            `(${incoming.sheets.sheets.length} sheet(s), saved ${when})`,
        )
      ) {
        setDriveStatus('');
        return;
      }
      store = incoming.sheets;
      save();
      store = loadStore(); // normalizes activeId and empty stores
      bus.clear(); // every block object was just replaced — old commands are stale
      renderAll();
      const worlds = await restoreWorlds(incoming.worlds);
      const brews = await restoreBrews(incoming.brews);
      const assets = await restoreAssets(incoming.assets);
      await restoreSkins(incoming.skins);
      if (assets) renderAll(); // image blocks re-mount now their bytes exist
      setDriveStatus(
        `✓ Restored from Drive (saved ${when})` +
          (worlds.restored ? ` · ${worlds.restored} world(s) restored` : '') +
          (worlds.skippedOlder ? ` · ${worlds.skippedOlder} world(s) kept (local copy newer)` : '') +
          (brews ? ` · ${brews} table(s) restored` : '') + '.',
      );
    } catch (err) {
      driveError(err, 'Drive load failed.');
    }
  });

  // Command-bar menus: picking an action closes the menu (the action's own
  // surface takes over); so does clicking anywhere else, and Escape. The
  // genre <select> stays open-able — only buttons and links close.
  const toolMenus = Array.from(document.querySelectorAll<HTMLDetailsElement>('.tool-menu'));
  for (const menu of toolMenus) {
    menu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.tool-menu-panel button, .tool-menu-panel a')) {
        menu.open = false;
      }
    });
  }
  document.addEventListener('click', (e) => {
    for (const menu of toolMenus) {
      if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') for (const menu of toolMenus) menu.open = false;
  });

  enableDragReorder(blocksEl, '.block', (from, to) => {
    const sheet = getActive(store);
    bus.execute({
      label: 'reorder blocks',
      apply: () => moveItem(sheet.blocks, from, to),
      revert: () => moveItem(sheet.blocks, to, from),
    });
  });

  // Undo/redo. Inside a contenteditable field the browser's native text undo
  // handles ctrl+Z (its input events run set(), keeping the model in sync);
  // everywhere else the command bus does.
  document.addEventListener('keydown', (e) => {
    if (!(e.ctrlKey || e.metaKey)) return;
    const key = e.key.toLowerCase();
    if (key !== 'z' && key !== 'y') return;
    if (e.target instanceof HTMLElement && e.target.isContentEditable) return;
    const redo = key === 'y' || (key === 'z' && e.shiftKey);
    if (redo ? bus.redo() : bus.undo()) e.preventDefault();
  });

  // Live-sync with pins and the tray; ignore our own writes so typing
  // in a contenteditable block never re-renders out from under the caret.
  window.addEventListener(SHEET_EVENT, ((e: CustomEvent) => {
    if (e.detail?.source === SOURCE) return;
    store = loadStore();
    bus.clear(); // fresh objects from storage — undo history would mutate stale ones
    renderAll();
  }) as EventListener);

  renderAll();

  // Deep link (GENERATORS-AS-ONEPAGERS.md §3.3): /sheet/?template=<id>&seed=…
  // opens a topic as a full page — the seamless transition from a generator's
  // roll-table or a composite's one-click builder to the editable one-pager. A
  // slot/curated id fills a template; a composite id (§3.2) runs build() with
  // its dials carried as extra params. Instantiate once, then strip the query so
  // a refresh doesn't spawn a duplicate; a link with a seed reproduces the page.
  {
    const params = new URLSearchParams(location.search);
    const wanted = params.get('template');
    if (wanted) {
      const forcedSeed = params.get('seed') ?? undefined;
      history.replaceState(null, '', location.pathname);
      if (isComposite(wanted)) {
        await instantiateComposite(wanted, forcedSeed, params);
      } else {
        const t = TEMPLATES_BY_ID.get(wanted);
        if (t) await instantiate(t, forcedSeed);
        else alert(`No one-pager found for “${wanted}”. It may have been renamed.`);
      }
    }
  }

  // Share link (PLAN.md §21.5): /sheet/#share=<deflated sheet> — the URL is
  // the data. Decode, import as a new sheet, then strip the hash so a refresh
  // doesn't import a duplicate. Damage fails loud: a truncated paste should
  // ask for a fresh link, not silently open someone's empty sheet.
  if (location.hash.startsWith('#share=')) {
    const decoded = await decodeShare(location.hash.slice('#share='.length));
    history.replaceState(null, '', location.pathname + location.search);
    if (decoded && decoded.blocks.length > 0) {
      importAsSheet(decoded.name, decoded.blocks);
    } else {
      alert('This share link is damaged or truncated — ask for it again, or for the sheet file.');
    }
  }
</script>

