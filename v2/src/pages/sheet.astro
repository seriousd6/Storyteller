    id: `pin-${newId()}`,
  }));
  menuAdd('[data-add-choice]', 'add choice', () => ({
    type: 'choice',
    label: 'Choose',
    value: 'Option A',
    options: ['Option A', 'Option B', 'Option C'],
    id: `pin-${newId()}`,
  }));
  menuAdd('[data-add-choicelist]', 'add choices', () => ({
    type: 'choiceList',
    label: 'Choices',
    options: ['Option A', 'Option B', 'Option C'],
    values: ['Option A'],
    id: `pin-${newId()}`,
  }));
  menuAdd('[data-add-profgrid]', 'add skills grid', () => ({
    type: 'profGrid',
    label: 'Skills',
    layout: 'row',
    items: [
      { name: 'Athletics', ability: 'str' },
      { name: 'Stealth', ability: 'dex' },
