---
import Base from '../layouts/Base.astro';
---

<Base
  title="World (alpha)"
  description="Everdeep alpha — a wiki for your world: linked pages for places, people, factions, and quests, saved in your browser."
  hideTray={true}
>
  <div class="wd-shell">
    <header class="wd-bar">
      <strong>World</strong>
      <select id="worldSel" aria-label="Choose world"></select>
      <button id="newWorldBtn" class="wd-btn">New</button>
      <button id="exampleBtn" class="wd-btn">Load example</button>
      <label class="wd-btn wd-file">Import<input type="file" id="importFile" accept=".json,application/json"></label>
      <button id="exportBtn" class="wd-btn">Export</button>
      <button id="deleteWorldBtn" class="wd-btn">Delete</button>
      <button id="driveSaveBtn" class="wd-btn" title="Back up sheets + worlds to your Google Drive">☁ Backup</button>
      <button id="driveLoadBtn" class="wd-btn" title="Restore from your Google Drive backup">☁ Restore</button>
      <span class="wd-status" id="driveStatus" aria-live="polite"></span>
      <span class="wd-saved" id="savedFlash">saved</span>
      <span class="wd-grow"></span>
      <label class="wd-toggle"><input type="checkbox" id="playerView"> Player View</label>
    </header>
    <div class="wd-main">
      <nav class="wd-nav">
        <input id="treeSearch" class="wd-search" type="search" placeholder="Search this world…" aria-label="Search pages">
        <div id="tree"></div>
        <button id="addRootBtn" class="wd-btn wd-ghosty">+ Add at top level</button>
      </nav>
      <article class="wd-page" id="page"></article>
    </div>
  </div>
</Base>

<style>
  .wd-shell { display:flex; flex-direction:column; min-height:70vh; }
  .wd-bar { display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding:8px 0 12px;
            border-bottom:1px solid var(--border, #8884); font-size:0.9rem; }
  .wd-bar select { max-width:180px; padding:4px 6px; }
  .wd-grow { flex:1; }
  .wd-saved { color:var(--accent, #7a9c5a); font-size:0.8rem; opacity:0; transition:opacity .3s; }
  .wd-status { font-size:0.78rem; opacity:0.8; }
  .wd-saved.show { opacity:1; }
  .wd-btn { font-size:0.85rem; padding:4px 10px; cursor:pointer; }
  .wd-ghosty { border-style:dashed; opacity:0.85; margin-top:10px; width:100%; }
  .wd-file { position:relative; overflow:hidden; display:inline-block; }
  .wd-file input { position:absolute; inset:0; opacity:0; cursor:pointer; }
  .wd-toggle { display:flex; gap:6px; align-items:center; cursor:pointer; }
  .wd-main { display:flex; gap:0; min-height:0; flex:1; }
  .wd-nav { width:250px; flex-shrink:0; border-right:1px solid var(--border, #8884);
            padding:12px 10px 12px 0; font-size:0.88rem; overflow:auto; max-height:75vh; position:sticky; top:0; }
  .wd-nav :global(.node) { padding:2px 6px; border-radius:5px; cursor:pointer; white-space:nowrap;
                           overflow:hidden; text-overflow:ellipsis; }
  .wd-nav :global(.node:hover) { background:#8882; }
  .wd-nav :global(.node.active) { background:#8883; font-weight:600; }
  .wd-nav :global(.kids) { margin-left:13px; border-left:1px solid #8884; padding-left:6px; }
  .wd-nav :global(.dead) { opacity:0.5; text-decoration:line-through; }
  .wd-search { width:100%; font:inherit; font-size:0.85rem; padding:4px 8px; margin-bottom:8px; }
  .wd-nav :global(.hitpath) { font-size:0.72rem; opacity:0.55; margin-left:20px; }
  .wd-nav :global(.tw) { display:inline-block; width:14px; cursor:pointer; opacity:0.55; user-select:none; }
  .wd-nav :global(.tw-leaf) { cursor:default; }
  .wd-nav :global(.node.droptarget) { outline:1px dashed #888a; background:#8883; }
  .wd-page { flex:1; padding:16px 0 60px 26px; max-width:760px; min-width:0; }
  .wd-page :global(h1.wd-title) { display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin:4px 0; }
  .wd-page :global(h1.wd-title input) { font:inherit; max-width:60%; padding:0 8px; }
  .wd-page :global(.crumbs) { font-size:0.8rem; opacity:0.7; }
  .wd-page :global(.kindchip) { font-size:0.65rem; text-transform:uppercase; letter-spacing:.08em;
    border:1px solid #8886; border-radius:10px; padding:1px 9px; vertical-align:middle; opacity:0.8; }
  .wd-page :global(section) { margin-top:22px; }
  .wd-page :global(section > h2) { font-size:0.78rem; text-transform:uppercase; letter-spacing:.1em;
    opacity:0.7; border-bottom:1px solid #8884; padding-bottom:4px; display:flex; gap:10px; align-items:center; }
  .wd-page :global(section > h2 .sp) { flex:1; }
  .wd-page :global(.frow) { display:grid; grid-template-columns:220px 1fr; gap:4px 16px; margin:7px 0; align-items:start; }
  .wd-page :global(.frow .fl) { opacity:0.75; font-size:0.85rem; padding-top:5px; }
  .wd-page :global(.frow input), .wd-page :global(.frow select), .wd-page :global(.frow textarea),
  .wd-page :global(.blockedit textarea) { width:100%; font:inherit; padding:5px 9px; }
  .wd-page :global(.frow textarea) { min-height:54px; resize:vertical; }
  .wd-page :global(.block) { margin:10px 0; position:relative; }
  .wd-page :global(.block .btools) { position:absolute; right:0; top:-6px; display:none; gap:4px; }
  .wd-page :global(.block:hover .btools) { display:flex; }
  .wd-page :global(.block .blabel) { font-size:0.72rem; text-transform:uppercase; letter-spacing:.06em; opacity:0.7; }
  .wd-page :global(.block.secret) { border-left:3px solid #b06a6a; padding:6px 12px; background:#b06a6a14; border-radius:0 6px 6px 0; }
  .wd-page :global(.blockedit .rowtools) { display:flex; gap:6px; margin-top:6px; align-items:center; font-size:0.8rem; opacity:0.9; flex-wrap:wrap; }
  .wd-page :global(ul.rel), .wd-page :global(ul.backs) { padding-left:18px; margin:8px 0; }
  .wd-page :global(.ghostnote) { font-size:0.82rem; opacity:0.65; font-style:italic; }
  .wd-page :global(.provenance) { font-family:ui-monospace, monospace; font-size:0.72rem; opacity:0.55;
    margin-top:26px; border-top:1px dashed #8886; padding-top:8px; word-break:break-all; }
  .wd-page :global(.addkinds) { display:flex; flex-wrap:wrap; gap:7px; margin-top:8px; }
  .wd-page :global(.newform) { display:flex; gap:8px; margin-top:10px; align-items:center; }
  .wd-page :global(.newform input) { flex:1; max-width:320px; font:inherit; padding:6px 9px; }
  .wd-page :global(.danger) { margin-top:20px; }
  .wd-page :global(.ghosthead) { font-size:0.78rem; text-transform:uppercase; letter-spacing:.08em; opacity:0.6; margin:14px 0 4px; }
  .wd-page :global(.ghostcard) { display:flex; align-items:center; gap:10px; flex-wrap:wrap;
    border:1px dashed #8887; border-radius:8px; padding:7px 12px; margin:6px 0; opacity:0.92; }
  .wd-page :global(.ghostcard .gname) { font-style:italic; }
  .wd-page :global(.ghostcard .glabel) { font-size:0.75rem; opacity:0.6; }
  .wd-page :global(.ghostcard .gtools) { margin-left:auto; display:flex; gap:5px; }
  @media (max-width: 720px) {
    .wd-nav { width:160px; }
    .wd-page { padding-left:14px; }
    .wd-page :global(.frow) { grid-template-columns:1fr; }
  }
</style>

<script>
  import REGISTRY from '../everdeep/registry.json';
  import {
    listWorlds, getWorld, putWorld, deleteWorld, newWorld, newEntity, touchEntity,
    looksLikeWorld, rid, now, type WorldDoc, type EntityRecord,
  } from '../engine/worldStore.ts';
  import { buildBackup, parseBackup, restoreWorlds } from '../engine/backup.ts';
  import { saveToDrive, loadFromDrive } from '../engine/drive';
  import { loadStore as loadSheetStore } from '../engine/sheetStore';
  import { renderBlockStatic } from '../engine/blockRender';
  import { getAllWorlds } from '../engine/worldStore.ts';
  import { childPath, ghostId } from '../everdeep/seeds.ts';
  import { blocksToEntity, extractName } from '../everdeep/adapters.ts';
  import type { CompositeModule } from '../engine/composite';
  import type { Block, Table, TableRegistry } from '../engine/types';

  type KindDef = (typeof REGISTRY.kinds)[number];
  const byKind: Record<string, KindDef> = Object.fromEntries(REGISTRY.kinds.map((k) => [k.id, k]));

  const ACTIVE_KEY = 'stb:everdeep:activeWorld';
  let WORLD: WorldDoc | null = null;
  let current: string | null = null;
  let playerView = false;
  let editingBlock: string | null = null;
  let addingKind: string | null = null;

  const $ = (id: string) => document.getElementById(id);
  const E = (): Record<string, EntityRecord> => WORLD?.entities ?? {};

  let saveT = 0;
  function save(): void {
    if (!WORLD) return;
    clearTimeout(saveT);
    const w = WORLD;
    saveT = window.setTimeout(() => {
      void putWorld(w).then(() => {
        const el = $('savedFlash');
        el?.classList.add('show');
        setTimeout(() => el?.classList.remove('show'), 900);
      });
    }, 250);
  }

  // ---------- derived ----------
  const childrenOf = (id: string) =>
    Object.values(E()).filter((e) => (e.parentId ?? '__root__') === id);
  const mentionRe = /\{@e (e_[a-z0-9]{14})(?:\|([^}]*))?\}/g;
  function backlinksTo(target: string): string[] {
    const out: string[] = [];
    for (const e of Object.values(E())) {
      if (e.id === target) continue;
      let hit =
        (e.relations ?? []).some((r) => r.target === target) ||
        Object.values(e.fields ?? {}).some((v) => typeof v === 'object' && v !== null && 'ref' in v && v.ref === target);
      if (!hit) for (const b of e.body ?? []) if (String(b.text ?? '').includes(target)) { hit = true; break; }
      if (hit) out.push(e.id);
    }
    return out;
  }
  const icon = (e: EntityRecord) => byKind[e.kind]?.icon ?? '▪️';
  const esc = (s: unknown) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;');
  const link = (id: string, label?: string) =>
    E()[id] ? `<a href="#${id}" data-id="${id}">${esc(label ?? E()[id].name)}</a>` : esc(label ?? id);
  const renderText = (t: unknown) => esc(t).replace(mentionRe, (_m, id: string, label?: string) => link(id, label));

  // ---------- chrome ----------
  async function renderChrome(): Promise<void> {
    const sel = $('worldSel') as HTMLSelectElement;
    const worlds = await listWorlds();
    sel.innerHTML =
      worlds.map((w) => `<option value="${w.id}" ${WORLD?.id === w.id ? 'selected' : ''}>${esc(w.name)} (${w.entityCount})</option>`).join('') ||
      '<option value="">— no worlds yet —</option>';
  }

  // ---------- tree (search, collapse, drag-to-reparent) ----------
  let searchQuery = '';
  let collapsed = new Set<string>();
  const COLLAPSE_KEY = 'stb:everdeep:collapsed';
  function loadCollapsed(): void {
    try {
      const all = JSON.parse(localStorage.getItem(COLLAPSE_KEY) ?? '{}') as Record<string, string[]>;
      collapsed = new Set(all[WORLD?.id ?? ''] ?? []);
    } catch { collapsed = new Set(); }
  }
  function saveCollapsed(): void {
    if (!WORLD) return;
    let all: Record<string, string[]> = {};
    try { all = JSON.parse(localStorage.getItem(COLLAPSE_KEY) ?? '{}') as Record<string, string[]>; } catch { /* fresh */ }
    all[WORLD.id] = [...collapsed];
    localStorage.setItem(COLLAPSE_KEY, JSON.stringify(all));
  }
  function crumbFor(e: EntityRecord): string {
    const parts: string[] = [];
    let p = e.parentId;
    while (p && E()[p]) { parts.unshift(E()[p].name); p = E()[p].parentId; }
    return parts.join(' › ');
  }
  function matches(e: EntityRecord, q: string): boolean {
    if (e.name.toLowerCase().includes(q)) return true;
    if ((e.aliases ?? []).some((a) => a.toLowerCase().includes(q))) return true;
    if ((e.tags ?? []).some((t) => t.toLowerCase().includes(q))) return true;
    if (Object.values(e.fields ?? {}).some((v) => typeof v === 'string' && v.toLowerCase().includes(q))) return true;
    if (!playerView || !e.secret) {
      for (const b of e.body ?? []) {
        if ((e.secretBlocks ?? []).includes(b.id) && playerView) continue;
        if (String(b.text ?? '').toLowerCase().includes(q)) return true;
      }
    }
    return false;
  }
  function renderTree(): void {
    const nav = $('tree');
    if (!nav) return;
    if (!WORLD) { nav.innerHTML = ''; return; }
    const q = searchQuery.trim().toLowerCase();
    if (q) {
      const hits = Object.values(E())
        .filter((e) => !(e.deleted && playerView) && !(e.secret && playerView))
        .filter((e) => matches(e, q))
        .slice(0, 40);
      nav.innerHTML = hits.length
        ? hits.map((e) => {
            const cls = ['node', e.id === current ? 'active' : '', e.deleted ? 'dead' : ''].join(' ');
            const crumb = crumbFor(e);
            return `<div class="${cls}" data-id="${e.id}">${icon(e)} ${esc(e.name)}</div>` +
              (crumb ? `<div class="hitpath">${esc(crumb)}</div>` : '');
          }).join('')
        : `<div class="hitpath">no pages match “${esc(searchQuery)}”</div>`;
      return;
    }
    const item = (id: string): string => {
      const e = E()[id];
      if (e.deleted && playerView) return '';
      const cls = ['node', id === current ? 'active' : '', e.deleted ? 'dead' : ''].join(' ');
      const kids = childrenOf(id).filter((k) => !(k.deleted && playerView));
      const folded = collapsed.has(id);
      const tw = kids.length
        ? `<span class="tw" data-toggle="${id}" title="${folded ? 'expand' : 'collapse'}">${folded ? '▸' : '▾'}</span>`
        : `<span class="tw tw-leaf"></span>`;
      let html = `<div class="${cls}" data-id="${id}" draggable="true">${tw}${icon(e)} ${esc(e.name)}</div>`;
      if (kids.length && !folded) html += `<div class="kids">${kids.map((k) => item(k.id)).join('')}</div>`;
      return html;
    };
    nav.innerHTML = childrenOf('__root__').map((e) => item(e.id)).join('');
  }

  // drag a page onto another to file it there; onto empty tree space for top level
  let dragId: string | null = null;
  function canDropOn(targetId: string | null): boolean {
    if (!dragId || !WORLD) return false;
    const d = E()[dragId];
    if (!d) return false;
    if (targetId === null) return d.parentId !== undefined; // already top-level? no-op
    if (targetId === dragId) return false;
    let p: string | undefined = targetId;
    while (p) { if (p === dragId) return false; p = E()[p]?.parentId; } // no cycles
    const tk = byKind[E()[targetId]?.kind ?? ''];
    return (tk?.childKinds ?? []).includes(d.kind);
  }
  document.addEventListener('dragstart', (ev) => {
    const n = (ev.target as HTMLElement).closest?.('.node[data-id]') as HTMLElement | null;
    if (!n) return;
    dragId = n.dataset.id ?? null;
    ev.dataTransfer?.setData('text/plain', dragId ?? '');
    if (ev.dataTransfer) ev.dataTransfer.effectAllowed = 'move';
  });
  document.addEventListener('dragover', (ev) => {
    const el = ev.target as HTMLElement;
    const n = el.closest?.('.node[data-id]') as HTMLElement | null;
    document.querySelectorAll('.droptarget').forEach((x) => x.classList.remove('droptarget'));
    if (n && canDropOn(n.dataset.id ?? null)) {
      ev.preventDefault();
      n.classList.add('droptarget');
    } else if (!n && el.closest?.('.wd-nav') && canDropOn(null)) {
      ev.preventDefault();
    }
  });
  document.addEventListener('drop', (ev) => {
    const el = ev.target as HTMLElement;
    const n = el.closest?.('.node[data-id]') as HTMLElement | null;
    document.querySelectorAll('.droptarget').forEach((x) => x.classList.remove('droptarget'));
    if (!dragId || !WORLD) return;
    const d = E()[dragId];
    if (!d) return;
    if (n && canDropOn(n.dataset.id ?? null)) {
      ev.preventDefault();
      d.parentId = n.dataset.id;
      collapsed.delete(n.dataset.id ?? ''); // reveal the new home
      saveCollapsed();
      touchEntity(d); save(); rerender();
    } else if (!n && el.closest?.('.wd-nav') && canDropOn(null)) {
      ev.preventDefault();
      delete d.parentId;
      touchEntity(d); save(); rerender();
    }
    dragId = null;
  });
  document.addEventListener('dragend', () => {
    document.querySelectorAll('.droptarget').forEach((x) => x.classList.remove('droptarget'));
    dragId = null;
  });

  // ---------- fields ----------
  function fieldRow(e: EntityRecord, def: { key: string; label: string; type: string; refKind?: string } | null, key: string): string {
    const v = e.fields?.[key];
    const label = def?.label ?? key;
    if (playerView) {
      if (v === undefined || v === '') return '';
      const shown =
        typeof v === 'object' && v !== null && 'ref' in v ? link(v.ref)
        : typeof v === 'object' && v !== null && 'date' in v ? esc(v.date)
        : Array.isArray(v) ? esc(v.join(', ')) : renderText(v);
      return `<div class="frow"><div class="fl">${esc(label)}</div><div>${shown}</div></div>`;
    }
    const type = def?.type ?? (typeof v === 'number' ? 'number' : 'text');
    let control: string;
    if (type === 'entityRef') {
      const opts = Object.values(E())
        .filter((x) => !x.deleted && (!def?.refKind || x.kind === def.refKind))
        .map((x) => `<option value="${x.id}" ${typeof v === 'object' && v !== null && 'ref' in v && v.ref === x.id ? 'selected' : ''}>${esc(x.name)}</option>`)
        .join('');
      control = `<select data-fkey="${key}" data-ftype="entityRef"><option value="">—</option>${opts}</select>`;
    } else if (type === 'longtext') {
      control = `<textarea data-fkey="${key}" data-ftype="longtext" placeholder="…">${esc(v ?? '')}</textarea>`;
    } else if (type === 'number') {
      control = `<input type="number" data-fkey="${key}" data-ftype="number" value="${typeof v === 'number' ? v : ''}">`;
    } else {
      const shown = typeof v === 'object' && v !== null && 'date' in v ? v.date : Array.isArray(v) ? v.join(', ') : (v ?? '');
      control = `<input data-fkey="${key}" data-ftype="${type}" value="${esc(shown)}" placeholder="…">`;
    }
    return `<div class="frow"><div class="fl">${esc(label)}</div><div>${control}</div></div>`;
  }

  const entityOptions = (exclude: string) =>
    Object.values(E()).filter((x) => !x.deleted && x.id !== exclude)
      .map((x) => `<option value="${x.id}">${icon(x)} ${esc(x.name)}</option>`).join('');

  // ---------- page ----------
  function renderPage(): void {
    const art = $('page');
    if (!art) return;
    if (!WORLD) {
      art.innerHTML = `<h1>Your worlds live here</h1>
        <p>This is the alpha of the worldbuilding wiki: linked pages for regions, settlements,
        people, factions, and quests, saved in your browser (IndexedDB) — no account needed.</p>
        <p><strong>New</strong> starts a blank world. <strong>Load example</strong> opens Vessia,
        a small pre-built world showing cross-links, secrets, and a quest web. Generators arrive
        in the next phase; today is the wiki itself.</p>`;
      return;
    }
    const ents = E();
    if (!current || !ents[current]) {
      art.innerHTML = `<h1>${esc(WORLD.name)}</h1>
        <p class="ghostnote">Pick a page from the tree, or add one at top level. Everything you
        write autosaves to this browser; Export gives you the world as one JSON file.</p>`;
      return;
    }
    const e = ents[current];
    const kind = byKind[e.kind] ?? ({ childKinds: [], suggestedFields: [] } as unknown as KindDef);
    const chain: string[] = [];
    let p = e.parentId;
    while (p && ents[p]) { chain.unshift(link(p)); p = ents[p].parentId; }
    let html = `<div class="crumbs">${chain.length ? chain.join(' › ') + ' ›' : esc(WORLD.name)}</div>`;
    html += `<h1 class="wd-title"><span>${icon(e)}</span><span id="nameSpan">${esc(e.name)}</span>` +
      `<span class="kindchip">${e.kind}${e.deleted ? ' · deleted' : ''}</span>` +
      (playerView ? '' : `<button class="wd-btn" id="renameBtn" title="rename">✏️</button>`) + `</h1>`;
    if (e.aliases?.length) html += `<div class="ghostnote">also called ${e.aliases.map(esc).join(', ')}</div>`;

    const sugg = kind.suggestedFields ?? [];
    const extraKeys = Object.keys(e.fields ?? {}).filter((k) => !sugg.some((s) => s.key === k));
    const rows = sugg.map((d) => fieldRow(e, d, d.key)).join('') + extraKeys.map((k) => fieldRow(e, null, k)).join('');
    if (rows.trim() || !playerView) {
      html += `<section><h2>Details<span class="sp"></span>${playerView ? '' : '<button class="wd-btn" id="addFieldBtn">+ field</button>'}</h2>${rows}</section>`;
    }

    html += `<section><h2>Entry<span class="sp"></span>${playerView ? '' : '<button class="wd-btn" id="addParaBtn">+ paragraph</button>'}</h2>`;
    for (const b of e.body ?? []) {
      const secret = (e.secretBlocks ?? []).includes(b.id);
      if (secret && playerView) continue;
      const cls = `block${secret ? ' secret' : ''}`;
      if (editingBlock === b.id && !playerView) {
        html += `<div class="${cls} blockedit" data-bid="${b.id}">
          <textarea id="blockTa">${esc(b.text ?? '')}</textarea>
          <div class="rowtools">
            <select id="linkSel"><option value="">insert link to…</option>${entityOptions(e.id)}</select>
            <button class="wd-btn" id="blockSave">Save</button>
            <button class="wd-btn" id="blockCancel">Cancel</button>
          </div></div>`;
        continue;
      }
      const structured = b.type !== 'paragraph';
      const rerollable = !playerView && e.gen?.generator.startsWith('composite:');
      const tools = playerView ? '' : `<span class="btools">
        ${rerollable ? `<button class="wd-btn" data-rblock="${b.id}" title="reroll this part">🎲</button>` : ''}
        ${structured ? '' : `<button class="wd-btn" data-edit="${b.id}">✏️</button>`}
        <button class="wd-btn" data-secret="${b.id}" title="toggle secret">${secret ? '🔓' : '🔒'}</button>
        <button class="wd-btn" data-delblock="${b.id}">✕</button></span>`;
      if (structured) {
        // statblocks/tables/lists from generators render via the shared block
        // renderer (one schema, one renderer — same as sheets and print)
        html += `<div class="${cls}" data-static-block="${b.id}">${tools}</div>`;
        continue;
      }
      const label = (b.label as string | undefined) ?? (secret ? 'Secret' : '');
      html += `<div class="${cls}">${tools}${label ? `<div class="blabel">${esc(label)}</div>` : ''}<p>${renderText(b.text ?? '')}</p></div>`;
    }
    if (!(e.body ?? []).length) html += `<div class="ghostnote">Nothing written yet.</div>`;
    html += `</section>`;

    if (e.relations?.length) {
      html += `<section><h2>Relations</h2><ul class="rel">` +
        e.relations.map((r) => `<li>${esc(r.type)} → ${link(r.target)}</li>`).join('') + `</ul></section>`;
    }
    const backs = backlinksTo(current);
    if (backs.length) {
      html += `<section><h2>Referenced by</h2><ul class="backs">` +
        backs.map((id) => `<li>${icon(ents[id])} ${link(id)}</li>`).join('') + `</ul></section>`;
    }

    if (!playerView && !e.deleted) {
      const kinds = (kind.childKinds ?? []).map((k) =>
        `<button class="wd-btn" data-addkind="${k}">${byKind[k]?.icon ?? ''} ${esc(byKind[k]?.label ?? k)}</button>`).join('');
      html += `<section><h2>Add inside ${esc(e.name)}</h2><div class="addkinds">${kinds || '<span class="ghostnote">this kind holds nothing</span>'}</div>`;
      if (addingKind) {
        const genTool = toolForKind(addingKind);
        html += `<div class="newform">${byKind[addingKind]?.icon ?? ''}
          <input id="newName" placeholder="${genTool ? `Name it — or leave blank and generate` : `Name the new ${esc(byKind[addingKind]?.label ?? addingKind)}…`}">
          ${genTool ? `<button class="wd-btn" id="genCreateBtn" title="Generate a full ${esc(byKind[addingKind]?.label ?? addingKind)}">🎲 Generate</button>` : ''}
          <button class="wd-btn" id="createBtn">Create blank</button><button class="wd-btn" id="cancelAdd">✕</button></div>`;
      }
      html += `<div id="ghosts"></div></section>`;
    }

    if (!playerView && e.gen) {
      const regenable = e.gen.generator.startsWith('composite:');
      html += `<div class="provenance">generated by ${esc(e.gen.generator)}` +
        `${e.gen.role ? ` · role “${esc(e.gen.role)}” of ${esc(e.gen.plan)}` : ''}<br>seed ${esc(e.gen.seed)}` +
        `${e.gen.overrides?.length ? `<br>kept by hand: ${esc(e.gen.overrides.join(', '))}` : ''}` +
        `${regenable ? `<br><button class="wd-btn" id="regenBtn" style="margin-top:6px">🎲 Regenerate page</button> <span class="ghostnote">keeps the parts you've edited</span>` : ''}</div>`;
    }
    if (!playerView) {
      html += `<div class="danger">${e.deleted
        ? `<button class="wd-btn" id="restoreBtn">Restore this page</button>`
        : `<button class="wd-btn" id="deleteBtn">Delete this page</button>`}</div>`;
    }
    art.innerHTML = html;
    // hydrate structured generator blocks through the shared renderer
    art.querySelectorAll<HTMLElement>('[data-static-block]').forEach((holder) => {
      const b = (e.body ?? []).find((x) => x.id === holder.dataset.staticBlock);
      if (b) holder.appendChild(renderBlockStatic(b as unknown as Parameters<typeof renderBlockStatic>[0]));
    });
    wirePage(e);
    if (!playerView && !e.deleted) void hydrateGhosts(e, kind);
  }

  // ---------- ghost children: the copy-on-write browse (CONTRACTS §1–2) ----------
  // Suggestions run the REAL generators against canonical seed paths derived
  // from the parent's entity id — the same ghost greets you every visit, and
  // nothing is stored until you Keep (materialize), Reroll, or Dismiss.
  const compositeModules = import.meta.glob<CompositeModule>('../composites/*.ts');
  const compositeRegistries = import.meta.glob<Record<string, Table>>('../generators/registries/*.json', { import: 'default' });

  interface GhostSlot { kind: string; label: string; tool: string; slot: number; slotKey: string }
  function ghostSlots(kind: KindDef): GhostSlot[] {
    const perKind: Record<string, number> = {};
    const out: GhostSlot[] = [];
    for (const s of kind.childSuggestions ?? []) {
      const gen: string | undefined = (s as { generator?: string }).generator;
      const count = (s as { ghostCount?: number }).ghostCount ?? 0;
      const tool = gen?.startsWith('composite:') ? gen.slice('composite:'.length) : null;
      for (let i = 0; i < count; i++) {
        // slot indices are per child KIND, in frozen registry order (CONTRACTS §6)
        const slot = perKind[s.kind] ?? 0;
        perKind[s.kind] = slot + 1;
        if (tool && `../composites/${tool}.ts` in compositeModules) {
          out.push({ kind: s.kind, label: s.label, tool, slot, slotKey: `${s.kind}:${slot}` });
        }
      }
    }
    return out;
  }

  async function runComposite(tool: string, seedPath: string): Promise<{ metaId: string; blocks: Block[] } | null> {
    const loadModule = compositeModules[`../composites/${tool}.ts`];
    const loadRegistry = compositeRegistries[`../generators/registries/${tool}.json`];
    if (!loadModule || !loadRegistry) return null;
    const [{ meta, build }, registry] = await Promise.all([loadModule(), loadRegistry()]);
    const tables: TableRegistry = new Map(Object.entries(registry));
    const opts: Record<string, string> = {};
    for (const o of meta.options) opts[o.id] = o.default;
    // The canonical path IS the composite seed: determinism flows from the
    // frozen path; the composite's internal hashing freezes with genVersion.
    return { metaId: meta.id, blocks: build(tables, seedPath, opts) };
  }

  async function hydrateGhosts(e: EntityRecord, kind: KindDef): Promise<void> {
    const holder = $('ghosts');
    if (!holder || !WORLD) return;
    const slots = ghostSlots(kind);
    if (!slots.length) return;
    const dismissed = new Set(e.ghostState?.dismissed ?? []);
    const cards: string[] = [];
    const live: Array<GhostSlot & { path: string; gid: string; name: string; metaId: string }> = [];
    for (const s of slots) {
      if (dismissed.has(s.slotKey)) continue;
      const reroll = e.ghostState?.rerolls?.[s.slotKey] ?? 0;
      const path = childPath(WORLD.seed, e.id, s.kind, s.slot, reroll);
      const gid = ghostId(path);
      if (E()[gid]) continue; // already materialized — it lives in the tree now
      const run = await runComposite(s.tool, path);
      if (!run) continue;
      const preview = blocksToEntity(run.metaId, path, run.blocks, s.label);
      live.push({ ...s, path, gid, name: preview.name, metaId: run.metaId });
      cards.push(`<div class="ghostcard" data-gslot="${s.slotKey}">
        <span class="gname">${byKind[s.kind]?.icon ?? ''} ${esc(preview.name)}</span>
        <span class="glabel">${esc(s.label)} — unwritten</span>
        <span class="gtools">
          <button class="wd-btn" data-gkeep="${s.slotKey}">Keep</button>
          <button class="wd-btn" data-greroll="${s.slotKey}">Reroll</button>
          <button class="wd-btn" data-gdismiss="${s.slotKey}">Dismiss</button>
        </span></div>`);
    }
    if (!cards.length) return;
    holder.innerHTML = `<div class="ghosthead">Unwritten — the world suggests:</div>` + cards.join('');
    holder.querySelectorAll<HTMLButtonElement>('[data-gkeep]').forEach((btn) =>
      btn.addEventListener('click', async () => {
        const g = live.find((x) => x.slotKey === btn.dataset.gkeep);
        if (!g || !WORLD) return;
        const run = await runComposite(g.tool, g.path);
        if (!run) return;
        const ne = blocksToEntity(run.metaId, g.path, run.blocks, g.label, e.id);
        ne.id = g.gid; // materialization keeps the ghost's derived id (CONTRACTS §2)
        WORLD.entities[ne.id] = ne;
        save();
        navigate(ne.id);
      }));
    holder.querySelectorAll<HTMLButtonElement>('[data-greroll]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const key = btn.dataset.greroll as string;
        e.ghostState ??= {};
        e.ghostState.rerolls ??= {};
        e.ghostState.rerolls[key] = (e.ghostState.rerolls[key] ?? 0) + 1;
        touchEntity(e); save(); rerender();
      }));
    holder.querySelectorAll<HTMLButtonElement>('[data-gdismiss]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const key = btn.dataset.gdismiss as string;
        e.ghostState ??= {};
        e.ghostState.dismissed ??= [];
        if (!e.ghostState.dismissed.includes(key)) e.ghostState.dismissed.push(key);
        touchEntity(e); save(); rerender();
      }));
  }

  // ---------- wiring ----------
  function wirePage(e: EntityRecord): void {
    $('renameBtn')?.addEventListener('click', () => {
      const span = $('nameSpan');
      if (!span) return;
      span.innerHTML = `<input id="nameInput" value="${esc(e.name)}">`;
      const inp = $('nameInput') as HTMLInputElement;
      inp.focus(); inp.select();
      const commit = () => {
        const v = inp.value.trim();
        if (v && v !== e.name) {
          e.name = v;
          markOverride(e, 'name');
          touchEntity(e); save();
        }
        rerender();
      };
      inp.addEventListener('keydown', (ev) => { if (ev.key === 'Enter') commit(); if (ev.key === 'Escape') rerender(); });
      inp.addEventListener('blur', commit);
    });
    document.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[data-fkey]').forEach((ctl) => {
      ctl.addEventListener('change', () => {
        const key = ctl.dataset.fkey as string, type = ctl.dataset.ftype;
        e.fields ??= {};
        const val = ctl.value;
        if (type === 'entityRef') { if (val) e.fields[key] = { ref: val }; else delete e.fields[key]; }
        else if (type === 'number') { if (val === '') delete e.fields[key]; else e.fields[key] = Number(val); }
        else if (type === 'date') { if (val) e.fields[key] = { date: val }; else delete e.fields[key]; }
        else { if (val.trim() === '') delete e.fields[key]; else e.fields[key] = val; }
        touchEntity(e); save();
        if (type === 'entityRef') rerender();
      });
    });
    $('addFieldBtn')?.addEventListener('click', () => {
      const key = prompt('Field name (lowercase-first, letters/numbers — e.g. "banner"):');
      if (!key) return;
      if (!/^[a-z][a-zA-Z0-9]*$/.test(key)) { alert('Use a lowercase-first alphanumeric key.'); return; }
      e.fields ??= {}; e.fields[key] ??= ''; touchEntity(e); save(); rerender();
    });
    $('addParaBtn')?.addEventListener('click', () => {
      e.body ??= [];
      const b = { type: 'paragraph', id: 'b_' + rid('', 8), text: '' };
      e.body.push(b); editingBlock = b.id; touchEntity(e); save(); rerender();
    });
    document.querySelectorAll<HTMLButtonElement>('[data-edit]').forEach((btn) =>
      btn.addEventListener('click', () => { editingBlock = btn.dataset.edit ?? null; rerender(); }));
    document.querySelectorAll<HTMLButtonElement>('[data-delblock]').forEach((btn) =>
      btn.addEventListener('click', () => {
        e.body = (e.body ?? []).filter((b) => b.id !== btn.dataset.delblock);
        e.secretBlocks = (e.secretBlocks ?? []).filter((id) => id !== btn.dataset.delblock);
        touchEntity(e); save(); rerender();
      }));
    document.querySelectorAll<HTMLButtonElement>('[data-secret]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const id = btn.dataset.secret as string;
        e.secretBlocks ??= [];
        e.secretBlocks = e.secretBlocks.includes(id) ? e.secretBlocks.filter((x) => x !== id) : [...e.secretBlocks, id];
        touchEntity(e); save(); rerender();
      }));
    const ta = $('blockTa') as HTMLTextAreaElement | null;
    if (ta) {
      ($('linkSel') as HTMLSelectElement | null)?.addEventListener('change', (ev) => {
        const sel = ev.target as HTMLSelectElement;
        const id = sel.value;
        if (!id) return;
        const ins = `{@e ${id}|${E()[id].name}}`;
        const s = ta.selectionStart ?? ta.value.length;
        ta.value = ta.value.slice(0, s) + ins + ta.value.slice(ta.selectionEnd ?? s);
        sel.value = ''; ta.focus();
      });
      $('blockSave')?.addEventListener('click', () => {
        const b = (e.body ?? []).find((b) => b.id === editingBlock);
        if (b) {
          b.text = ta.value;
          markOverride(e, `block:${b.id}`); // hand-edited parts survive regeneration
          touchEntity(e); save();
        }
        editingBlock = null; rerender();
      });
      $('blockCancel')?.addEventListener('click', () => { editingBlock = null; rerender(); });
      ta.focus();
    }
    document.querySelectorAll<HTMLButtonElement>('[data-addkind]').forEach((btn) =>
      btn.addEventListener('click', () => {
        addingKind = btn.dataset.addkind ?? null;
        rerender();
        setTimeout(() => ($('newName') as HTMLInputElement | null)?.focus(), 0);
      }));
    $('cancelAdd')?.addEventListener('click', () => { addingKind = null; rerender(); });
    const create = () => {
      const name = ($('newName') as HTMLInputElement | null)?.value.trim();
      if (!name || !addingKind || !WORLD) return;
      const ne = newEntity(addingKind, name, e.id);
      WORLD.entities[ne.id] = ne;
      save();
      addingKind = null;
      navigate(ne.id);
    };
    $('createBtn')?.addEventListener('click', create);
    ($('newName') as HTMLInputElement | null)?.addEventListener('keydown', (ev) => { if (ev.key === 'Enter') create(); });
    $('genCreateBtn')?.addEventListener('click', async () => {
      if (!addingKind || !WORLD) return;
      const tool = toolForKind(addingKind);
      if (!tool) return;
      const path = `${WORLD.seed}/${e.id}/adhoc:${addingKind}:${rid('', 6)}`;
      const run = await runComposite(tool, path);
      if (!run) return;
      const typed = ($('newName') as HTMLInputElement | null)?.value.trim();
      const ne = blocksToEntity(run.metaId, path, run.blocks, byKind[addingKind]?.label ?? addingKind, e.id);
      ne.kind = addingKind; // the chosen kind wins over the tool's default mapping
      if (typed) { ne.name = typed; markOverride(ne, 'name'); }
      WORLD.entities[ne.id] = ne;
      save();
      addingKind = null;
      navigate(ne.id);
    });
    $('deleteBtn')?.addEventListener('click', () => {
      if (!confirm(`Delete “${e.name}”? (It becomes recoverable; children are kept.)`)) return;
      e.deleted = now(); touchEntity(e); save(); rerender();
    });
    $('restoreBtn')?.addEventListener('click', () => { delete e.deleted; touchEntity(e); save(); rerender(); });

    // reroll one part: rebuild from a fresh seed and take only this block's
    // counterpart (composite output structure is stable per genVersion)
    document.querySelectorAll<HTMLButtonElement>('[data-rblock]').forEach((btn) =>
      btn.addEventListener('click', async () => {
        const tool = toolOfGen(e);
        if (!tool || !WORLD || !e.gen) return;
        const idx = (e.body ?? []).findIndex((b) => b.id === btn.dataset.rblock);
        if (idx < 0) return;
        const run = await runComposite(tool, `${e.gen.seed}/rb:${rid('', 6)}`);
        const fresh = run?.blocks[idx];
        if (!fresh) return;
        const keepId = e.body![idx].id;
        e.body![idx] = { ...structuredClone(fresh), id: keepId } as (typeof e.body)[number];
        // a fresh roll is no longer a hand edit
        if (e.gen.overrides) e.gen.overrides = e.gen.overrides.filter((o) => o !== `block:${keepId}`);
        touchEntity(e); save(); rerender();
      }));
    // regenerate the whole page around hand-edited parts
    $('regenBtn')?.addEventListener('click', async () => {
      const tool = toolOfGen(e);
      if (!tool || !WORLD || !e.gen) return;
      const newSeed = `${WORLD.seed}/${e.id}/regen:${rid('', 6)}`;
      const run = await runComposite(tool, newSeed);
      if (!run) return;
      const overrides = new Set(e.gen.overrides ?? []);
      (e.body ?? []).forEach((b, idx) => {
        const fresh = run.blocks[idx];
        if (!fresh || overrides.has(`block:${b.id}`)) return;
        e.body![idx] = { ...structuredClone(fresh), id: b.id } as (typeof e.body)[number];
      });
      if (!overrides.has('name')) e.name = extractName(run.blocks, e.name);
      e.gen.seed = newSeed;
      touchEntity(e); save(); rerender();
    });
  }

  function markOverride(e: EntityRecord, key: string): void {
    if (!e.gen) return;
    e.gen.overrides ??= [];
    if (!e.gen.overrides.includes(key)) e.gen.overrides.push(key);
  }
  function toolOfGen(e: EntityRecord): string | null {
    const m = /^composite:(?:gm|solo|writing)\/(.+)$/.exec(e.gen?.generator ?? '');
    const tool = m?.[1] ?? null;
    return tool && `../composites/${tool}.ts` in compositeModules ? tool : null;
  }
  function toolForKind(kindId: string): string | null {
    for (const g of byKind[kindId]?.generators ?? []) {
      if (typeof g.id === 'string' && g.id.startsWith('composite:')) {
        const tool = g.id.slice('composite:'.length);
        if (`../composites/${tool}.ts` in compositeModules) return tool;
      }
    }
    return null;
  }

  // ---------- shell ----------
  function rerender(): void { renderTree(); renderPage(); }
  function navigate(id: string | null): void {
    current = id;
    editingBlock = null;
    addingKind = null;
    history.replaceState(null, '', id ? `#${id}` : location.pathname);
    rerender();
  }

  async function openWorld(id: string | null): Promise<void> {
    WORLD = id ? (await getWorld(id)) ?? null : null;
    if (WORLD) localStorage.setItem(ACTIVE_KEY, WORLD.id);
    else localStorage.removeItem(ACTIVE_KEY);
    loadCollapsed();
    current = null;
    await renderChrome();
    rerender();
  }

  document.addEventListener('click', (ev) => {
    const tg = (ev.target as HTMLElement).closest?.('[data-toggle]') as HTMLElement | null;
    if (tg) {
      const id = tg.dataset.toggle ?? '';
      if (collapsed.has(id)) collapsed.delete(id); else collapsed.add(id);
      saveCollapsed();
      renderTree();
      return;
    }
    const t = (ev.target as HTMLElement).closest('a[data-id], .node[data-id]') as HTMLElement | null;
    if (t) { ev.preventDefault(); navigate(t.dataset.id ?? null); }
  });
  ($('playerView') as HTMLInputElement).addEventListener('change', (ev) => {
    playerView = (ev.target as HTMLInputElement).checked;
    editingBlock = null; addingKind = null;
    if (playerView && current && E()[current]?.deleted) current = null;
    rerender();
  });
  ($('worldSel') as HTMLSelectElement).addEventListener('change', (ev) => {
    void openWorld((ev.target as HTMLSelectElement).value || null);
  });
  $('newWorldBtn')?.addEventListener('click', async () => {
    const name = prompt('Name your world:');
    if (!name?.trim()) return;
    const seed = prompt('World seed (drives future generation — any phrase, no "/"):', name.trim().toLowerCase().replace(/[\s/]+/g, '-'));
    if (seed === null) return;
    const w = newWorld(name.trim(), (seed.trim() || 'seed').replace(/\//g, '-'));
    await putWorld(w);
    await openWorld(w.id);
  });
  $('exampleBtn')?.addEventListener('click', async () => {
    const res = await fetch('/labs/vessia.example.json');
    const doc: unknown = await res.json();
    if (!looksLikeWorld(doc)) { alert('Example failed to load.'); return; }
    await putWorld(doc);
    await openWorld(doc.id);
  });
  ($('importFile') as HTMLInputElement).addEventListener('change', async (ev) => {
    const file = (ev.target as HTMLInputElement).files?.[0];
    if (!file) return;
    try {
      const doc: unknown = JSON.parse(await file.text());
      if (!looksLikeWorld(doc)) { alert('That file does not look like an Everdeep world.'); return; }
      const existing = await getWorld(doc.id);
      if (existing && !confirm(`A world “${existing.name}” with this id already exists. Overwrite it?`)) return;
      await putWorld(doc);
      await openWorld(doc.id);
    } finally {
      (ev.target as HTMLInputElement).value = '';
    }
  });
  $('exportBtn')?.addEventListener('click', () => {
    if (!WORLD) return;
    const blob = new Blob([JSON.stringify(WORLD, null, 2)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `${WORLD.name || 'world'}.json`;
    a.click();
    URL.revokeObjectURL(a.href);
  });
  $('deleteWorldBtn')?.addEventListener('click', async () => {
    if (!WORLD) return;
    if (!confirm(`Delete the whole world “${WORLD.name}” from this browser? Export first if you want a copy.`)) return;
    await deleteWorld(WORLD.id);
    const rest = await listWorlds();
    await openWorld(rest[0]?.id ?? null);
  });
  const setDriveStatus = (msg: string) => { const el = $('driveStatus'); if (el) el.textContent = msg; };
  $('driveSaveBtn')?.addEventListener('click', async () => {
    try {
      setDriveStatus('Saving…');
      const result = await saveToDrive(await buildBackup(loadSheetStore()));
      setDriveStatus(`✓ backed up ${new Date(result.modifiedTime).toLocaleTimeString()}`);
    } catch (err) {
      setDriveStatus('Drive save failed — connect on first use, or see /sheet/.');
      console.error(err);
    }
  });
  $('driveLoadBtn')?.addEventListener('click', async () => {
    try {
      setDriveStatus('Checking Drive…');
      const backup = await loadFromDrive();
      if (!backup) { setDriveStatus('No Drive backup yet — ☁ Backup first.'); return; }
      const incoming = parseBackup(backup.json);
      if (!incoming.worlds.length && !incoming.sheets) { setDriveStatus('Backup contains nothing restorable.'); return; }
      if (!confirm(`Restore from Drive backup saved ${new Date(backup.modifiedTime).toLocaleString()}? Worlds with newer local edits are kept; sheets are only restored from /sheet/.`)) { setDriveStatus(''); return; }
      const res = await restoreWorlds(incoming.worlds);
      setDriveStatus(`✓ ${res.restored} world(s) restored${res.skippedOlder ? `, ${res.skippedOlder} kept (local newer)` : ''}.`);
      const worlds = await listWorlds();
      await openWorld(WORLD?.id ?? worlds[0]?.id ?? null);
    } catch (err) {
      setDriveStatus('Drive load failed.');
      console.error(err);
    }
  });

  $('addRootBtn')?.addEventListener('click', async () => {
    if (!WORLD) { alert('Create or load a world first.'); return; }
    const name = prompt('Name the new top-level region:');
    if (!name?.trim()) return;
    const ne = newEntity('region', name.trim());
    WORLD.entities[ne.id] = ne;
    save();
    navigate(ne.id);
  });
  ($('treeSearch') as HTMLInputElement | null)?.addEventListener('input', (ev) => {
    searchQuery = (ev.target as HTMLInputElement).value;
    renderTree();
  });
  // hover tooltips on entity links: name · kind · where it lives (free —
  // World Anvil charges for this)
  document.addEventListener('mouseover', (ev) => {
    const a = (ev.target as HTMLElement).closest?.('a[data-id]') as HTMLElement | null;
    if (!a || a.title) return;
    const e = E()[a.dataset.id ?? ''];
    if (!e) return;
    const crumb = crumbFor(e);
    const firstLine = (e.body ?? []).map((b) => String(b.text ?? '')).find((t) => t.trim());
    a.title = `${e.name} · ${e.kind}${crumb ? `\nin ${crumb}` : ''}${firstLine ? `\n${firstLine.replace(/\{@e [^}|]+\|?([^}]*)\}/g, '$1').slice(0, 140)}` : ''}`;
  });
  window.addEventListener('hashchange', () => {
    const id = location.hash.slice(1);
    if (E()[id]) navigate(id);
  });

  void (async () => {
    const worlds = await listWorlds();
    const remembered = localStorage.getItem(ACTIVE_KEY);
    let pick = worlds.find((w) => w.id === remembered)?.id ?? worlds[0]?.id ?? null;
    // deep link: #e_… may live in a different world — find its home
    const hashId = location.hash.slice(1);
    if (hashId.startsWith('e_')) {
      const all = await getAllWorlds();
      const home = all.find((w) => hashId in (w.entities ?? {}));
      if (home) pick = home.id;
    }
    await openWorld(pick);
    if (E()[hashId]) navigate(hashId);
  })();
</script>
