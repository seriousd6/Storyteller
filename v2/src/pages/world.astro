---
import Base from '../layouts/Base.astro';
---

<Base
  title="World (alpha)"
  description="Everdeep alpha — a wiki for your world: linked pages for places, people, factions, and quests, saved in your browser."
  hideTray={true}
>
  <div class="wd-shell">
    <header class="wd-bar">
      <strong>World</strong>
      <select id="worldSel" aria-label="Choose world"></select>
      <button id="newWorldBtn" class="wd-btn">New</button>
      <button id="exampleBtn" class="wd-btn">Load example</button>
      <label class="wd-btn wd-file">Import<input type="file" id="importFile" accept=".json,application/json"></label>
      <button id="exportBtn" class="wd-btn">Export</button>
      <button id="deleteWorldBtn" class="wd-btn">Delete</button>
      <button id="driveSaveBtn" class="wd-btn" title="Back up sheets + worlds to your Google Drive">☁ Backup</button>
      <button id="driveLoadBtn" class="wd-btn" title="Restore from your Google Drive backup">☁ Restore</button>
      <span class="wd-status" id="driveStatus" aria-live="polite"></span>
      <span class="wd-saved" id="savedFlash">saved</span>
      <span class="wd-grow"></span>
      <span class="wd-date" id="dateChip" title="The world's calendar (Phase D)">
        <button id="dayBack" class="wd-btn wd-daybtn" title="Back one day">‹</button>
        <button id="dateBtn" class="wd-btn" title="Click to set the date"></button>
        <button id="dayFwd" class="wd-btn wd-daybtn" title="Advance one day">›</button>
        <button id="weekFwd" class="wd-btn wd-daybtn" title="Advance ten days (a tenday)">»</button>
        <button id="timelineBtn" class="wd-btn wd-daybtn" title="The timeline — every dated event">🕰</button>
      </span>
      <span class="wd-party" id="partyComp" title="Party composition — encounters and hoards you roll in this world size to it">
        <span class="wd-party-i">⚔</span>
        <select id="partyLevel" class="wd-partysel" aria-label="Party level"></select>
        <select id="partySize" class="wd-partysel" aria-label="Party size"></select>
      </span>
      <button id="mapBtn" class="wd-btn" title="Jump between the page view and the world map">🗺 Map</button>
      <label class="wd-toggle"><input type="checkbox" id="playerView"> Player View</label>
    </header>
    <div class="wd-main">
      <nav class="wd-nav" id="nav">
        <div class="wd-navtop">
          <input id="treeSearch" class="wd-search" type="search" placeholder="Search this world…" aria-label="Search pages">
          <button id="navMin" class="wd-btn wd-navmin" title="Hide the tree">«</button>
        </div>
        <div id="tree"></div>
        <button id="addRootBtn" class="wd-btn wd-ghosty">+ Add at top level</button>
      </nav>
      <div class="wd-grip" id="navGrip" role="separator" aria-orientation="vertical"
           title="Drag to resize the tree · double-click to fit the longest name"></div>
      <button id="navShow" class="wd-navshow" title="Show the tree" aria-label="Show the tree" hidden>▸</button>
      <article class="wd-page" id="page"></article>
      <div class="wd-map" id="mapHost"></div>
    </div>
  </div>
</Base>

<style>
  .wd-shell { display:flex; flex-direction:column; min-height:70vh; }
  .wd-bar { display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding:8px 0 12px;
            border-bottom:1px solid var(--border, #8884); font-size:0.9rem; }
  .wd-bar select { max-width:180px; padding:4px 6px; }
  .wd-grow { flex:1; }
  .wd-saved { color:var(--accent, #7a9c5a); font-size:0.8rem; opacity:0; transition:opacity .3s; }
  :global(#siteOverlay) { position:fixed; inset:0; z-index:70; background:var(--color-bg, #fff);
    animation: wd-descend 0.22s ease-out; }
  @keyframes -global-wd-descend { from { opacity:0; transform:scale(1.06); } to { opacity:1; transform:scale(1); } }
  :global(.wd-adddlg) { position:fixed; inset:0; background:#0008; z-index:60; display:flex; align-items:center; justify-content:center; }
  :global(.wd-adddlg-card) { background:var(--color-surface, #fff); border:1px solid var(--color-border, #ccc);
    border-radius:12px; padding:18px 20px; width:min(430px, 92vw); display:flex; flex-direction:column; gap:10px;
    box-shadow:0 12px 40px #0005; }
  :global(.wd-adddlg-card h3) { margin:0; font-size:1rem; }
  :global(.wd-adddlg-card .wd-water) { color:#3b7ea1; font-size:0.8rem; }
  :global(.wd-adddlg-card label) { display:flex; gap:8px; align-items:center; }
  :global(.wd-adddlg-card select), :global(.wd-adddlg-card input) { flex:1; padding:4px 8px; }
  :global(.wd-iconrow) { display:flex; gap:4px; flex-wrap:wrap; min-height:30px; align-items:center; }
  :global(.wd-iconbtn) { font-size:1.05rem; padding:3px 7px; border:1px solid var(--color-border, #ccc);
    border-radius:8px; background:none; cursor:pointer; }
  :global(.wd-iconbtn.on) { outline:2px solid var(--accent, #7a9c5a); }
  :global(.wd-dlgbtns) { display:flex; gap:8px; justify-content:flex-end; }
  .wd-date { display:inline-flex; gap:2px; align-items:center; }
  .wd-daybtn { padding-inline:7px; }
  :global(.wd-tl) { max-height:70vh; overflow-y:auto; min-width:min(480px, 92vw); }
  :global(.wd-tlrow) { display:flex; gap:10px; align-items:baseline; padding:2px 0; }
  :global(.wd-tldate) { font-size:0.78rem; opacity:0.7; min-width:12.5em; }
  :global(.wd-future a) { font-style:italic; }
  :global(.wd-tlnow) { text-align:center; color:var(--accent, #7a9c5a); font-size:0.8rem; margin:6px 0; }
  :global(.wd-stamp) { margin-left:6px; }
  .wd-status { font-size:0.78rem; opacity:0.8; }
  .wd-saved.show { opacity:1; }
  .wd-btn { font-size:0.85rem; padding:4px 10px; cursor:pointer; }
  .wd-ghosty { border-style:dashed; opacity:0.85; margin-top:10px; width:100%; }
  .wd-file { position:relative; overflow:hidden; display:inline-block; }
  .wd-file input { position:absolute; inset:0; opacity:0; cursor:pointer; }
  .wd-toggle { display:flex; gap:6px; align-items:center; cursor:pointer; }
  .wd-party { display:inline-flex; gap:3px; align-items:center; }
  .wd-party-i { font-size:0.95rem; opacity:0.8; }
  .wd-partysel { font-size:0.8rem; padding:3px 4px; cursor:pointer; }
  .wd-main { display:flex; gap:0; min-height:0; flex:1; }
  /* width is owner-draggable (item #16) and persisted; --navw is set on .wd-main */
  .wd-nav { width:var(--navw, 250px); flex-shrink:0; padding:12px 2px 12px 0;
            font-size:0.88rem; overflow:auto; max-height:75vh; position:sticky; top:0; }
  .wd-nav.min { display:none; }
  /* the drag grip doubles as the tree's right-hand rule */
  .wd-grip { flex:none; width:5px; cursor:col-resize; background:var(--border, #8884);
             background-clip:content-box; border-inline:2px solid transparent; position:relative; z-index:1; }
  .wd-grip:hover, .wd-grip.dragging { background:var(--accent, #7a9c5a); }
  .wd-grip.min { display:none; }
  /* folded, the tree leaves a 16px rail — any wider and the button would eat
     back the width folding just freed */
  .wd-navshow { flex:none; width:16px; align-self:stretch; max-height:75vh; margin:12px 5px 0 0;
                padding:0; font-size:0.7rem; line-height:1; cursor:pointer; opacity:.75;
                background:none; border:1px solid var(--border, #8884); border-radius:4px; }
  .wd-navshow:hover { opacity:1; background:#8882; }
  .wd-navtop { display:flex; gap:4px; align-items:center; margin-bottom:8px; }
  .wd-navmin { flex:none; padding:4px 7px; line-height:1; }
  /* a row is [twisty][name……][lock] — the lock owns a column of its own, so a
     long name is ellipsised by the NAME's box and never runs under the padlock */
  .wd-nav :global(.node) { display:flex; align-items:center; gap:1px; padding:2px 4px 2px 0;
                           border-radius:5px; cursor:pointer; }
  .wd-nav :global(.node .nm) { flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .wd-nav :global(.node:hover) { background:#8882; }
  .wd-nav :global(.node.active) { background:#8883; font-weight:600; }
  .wd-nav :global(.kids) { margin-left:13px; border-left:1px solid #8884; padding-left:6px; }
  .wd-nav :global(.dead) { opacity:0.5; }
  .wd-nav :global(.dead .nm) { text-decoration:line-through; }
  .wd-search { flex:1; min-width:0; font:inherit; font-size:0.85rem; padding:4px 8px; }
  .wd-nav :global(.hitpath) { font-size:0.72rem; opacity:0.55; margin-left:20px;
                              overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .wd-nav :global(.tw) { flex:none; display:inline-block; width:14px; cursor:pointer; opacity:0.55; user-select:none; }
  .wd-nav :global(.tw-leaf) { cursor:default; }
  /* the lock only appears on hover — it must never compete with the page name */
  .wd-nav :global(.lk) { flex:none; cursor:pointer; opacity:0; font-size:0.72rem; padding:0 2px; transition:opacity .12s; }
  .wd-nav :global(.node:hover .lk) { opacity:0.5; }
  .wd-nav :global(.lk:hover) { opacity:1 !important; }
  .wd-nav :global(.node.dim) { opacity:0.6; }
  .wd-nav :global(.node.droptarget) { outline:1px dashed #888a; background:#8883; }
  .wd-nav :global(.grp) { font-size:0.72rem; text-transform:uppercase; letter-spacing:.08em; opacity:0.8;
    margin:10px 0 3px; font-weight:600; user-select:none; }
  .wd-nav :global(.grp:first-child) { margin-top:2px; }
  .wd-nav :global(.gcount) { opacity:0.5; font-weight:400; margin-left:6px; }
  .wd-page { flex:1; padding:16px 0 60px 26px; max-width:760px; min-width:0; }
  .wd-page :global(h1.wd-title) { display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin:4px 0; }
  .wd-page :global(h1.wd-title input) { font:inherit; max-width:60%; padding:0 8px; }
  .wd-page :global(.crumbs) { font-size:0.8rem; opacity:0.7; }
  .wd-page :global(.kindchip) { font-size:0.65rem; text-transform:uppercase; letter-spacing:.08em;
    border:1px solid #8886; border-radius:10px; padding:1px 9px; vertical-align:middle; opacity:0.8; }
  .wd-page :global(section) { margin-top:22px; }
  .wd-page :global(section > h2) { font-size:0.78rem; text-transform:uppercase; letter-spacing:.1em;
    opacity:0.7; border-bottom:1px solid #8884; padding-bottom:4px; display:flex; gap:10px; align-items:center; }
  .wd-page :global(section > h2 .sp) { flex:1; }
  .wd-page :global(.frow) { display:grid; grid-template-columns:220px 1fr; gap:4px 16px; margin:7px 0; align-items:start; }
  .wd-page :global(.frow .fl) { opacity:0.75; font-size:0.85rem; padding-top:5px; }
  .wd-page :global(.frow input), .wd-page :global(.frow select), .wd-page :global(.frow textarea),
  .wd-page :global(.blockedit textarea) { width:100%; font:inherit; padding:5px 9px; }
  .wd-page :global(.frow textarea) { min-height:54px; resize:vertical; }
  .wd-page :global(.block) { margin:10px 0; position:relative; }
  .wd-page :global(.block .btools) { position:absolute; right:0; top:-6px; display:none; gap:4px; }
  .wd-page :global(.block:hover .btools) { display:flex; }
  .wd-page :global(.block .blabel) { font-size:0.72rem; text-transform:uppercase; letter-spacing:.06em; opacity:0.7; }
  .wd-page :global(.block.secret) { border-left:3px solid #b06a6a; padding:6px 12px; background:#b06a6a14; border-radius:0 6px 6px 0; }
  .wd-page :global(.blockedit .rowtools) { display:flex; gap:6px; margin-top:6px; align-items:center; font-size:0.8rem; opacity:0.9; flex-wrap:wrap; }
  .wd-page :global(ul.rel), .wd-page :global(ul.backs) { padding-left:18px; margin:8px 0; }
  .wd-page :global(.ghostnote) { font-size:0.82rem; opacity:0.65; font-style:italic; }
  .wd-page :global(.provenance) { font-family:ui-monospace, monospace; font-size:0.72rem; opacity:0.55;
    margin-top:26px; border-top:1px dashed #8886; padding-top:8px; word-break:break-all; }
  .wd-page :global(.addkinds) { display:flex; flex-wrap:wrap; gap:7px; margin-top:8px; }
  .wd-page :global(.newform) { display:flex; gap:8px; margin-top:10px; align-items:center; }
  .wd-page :global(.newform input) { flex:1; max-width:320px; font:inherit; padding:6px 9px; }
  .wd-page :global(.danger) { margin-top:20px; }
  .wd-page :global(.acdrop) { display:flex; flex-direction:column; border:1px solid #8886; border-radius:8px;
    margin-top:4px; overflow:hidden; max-width:420px; background:var(--panel, #fff); }
  .wd-page :global(.acitem) { text-align:left; font:inherit; font-size:0.9rem; padding:5px 10px;
    background:none; border:none; cursor:pointer; }
  .wd-page :global(.acitem.sel), .wd-page :global(.acitem:hover) { background:#8883; }
  .wd-page :global(.ackind) { font-size:0.7rem; opacity:0.55; text-transform:uppercase; letter-spacing:.06em; }
  .wd-page :global(.wd-sbsec) { position:relative; padding-right:34px; }
  .wd-page :global(.wd-die) { padding:1px 6px; font-size:0.8rem; opacity:0; transition:opacity .15s; }
  .wd-page :global(.wd-sbsec:hover .wd-die) { opacity:0.85; }
  .wd-page :global(.wd-die-sec) { position:absolute; right:0; top:2px; }
  .wd-page :global(.wd-sbpair .wd-die) { margin-left:6px; }
  .wd-page :global(.sbname) { font-variant:small-caps; font-size:1.25rem; }
  .wd-page :global(.sbmeta) { font-style:italic; opacity:0.75; }
  .wd-page :global(.ghosthead) { font-size:0.78rem; text-transform:uppercase; letter-spacing:.08em; opacity:0.6; margin:14px 0 4px; }
  .wd-page :global(.pwrap) { float:right; width:160px; margin:2px 0 12px 18px; }
  .wd-page :global(.pcard) { background:#faf6ea; border:1px solid #d8d0bc; border-radius:9px; padding:5px;
    box-shadow:1px 2px 5px #0002; transform:rotate(0.6deg); }
  .wd-page :global(.pcard svg) { display:block; width:100%; height:auto; }
  .wd-page :global(.ptools) { display:flex; flex-wrap:wrap; gap:3px; margin-top:5px; justify-content:center; }
  .wd-page :global(.wd-photo) { float:right; clear:right; width:190px; margin:2px 0 12px 18px; text-align:center; }
  .wd-page :global(.wd-photo-img) { display:block; width:100%; height:auto; border-radius:9px; border:1px solid #d8d0bc; box-shadow:1px 2px 6px #0002; margin-bottom:5px; }
  .wd-page :global(.wd-photo .wd-btn) { cursor:pointer; }
  .wd-page :global(.rel) { list-style:none; padding-left:0; margin:4px 0; }
  .wd-page :global(.rel > li) { margin:2px 0; }
  .wd-page :global(.rel-note) { font-style:italic; opacity:0.85; }
  .wd-page :global(.rel-add) { display:flex; flex-wrap:wrap; gap:5px; align-items:center; margin-top:7px; }
  .wd-page :global(.rel-add input), .wd-page :global(.rel-add select) { padding:2px 5px; font:inherit; }
  .wd-page :global(.rel-type) { width:8rem; }
  .wd-page :global(.rel-note-in) { flex:1; min-width:9rem; }
  .wd-page :global(.pdie) { font-size:0.62rem; padding:1px 6px; opacity:0.8; }
  .wd-page :global(.ghostcard) { display:flex; align-items:center; gap:10px; flex-wrap:wrap;
    border:1px dashed #8887; border-radius:8px; padding:7px 12px; margin:6px 0; opacity:0.92; }
  .wd-page :global(.ghostcard .gname) { font-style:italic; }
  .wd-page :global(.ghostcard .glabel) { font-size:0.75rem; opacity:0.6; }
  .wd-page :global(.ghostcard .gtools) { margin-left:auto; display:flex; gap:5px; }
  .wd-page.mapoff { display:none; }
  .wd-map { display:none; flex:1; min-width:0; margin:12px 0 12px 16px; }
  .wd-map.on { display:block; }
  .wd-map :global(.mv-wrap) { position:relative; height:76vh; min-height:360px; }
  .wd-map :global(.mv-canvas) { display:block; border-radius:10px; cursor:grab; touch-action:none; background:#1d2f47; }
  /* translucent + blurred, not solid ink (round-2 note): pins and coastline
     ghost through the panel instead of vanishing under it, and the blur keeps
     the small text readable over bright terrain */
  .wd-map :global(.mv-legend) { position:absolute; top:10px; right:10px; background:#10141ab0; color:#f4efdf;
    backdrop-filter:blur(3px); -webkit-backdrop-filter:blur(3px);
    padding:8px 12px; border-radius:9px; font-size:0.72rem; max-width:200px; line-height:1.8; }
  .wd-map :global(.mv-ltitle) { font-size:0.66rem; text-transform:uppercase; letter-spacing:.1em; opacity:.7;
    display:flex; align-items:center; justify-content:space-between; gap:8px; }
  .wd-map :global(.mv-legmin) { background:#ffffff1a; color:#f4efdf; border:none; border-radius:5px; cursor:pointer;
    width:20px; height:20px; line-height:1; font-size:0.95rem; opacity:.85; }
  .wd-map :global(.mv-legmin:hover) { background:#ffffff33; }
  .wd-map :global(.mv-legend-min .mv-legbody) { display:none; }
  .wd-map :global(.mv-legend-min) { max-width:unset; }
  .wd-map :global(.mv-legend-min .mv-ltitle) { opacity:1; }
  .wd-map :global(.mv-key) { display:inline-flex; align-items:center; gap:5px; margin-right:9px; white-space:nowrap; }
  /* inline-flex beats [hidden]'s display:none, so say it outright — the realms
     legend lists only what's on screen (item #29) */
  .wd-map :global(.mv-key[hidden]) { display:none; }
  .wd-map :global(.mv-claimcount) { opacity:.55; font-size:0.62rem; letter-spacing:0; }
  .wd-map :global(.mv-key i) { width:11px; height:11px; border-radius:3px; display:inline-block; }
  /* Earth has 169 landed crowns and the legend listed every one of them in an
     unbounded column that ran off the map (owner, item #20). */
  .wd-map :global(.mv-claims) { margin-top:3px; max-height:26vh; overflow-y:auto;
    overscroll-behavior:contain; padding-right:3px; }
  .wd-map :global(.mv-claims::-webkit-scrollbar) { width:7px; }
  .wd-map :global(.mv-claims::-webkit-scrollbar-thumb) { background:#ffffff30; border-radius:4px; }
  .wd-map :global(.mv-claims::-webkit-scrollbar-track) { background:transparent; }
  .wd-map :global(.mv-toggle) { display:inline-flex; gap:5px; align-items:center; cursor:pointer; margin-top:3px; margin-right:8px; }
  .wd-map :global(.mv-layers) { margin-top:2px; }
  /* Map key (overlay legend): a symbol/colour key for what each overlay draws —
     the Layers toggles turn them on, this says what they mean. Chips wrap so it
     stays a few compact lines. Line/ring/box swatches match the canvas colours. */
  .wd-map :global(.mv-mapkey) { margin-top:3px; display:flex; flex-wrap:wrap; line-height:1.5; }
  /* the fold: display:flex above beats the `hidden` attribute, so say it
     outright (docs/PITFALLS.md — [hidden] loses to any authored display:) */
  .wd-map :global(.mv-mapkey[hidden]) { display:none; }
  .wd-map :global(.mv-mapkey .mv-key) { margin-right:8px; margin-bottom:2px; }
  .wd-map :global(.mv-ln) { width:14px !important; height:3px !important; border-radius:2px; }
  .wd-map :global(.mv-ring) { width:11px; height:11px; border-radius:50% !important; background:none !important; border:2px solid; }
  .wd-map :global(.mv-box) { width:10px; height:10px; border-radius:2px !important; background:none !important; border:1.5px dashed; }
  .wd-map :global(.mv-elevkey) { margin-top:6px; font-size:0.62rem; text-transform:uppercase; letter-spacing:.07em; opacity:.72; }
  .wd-map :global(.mv-elevkey i) { display:block; height:9px; border-radius:3px; margin:2px 0 1px;
    background:linear-gradient(90deg,#2e3f5a,#3a4a2e,#6a7f4a,#b9a86a,#e8e8e0); }
  .wd-map :global(.mv-elevkey span) { font-size:0.55rem; opacity:.7; letter-spacing:0; text-transform:none; }
  .wd-map :global(.mv-clickable) { cursor:pointer; }
  .wd-map :global(.mv-clickable:hover) { text-decoration:underline; }
  .wd-map :global(.mv-shead) { cursor:pointer; font-size:0.64rem; text-transform:uppercase; letter-spacing:.08em;
    opacity:.65; margin-top:5px; user-select:none; }
  .wd-map :global(.mv-shead:hover) { opacity:1; }
  .wd-map :global(.mv-paintbtn) { background:none; border:none; cursor:pointer; font-size:0.7rem; padding:0 2px;
    opacity:0.45; margin-left:2px; }
  .wd-map :global(.mv-paintbtn:hover) { opacity:1; }
  .wd-map :global(.mv-paintbtn.mv-painting) { opacity:1; outline:1px solid #f4efdf88; border-radius:4px; }
  .wd-map :global(.mv-terrbtn) { background:none; border:none; cursor:pointer; font-size:0.7rem; padding:0 2px;
    opacity:0.5; margin-left:4px; }
  .wd-map :global(.mv-terrbtn:hover) { opacity:1; }
  .wd-map :global(.mv-brushes .mv-key) { cursor:pointer; border-radius:4px; padding:0 3px; }
  .wd-map :global(.mv-brushes .mv-key:hover) { background:#f4efdf22; }
  .wd-map :global(.mv-brush-on) { outline:1px solid #f4efdf99; background:#f4efdf1c; }
  .wd-map :global(.mv-paintdone) { font-size:0.7rem; padding:1px 8px; cursor:pointer; background:#f4efdf22;
    color:#f4efdf; border:1px solid #f4efdf55; border-radius:5px; }
  .wd-map :global(.mv-claims .mv-key) { display:flex; align-items:center; max-width:100%; }
  /* out-of-view realms: [hidden] must beat the display:flex above — the generic
     .mv-key[hidden] rule ties on specificity and loses on source order, which
     is why the legend count filtered but the rows never hid (queue #33) */
  .wd-map :global(.mv-claims .mv-key[hidden]) { display:none; }
  /* long realm names never overflow the legend (batch 47) */
  .wd-map :global(.mv-cname) { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; min-width:0; flex:1; }
  .wd-map :global(.mv-claims .mv-key i) { flex:0 0 auto; }
  .wd-map :global(.mv-paintbtn) { flex:0 0 auto; background:none; border:none; cursor:pointer; padding:0 0 0 3px; font-size:0.72rem; }
  .wd-map :global(.mv-tools) { display:flex; gap:6px; margin-top:5px; }
