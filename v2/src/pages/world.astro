  /* the peek card: what you tapped, without leaving the map (owner, item #17) */
  .wd-map :global(.mv-card) { position:absolute; width:265px; background:#10141af2; color:#f4efdf;
    border:1px solid #ffffff26; border-radius:10px; padding:9px 11px 11px; font-size:0.78rem;
    box-shadow:0 8px 26px #0007; z-index:3; }
  .wd-map :global(.mv-card[hidden]) { display:none; }
  .wd-map :global(.mv-cardhead) { display:flex; align-items:center; gap:7px; }
  .wd-map :global(.mv-cardglyph) { font-size:1rem; }
  .wd-map :global(.mv-cardname) { font-weight:600; font-size:0.92rem; flex:1; min-width:0;
    overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .wd-map :global(.mv-cardx) { background:none; border:none; color:#f4efdf; opacity:.55; cursor:pointer;
    font-size:1.05rem; line-height:1; padding:0 2px; }
  .wd-map :global(.mv-cardx:hover) { opacity:1; }
  .wd-map :global(.mv-cardkind) { font-size:0.66rem; text-transform:uppercase; letter-spacing:.07em;
    opacity:.6; margin-top:2px; }
  .wd-map :global(.mv-cardfacts) { display:flex; flex-wrap:wrap; gap:1px 10px; margin-top:6px; opacity:.9; }
  .wd-map :global(.mv-cardfacts b) { font-weight:600; opacity:.6; font-size:0.66rem;
    text-transform:uppercase; letter-spacing:.05em; margin-right:2px; }
  .wd-map :global(.mv-cardbrief) { margin:7px 0 0; line-height:1.45; opacity:.92; }
  .wd-map :global(.mv-cardempty) { font-style:italic; opacity:.5; }
  .wd-map :global(.mv-cardmore) { margin-top:9px; font-size:0.78rem; padding:3px 12px; cursor:pointer;
    background:#f4efdf; color:#10141a; border:1px solid #f4efdf; border-radius:7px; font-weight:600; }
  .wd-map :global(.mv-cardmore:hover) { background:#ffd479; border-color:#ffd479; }
  @media (max-width: 720px) {
    /* still draggable, but the tree may never eat a phone screen */
    .wd-nav { width:min(var(--navw, 250px), 45vw); }
    .wd-page { padding-left:14px; }
    .wd-page :global(.frow) { grid-template-columns:1fr; }
    .wd-map { margin-left:8px; }
  }
</style>

<script>
  import REGISTRY from '../everdeep/registry.json';
  import {
    listWorlds, getWorld, putWorld, putWorldRaw, deleteWorld, newWorld, newEntity, touchEntity,
    looksLikeWorld, mergeWorlds, rid, now, type WorldDoc, type EntityRecord, type MergeConflict,
  } from '../engine/worldStore.ts';
  import { buildBackup, parseBackup, restoreWorlds } from '../engine/backup.ts';
  import { saveToDrive, loadFromDrive } from '../engine/drive';
  import { initSheetStore, loadStore as loadSheetStore } from '../engine/sheetStore';
  import { renderBlockStatic } from '../engine/blockRender';
  import { getAllWorlds } from '../engine/worldStore.ts';
  import { childPath, ghostId, h32 } from '../everdeep/seeds.ts';
  import {
    buildPortraitSVG, defaultRecipe, parseRecipe, serializeRecipe, rerollLayer,
    knownRace, knownSex, RACES, PORTRAIT_LAYERS, rerollLook,
  } from '../everdeep/portraits.ts';
  import { blocksToEntity, extractName } from '../everdeep/adapters.ts';
  import {
    deriveSettleType, profileFor, localGovernment, localDefenses,
    SETTLE_TYPES, type SettleType,
  } from '../everdeep/placeProfile.ts';
  import { buildEpicCampaign, buildQuestChain, buildLifeWeb, buildKinWeb, buildKingdom, type RealmGov } from '../everdeep/webs.ts';
  import { makeComposer } from '../engine/composite.ts';
  import { mountMap, BIOME_COLORS, ANCHOR_ICON, type MapHandle } from '../everdeep/mapView.ts';
  import { biomeAt, ensureEarthGrid, EARTH_CIRCUM_FT, type TerrainCfg, type Landform } from '../everdeep/terrain.ts';
  import { generateHydrology } from '../everdeep/hydrology.ts';
  import { generateGeography, type GeoFeature } from '../everdeep/geography.ts';
  import { generateSettlements, settleTier } from '../everdeep/settlements.ts';
  import {
    ensureEarthAdmin, generateEarthRealms, EARTH_CONTINENTS, type EarthRealm,
  } from '../everdeep/earthRealms.ts';
  import { CLAIM_HEX_FT, claimAddr, pointToHex } from '../everdeep/hexgrid.ts';
  import { geoName } from '../everdeep/geoNames.ts';
  import { spaceKindFor, siteById } from '../everdeep/sites.ts';
  import { ensureGeneratedSite } from '../everdeep/siteOps.ts';
  import { mountSite, type SiteHandle } from '../everdeep/siteView.ts';
  import type { CompositeModule } from '../engine/composite';
  import type { Block, Table, TableRegistry } from '../engine/types';

  type KindDef = (typeof REGISTRY.kinds)[number];
  const byKind: Record<string, KindDef> = Object.fromEntries(REGISTRY.kinds.map((k) => [k.id, k]));

  const ACTIVE_KEY = 'stb:everdeep:activeWorld';
  let WORLD: WorldDoc | null = null;
  let current: string | null = null;
  let playerView = false;
  let editingBlock: string | null = null;
  let addingKind: string | null = null;
  let creatingWorld = false;

  const $ = (id: string) => document.getElementById(id);
  const E = (): Record<string, EntityRecord> => WORLD?.entities ?? {};

  // One pending save PER WORLD: with a single shared timer, a save scheduled
  // for world A was silently cancelled by any save for world B within the
  // debounce window (e.g. switching worlds right after an edit) — A's edit
  // never reached IndexedDB.
  const saveT = new Map<string, number>();
  function save(): void {
    if (!WORLD) return;
    const w = WORLD;
    clearTimeout(saveT.get(w.id));
    saveT.set(w.id, window.setTimeout(() => {
      saveT.delete(w.id);
      void putWorld(w).then(() => {
        const el = $('savedFlash');
        el?.classList.add('show');
        setTimeout(() => el?.classList.remove('show'), 900);
      });
    }, 250));
  }

  // ---------- derived ----------
  // Parent→children index, alive only for the duration of one synchronous
  // render pass. `childrenOf` scans every entity, so calling it once per tree
  // node is O(n²): at 4,103 entities that measured ~2.9 s of blocking work on
  // every pane open. Indexing once per pass makes it O(n). Because the index
  // never outlives a pass, no mutation can leave it stale.
  let kidIdx: Map<string, EntityRecord[]> | null = null;
  /** Run `fn` with the index built once. Nested calls reuse the outer index. */
  function withKidIdx<T>(fn: () => T): T {
    if (kidIdx) return fn();
    const m = new Map<string, EntityRecord[]>();
    for (const e of Object.values(E())) {
      const p = e.parentId ?? '__root__';
      const at = m.get(p);
      if (at) at.push(e);
      else m.set(p, [e]);
    }
    kidIdx = m;
    try {
      return fn();
    } finally {
      kidIdx = null;
    }
  }
  const childrenOf = (id: string): EntityRecord[] =>
    kidIdx
      ? (kidIdx.get(id) ?? [])
      : Object.values(E()).filter((e) => (e.parentId ?? '__root__') === id);
  const mentionRe = /\{@e (e_[a-z0-9]{14})(?:\|([^}]*))?\}/g;
  function backlinksTo(target: string): string[] {
    const out: string[] = [];
    for (const e of Object.values(E())) {
      if (e.id === target) continue;
      let hit =
        (e.relations ?? []).some((r) => r.target === target) ||
        Object.values(e.fields ?? {}).some((v) => typeof v === 'object' && v !== null && 'ref' in v && v.ref === target);
      if (!hit) for (const b of e.body ?? []) if (String(b.text ?? '').includes(target)) { hit = true; break; }
      if (hit) out.push(e.id);
    }
    return out;
  }
  const icon = (e: EntityRecord) => byKind[e.kind]?.icon ?? '▪️';
  // Escape for BOTH text and attribute contexts: names are user- and
  // generator-controlled and get interpolated into double-quoted attributes
  // (title="…", value="…"), so an unescaped `"` breaks out of the attribute —
  // an injection, not just a rendering bug.
  const esc = (s: unknown) =>
    String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  const link = (id: string, label?: string) =>
    E()[id] ? `<a href="#${id}" data-id="${id}">${esc(label ?? E()[id].name)}</a>` : esc(label ?? id);
  const renderText = (t: unknown) => esc(t).replace(mentionRe, (_m, id: string, label?: string) => link(id, label));

  // ---------- chrome ----------
  async function renderChrome(): Promise<void> {
    const sel = $('worldSel') as HTMLSelectElement;
    const worlds = await listWorlds();
    sel.innerHTML =
      worlds.map((w) => `<option value="${w.id}" ${WORLD?.id === w.id ? 'selected' : ''}>${esc(w.name)} (${w.entityCount})</option>`).join('') ||
      '<option value="">— no worlds yet —</option>';
  }

  // ---------- tree (search, collapse, hide, drag-to-reparent) ----------
  // Folding is EXPANDED-BY-DEFAULT no longer (owner, item #5: "so much
  // information has locked it up"). The old `collapsed` set only remembered what
  // you had MANUALLY folded, so a 4,103-entity world opened with every node
  // rendered. We track what's explicitly OPEN instead — so the default is shut,
  // and the tree only ever shows the path you're working on.
  const GROUP_IDS = ['grp_geo', 'grp_pol', 'grp_story'];
  const GEO_KINDS = new Set(['region', 'biome', 'settlement', 'landmark', 'place', 'district', 'building']);
  let searchQuery = '';
  let expanded = new Set<string>();
  /** Subtrees the user has locked shut and sunk to the "Hidden" section. */
  let hidden = new Set<string>();
  const TREE_KEY = 'stb:everdeep:tree';
  type TreeState = Record<string, { expanded?: string[]; hidden?: string[] }>;
  const readTree = (): TreeState => {
    try { return JSON.parse(localStorage.getItem(TREE_KEY) ?? '{}') as TreeState; } catch { return {}; }
  };
  function loadTreeState(): void {
    const st = readTree()[WORLD?.id ?? ''];
    // first open of a world: the three top groups are open, everything under
    // them folded — a legible handful of rows instead of thousands
    expanded = new Set(st?.expanded ?? GROUP_IDS);
    hidden = new Set(st?.hidden ?? []);
  }
  function saveTreeState(): void {
    if (!WORLD) return;
    const all = readTree();
    all[WORLD.id] = { expanded: [...expanded], hidden: [...hidden] };
    localStorage.setItem(TREE_KEY, JSON.stringify(all));
  }

  /** Which top-level group a node lives under (its root ancestor decides). */
  function groupIdOf(id: string): string {
    let cur = E()[id], guard = 0;
    while (cur?.parentId && E()[cur.parentId] && guard++ < 64) cur = E()[cur.parentId]!;
    if (!cur) return 'grp_story';
    return GEO_KINDS.has(cur.kind) ? 'grp_geo' : cur.kind === 'faction' ? 'grp_pol' : 'grp_story';
  }

  /** Open just this page's path and nothing else: unfold every ancestor (and
   *  its group), un-hide any locked region it sits inside, and let the render
   *  scroll it into view. Other branches keep whatever state they had. */
  function revealPath(id: string): void {
    if (!E()[id]) return;
    const chain: string[] = [];
    let cur: string | undefined = id, guard = 0;
    while (cur && guard++ < 64) {
      chain.push(cur);
      cur = E()[cur]?.parentId;
    }
    // the node itself needn't open; its ancestors must
    for (const a of chain.slice(1)) expanded.add(a);
    for (const a of chain) hidden.delete(a); // clicking into a hidden region unlocks it
    expanded.add(groupIdOf(id));
    saveTreeState();
  }
  function crumbFor(e: EntityRecord): string {
    const parts: string[] = [];
    // guard: an imported doc can carry a parentId cycle — never walk forever
    let p = e.parentId, guard = 0;
    while (p && E()[p] && guard++ < 64) { parts.unshift(E()[p].name); p = E()[p].parentId; }
    return parts.join(' › ');
  }
  function matches(e: EntityRecord, q: string): boolean {
    if (e.name.toLowerCase().includes(q)) return true;
    if ((e.aliases ?? []).some((a) => a.toLowerCase().includes(q))) return true;
    if ((e.tags ?? []).some((t) => t.toLowerCase().includes(q))) return true;
    if (Object.values(e.fields ?? {}).some((v) => typeof v === 'string' && v.toLowerCase().includes(q))) return true;
    if (!playerView || !e.secret) {
      for (const b of e.body ?? []) {
        if ((e.secretBlocks ?? []).includes(b.id) && playerView) continue;
        if (String(b.text ?? '').toLowerCase().includes(q)) return true;
      }
    }
    return false;
  }
  function renderTree(): void {
    const nav = $('tree');
    if (!nav) return;
    if (!WORLD) { nav.innerHTML = ''; return; }
    const q = searchQuery.trim().toLowerCase();
    if (q) {
      const hits = Object.values(E())
        .filter((e) => !(e.deleted && playerView) && !(e.secret && playerView))
        .filter((e) => matches(e, q))
        .slice(0, 40);
      nav.innerHTML = hits.length
        ? hits.map((e) => {
            const cls = ['node', e.id === current ? 'active' : '', e.deleted ? 'dead' : ''].join(' ');
            const crumb = crumbFor(e);
            return `<div class="${cls}" data-id="${e.id}">` +
              `<span class="nm" title="${esc(e.name)}">${icon(e)} ${esc(e.name)}</span></div>` +
              (crumb ? `<div class="hitpath" title="${esc(crumb)}">${esc(crumb)}</div>` : '');
          }).join('')
        : `<div class="hitpath">no pages match “${esc(searchQuery)}”</div>`;
      return;
    }
    const item = (id: string): string => {
      const e = E()[id];
      if (e.deleted && playerView) return '';
      const cls = ['node', id === current ? 'active' : '', e.deleted ? 'dead' : ''].join(' ');
      // a locked child is gone from here — it lives on the Hidden shelf until
      // it's unlocked or something inside it is clicked
      const kids = childrenOf(id).filter((k) => !(k.deleted && playerView) && !hidden.has(k.id));
      const open = expanded.has(id);
      const tw = kids.length
        ? `<span class="tw" data-toggle="${id}" title="${open ? 'collapse' : 'expand'}">${open ? '▾' : '▸'}</span>`
        : `<span class="tw tw-leaf"></span>`;
      // only a branch can be locked away — hiding a leaf means nothing
      const lock = kids.length ? `<span class="lk" data-hide="${id}" title="hide this region">🔒</span>` : '';
      let html = `<div class="${cls}" data-id="${id}" draggable="true">${tw}` +
        `<span class="nm" title="${esc(e.name)}">${icon(e)} ${esc(e.name)}</span>${lock}</div>`;
      if (kids.length && open) html += `<div class="kids">${kids.map((k) => item(k.id)).join('')}</div>`;
      return html;
    };
    // top level folds into Geography / Politics / People & Story (batch 10):
    // places under one toggle, powers under another, everything else third
    const GROUPS: Array<{ id: string; label: string; match: (k: string) => boolean }> = [
      { id: 'grp_geo', label: '🌍 Geography', match: (k) => GEO_KINDS.has(k) },
      { id: 'grp_pol', label: '🛡️ Politics', match: (k) => k === 'faction' },
      { id: 'grp_story', label: '📜 People & Story', match: () => true },
    ];
    const roots = childrenOf('__root__').filter((e) => !(e.deleted && playerView));
    const taken = new Set<string>();
    let html = GROUPS.map((g) => {
      const mine = roots.filter((e) => !taken.has(e.id) && g.match(e.kind));
      mine.forEach((e) => taken.add(e.id));
      const shown = mine.filter((e) => !hidden.has(e.id)); // locked regions sink below
      if (!mine.length) return '';
      const open = expanded.has(g.id);
      return `<div class="grp"><span class="tw" data-toggle="${g.id}">${open ? '▾' : '▸'}</span>${g.label}` +
        `<span class="gcount">${shown.length}${shown.length !== mine.length ? ` +${mine.length - shown.length}🔒` : ''}</span></div>` +
        (open ? `<div class="kids">${shown.map((e) => item(e.id)).join('')}</div>` : '');
    }).join('');
    // the Hidden shelf: regions locked shut and parked at the bottom until an
    // item inside one is clicked (revealPath un-hides it) or it's unlocked here
    const hid = [...hidden].map((id) => E()[id]).filter((e) => e && !(e.deleted && playerView));
    if (hid.length) {
      const open = expanded.has('grp_hidden');
      html += `<div class="grp"><span class="tw" data-toggle="grp_hidden">${open ? '▾' : '▸'}</span>🔒 Hidden` +
        `<span class="gcount">${hid.length}</span></div>` +
        (open
          ? `<div class="kids">${hid.map((e) => `<div class="node dim" data-id="${e!.id}"><span class="tw tw-leaf"></span>` +
              `<span class="nm" title="${esc(e!.name)}">${icon(e!)} ${esc(e!.name)}</span>` +
              `<span class="lk" data-show="${e!.id}" title="unlock this region">🔓</span></div>`).join('')}</div>`
          : '');
    }
    nav.innerHTML = html;
    // keep the page you're on visible — the tree can be long
    nav.querySelector('.node.active')?.scrollIntoView({ block: 'nearest' });
  }

  // drag a page onto another to file it there; onto empty tree space for top level
  let dragId: string | null = null;
  function canDropOn(targetId: string | null): boolean {
    if (!dragId || !WORLD) return false;
    const d = E()[dragId];
    if (!d) return false;
    if (targetId === null) return d.parentId !== undefined; // already top-level? no-op
    if (targetId === dragId) return false;
    let p: string | undefined = targetId, guard = 0;
    while (p && guard++ < 64) { if (p === dragId) return false; p = E()[p]?.parentId; } // no cycles
    const tk = byKind[E()[targetId]?.kind ?? ''];
    return (tk?.childKinds ?? []).includes(d.kind);
  }
  document.addEventListener('dragstart', (ev) => {
    const n = (ev.target as HTMLElement).closest?.('.node[data-id]') as HTMLElement | null;
    if (!n) return;
    dragId = n.dataset.id ?? null;
    ev.dataTransfer?.setData('text/plain', dragId ?? '');
    if (ev.dataTransfer) ev.dataTransfer.effectAllowed = 'move';
  });
  document.addEventListener('dragover', (ev) => {
    const el = ev.target as HTMLElement;
    const n = el.closest?.('.node[data-id]') as HTMLElement | null;
    document.querySelectorAll('.droptarget').forEach((x) => x.classList.remove('droptarget'));
    if (n && canDropOn(n.dataset.id ?? null)) {
      ev.preventDefault();
      n.classList.add('droptarget');
    } else if (!n && el.closest?.('.wd-nav') && canDropOn(null)) {
      ev.preventDefault();
    }
  });
  document.addEventListener('drop', (ev) => {
    const el = ev.target as HTMLElement;
    const n = el.closest?.('.node[data-id]') as HTMLElement | null;
    document.querySelectorAll('.droptarget').forEach((x) => x.classList.remove('droptarget'));
    if (!dragId || !WORLD) return;
    const d = E()[dragId];
    if (!d) return;
    if (n && canDropOn(n.dataset.id ?? null)) {
      ev.preventDefault();
      d.parentId = n.dataset.id;
      expanded.add(n.dataset.id ?? ''); // reveal the new home
      saveTreeState();
      touchEntity(d); save(); rerender();
    } else if (!n && el.closest?.('.wd-nav') && canDropOn(null)) {
      ev.preventDefault();
      delete d.parentId;
      touchEntity(d); save(); rerender();
    }
    dragId = null;
  });
  document.addEventListener('dragend', () => {
    document.querySelectorAll('.droptarget').forEach((x) => x.classList.remove('droptarget'));
    dragId = null;
  });

  // ---------- fields ----------
  function fieldRow(e: EntityRecord, def: { key: string; label: string; type: string; refKind?: string | string[]; options?: string[]; secret?: boolean } | null, key: string): string {
    const v = e.fields?.[key];
    // GM-only fields (a person's disposition, the "why", GM notes) never render
    // in Player View — the whole point of a characterization note is it's secret.
    if (playerView && def?.secret) return '';
    const label = (def?.secret ? '🔒 ' : '') + (def?.label ?? key);
    if (playerView) {
      if (v === undefined || v === '') return '';
      const shown =
        typeof v === 'object' && v !== null && 'ref' in v ? link(v.ref)
        : typeof v === 'object' && v !== null && 'date' in v ? esc(v.date)
        : Array.isArray(v) ? esc(v.join(', ')) : renderText(v);
      return `<div class="frow"><div class="fl">${esc(label)}</div><div>${shown}</div></div>`;
    }
    // An undeclared key holding a `{ref}` must render as an entity select, not
    // a text input — the text path shows `String({ref})` = "[object Object]"
    // and a change writes that literal back, destroying the reference.
    const type = def?.type ?? (
      typeof v === 'number' ? 'number'
      : typeof v === 'object' && v !== null && 'ref' in v ? 'entityRef'
      : 'text');
    let control: string;
    if (type === 'entityRef') {
      // refKind may name SEVERAL kinds: a faction's seat is whatever it holds —
      // webs.ts hands it a capital, but the def said `place`, so the settlement
      // it was actually given could never appear as an option and the select
      // quietly read "—" (item #28)
      const kinds = def?.refKind == null ? null
        : Array.isArray(def.refKind) ? def.refKind : [def.refKind];
      let pool = Object.values(E()).filter((x) => !x.deleted && (!kinds || kinds.includes(x.kind)));
      // A REGION's seat and ruler choose from ITS OWN political area (queue
      // #32): the seat is one of the realm's settlements; the ruler someone
      // who lives in them. "Political area" = the containment subtree — the
      // same rule the law-of-the-land inheritance walks. You could seat
      // fantasy-France in another continent's city before this. The CURRENT
      // pick always stays listed even when out of scope, so an existing
      // reference never silently vanishes from its own select.
      if (e.kind === 'region' && (key === 'seat' || key === 'ruler')) {
        const cur = typeof v === 'object' && v !== null && 'ref' in v ? v.ref : null;
        const kids = new Map<string, string[]>();
        for (const x of Object.values(E())) {
          if (!x.parentId || x.deleted) continue;
          const arr = kids.get(x.parentId);
          if (arr) arr.push(x.id); else kids.set(x.parentId, [x.id]);
        }
        const seen = new Set<string>([e.id]);
        const stack = [e.id];
        while (stack.length) {
          const id = stack.pop()!;
          for (const c of kids.get(id) ?? []) if (!seen.has(c)) { seen.add(c); stack.push(c); }
        }
        const towns = new Set([...seen].filter((id) => E()[id]?.kind === 'settlement'));
        // "lives there" = parented anywhere in the realm's subtree (its towns,
        // or the realm itself — Earth's rulers sit at court, parented under
        // the region directly) or homed in one of its settlements
        const livesThere = (x: { parentId?: string; fields?: Record<string, unknown> }): boolean => {
          if (x.parentId && seen.has(x.parentId)) return true;
          const home = x.fields?.home;
          return typeof home === 'object' && home !== null && 'ref' in home && seen.has((home as { ref: string }).ref);
        };
        pool = pool.filter((x) => x.id === cur || (key === 'seat' ? towns.has(x.id) : livesThere(x)));
      }
      const opts = pool
        .map((x) => `<option value="${x.id}" ${typeof v === 'object' && v !== null && 'ref' in v && v.ref === x.id ? 'selected' : ''}>${esc(x.name)}</option>`)
        .join('');
      control = `<select data-fkey="${key}" data-ftype="entityRef"><option value="">—</option>${opts}</select>`;
    } else if (type === 'enum') {
      // A fixed dropdown (disposition toward the party, …) — options come from
      // the kind's registry field def; the commit handler stores it like text.
      const cur = typeof v === 'string' ? v : '';
      const opts = (def?.options ?? []).map((o) => `<option value="${esc(o)}"${cur === o ? ' selected' : ''}>${esc(o)}</option>`).join('');
      control = `<select data-fkey="${key}" data-ftype="enum"><option value=""${cur === '' ? ' selected' : ''}>—</option>${opts}</select>`;
    } else if (type === 'longtext') {
      control = `<textarea data-fkey="${key}" data-ftype="longtext" placeholder="…">${esc(v ?? '')}</textarea>`;
    } else if (type === 'number') {
      control = `<input type="number" data-fkey="${key}" data-ftype="number" value="${typeof v === 'number' ? v : ''}">`;
    } else {
      const shown = typeof v === 'object' && v !== null && 'date' in v ? v.date : Array.isArray(v) ? v.join(', ') : (v ?? '');
      control = `<input data-fkey="${key}" data-ftype="${type}" value="${esc(shown)}" placeholder="…">`;
      // date fields can stamp the world clock (Phase D, batch 34) — writes
      // the formatted date AND a machine-readable day for the timeline
      if (type === 'date') control += `<button class="wd-btn wd-stamp" data-stamp="${key}" title="Stamp today's date">📅 today</button>`;
    }
    return `<div class="frow"><div class="fl">${esc(label)}</div><div>${control}</div></div>`;
  }

  const entityOptions = (exclude: string) =>
    Object.values(E()).filter((x) => !x.deleted && x.id !== exclude)
      .map((x) => `<option value="${x.id}">${icon(x)} ${esc(x.name)}</option>`).join('');

  // ---------- world creation (user-led, Civ-style — PLAN §6.1) ----------
  interface WorldgenResult {
    routes: Array<{ id: string; kind: string; pts: Array<[number, number]> }>;
    lakePaint: Record<string, string>;
    features: GeoFeature[];
    nodes: Array<{ tier: 'capital' | 'town' | 'village'; x: number; y: number; pop: number; name: string; type: string; reason: string; ki: number }>;
    roads: Array<{ id: string; kind: string; pts: Array<[number, number]> }>;
    bridges: Array<[number, number]>;
    /** Only an 'earth' world has real borders to read (item #3); empty otherwise. */
    realms?: EarthRealm[];
  }
  // Run rivers + settlements + roads OFF the main thread (batch 71). Falls back
  // to inline generation if a module worker can't start (old browser, CSP…),
  // so world creation always works — it just freezes briefly in that case.
  /**
   * Build Earth — 2026 in the worker (owner: "everything should be in browser so
   * the end user experience is what we build on"; "point it at the workers, no
   * more drift").
   *
   * This is the SAME earth2026.ts the bake calls — the demo's real cities on
   * their real coordinates, the great rivers on their real courses, the fantasy
   * names — none of which a user could get before, because it all lived in a
   * script that only ever ran on my machine. ~45s, which is why it is in a
   * worker with a progress line rather than on the UI thread.
   */
  async function runEarth2026(name: string, onStage: (s: string) => void): Promise<WorldDoc | null> {
    try {
      const worker = new Worker(new URL('../everdeep/worldgen.worker.ts', import.meta.url), { type: 'module' });
      const world = await new Promise<WorldDoc>((resolve, reject) => {
        worker.onmessage = (ev: MessageEvent) => {
          const m = ev.data as { type: string; stage?: string; detail?: string; error?: string; world?: WorldDoc };
          if (m.type === 'progress') onStage(m.detail ?? m.stage ?? '');
          else if (m.type === 'earth2026-done') resolve(m.world!);
          else if (m.type === 'error') reject(new Error(m.error));
        };
        worker.onerror = (e: ErrorEvent) => reject(new Error(e.message || 'worker error'));
        worker.postMessage({ op: 'earth2026', cfg: {}, earth: { id: rid('w_'), name, stamp: new Date().toISOString() } });
      });
      worker.terminate();
      return world;
    } catch (err) {
      console.warn('earth2026 worker unavailable', err);
      return null;
    }
  }
  async function runWorldgen(cfg: TerrainCfg, onStage: (s: string) => void): Promise<WorldgenResult | null> {
    try {
      const worker = new Worker(new URL('../everdeep/worldgen.worker.ts', import.meta.url), { type: 'module' });
      const result = await new Promise<WorldgenResult>((resolve, reject) => {
        worker.onmessage = (ev: MessageEvent) => {
          const m = ev.data as { type: string; stage?: string; error?: string } & WorldgenResult;
          if (m.type === 'progress') onStage(m.stage!);
          else if (m.type === 'done') resolve(m);
          else if (m.type === 'error') reject(new Error(m.error));
        };
        worker.onerror = (e: ErrorEvent) => reject(new Error(e.message || 'worker error'));
        worker.postMessage({ cfg });
      });
      worker.terminate();
      return result;
    } catch (err) {
      console.warn('worldgen worker unavailable, running inline', err);
      onStage('rivers');
      if (cfg.landform === 'earth') { try { await ensureEarthGrid(); } catch { /* renders as ocean */ } }
      await new Promise((r) => setTimeout(r, 30));
      let hy: ReturnType<typeof generateHydrology> | null = null;
      try { hy = generateHydrology(cfg); } catch (e) { console.warn('hydrology skipped', e); return null; }
      let features: GeoFeature[] = [];
      try { features = generateGeography(cfg, hy.grid, cfg.seed); } catch (e) { console.warn('geography skipped', e); }
      onStage('roads');
      await new Promise((r) => setTimeout(r, 30));
      let settle: ReturnType<typeof generateSettlements> = { nodes: [], routes: [], bridges: [] };
      try { settle = generateSettlements(cfg, hy.grid); } catch (e) { console.warn('settlements skipped', e); }
      let realms: EarthRealm[] = [];
      if (cfg.landform === 'earth') {
        try { await ensureEarthAdmin(); realms = generateEarthRealms(cfg).realms; }
        catch (e) { console.warn('realms skipped', e); } // a world with no crowns still opens
      }
      return { routes: hy.routes, lakePaint: hy.lakePaint, features, nodes: settle.nodes, roads: settle.routes, bridges: settle.bridges, realms };
    }
  }

  // --- road regeneration on edit (batch 73) ---
  // When the user adds or removes a settlement, re-forge the road network over
  // the world's current towns (off-thread, debounced) so the map stays coherent.
  function terrainCfgOf(plane: PlaneRec | null): TerrainCfg | null {
    const t = plane?.terrain as Record<string, unknown> | undefined;
    if (!t || !WORLD || !t.circumFt) return null;
    return {
      seed: WORLD.seed, circumFt: Number(t.circumFt), heightFt: Number(t.heightFt),
      landform: (t.landform as Landform) ?? 'continents', continents: Number(t.continents ?? 3),
      waterPct: Number(t.waterPct ?? 55), climate: (t.climate as TerrainCfg['climate']) ?? 'temperate',
      climateModel: t.climateModel as 'noise' | 'earthlike' | undefined,
      reliefModel: t.reliefModel as 'classic' | 'sculpted' | undefined,
    };
  }
  function settlementNodesFromPlane(plane: PlaneRec): Array<{ tier: 'capital' | 'town' | 'village'; x: number; y: number; pop: number; name: string; type: string; reason: string; ki: number }> {
    const out: Array<{ tier: 'capital' | 'town' | 'village'; x: number; y: number; pop: number; name: string; type: string; reason: string; ki: number }> = [];
    for (const a of plane.anchors ?? []) {
      const e = WORLD?.entities[a.entityId];
      if (!e || e.kind !== 'settlement' || e.deleted) continue;
      const tags = e.tags ?? [];
      // settleTier is the ONE rule (settlements.ts) — this used to re-derive it
      // here and got it wrong for every city-tagged settlement
      const pop0 = Number(e.fields?.population ?? 0);
      const tier = settleTier(tags, pop0);
      const pop = pop0 || (tier === 'capital' ? 50_000 : tier === 'town' ? 3_000 : 300);
      out.push({ tier, x: a.x, y: a.y, pop, name: e.name, type: '', reason: '', ki: 0 });
    }
    return out;
  }
  async function runRoadsWorker(cfg: TerrainCfg, nodes: unknown[]): Promise<{ roads: Array<{ id: string; kind: string; pts: Array<[number, number]> }>; bridges: Array<[number, number]> } | null> {
    try {
      const worker = new Worker(new URL('../everdeep/worldgen.worker.ts', import.meta.url), { type: 'module' });
      const res = await new Promise<{ roads: Array<{ id: string; kind: string; pts: Array<[number, number]> }>; bridges: Array<[number, number]> }>((resolve, reject) => {
        worker.onmessage = (ev: MessageEvent) => { const m = ev.data as { type: string; error?: string; roads?: unknown; bridges?: unknown }; if (m.type === 'roads-done') resolve(m as never); else if (m.type === 'error') reject(new Error(m.error)); };
        worker.onerror = (e: ErrorEvent) => reject(new Error(e.message || 'worker error'));
        worker.postMessage({ op: 'roads', cfg, nodes });
      });
      worker.terminate();
      return res;
    } catch (e) { console.warn('road rebuild failed', e); return null; }
  }
  let roadRebuildT = 0, roadRebuilding = false;
  function scheduleRoadRebuild(): void { clearTimeout(roadRebuildT); roadRebuildT = window.setTimeout(() => { void regenerateRoads(); }, 900); }
  async function regenerateRoads(): Promise<void> {
    if (!WORLD || roadRebuilding) return;
    const plane = surfacePlane(WORLD);
    const cfg = terrainCfgOf(plane);
    if (!plane || !cfg) return;
    const nodes = settlementNodesFromPlane(plane);
    if (nodes.length < 2) return;
    roadRebuilding = true;
    const worldId = WORLD.id; // the user can switch worlds during the await
    try {
      const res = await runRoadsWorker(cfg, nodes);
      if (!res || WORLD?.id !== worldId) return;
      // keep rivers, swap the road routes for the freshly-forged network
      const routes = (plane.routes ??= []);
      const rivers = routes.filter((r) => r.kind === 'river' || r.kind === 'seaRoute');
      plane.routes = [...rivers, ...res.roads];
      // regenerate the auto bridges: drop the old ones, place the new crossings
      for (const a of (plane.anchors ?? []).slice()) { const e = WORLD.entities[a.entityId]; if (e && (e.tags ?? []).includes('bridge')) delete WORLD.entities[a.entityId]; }
      plane.anchors = (plane.anchors ?? []).filter((a) => !!WORLD!.entities[a.entityId]);
      for (const [bx, by] of res.bridges) {
        const e = newEntity('landmark', 'River Bridge'); e.tags = ['bridge'];
        e.body = [{ type: 'paragraph', id: 'b_bridge', text: 'Where a road crosses the great river — tolls, gossip, and the slow traffic of carts.' }];
        WORLD.entities[e.id] = e;
        plane.anchors!.push({ entityId: e.id, x: Math.round(bx), y: Math.round(by), tier: 'region', icon: 'bridge' });
      }
      save();
      if (mapMode) remountMap();
    } finally { roadRebuilding = false; }
  }

  // --- river re-trace when the user paints water (batch 73 part 2) ---
  function worldWaterSig(plane: PlaneRec): string {
    const bp = plane.biomePaint ?? {};
    return Object.keys(bp).filter((k) => k.startsWith('world:') && (bp[k] === 'water' || bp[k] === 'deep')).sort().join('|');
  }
  async function runRiversWorker(cfg: TerrainCfg, forcedWater: string[]): Promise<{ routes: Array<{ id: string; kind: string; pts: Array<[number, number]> }>; lakePaint: Record<string, string> } | null> {
    try {
      const worker = new Worker(new URL('../everdeep/worldgen.worker.ts', import.meta.url), { type: 'module' });
      const res = await new Promise<{ routes: Array<{ id: string; kind: string; pts: Array<[number, number]> }>; lakePaint: Record<string, string> }>((resolve, reject) => {
        worker.onmessage = (ev: MessageEvent) => { const m = ev.data as { type: string; error?: string }; if (m.type === 'rivers-done') resolve(m as never); else if (m.type === 'error') reject(new Error(m.error)); };
        worker.onerror = (e: ErrorEvent) => reject(new Error(e.message || 'worker error'));
        worker.postMessage({ op: 'rivers', cfg, forcedWater });
      });
      worker.terminate();
      return res;
    } catch (e) { console.warn('river re-trace failed', e); return null; }
  }
  let lastWaterSig = '', riverRebuildT = 0, riverRebuilding = false;
  function scheduleRiverRebuild(): void { clearTimeout(riverRebuildT); riverRebuildT = window.setTimeout(() => { void regenerateRivers(); }, 900); }
  async function regenerateRivers(): Promise<void> {
    if (!WORLD || riverRebuilding) return;
    const plane = surfacePlane(WORLD);
    const cfg = terrainCfgOf(plane);
    if (!plane || !cfg) return;
    const bp = plane.biomePaint ?? {};
    const forcedWater = Object.keys(bp).filter((k) => k.startsWith('world:') && (bp[k] === 'water' || bp[k] === 'deep')).map((k) => k.slice('world:'.length));
    riverRebuilding = true;
    const worldId = WORLD.id; // the user can switch worlds during the await
    try {
      const res = await runRiversWorker(cfg, forcedWater);
      if (!res || WORLD?.id !== worldId) return;
      const routes = (plane.routes ??= []);
      const notRivers = routes.filter((r) => r.kind !== 'river'); // keep roads etc.
      plane.routes = [...notRivers, ...res.routes];
      plane.biomePaint = { ...(plane.biomePaint ?? {}), ...res.lakePaint }; // keep the user's paint, add fresh lakes
      lastWaterSig = worldWaterSig(plane);
      save();
      if (mapMode) remountMap();
    } finally { riverRebuilding = false; }
  }

  function renderNewWorldForm(art: HTMLElement): void {
    art.innerHTML = `<h1>New world</h1>
      <p class="ghostnote">Shape it like a strategy game: pick a landform, set the dials, watch the
      sketch. The seed drives every future generation in this world — same seed, same world.</p>
      <div class="frow"><div class="fl">Name</div><div><input id="nwName" placeholder="e.g. Aldermoor"></div></div>
      <div class="frow"><div class="fl">Seed</div><div><input id="nwSeed" placeholder="defaults to the name — change it to reroll the sketch"></div></div>
      <div class="frow"><div class="fl">Landform</div><div style="display:flex; gap:8px">
        <select id="nwLandform" style="flex:1">
          <option value="earth">🌎 Real Earth — the actual continents</option>
          <option value="continent">One big continent</option>
          <option value="continents" selected>Several continents</option>
          <option value="pangea">Pangea — a world-spanning landmass</option>
          <option value="archipelago">Archipelago — many islands</option>
          <option value="isles">Scattered isles</option>
        </select>
        <select id="nwContinents" style="width:70px" aria-label="How many continents">
          <option>2</option><option selected>3</option><option>4</option><option>5</option>
        </select></div></div>
      <div class="frow"><div class="fl" id="nwWaterLabel">Water</div><div style="display:flex; gap:10px; align-items:center">
        <input type="range" id="nwWater" min="20" max="85" value="55" style="flex:1; padding:0"><span id="nwWaterVal">55%</span></div></div>
      <div class="frow"><div class="fl">Climate</div><div><select id="nwClimate">
        <option value="temperate" selected>Temperate</option><option value="hot">Hot</option><option value="cold">Cold</option>
      </select></div></div>
      <div class="frow" id="nwModelRow"><div class="fl">Model</div><div style="display:flex; gap:6px; align-items:center">
        <input type="checkbox" id="nwEarthlike" checked style="width:auto; flex:0">
        <label for="nwEarthlike" style="cursor:pointer">🌍 Earth-like climate — rain bands, rain shadows, dry interiors</label></div></div>
      <div class="frow"><div class="fl">Size</div><div><select id="nwSize">
        <option value="${EARTH_CIRCUM_FT}" selected>Earth-size — 25,000 mi around</option>
        <option value="${EARTH_CIRCUM_FT / 2}">Half — 12,500 mi</option>
        <option value="${EARTH_CIRCUM_FT / 4}">Quarter — 6,250 mi</option>
      </select><div class="ghostnote">east–west edges wrap seamlessly; endless worlds arrive later</div></div></div>
      <div class="frow"><div class="fl">Sketch</div><div>
        <canvas id="nwPreview" width="384" height="192" style="width:100%; max-width:440px; border-radius:8px; display:block"></canvas>
        <div class="ghostnote">the whole world, roughly — the real map has vastly more detail</div></div></div>
      <div class="newform"><button class="wd-btn" id="nwCreate">Create world</button>
      <button class="wd-btn" id="nwCancel">Cancel</button></div>`;

    const val = (id: string) => ($(id) as HTMLInputElement | HTMLSelectElement).value;
    const readCfg = (): TerrainCfg => {
      const circumFt = Number(val('nwSize'));
      const landform = val('nwLandform') as Landform;
      // Real Earth stays canonical unless the seed field is filled in (any seed
      // drifts it); a blank seed is the 'earth' sentinel, NOT the world name — so
      // naming it "Earth" doesn't accidentally count as a drift request.
      const seed = landform === 'earth'
        ? (val('nwSeed').trim() || 'earth')
        : (val('nwSeed').trim() || val('nwName').trim().toLowerCase().replace(/[\s/]+/g, '-') || 'seed').replace(/\//g, '-');
      return {
        seed, circumFt, heightFt: circumFt / 2,
        landform,
        continents: Number(val('nwContinents')),
        waterPct: Number(val('nwWater')),
        climate: val('nwClimate') as TerrainCfg['climate'],
        // earth carries its own (earthlike) climate; the checkbox drives the rest
        climateModel: landform === 'earth' || ($('nwEarthlike') as HTMLInputElement | null)?.checked ? 'earthlike' : 'noise',
      };
    };
    let paintT = 0;
    const paint = () => {
      clearTimeout(paintT);
      paintT = window.setTimeout(async () => {
        const canvas = $('nwPreview') as HTMLCanvasElement | null;
        if (!canvas) return;
        const cfg = readCfg();
        const earth = cfg.landform === 'earth';
        // earth-specific dials: the water slider becomes a sea-level dial, the
        // climate model is fixed (real Earth = earthlike), continents N/A.
        ($('nwWaterLabel') as HTMLElement).textContent = earth ? 'Sea level' : 'Water';
        ($('nwModelRow') as HTMLElement).style.display = earth ? 'none' : '';
        ($('nwContinents') as HTMLElement).style.display = cfg.landform === 'continents' ? '' : 'none';
        const seedHint = $('nwSeed') as HTMLInputElement | null;
        if (seedHint) seedHint.placeholder = earth
          ? 'blank = the real Earth; any seed drifts the continents'
          : 'defaults to the name — change it to reroll the sketch';
        if (earth) await ensureEarthGrid(); // load the baked grid before drawing
        const ctx = canvas.getContext('2d')!;
        const cols = 128, rows = 64;
        const cw = canvas.width / cols, ch = canvas.height / rows;
        for (let j = 0; j < rows; j++) {
          for (let i = 0; i < cols; i++) {
            const x = ((i + 0.5) / cols) * cfg.circumFt;
            const y = ((j + 0.5) / rows - 0.5) * cfg.heightFt;
            const [r, g, b] = BIOME_COLORS[biomeAt(cfg, x, y, 4)];
            ctx.fillStyle = `rgb(${r},${g},${b})`;
            ctx.fillRect(i * cw, j * ch, cw + 1, ch + 1);
          }
        }
        ($('nwWaterVal') as HTMLElement).textContent = earth
          ? (cfg.waterPct === 50 ? 'today' : cfg.waterPct > 50 ? `+${cfg.waterPct - 50}` : `${cfg.waterPct - 50}`)
          : `${cfg.waterPct}%`;
      }, 120);
    };
    ['nwName', 'nwSeed', 'nwLandform', 'nwContinents', 'nwWater', 'nwClimate', 'nwEarthlike', 'nwSize'].forEach((id) =>
      $(id)?.addEventListener('input', paint));
    // picking Real Earth snaps the sea-level dial to "today" (canonical Earth)
    $('nwLandform')?.addEventListener('change', () => {
      if (val('nwLandform') === 'earth') ($('nwWater') as HTMLInputElement).value = '50';
    });
    paint();
    $('nwCancel')?.addEventListener('click', () => { creatingWorld = false; rerender(); });
    $('nwCreate')?.addEventListener('click', async () => {
      const name = val('nwName').trim();
      if (!name) { ($('nwName') as HTMLInputElement).focus(); return; }
      const cfg = readCfg();
      const w = newWorld(name, cfg.seed);
      // rivers & lakes are part of the world from the start (owner, batch 61):
      // trace the drainage of the freshly-chosen terrain so a new world has its
      // watercourses, not just biomes. (The Vessia example is baked separately;
      // this gives every OTHER world the same hydrology.) The trace is a couple
      // of seconds on an Earth-size map, so show a label and yield a frame so it
      // paints before the synchronous work blocks the thread.
      const createBtn = $('nwCreate') as HTMLButtonElement | null;
      const setBtn = (t: string) => { if (createBtn) { createBtn.textContent = t; createBtn.disabled = true; } };
      setBtn('Tracing rivers…');
      await new Promise((r) => setTimeout(r, 30));

      // 🌎 Real Earth, undrifted: build the REAL one — every regional power in
      // its place, every major city at its real coordinates under a fantasyfied
      // name, the great rivers on their real courses. This is the flagship demo,
      // and until now the only way to get it was to load the shipped example:
      // a user who picked Real Earth here got the right coastlines and invented
      // cities. Same module the bake calls, so there is nothing to drift.
      // (A drifted Earth — any seed — still takes the procedural path below:
      // the real cities belong to the real coastline.)
      if (cfg.landform === 'earth' && cfg.seed === 'earth') {
        const earth = await runEarth2026(name, (s) => setBtn(s ? `${s.charAt(0).toUpperCase()}${s.slice(1)}…` : 'Building Earth…'));
        if (earth) {
          creatingWorld = false;
          await putWorld(earth);
          await openWorld(earth.id);
          setMapMode(true);
          return;
        }
        setBtn('Tracing rivers…'); // worker unavailable — fall through
      }
      // rivers + settlements + roads run in a Web Worker (batch 71) so the UI
      // never freezes; the inline fallback keeps it working if a worker can't
      // start. Only serialisable data crosses back — the main thread mints the
      // entities and anchors from it.
      const gen = await runWorldgen(cfg, (stage) => setBtn(
        stage === 'realms' ? 'Drawing borders…' : stage === 'roads' ? 'Building roads…' : 'Tracing rivers…'));
      const anchors: PlaneAnchor[] = [];
      const claims: Record<string, string[]> = {};
      // --- the crowns of a real Earth (item #3) ---
      // The bake has always grown this tree for the shipped fixture; an owner
      // who picks 🌎 Real Earth in this dialog now grows the same one, from the
      // same module. Continents first, so 245 realms don't land at the root.
      const realmOfHex = new Map<string, string>();
      if (gen?.realms?.length) {
        const contId: Record<string, string> = {};
        const usedConts = new Set(gen.realms.map((r) => r.region));
        for (const [reg, label] of Object.entries(EARTH_CONTINENTS)) {
          if (!usedConts.has(reg)) continue;
          const c = newEntity('region', label);
          c.tags = ['continent'];
          w.entities[c.id] = c;
          contId[reg] = c.id;
        }
        for (const R of gen.realms) {
          const e = newEntity('region', R.name, contId[R.region]);
          e.tags = ['kingdom-lands'];
          e.fields = { government: R.government };
          w.entities[e.id] = e;
          if (R.hexes.length) {
            claims[e.id] = R.hexes;
            for (const h of R.hexes) realmOfHex.set(h, e.id);
          }
          // the crown's name, written across its own ground (item #21)
          if (R.label) {
            anchors.push({ entityId: e.id, x: R.label[0], y: R.label[1], tier: 'world', icon: 'label' });
          }
        }
      }
      if (gen) {
        // A NOISE world has no Earth realms to file under, and 90 settlements
        // in one flat list is not a tree (audit V18). The kingdom index (ki)
        // came free from generation — a capital and its hinterland share one —
        // so each capital raises a petty crown and its holdings file under it.
        const crownOfKi = new Map<number, string>();
        if (!gen.realms?.length) {
          for (const n of gen.nodes) {
            if (n.tier !== 'capital' || crownOfKi.has(n.ki)) continue;
            const title = ['Kingdom', 'Crownlands', 'Realm', 'Dominion', 'March'][n.name.length % 5];
            const c = newEntity('region', `The ${title} of ${n.name}`);
            c.tags = ['kingdom-lands'];
            w.entities[c.id] = c;
            crownOfKi.set(n.ki, c.id);
          }
        }
        for (const n of gen.nodes) {
          const e = newEntity('settlement', n.name);
          e.tags = [n.tier, n.type.replace(/ /g, '-')];
          // carry the node type in fields too (batch 76) so a kingdom's web can
          // read a holding's kind without re-parsing the tag
          // population is a NUMBER: the registry types it number, so a string
          // renders as an empty input and breaks numeric sorts/tiers
          e.fields = { population: n.pop, settlementType: n.type };
          e.body = [{ type: 'paragraph', id: 'b_why', text: n.reason }];
          // a town stands in somebody's realm — file it under the crown that
          // holds its hex, the way the bake files its cities
          const [hq, hr] = pointToHex(CLAIM_HEX_FT.world, n.x, n.y);
          const owner = realmOfHex.get(claimAddr('world', hq, hr)) ?? crownOfKi.get(n.ki);
          if (owner) e.parentId = owner;
          w.entities[e.id] = e;
          anchors.push({ entityId: e.id, x: Math.round(n.x), y: Math.round(n.y),
            tier: n.tier === 'capital' ? 'world' : 'region', icon: n.tier === 'capital' ? 'city' : 'town',
            ...(n.tier === 'capital' ? { promoted: true } : {}) });
        }
        for (const [bx, by] of gen.bridges) {
          const e = newEntity('landmark', 'River Bridge');
          e.tags = ['bridge'];
          e.body = [{ type: 'paragraph', id: 'b_bridge', text: 'Where a road crosses the great river — tolls, gossip, and the slow traffic of carts.' }];
          w.entities[e.id] = e;
          anchors.push({ entityId: e.id, x: Math.round(bx), y: Math.round(by), tier: 'region', icon: 'bridge' });
        }
        // named geography (item #1): the oceans, seas, ranges, forests, deserts,
        // lakes and great rivers, as biome-kind entities the Geography tab lists
        // and edits, written on the map as cartographic label anchors
        for (const f of gen.features ?? []) {
          const e = newEntity('biome', f.name);
          e.tags = [f.kind, 'geography'];
          w.entities[e.id] = e;
          anchors.push({ entityId: e.id, x: Math.round(f.x), y: Math.round(f.y), tier: 'world', icon: 'label', ...(f.big ? { promoted: true } : {}) });
        }
      }
      // pin the dials into the doc at creation — later default changes never
      // redraw this world (drift policy, CONTRACTS §5)
      (w.planes as PlaneRec[]).push({
        id: 'p_surface', name: 'The Surface', unit: 'ft', orientation: 'pointy',
        terrain: {
          landform: cfg.landform,
          ...(cfg.landform === 'continents' ? { continents: cfg.continents } : {}),
          circumFt: cfg.circumFt, heightFt: cfg.heightFt,
          waterPct: cfg.waterPct, climate: cfg.climate,
          ...(cfg.climateModel === 'earthlike' ? { climateModel: 'earthlike' } : {}),
          // Worldcraft: readCfg starts minting 'sculpted' when the first
          // landform term ships (WORLDCRAFT.md L-2/L-3); pinned like the rest.
          ...(cfg.reliefModel === 'sculpted' ? { reliefModel: 'sculpted' } : {}),
        },
        anchors,
        routes: [...(gen?.routes ?? []), ...(gen?.roads ?? [])],
        ...(Object.keys(claims).length ? { claims } : {}),
        ...(gen && Object.keys(gen.lakePaint).length ? { biomePaint: gen.lakePaint } : {}),
      } as PlaneRec);
      creatingWorld = false;
      await putWorld(w);
      await openWorld(w.id);
      setMapMode(true); // land the new creator on their new world
    });
    setTimeout(() => ($('nwName') as HTMLInputElement | null)?.focus(), 0);
  }

  // ---------- page ----------
  function renderPage(): void {
    const art = $('page');
    if (!art) return;
    if (creatingWorld) { renderNewWorldForm(art); return; }
    if (!WORLD) {
      art.innerHTML = `<h1>Your worlds live here</h1>
        <p>This is the alpha of the worldbuilding wiki: linked pages for regions, settlements,
        people, factions, and quests, saved in your browser (IndexedDB) — no account needed.</p>
        <p><strong>New</strong> starts a blank world. <strong>Load example</strong> opens
        <em>Earth — 2026</em>: a full fantasyfied Earth — every regional power, its real cities,
        rivers, and named geography, with the world's leaders reimagined as its rulers. A tour of
        the whole tool in one map.</p>`;
      return;
    }
    const ents = E();
    if (!current || !ents[current]) {
      // the conflict inbox (queue #38): every merge decision that kept one
      // side of a page — the losing version is right here, restorable
      const inbox = (WORLD.conflicts ?? []) as MergeConflict[];
      const inboxHtml = !playerView && inbox.length ? `<section><h2>⚖ Conflict inbox (${inbox.length})</h2>
        <p class="ghostnote">Where two devices edited the same page, the newer edit won — the other version is kept here.</p>
        ${inbox.map((c, i) => `<p class="frow"><span>${esc(c.name ?? c.id)} — ${
          c.reason === 'both-edited' ? `kept the ${c.kept} edit` :
          c.reason === 'parent-missing' ? 'its parent was deleted on the other device; moved to top level' :
          'the map layers differed; kept one side whole'}<span class="ghostnote"> · ${esc((c.at ?? '').slice(0, 10))}</span></span>
          <span>${c.loser ? `<button class="wd-btn" data-crestore="${i}">restore the other version as a copy</button>` : ''}
          <button class="wd-btn" data-cdismiss="${i}">dismiss</button></span></p>`).join('')}</section>` : '';
      art.innerHTML = `<h1>${esc(WORLD.name)}</h1>
        <p class="ghostnote">Pick a page from the tree, or add one at top level. Everything you
        write autosaves to this browser; Export gives you the world as one JSON file.</p>
        ${inboxHtml}
        ${playerView ? '' : `<section><h2>Campaign webs</h2>
        <p><button class="wd-btn" id="epicBtn">🏔 Generate an epic campaign</button>
        <span class="ghostnote" id="epicStatus">acts across regions, checkpoint bosses, strongholds,
        foreshadowing hints, and a quest chain — different bones every time</span></p>
        <p><button class="wd-btn" id="kingdomBtn">🏰 Generate a kingdom</button>
        <span class="ghostnote" id="kingdomStatus">a realm rolled from the standalone tables — its crown and law,
        the ruler on the throne, the capital that names it, and the towns, villages, and landmarks under it</span></p></section>`}`;
      document.querySelectorAll<HTMLButtonElement>('[data-cdismiss]').forEach((btn) =>
        btn.addEventListener('click', () => {
          WORLD!.conflicts!.splice(Number(btn.dataset.cdismiss), 1);
          save(); renderPage();
        }));
      document.querySelectorAll<HTMLButtonElement>('[data-crestore]').forEach((btn) =>
        btn.addEventListener('click', () => {
          const c = inbox[Number(btn.dataset.crestore)];
          if (!c?.loser) return;
          // the losing version comes back as a NEW page beside the winner, so
          // the GM can compare and fold the two together by hand
          const copy = structuredClone(c.loser);
          copy.id = rid('e_');
          copy.name = `${copy.name} (from the other device)`;
          delete copy.deleted;
          E()[copy.id] = copy;
          WORLD!.conflicts!.splice(Number(btn.dataset.crestore), 1);
          save(); navigate(copy.id);
        }));
      $('epicBtn')?.addEventListener('click', async () => {
        const btn = $('epicBtn') as HTMLButtonElement;
        btn.disabled = true;
        const st = $('epicStatus');
        if (st) st.textContent = 'weaving the web…';
        const res = await buildEpicCampaign(WORLD!, runComposite);
        if (!res) { if (st) st.textContent = 'generation failed — try again'; btn.disabled = false; return; }
        save();
        navigate(res.rootId);
      });
      $('kingdomBtn')?.addEventListener('click', async () => {
        const btn = $('kingdomBtn') as HTMLButtonElement;
        btn.disabled = true;
        const st = $('kingdomStatus');
        if (st) st.textContent = 'raising the realm…';
        const gov = await rollRealmGov(`${WORLD!.seed}/kingdom-gov:${rid('', 6)}`);
        const res = await buildKingdom(WORLD!, runComposite, { gov });
        if (!res) { if (st) st.textContent = 'generation failed — try again'; btn.disabled = false; return; }
        save();
        navigate(res.rootId);
      });
      return;
    }
    const e = ents[current];
    const kind = byKind[e.kind] ?? ({ childKinds: [], suggestedFields: [] } as unknown as KindDef);
    const chain: string[] = [];
    let p = e.parentId, crumbGuard = 0;
    while (p && ents[p] && crumbGuard++ < 64) { chain.unshift(link(p)); p = ents[p].parentId; }
    let html = `<div class="crumbs">${chain.length ? chain.join(' › ') + ' ›' : esc(WORLD.name)}</div>`;
    html += `<h1 class="wd-title"><span>${icon(e)}</span><span id="nameSpan">${esc(e.name)}</span>` +
      `<span class="kindchip">${e.kind}${e.deleted ? ' · deleted' : ''}</span>` +
      (playerView ? '' : `<button class="wd-btn" id="renameBtn" title="rename">✏️</button>`) +
      (hasMapPresence(e.id) ? `<button class="wd-btn" id="showMapBtn" title="Show on the map">🗺</button>`
        : playerView ? '' : `<button class="wd-btn" id="placeMapBtn" title="Place this page on the map — tap a hex">📍</button>`) +
      (!e.deleted && spaceKindFor(e, anchorOf(e.id)?.icon)
        ? `<button class="wd-btn" id="siteBtn" title="Enter — the interior map (nested-spaces epic)">🏰</button>` : '') + `</h1>`;
    if (e.aliases?.length) html += `<div class="ghostnote">also called ${e.aliases.map(esc).join(', ')}</div>`;

    // Upload a real photo onto any entity (Codex B2): a character's face, the
    // inn where the party met — stored in the content-hashed asset store,
    // referenced by id in fields.photo, mounted async in wirePage.
    const hasPhoto = typeof e.fields?.photo === 'string' && !!e.fields.photo;
    if (!e.deleted) {
      html += `<div class="wd-photo">` +
        (hasPhoto ? `<img class="wd-photo-img" id="entityPhoto" alt="${esc(e.name)}">` : '') +
        (playerView ? '' :
          `<label class="wd-btn wd-photo-add">${hasPhoto ? '📷 Replace' : '📷 Add photo'}<input type="file" accept="image/*" id="photoInput" hidden></label>` +
          (hasPhoto ? ` <button class="wd-btn" id="photoRemove" title="Remove photo">✕</button>` : '')) +
        `</div>`;
    }

    // every person gets a notebook-pencil portrait (batch 8: additive bust
    // art, race-pertinent, seeded, per-layer rerollable) — unless a real photo
    // has been uploaded, which takes its place.
    if (e.kind === 'person' && !hasPhoto) {
      // sex and race are LOCKED to the person's own fields when set —
      // they are facts about the person, not the sketch (batch 18)
      const sexLocked = !!knownSex(e.fields?.gender ?? e.fields?.sex);
      const raceLocked = !!knownRace(e.fields?.race);
      html += `<div class="pwrap"><div class="pcard" id="portraitBox"></div>` +
        (playerView ? '' : `<div class="ptools">` +
          `<button class="wd-btn pdie" data-portrait-layer="look" title="Reroll the whole look — race and gender stay">🎲 look</button>` +
          PORTRAIT_LAYERS.map((l) => `<button class="wd-btn pdie" data-portrait-layer="${l.key}" title="Reroll ${l.label}">${l.label}</button>`).join('') +
          (sexLocked ? '' : `<button class="wd-btn pdie" data-portrait-layer="sex" title="Cycle sex">sex</button>`) +
          (raceLocked ? '' : `<button class="wd-btn pdie" data-portrait-layer="race" title="Cycle race">race</button>`) +
          `</div>`) +
        `</div>`;
    }

    // A known place arrives with its DETAILS already written (queue #37): a
    // settlement whose page opens with blank government/defenses/trade/type
    // gets them derived from what the world already knows — its size, the
    // land it sits on, the realm's law above it, and the political web's
    // seat/ruler — deterministically from the seed, so every open derives the
    // same words. Only UNDEFINED fields fill; anything typed or generated
    // stays untouched (and the web-derived values are exactly what ctxFor
    // threads back into a page reroll, so they cannot drift apart).
    if (!playerView && !e.deleted && e.kind === 'settlement') fillSettlementFields(e);
    const sugg = kind.suggestedFields ?? [];
    const extraKeys = Object.keys(e.fields ?? {}).filter((k) => k !== 'portrait' && k !== 'photo' && !sugg.some((s) => s.key === k));
    const rows = sugg.map((d) => fieldRow(e, d, d.key)).join('') + extraKeys.map((k) => fieldRow(e, null, k)).join('');
    if (rows.trim() || !playerView) {
      html += `<section><h2>Details<span class="sp"></span>${playerView ? '' : '<button class="wd-btn" id="addFieldBtn">+ field</button>'}</h2>${rows}</section>`;
    }

    html += `<section><h2>Entry<span class="sp"></span>${playerView ? '' : '<button class="wd-btn" id="addParaBtn">+ paragraph</button>'}</h2>`;
    for (const b of e.body ?? []) {
      const secret = (e.secretBlocks ?? []).includes(b.id);
      if (secret && playerView) continue;
      const cls = `block${secret ? ' secret' : ''}`;
      if (editingBlock === b.id && !playerView) {
        html += `<div class="${cls} blockedit" data-bid="${b.id}">
          <textarea id="blockTa">${esc(b.text ?? '')}</textarea>
          <div class="acdrop" id="acDrop" hidden></div>
          <div class="rowtools">
            <select id="linkSel"><option value="">insert link to…</option>${entityOptions(e.id)}</select>
            <button class="wd-btn" id="blockSave">Save</button>
            <button class="wd-btn" id="blockCancel">Cancel</button>
            <span>type @ to link as you write</span>
          </div></div>`;
        continue;
      }
      const structured = b.type !== 'paragraph';
      const rerollable = !playerView && e.gen?.generator.startsWith('composite:');
      const tools = playerView ? '' : `<span class="btools">
        ${rerollable ? `<button class="wd-btn" data-rblock="${b.id}" title="reroll this part">🎲</button>` : ''}
        ${structured ? '' : `<button class="wd-btn" data-edit="${b.id}">✏️</button>`}
        <button class="wd-btn" data-secret="${b.id}" title="toggle secret">${secret ? '🔓' : '🔒'}</button>
        <button class="wd-btn" data-delblock="${b.id}">✕</button></span>`;
      if (structured) {
        // statblocks/tables/lists from generators render via the shared block
        // renderer (one schema, one renderer — same as sheets and print)
        html += `<div class="${cls}" data-static-block="${b.id}">${tools}</div>`;
        continue;
      }
      const label = (b.label as string | undefined) ?? (secret ? 'Secret' : '');
      html += `<div class="${cls}">${tools}${label ? `<div class="blabel">${esc(label)}</div>` : ''}<p>${renderText(b.text ?? '')}</p></div>`;
    }
    if (!(e.body ?? []).length) {
      // a political power's entry is rollable (#35, owner D13): a terse
      // gazetteer draft, deterministic off the entity's seed path. Only
      // offered while the page is blank — a roll never stomps written prose.
      if (!playerView && !e.deleted && e.kind === 'region') {
        html += `<div class="addkinds"><button class="wd-btn" id="rollEntryBtn">🎲 Roll entry</button>
          <span class="ghostnote" id="entryStatus">a gazetteer draft — rule, land, people, trade, forces, and the tensions of the day</span></div>`;
      } else {
        html += `<div class="ghostnote">Nothing written yet.</div>`;
      }
    }
    html += `</section>`;

    // Relations (Codex B3): typed connections between entities, WITH the note
    // the render used to drop ("saved his life at Redwater", "met the party at
    // the docks"). Generators still write these (webs.ts); now a GM can add,
    // annotate, and remove them by hand. Shown read-only in Player View.
    const rels = e.relations ?? [];
    if (rels.length || !playerView) {
      const rows = rels.map((r, i) => {
        const noteHtml = r.note ? ` — <span class="rel-note">${renderText(r.note)}</span>` : '';
        const when = (r.start || r.end) ? ` <span class="ghostnote">(${esc([r.start, r.end].filter(Boolean).join(' – '))})</span>` : '';
        const tools = playerView ? '' :
          ` <button class="wd-btn" data-rel-note="${i}" title="Edit the note">✎</button>` +
          `<button class="wd-btn" data-rel-del="${i}" title="Remove this connection">✕</button>`;
        return `<li>${esc(r.type)} → ${link(r.target)}${noteHtml}${when}${tools}</li>`;
      }).join('');
      const suggestions = ['ally of', 'rival of', 'enemy of', 'friend of', 'family of', 'mentor of', 'member of', 'works for', 'loves', 'owes a debt to', 'met the party at', 'knows'];
      const adder = playerView ? '' :
        `<li class="rel-add">` +
        `<input id="relType" list="relTypes" placeholder="is / met at…" class="rel-type">` +
        `<datalist id="relTypes">${suggestions.map((t) => `<option value="${esc(t)}">`).join('')}</datalist>` +
        `<select id="relTarget"><option value="">— who / where —</option>${entityOptions(e.id)}</select>` +
        `<input id="relNote" placeholder="note — why / how (optional)" class="rel-note-in">` +
        `<button class="wd-btn" id="relAdd">+ connect</button>` +
        `</li>`;
      html += `<section><h2>Relations</h2><ul class="rel">${rows}${adder}</ul></section>`;
    }
    const backs = backlinksTo(current);
    if (backs.length) {
      html += `<section><h2>Referenced by</h2><ul class="backs">` +
        backs.map((id) => `<li>${icon(ents[id])} ${link(id)}</li>`).join('') + `</ul></section>`;
    }

    if (!playerView && !e.deleted) {
      const kinds = (kind.childKinds ?? []).map((k) =>
        `<button class="wd-btn" data-addkind="${k}">${byKind[k]?.icon ?? ''} ${esc(byKind[k]?.label ?? k)}</button>`).join('');
      html += `<section><h2>Add inside ${esc(e.name)}</h2><div class="addkinds">${kinds || '<span class="ghostnote">this kind holds nothing</span>'}</div>`;
      if (addingKind) {
        const genTool = toolForKind(addingKind);
        html += `<div class="newform">${byKind[addingKind]?.icon ?? ''}
          <input id="newName" placeholder="${genTool ? `Name it — or leave blank and generate` : `Name the new ${esc(byKind[addingKind]?.label ?? addingKind)}…`}">
          ${genTool ? `<button class="wd-btn" id="genCreateBtn" title="Generate a full ${esc(byKind[addingKind]?.label ?? addingKind)}">🎲 Generate</button>` : ''}
          <button class="wd-btn" id="createBtn">Create blank</button><button class="wd-btn" id="cancelAdd">✕</button></div>`;
      }
      if (e.kind === 'region' || e.kind === 'settlement') {
        html += `<div class="addkinds" style="margin-top:10px">
          <button class="wd-btn" id="webChainBtn">🕸 Side-quest chain</button>
          ${e.kind === 'settlement' ? `<button class="wd-btn" id="webLifeBtn">🫂 Local life</button>` : ''}
          <span class="ghostnote" id="webStatus">small webs: a local chain reuses local people as patrons; local life mints rival shops, a family, a feud</span>
        </div>`;
      }
      if (e.kind === 'settlement') {
        // city-level landmarks — inside and nearby — as pickable options
        // (owner, batch 80): roll a few, keep the ones that fit
        html += `<div class="addkinds" style="margin-top:10px">
          <button class="wd-btn" id="lmUrbanBtn">🏛 Landmark in town</button>
          <button class="wd-btn" id="lmNearBtn">🌄 Landmark nearby</button>
          <span class="ghostnote" id="lmStatus">roll a few options and pick the ones that belong</span>
        </div><div id="lmOptions" class="addkinds" style="margin-top:8px"></div>`;
      }
      if (e.kind === 'person' && !(e.tags ?? []).includes('deceased')) {
        html += `<div class="addkinds" style="margin-top:10px">
          <button class="wd-btn" id="webKinBtn">👪 Kith &amp; kin</button>
          <span class="ghostnote" id="webStatus">parents and a grandparent, siblings, friends, an enemy — reusing people who already exist where it can</span>
        </div>`;
      }
      html += `<div id="ghosts"></div></section>`;
    }

    if (!playerView && e.gen) {
      const regenable = e.gen.generator.startsWith('composite:');
      html += `<div class="provenance">generated by ${esc(e.gen.generator)}` +
        `${e.gen.role ? ` · role “${esc(e.gen.role)}” of ${esc(e.gen.plan)}` : ''}<br>seed ${esc(e.gen.seed)}` +
        `${e.gen.overrides?.length ? `<br>kept by hand: ${esc(e.gen.overrides.join(', '))}` : ''}` +
        `${regenable ? `<br><button class="wd-btn" id="regenBtn" style="margin-top:6px">🎲 Regenerate page</button> <span class="ghostnote">keeps the parts you've edited</span>` : ''}</div>`;
    }
    if (!playerView) {
      html += `<div class="danger">${e.deleted
        ? `<button class="wd-btn" id="restoreBtn">Restore this page</button>`
        : `<button class="wd-btn" id="deleteBtn">Delete this page</button>`}</div>`;
    }
    art.innerHTML = html;
    // hydrate structured generator blocks: shared renderer, plus per-section
    // and per-field dice on rerollable statblocks (GM view)
    const deepReroll = !playerView && !!toolOfGen(e);
    art.querySelectorAll<HTMLElement>('[data-static-block]').forEach((holder) => {
      const b = (e.body ?? []).find((x) => x.id === holder.dataset.staticBlock);
      if (!b) return;
      if (deepReroll && b.type === 'statblock') holder.appendChild(renderStatblockRerollable(e, b));
      else holder.appendChild(renderBlockStatic(b as unknown as Parameters<typeof renderBlockStatic>[0]));
    });
    wirePage(e);
    if (!playerView && !e.deleted) void hydrateGhosts(e, kind);
  }

  // ---------- ghost children: the copy-on-write browse (CONTRACTS §1–2) ----------
  // Suggestions run the REAL generators against canonical seed paths derived
  // from the parent's entity id — the same ghost greets you every visit, and
  // nothing is stored until you Keep (materialize), Reroll, or Dismiss.
  const compositeModules = import.meta.glob<CompositeModule>('../composites/*.ts');
  const compositeRegistries = import.meta.glob<Record<string, Table>>('../generators/registries/*.json', { import: 'default' });

  interface GhostSlot { kind: string; label: string; tool: string; slot: number; slotKey: string }
  function ghostSlots(kind: KindDef): GhostSlot[] {
    const perKind: Record<string, number> = {};
    const out: GhostSlot[] = [];
    for (const s of kind.childSuggestions ?? []) {
      const gen: string | undefined = (s as { generator?: string }).generator;
      const count = (s as { ghostCount?: number }).ghostCount ?? 0;
      const tool = gen?.startsWith('composite:') ? gen.slice('composite:'.length) : null;
      for (let i = 0; i < count; i++) {
        // slot indices are per child KIND, in frozen registry order (CONTRACTS §6)
        const slot = perKind[s.kind] ?? 0;
        perKind[s.kind] = slot + 1;
        if (tool && `../composites/${tool}.ts` in compositeModules) {
          out.push({ kind: s.kind, label: s.label, tool, slot, slotKey: `${s.kind}:${slot}` });
        }
      }
    }
    return out;
  }

  async function runComposite(tool: string, seedPath: string, extra?: Record<string, string>): Promise<{ metaId: string; blocks: Block[]; locked?: Record<string, string> } | null> {
    const loadModule = compositeModules[`../composites/${tool}.ts`];
    const loadRegistry = compositeRegistries[`../generators/registries/${tool}.json`];
    if (!loadModule || !loadRegistry) return null;
    const [mod, registry] = await Promise.all([loadModule(), loadRegistry()]);
    const { meta, build } = mod;
    const tables: TableRegistry = new Map(Object.entries(registry));
    const opts: Record<string, string> = {};
    for (const o of meta.options) opts[o.id] = o.default;
    if (extra) for (const [k, v] of Object.entries(extra)) if (v) opts[k] = v;
    // Reroll-invariant dimensions (batch 93): resolved HERE, at creation, from
    // the same seed + context the build ran with — so the caller can persist
    // them onto gen.opts and a later reroll keeps the node type, scale, and
    // biome the page was created with (a ghost's hamlet-of-40 stays one).
    const lock = (mod as { lockOpts?: (t: TableRegistry, s: string, o: Record<string, string>) => Record<string, string> }).lockOpts;
    const locked = lock ? lock(tables, seedPath, opts) : undefined;
    // The canonical path IS the composite seed: determinism flows from the
    // frozen path; the composite's internal hashing freezes with genVersion.
    return { metaId: meta.id, blocks: build(tables, seedPath, opts), locked };
  }

  // Roll a realm-scale government from the government bundle (the settlement
  // composite only rolls a town-scale office; a crown gets the full constitution).
  // Mirrors the Vessia bake's rollGovernment. Used by "Generate a kingdom".
  async function rollRealmGov(seed: string): Promise<RealmGov> {
    const load = compositeRegistries['../generators/registries/government.json'];
    if (!load) return { name: 'a local lordship', brief: '', detail: '' };
    const registry = await load();
    const tables: TableRegistry = new Map(Object.entries(registry));
    const c = makeComposer(tables, seed);
    const full = c.text('{table:gm/government/government}');
    const name = full.split(/[—–-]/)[0]!.trim();
    const lead = full.indexOf('Leadership:');
    const brief = full.length > 700 ? full.slice(0, lead > 0 ? lead : 700).trim() : full;
    const detail = lead >= 0 ? full.slice(lead).trim() : '';
    return { name, brief, detail };
  }

  // Recover a composite's LOCKED options (batch 93) — the dimensions that must
  // survive a reroll, like a shop's merchant type. Resolved from the entity's
  // BASE seed (unchanged by rerolls), so an existing shop recovers its original
  // type. Persisted onto e.gen.opts the first time, then reused. Composites
  // without a lockOpts export have nothing to lock (returns {}).
  const lockCache = new Map<string, Record<string, string>>();
  async function lockedOptsFor(e: EntityRecord): Promise<Record<string, string>> {
    const tool = toolOfGen(e);
    if (!tool || !e.gen) return {};
    if (e.gen.opts) return e.gen.opts;
    const key = tool + '|' + e.gen.seed;
    if (lockCache.has(key)) return lockCache.get(key)!;
    const loadModule = compositeModules[`../composites/${tool}.ts`];
    const loadRegistry = compositeRegistries[`../generators/registries/${tool}.json`];
    if (!loadModule || !loadRegistry) return {};
    const [mod, registry] = await Promise.all([loadModule(), loadRegistry()]);
    const lock = (mod as { lockOpts?: (t: TableRegistry, s: string, o: Record<string, string>) => Record<string, string> }).lockOpts;
    if (!lock) return {};
    const tables: TableRegistry = new Map(Object.entries(registry));
    const base: Record<string, string> = {};
    for (const o of mod.meta.options) base[o.id] = o.default;
    const locked = lock(tables, e.gen.seed, base);
    lockCache.set(key, locked);
    e.gen.opts = locked; // persist so it's stable and cheap next time
    return locked;
  }

  // ---------- ancestor context (owner, batch 20) ----------
  // Generation inside the world knows where it is: the law of the land flows
  // down from the first ancestor that declares a government, and the ground
  // underfoot comes from the nearest anchored ancestor's terrain.
  function lawOfTheLand(parentId: string | undefined): string {
    let guard = 0;
    for (let id = parentId; id && guard++ < 64; ) {
      const p = E()[id];
      if (!p) break;
      const gov = p.fields?.government;
      if (typeof gov === 'string' && gov.trim()) return gov.trim();
      id = p.parentId;
    }
    return '';
  }
  function biomeAtXY(x: number, y: number): string {
    const plane = ((WORLD?.planes ?? []) as Array<{ id?: string; terrain?: Record<string, unknown> }>).find((p) => p.id === 'p_surface');
    const t = plane?.terrain;
    if (!WORLD || !t) return '';
    return biomeAt({ seed: WORLD.seed, ...t } as TerrainCfg, x, y, 6);
  }
  function biomeOfEntity(id: string | undefined): string {
    let guard = 0;
    for (let cur = id; cur && guard++ < 64; ) {
      const a = anchorOf(cur);
      if (a) return biomeAtXY(a.x, a.y);
      cur = E()[cur]?.parentId;
    }
    return '';
  }
  /** Fill a settlement's blank DETAILS from what the world knows (queue #37).
   *  Deterministic per entity+field (seed-derived rolls); writes once and
   *  saves only when something was actually blank. */
  function fillSettlementFields(e: EntityRecord): void {
    const f = (e.fields ??= {}) as Record<string, unknown>;
    const roll = (key: string): number => h32(`${WORLD!.seed}/${e.id}/f:${key}`, 37) / 4294967296;
    // POPULATION outranks the tags for sizing: the bake tags 'city' only at
    // 500k, so a 403k metropolis is tagged 'town' and would derive a bailiff
    // and a market square. 25k is where the composite's own scale calls a
    // place a city (regional city threshold in settlements.ts typeOf).
    const pop = Number(f.population ?? 0);
    const size = pop >= 25_000 ? 'city' : pop >= 1_000 ? 'town' : pop > 0 ? 'village'
      : ((e.tags ?? []).find((t) => ['hamlet', 'village', 'town', 'city'].includes(t)) ?? 'town');
    const biome = biomeOfEntity(e.id) || 'grass';
    let dirty = false;

    // is this place some crown's seat? (drives both the type and the ruler)
    const crown = Object.values(E()).find((r) => {
      if (r.kind !== 'region' || r.deleted) return false;
      const seat = r.fields?.seat;
      return typeof seat === 'object' && seat !== null && 'ref' in seat && (seat as { ref: string }).ref === e.id;
    });

    if (f.settlementType === undefined) {
      const t = deriveSettleType({ biome, size, roll: roll('settlementType') });
      // "royal seat" is a FACT of the political web, not a dice face: only a
      // city that actually seats a crown may derive it
      f.settlementType = t === 'royal seat' && !crown && !(e.tags ?? []).includes('capital') ? 'regional city' : t;
      dirty = true;
    }
    const type = (SETTLE_TYPES.includes(String(f.settlementType) as SettleType)
      ? String(f.settlementType) : deriveSettleType({ biome, size, roll: roll('settlementType') })) as SettleType;

    if (f.trade === undefined) {
      f.trade = profileFor(type, biome).trade;
      dirty = true;
    }
    if (f.government === undefined) {
      f.government = localGovernment({ size, realmGov: lawOfTheLand(e.parentId), roll: roll('government') });
      dirty = true;
    }
    if (f.defenses === undefined) {
      f.defenses = localDefenses({ size, roll: roll('defenses') });
      dirty = true;
    }
    if (f.ruler === undefined && crown) {
      // the political web knows who holds power in a realm's SEAT — copy the
      // crown's ruler reference; anywhere else stays open for the GM
      const ruler = crown.fields?.ruler;
      if (typeof ruler === 'object' && ruler !== null && 'ref' in ruler) {
        f.ruler = { ref: (ruler as { ref: string }).ref };
        dirty = true;
      }
    }
    if (dirty) { touchEntity(e); save(); }
  }

  /** context passed into a composite run under a parent page. seedPath keeps
   *  the tier-aware size spread deterministic (preview === keep). */
  function ctxFor(tool: string, parentId: string | undefined, seedPath?: string): Record<string, string> {
    if (tool === 'settlement') {
      // biome grounds the node type so a suggested settlement's economy fits
      // the land it sits on (owner, batch 76)
      const biome = biomeOfEntity(parentId);
      const ctx: Record<string, string> = { government: lawOfTheLand(parentId) };
      if (biome) ctx.biome = biome;
      if (seedPath) {
        // honest Zipf spread instead of every suggestion being a town
        const sizes = ['village', 'village', 'village', 'village', 'village', 'town', 'town', 'town', 'town', 'city'];
        ctx.size = sizes[h32(seedPath, 71) % sizes.length]!;
      }
      return ctx;
    }
    if (tool === 'landmark') return { biome: biomeOfEntity(parentId) };
    // encounters and hoards rolled inside a world size to the party (batch 94)
    if (tool === 'encounter') { const p = partyComp(); return { size: String(p.size), level: String(p.level) }; }
    if (tool === 'hoard') return { tier: hoardTierForLevel(partyComp().level) };
    return {};
  }
  /** The party this world is sized for (batch 94); sensible defaults. */
  function partyComp(): { level: number; size: number } {
    const p = WORLD?.settings?.party ?? {};
    return { level: Math.min(20, Math.max(1, p.level ?? 3)), size: Math.min(8, Math.max(1, p.size ?? 4)) };
  }
  /** Map a party level onto the hoard's DMG challenge tier. */
  function hoardTierForLevel(level: number): string {
    return level <= 4 ? '0-4' : level <= 10 ? '5-10' : level <= 16 ? '11-16' : '17+';
  }

  async function hydrateGhosts(e: EntityRecord, kind: KindDef): Promise<void> {
    const holder = $('ghosts');
    if (!holder || !WORLD) return;
    const slots = ghostSlots(kind);
    if (!slots.length) return;
    const dismissed = new Set(e.ghostState?.dismissed ?? []);
    const cards: string[] = [];
    const live: Array<GhostSlot & { path: string; gid: string; name: string; metaId: string }> = [];
    for (const s of slots) {
      if (dismissed.has(s.slotKey)) continue;
      const reroll = e.ghostState?.rerolls?.[s.slotKey] ?? 0;
      const path = childPath(WORLD.seed, e.id, s.kind, s.slot, reroll);
      const gid = ghostId(path);
      if (E()[gid]) continue; // already materialized — it lives in the tree now
      const run = await runComposite(s.tool, path, ctxFor(s.tool, e.id, path));
      if (!run) continue;
      const preview = blocksToEntity(run.metaId, path, run.blocks, s.label);
      live.push({ ...s, path, gid, name: preview.name, metaId: run.metaId });
      cards.push(`<div class="ghostcard" data-gslot="${s.slotKey}">
        <span class="gname">${byKind[s.kind]?.icon ?? ''} ${esc(preview.name)}</span>
        <span class="glabel">${esc(s.label)} — unwritten</span>
        <span class="gtools">
          <button class="wd-btn" data-gkeep="${s.slotKey}">Keep</button>
          <button class="wd-btn" data-greroll="${s.slotKey}">Reroll</button>
          <button class="wd-btn" data-gdismiss="${s.slotKey}">Dismiss</button>
        </span></div>`);
    }
    if (!cards.length) return;
    holder.innerHTML = `<div class="ghosthead">Unwritten — the world suggests:</div>` + cards.join('');
    holder.querySelectorAll<HTMLButtonElement>('[data-gkeep]').forEach((btn) =>
      btn.addEventListener('click', async () => {
        const g = live.find((x) => x.slotKey === btn.dataset.gkeep);
        if (!g || !WORLD) return;
        const run = await runComposite(g.tool, g.path, ctxFor(g.tool, e.id, g.path));
        if (!run) return;
        const ne = blocksToEntity(run.metaId, g.path, run.blocks, g.label, e.id);
        ne.id = g.gid; // materialization keeps the ghost's derived id (CONTRACTS §2)
        if (run.locked && Object.keys(run.locked).length && ne.gen) ne.gen.opts = run.locked;
        WORLD.entities[ne.id] = ne;
        save();
        navigate(ne.id);
      }));
    holder.querySelectorAll<HTMLButtonElement>('[data-greroll]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const key = btn.dataset.greroll as string;
        e.ghostState ??= {};
        e.ghostState.rerolls ??= {};
        e.ghostState.rerolls[key] = (e.ghostState.rerolls[key] ?? 0) + 1;
        touchEntity(e); save(); rerender();
      }));
    holder.querySelectorAll<HTMLButtonElement>('[data-gdismiss]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const key = btn.dataset.gdismiss as string;
        e.ghostState ??= {};
        e.ghostState.dismissed ??= [];
        if (!e.ghostState.dismissed.includes(key)) e.ghostState.dismissed.push(key);
        touchEntity(e); save(); rerender();
      }));
  }

  // ---------- wiring ----------
  function wirePage(e: EntityRecord): void {
    $('showMapBtn')?.addEventListener('click', () => setMapMode(true)); // remount focuses `current`
    $('siteBtn')?.addEventListener('click', () => enterInterior(e.id));
    $('placeMapBtn')?.addEventListener('click', () => {
      // "writing in a new item does not save it to the map" (owner, batch 32):
      // any unpinned page can now be placed — open the map, tap a hex
      if (!WORLD) return;
      setMapMode(true);
      map?.pickHex((x, y, tier, biome) => {
        if (!WORLD) return;
        const plane = surfacePlane(WORLD, true);
        const onWater = biome === 'water' || biome === 'deep';
        if (onWater) (e.tags ??= []).push('waterborne');
        (plane!.anchors ??= []).push({ entityId: e.id, x: Math.round(x), y: Math.round(y),
          tier: tier as 'world' | 'region' | 'locale', ...(onWater ? { icon: 'waterborne' } : {}) });
        save();
        navigate(e.id);
      });
    });
    const pbox = $('portraitBox');
    if (pbox && e.kind === 'person') {
      const race = knownRace(e.fields?.race) ?? RACES[h32(e.id, 7) % RACES.length]!;
      const sexLock = knownSex(e.fields?.gender ?? e.fields?.sex);
      const stored = typeof e.fields?.portrait === 'string' ? parseRecipe(e.fields.portrait) : null;
      const recipe = stored ?? defaultRecipe(e.gen?.seed ?? e.id, race, sexLock);
      if (sexLock) recipe.sex = sexLock; // the gender field always wins
      if (knownRace(e.fields?.race)) recipe.race = knownRace(e.fields?.race)!; // so does the race field
      pbox.innerHTML = buildPortraitSVG(recipe, e.id);
      document.querySelectorAll<HTMLButtonElement>('[data-portrait-layer]').forEach((btn) =>
        btn.addEventListener('click', () => {
          const key = btn.dataset.portraitLayer;
          const next = key === 'look' ? rerollLook(recipe) : rerollLayer(recipe, key as Parameters<typeof rerollLayer>[1]);
          e.fields ??= {};
          e.fields.portrait = serializeRecipe(next);
          touchEntity(e); save(); rerender();
        }));
    }

    // Uploaded photo (Codex B2): resolve the object URL from the asset store —
    // null means the bytes never reached this device (a synced world whose
    // images stayed local), so say so instead of a broken image.
    const photoImg = $('entityPhoto') as HTMLImageElement | null;
    const photoId = e.fields?.photo;
    if (photoImg && typeof photoId === 'string') {
      void import('../engine/assetStore')
        .then(({ getAssetUrl }) => getAssetUrl(photoId))
        .then((url) => {
          if (url) photoImg.src = url;
          else photoImg.replaceWith(Object.assign(document.createElement('div'),
            { className: 'ghostnote', textContent: '⚠ photo not on this device' }));
        });
    }
    $('photoInput')?.addEventListener('change', async (ev) => {
      const file = (ev.target as HTMLInputElement).files?.[0];
      if (!file) return;
      const { putAssetFromFile } = await import('../engine/assetStore');
      const meta = await putAssetFromFile(file);
      e.fields ??= {};
      e.fields.photo = meta.id;
      touchEntity(e); save(); rerender();
    });
    $('photoRemove')?.addEventListener('click', () => {
      if (e.fields) delete e.fields.photo;
      touchEntity(e); save(); rerender();
    });

    // Relations editor (Codex B3): add / annotate / remove a typed connection.
    $('relAdd')?.addEventListener('click', () => {
      const type = ($('relType') as HTMLInputElement | null)?.value.trim();
      const target = ($('relTarget') as HTMLSelectElement | null)?.value;
      const note = ($('relNote') as HTMLInputElement | null)?.value.trim();
      if (!type || !target) { alert('Pick a relationship and who or where it connects to.'); return; }
      (e.relations ??= []).push({ type, target, ...(note ? { note } : {}) });
      touchEntity(e); save(); rerender();
    });
    document.querySelectorAll<HTMLButtonElement>('[data-rel-del]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const i = Number(btn.dataset.relDel);
        if (e.relations && i >= 0 && i < e.relations.length) { e.relations.splice(i, 1); touchEntity(e); save(); rerender(); }
      }));
    document.querySelectorAll<HTMLButtonElement>('[data-rel-note]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const r = e.relations?.[Number(btn.dataset.relNote)];
        if (!r) return;
        const note = prompt('Note for this connection (why / how / when):', r.note ?? '');
        if (note === null) return;
        if (note.trim()) r.note = note.trim(); else delete r.note;
        touchEntity(e); save(); rerender();
      }));
    $('renameBtn')?.addEventListener('click', () => {
      const span = $('nameSpan');
      if (!span) return;
      span.innerHTML = `<input id="nameInput" value="${esc(e.name)}">`;
      const inp = $('nameInput') as HTMLInputElement;
      inp.focus(); inp.select();
      const commit = () => {
        const v = inp.value.trim();
        if (v && v !== e.name) {
          e.name = v;
          markOverride(e, 'name');
          touchEntity(e); save();
        }
        rerender();
      };
      inp.addEventListener('keydown', (ev) => { if (ev.key === 'Enter') commit(); if (ev.key === 'Escape') rerender(); });
      inp.addEventListener('blur', commit);
    });
    document.querySelectorAll<HTMLButtonElement>('[data-stamp]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const cal = calOf();
        if (!cal || !WORLD) return;
        const key = btn.dataset.stamp!;
        e.fields ??= {};
        e.fields[key] = fmtWorldDate(cal.day);
        (e.fields as Record<string, unknown>)[key + 'Day'] = cal.day;
        touchEntity(e); save(); rerender();
      }));
    document.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[data-fkey]').forEach((ctl) => {
      ctl.addEventListener('change', () => {
        const key = ctl.dataset.fkey as string, type = ctl.dataset.ftype;
        e.fields ??= {};
        const val = ctl.value;
        if (type === 'entityRef') { if (val) e.fields[key] = { ref: val }; else delete e.fields[key]; }
        else if (type === 'number') { if (val === '') delete e.fields[key]; else e.fields[key] = Number(val); }
        else if (type === 'date') {
          // Keep the machine-readable day in sync with the typed text, or the
          // timeline never sees a hand-entered date (only the 📅 stamp wrote
          // `${key}Day` before). An unparseable phrase clears the stale day.
          const f = e.fields as Record<string, unknown>;
          if (val) {
            e.fields[key] = { date: val };
            const d = parseWorldDate(val);
            if (d != null) f[key + 'Day'] = d; else delete f[key + 'Day'];
          } else { delete e.fields[key]; delete f[key + 'Day']; }
        }
        else { if (val.trim() === '') delete e.fields[key]; else e.fields[key] = val; }
        touchEntity(e); save();
        if (type === 'entityRef') rerender();
      });
    });
    $('addFieldBtn')?.addEventListener('click', () => {
      const key = prompt('Field name (lowercase-first, letters/numbers — e.g. "banner"):');
      if (!key) return;
      if (!/^[a-z][a-zA-Z0-9]*$/.test(key)) { alert('Use a lowercase-first alphanumeric key.'); return; }
      e.fields ??= {}; e.fields[key] ??= ''; touchEntity(e); save(); rerender();
    });
    $('addParaBtn')?.addEventListener('click', () => {
      e.body ??= [];
      const b = { type: 'paragraph', id: 'b_' + rid('', 8), text: '' };
      e.body.push(b); editingBlock = b.id; touchEntity(e); save(); rerender();
    });
    document.querySelectorAll<HTMLButtonElement>('[data-edit]').forEach((btn) =>
      btn.addEventListener('click', () => { editingBlock = btn.dataset.edit ?? null; rerender(); }));
    document.querySelectorAll<HTMLButtonElement>('[data-delblock]').forEach((btn) =>
      btn.addEventListener('click', () => {
        e.body = (e.body ?? []).filter((b) => b.id !== btn.dataset.delblock);
        e.secretBlocks = (e.secretBlocks ?? []).filter((id) => id !== btn.dataset.delblock);
        touchEntity(e); save(); rerender();
      }));
    document.querySelectorAll<HTMLButtonElement>('[data-secret]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const id = btn.dataset.secret as string;
        e.secretBlocks ??= [];
        e.secretBlocks = e.secretBlocks.includes(id) ? e.secretBlocks.filter((x) => x !== id) : [...e.secretBlocks, id];
        touchEntity(e); save(); rerender();
      }));
    const ta = $('blockTa') as HTMLTextAreaElement | null;
    if (ta) {
      // @ mention autocomplete: type @nam… and pick; inserts {@e id|Name}
      const drop = $('acDrop');
      let acStart = -1;
      let acItems: EntityRecord[] = [];
      let acIndex = 0;
      const acHide = () => { if (drop) drop.hidden = true; acStart = -1; };
      const acInsert = (ent: EntityRecord) => {
        if (acStart < 0) return;
        const pos = ta.selectionStart ?? ta.value.length;
        const token = `{@e ${ent.id}|${ent.name}}`;
        ta.value = ta.value.slice(0, acStart) + token + ta.value.slice(pos);
        const caret = acStart + token.length;
        ta.setSelectionRange(caret, caret);
        acHide();
        ta.focus();
      };
      const acRender = () => {
        if (!drop) return;
        drop.innerHTML = acItems
          .map((x, i) => `<button type="button" class="acitem${i === acIndex ? ' sel' : ''}" data-ac="${i}">${icon(x)} ${esc(x.name)} <span class="ackind">${x.kind}</span></button>`)
          .join('');
        drop.hidden = !acItems.length;
        drop.querySelectorAll<HTMLButtonElement>('[data-ac]').forEach((btn) =>
          btn.addEventListener('mousedown', (ev) => { ev.preventDefault(); acInsert(acItems[Number(btn.dataset.ac)]); }));
      };
      const acUpdate = () => {
        const pos = ta.selectionStart ?? 0;
        const before = ta.value.slice(0, pos);
        const m = /(^|[\s(])@([^@{}\n]{0,30})$/.exec(before);
        if (!m) { acHide(); return; }
        const q = (m[2] ?? '').toLowerCase();
        acStart = pos - (m[2]?.length ?? 0) - 1;
        acItems = Object.values(E())
          .filter((x) => !x.deleted && x.id !== e.id)
          .filter((x) => !q || x.name.toLowerCase().includes(q) || (x.aliases ?? []).some((a) => a.toLowerCase().includes(q)))
          .slice(0, 8);
        acIndex = 0;
        acRender();
      };
      ta.addEventListener('input', acUpdate);
      ta.addEventListener('keydown', (ev) => {
        if (!drop || drop.hidden) return;
        if (ev.key === 'ArrowDown') { ev.preventDefault(); acIndex = Math.min(acIndex + 1, acItems.length - 1); acRender(); }
        else if (ev.key === 'ArrowUp') { ev.preventDefault(); acIndex = Math.max(acIndex - 1, 0); acRender(); }
        else if (ev.key === 'Enter' || ev.key === 'Tab') { ev.preventDefault(); acInsert(acItems[acIndex]); }
        else if (ev.key === 'Escape') acHide();
      });
      ta.addEventListener('blur', () => setTimeout(acHide, 150));
      ($('linkSel') as HTMLSelectElement | null)?.addEventListener('change', (ev) => {
        const sel = ev.target as HTMLSelectElement;
        const id = sel.value;
        if (!id) return;
        const ins = `{@e ${id}|${E()[id].name}}`;
        const s = ta.selectionStart ?? ta.value.length;
        ta.value = ta.value.slice(0, s) + ins + ta.value.slice(ta.selectionEnd ?? s);
        sel.value = ''; ta.focus();
      });
      $('blockSave')?.addEventListener('click', () => {
        const b = (e.body ?? []).find((b) => b.id === editingBlock);
        if (b) {
          b.text = ta.value;
          markOverride(e, `block:${b.id}`); // hand-edited parts survive regeneration
          touchEntity(e); save();
        }
        editingBlock = null; rerender();
      });
      $('blockCancel')?.addEventListener('click', () => { editingBlock = null; rerender(); });
      ta.focus();
    }
    document.querySelectorAll<HTMLButtonElement>('[data-addkind]').forEach((btn) =>
      btn.addEventListener('click', () => {
        addingKind = btn.dataset.addkind ?? null;
        rerender();
        setTimeout(() => ($('newName') as HTMLInputElement | null)?.focus(), 0);
      }));
    $('cancelAdd')?.addEventListener('click', () => { addingKind = null; rerender(); });
    const create = () => {
      const name = ($('newName') as HTMLInputElement | null)?.value.trim();
      if (!name || !addingKind || !WORLD) return;
      const ne = newEntity(addingKind, name, e.id);
      WORLD.entities[ne.id] = ne;
      save();
      addingKind = null;
      navigate(ne.id);
    };
    $('createBtn')?.addEventListener('click', create);
    ($('newName') as HTMLInputElement | null)?.addEventListener('keydown', (ev) => { if (ev.key === 'Enter') create(); });
    $('genCreateBtn')?.addEventListener('click', async () => {
      if (!addingKind || !WORLD) return;
      const tool = toolForKind(addingKind);
      if (!tool) return;
      const path = `${WORLD.seed}/${e.id}/adhoc:${addingKind}:${rid('', 6)}`;
      const run = await runComposite(tool, path, ctxFor(tool, e.id, path));
      if (!run) return;
      const typed = ($('newName') as HTMLInputElement | null)?.value.trim();
      const ne = blocksToEntity(run.metaId, path, run.blocks, byKind[addingKind]?.label ?? addingKind, e.id);
      ne.kind = addingKind; // the chosen kind wins over the tool's default mapping
      if (typed) { ne.name = typed; markOverride(ne, 'name'); }
      if (run.locked && Object.keys(run.locked).length && ne.gen) ne.gen.opts = run.locked;
      WORLD.entities[ne.id] = ne;
      save();
      addingKind = null;
      navigate(ne.id);
    });
    $('webChainBtn')?.addEventListener('click', async () => {
      if (!WORLD) return;
      const st = $('webStatus');
      if (st) st.textContent = 'weaving a chain…';
      const res = await buildQuestChain(WORLD, runComposite, e);
      if (!res) { if (st) st.textContent = 'failed — try again'; return; }
      save();
      if (st) st.textContent = `✓ ${res.created} pages${res.reusedPatron ? ' — a local was recruited as patron' : ''}${res.wide ? ' — this one crosses regions' : ''}`;
      navigate(res.rootId);
    });
    $('webLifeBtn')?.addEventListener('click', async () => {
      if (!WORLD) return;
      const st = $('webStatus');
      if (st) st.textContent = 'stirring local life…';
      const res = await buildLifeWeb(WORLD, runComposite, e);
      if (!res) { if (st) st.textContent = 'failed — try again'; return; }
      save();
      navigate(res.rootId);
    });
    $('webKinBtn')?.addEventListener('click', async () => {
      if (!WORLD) return;
      const st = $('webStatus');
      if (st) st.textContent = 'tracing the family line…';
      const res = await buildKinWeb(WORLD, runComposite, e);
      if (!res) { if (st) st.textContent = 'failed — try again'; return; }
      save();
      navigate(res.rootId);
    });

    // #35 (owner D13): roll a realm's entry as a terse gazetteer — facts
    // first, almanac voice. DETERMINISTIC off the entity's seed path
    // (CONTRACTS §1): the same realm compiles the same entry, today and
    // after a reload; known fields (government, ruler, seat) are read, not
    // re-rolled, and a rolled government is promoted back into fields so
    // the page and the map speak one law (§6.7).
    $('rollEntryBtn')?.addEventListener('click', async () => {
      if (!WORLD) return;
      const st = $('entryStatus');
      if (st) st.textContent = 'compiling the gazetteer…';
      const S = `${WORLD.seed}/${e.id}/entry`;
      const load = compositeRegistries['../generators/registries/realm.json'];
      if (!load) { if (st) st.textContent = 'realm tables missing'; return; }
      const registry = await load();
      const tables: TableRegistry = new Map(Object.entries(registry));
      const roll = (key: string) => makeComposer(tables, `${S}:${key}`).text(`{table:gm/realm/${key}}`).trim();
      const F = e.fields ?? (e.fields = {});
      const refEnt = (v: unknown) => {
        const r = (v as { ref?: string } | undefined)?.ref;
        const t = r ? E()[r] : undefined;
        return t && !t.deleted ? t : undefined;
      };
      let govLine: string;
      const knownGov = typeof F.government === 'string' ? F.government.trim() : '';
      if (knownGov) {
        govLine = knownGov.endsWith('.') ? knownGov : knownGov + '.';
      } else {
        const g = await rollRealmGov(`${S}:gov`);
        govLine = g.brief || g.name;
        F.government = g.name;
      }
      const ruler = refEnt(F.ruler);
      if (ruler) govLine += ` Presently held by ${ruler.name}.`;
      const blocks: Array<{ type: 'paragraph'; id: string; label?: string; text: string }> = [];
      const push = (key: string, label: string, text: string) => {
        if (text) blocks.push({ type: 'paragraph', id: `b_en_${key}`, label, text });
      };
      push('gov', 'Government', govLine);
      const seat = refEnt(F.seat);
      if (seat) {
        const pop = Number(seat.fields?.population ?? 0);
        push('seat', 'Seat', `${seat.name}${pop ? ` (pop. ~${pop.toLocaleString()})` : ''}.`);
      }
      push('climate', 'Climate & land', roll('climate'));
      push('culture', 'People & custom', roll('culture'));
      push('trade', 'Trade', roll('trade'));
      push('forces', 'Forces', roll('forces'));
      push('stance', 'Disposition', roll('stance'));
      push('peril', 'Peril', roll('peril'));
      push('tension', 'Current tensions', roll('tension'));
      e.body = blocks;
      touchEntity(e);
      save();
      rerender();
    });

    // city-level landmark picker (batch 80): roll N options for "in town" or
    // "nearby", show them as chips, and file the picked one under this place —
    // dropped on the map beside the settlement when it has a pin.
    const rollLandmarks = async (setting: 'urban' | 'wild'): Promise<void> => {
      if (!WORLD) return;
      const st = $('lmStatus'); const box = $('lmOptions');
      if (!box) return;
      if (st) st.textContent = 'rolling options…';
      const opts: Record<string, string> = setting === 'urban' ? { setting: 'urban' } : { setting: 'wild', biome: biomeOfEntity(e.id) };
      const runs: Array<{ seed: string; metaId: string; blocks: Block[]; name: string; locked?: Record<string, string> }> = [];
      for (let i = 0; i < 4; i++) {
        const seed = `${WORLD.seed}/${e.id}/lm:${setting}:${rid('', 6)}`;
        const run = await runComposite('landmark', seed, opts);
        if (!run) continue;
        const sb = run.blocks.find((b) => (b as { type?: string }).type === 'statblock') as { name?: string } | undefined;
        runs.push({ seed, metaId: run.metaId, blocks: run.blocks, name: sb?.name ?? 'Landmark', locked: run.locked });
      }
      if (!runs.length) { if (st) st.textContent = 'failed — try again'; return; }
      if (st) st.textContent = 'pick one to add it here, or roll again:';
      const glyph = setting === 'urban' ? '🏛' : '🌄';
      box.innerHTML = runs.map((r, i) => `<button class="wd-btn" data-lm="${i}" title="add this landmark">${glyph} ${esc(r.name)}</button>`).join('')
        + `<button class="wd-btn" data-lm="more">🎲 more</button>`;
      box.querySelectorAll<HTMLButtonElement>('[data-lm]').forEach((btn) => btn.addEventListener('click', () => {
        if (btn.dataset.lm === 'more') { void rollLandmarks(setting); return; }
        const r = runs[Number(btn.dataset.lm)];
        if (!r || !WORLD) return;
        const ne = blocksToEntity(r.metaId, r.seed, r.blocks, r.name, e.id);
        ne.kind = 'landmark';
        ne.tags = [setting === 'urban' ? 'in-town' : 'nearby'];
        if (r.locked && Object.keys(r.locked).length && ne.gen) ne.gen.opts = r.locked;
        WORLD.entities[ne.id] = ne;
        // drop it near the settlement's pin, if it has one
        const sa = anchorOf(e.id);
        if (sa) {
          const plane = surfacePlane(WORLD, true);
          let x = sa.x, y = sa.y;
          if (setting === 'wild') { const ang = Math.random() * Math.PI * 2, d = (15 + Math.random() * 30) * 5280; x = Math.round(sa.x + Math.cos(ang) * d); y = Math.round(sa.y + Math.sin(ang) * d); }
          else { x = Math.round(sa.x + (Math.random() - 0.5) * 4000); y = Math.round(sa.y + (Math.random() - 0.5) * 4000); }
          (plane!.anchors ??= []).push({ entityId: ne.id, x, y, tier: 'locale', icon: 'landmark' });
        }
        save();
        navigate(ne.id);
      }));
    };
    $('lmUrbanBtn')?.addEventListener('click', () => void rollLandmarks('urban'));
    $('lmNearBtn')?.addEventListener('click', () => void rollLandmarks('wild'));
    $('deleteBtn')?.addEventListener('click', () => {
      if (!confirm(`Delete “${e.name}”? (It becomes recoverable; children are kept.)`)) return;
      e.deleted = now(); touchEntity(e); save(); rerender();
    });
    $('restoreBtn')?.addEventListener('click', () => { delete e.deleted; touchEntity(e); save(); rerender(); });

    // reroll one part: rebuild from a fresh seed and take only this block's
    // counterpart (composite output structure is stable per genVersion)
    document.querySelectorAll<HTMLButtonElement>('[data-rblock]').forEach((btn) =>
      btn.addEventListener('click', async () => {
        const tool = toolOfGen(e);
        if (!tool || !WORLD || !e.gen) return;
        const idx = (e.body ?? []).findIndex((b) => b.id === btn.dataset.rblock);
        if (idx < 0) return;
        const run = await runComposite(tool, `${e.gen.seed}/rb:${rid('', 6)}`, await lockedOptsFor(e));
        const fresh = run ? matchBlock(run.blocks, e.body!, idx) : undefined;
        if (!fresh) return;
        const keepId = e.body![idx].id;
        e.body![idx] = { ...structuredClone(fresh), id: keepId } as NonNullable<typeof e.body>[number];
        // a fresh roll is no longer a hand edit
        if (e.gen.overrides) e.gen.overrides = e.gen.overrides.filter((o) => o !== `block:${keepId}`);
        touchEntity(e); save(); rerender();
      }));
    // regenerate the whole page around hand-edited parts
    $('regenBtn')?.addEventListener('click', async () => {
      const tool = toolOfGen(e);
      if (!tool || !WORLD || !e.gen) return;
      const newSeed = `${WORLD.seed}/${e.id}/regen:${rid('', 6)}`;
      const run = await runComposite(tool, newSeed, await lockedOptsFor(e));
      if (!run) return;
      const overrides = new Set(e.gen.overrides ?? []);
      (e.body ?? []).forEach((b, idx) => {
        const fresh = matchBlock(run.blocks, e.body!, idx);
        if (!fresh || overrides.has(`block:${b.id}`)) return;
        e.body![idx] = { ...structuredClone(fresh), id: b.id } as NonNullable<typeof e.body>[number];
      });
      if (!overrides.has('name')) e.name = extractName(run.blocks, e.name);
      e.gen.seed = newSeed;
      touchEntity(e); save(); rerender();
    });
  }

  /** Find a body block's counterpart in a freshly built run: same type, n-th of
   *  that type. Raw body index misaligns as soon as any block was deleted —
   *  deleting block B of [A,B,C] made a reroll of C copy in B's fresh content. */
  function matchBlock<T extends { type: string }>(
    freshBlocks: T[], body: Array<{ type: string }>, idx: number,
  ): T | undefined {
    const b = body[idx];
    if (!b) return undefined;
    const nth = body.slice(0, idx).filter((x) => x.type === b.type).length;
    return freshBlocks.filter((x) => x.type === b.type)[nth];
  }

  // ---------- deep reroll: sections and single fields inside statblocks ----------
  interface SbSection { type: string; label?: string; pairs?: Array<{ key: string; value: string }>; [k: string]: unknown }
  interface SbBlock { type: 'statblock'; id: string; name?: string; meta?: string; sections?: SbSection[] }

  /** Find this section's counterpart in a freshly built statblock: same type +
   *  label when labeled, else the n-th section of that type. Composite output
   *  varies (optional sections), so retry a few seeds until one matches. */
  function matchSection(freshSections: SbSection[], sec: SbSection, nthOfType: number): SbSection | undefined {
    if (sec.label) return freshSections.find((s) => s.type === sec.type && s.label === sec.label);
    return freshSections.filter((s) => s.type === sec.type)[nthOfType];
  }

  async function freshStatblock(e: EntityRecord, tries = 5): Promise<SbBlock | null> {
    const tool = toolOfGen(e);
    if (!tool || !e.gen) return null;
    const locked = await lockedOptsFor(e);
    for (let i = 0; i < tries; i++) {
      const run = await runComposite(tool, `${e.gen.seed}/rf:${rid('', 6)}`, locked);
      const sb = run?.blocks.find((b) => b.type === 'statblock') as SbBlock | undefined;
      if (sb) return sb;
    }
    return null;
  }

  function renderStatblockRerollable(e: EntityRecord, block: unknown): HTMLElement {
    const b = block as SbBlock;
    const root = document.createElement('div');
    root.className = 'b b-statblock wd-sb';
    const head = document.createElement('div');
    head.innerHTML = `<span class="sbname">${esc(b.name ?? '')}</span>${b.meta ? ` <span class="sbmeta">${esc(b.meta)}</span>` : ''}`;
    root.appendChild(head);
    const typeCounts: Record<string, number> = {};
    (b.sections ?? []).forEach((sec, j) => {
      const nth = typeCounts[sec.type] ?? 0;
      typeCounts[sec.type] = nth + 1;
      const wrap = document.createElement('div');
      wrap.className = 'wd-sbsec';
      const applyFresh = async (apply: (fresh: SbSection) => void) => {
        const fsb = await freshStatblock(e);
        const fresh = fsb ? matchSection(fsb.sections ?? [], sec, nth) : undefined;
        if (!fresh) return;
        apply(structuredClone(fresh));
        touchEntity(e); save(); rerender();
      };
      if (sec.type === 'keyValue' && Array.isArray(sec.pairs)) {
        // per-field dice: reroll a single pair, matched by key
        for (const [k, pair] of sec.pairs.entries()) {
          const row = document.createElement('p');
          row.className = 'wd-sbpair';
          row.innerHTML = `<b class="block-label">${esc(pair.key)}.</b> <span>${esc(pair.value)}</span>`;
          const die = document.createElement('button');
          die.className = 'wd-btn wd-die';
          die.title = `reroll ${pair.key}`;
          die.textContent = '🎲';
          die.addEventListener('click', () => void applyFresh((fresh) => {
            const fp = (fresh.pairs ?? []).find((p) => p.key === pair.key) ?? (fresh.pairs ?? [])[k];
            if (fp) sec.pairs![k] = { key: pair.key, value: fp.value };
          }));
          row.appendChild(die);
          wrap.appendChild(row);
        }
      } else {
        wrap.appendChild(renderBlockStatic(sec as unknown as Parameters<typeof renderBlockStatic>[0]));
        const die = document.createElement('button');
        die.className = 'wd-btn wd-die wd-die-sec';
        die.title = `reroll ${sec.label ?? sec.type}`;
        die.textContent = '🎲';
        die.addEventListener('click', () => void applyFresh((fresh) => {
          b.sections![j] = fresh;
        }));
        wrap.appendChild(die);
      }
      root.appendChild(wrap);
    });
    return root;
  }

  function markOverride(e: EntityRecord, key: string): void {
    if (!e.gen) return;
    e.gen.overrides ??= [];
    if (!e.gen.overrides.includes(key)) e.gen.overrides.push(key);
  }
  function toolOfGen(e: EntityRecord): string | null {
    const m = /^composite:(?:gm|solo|writing)\/(.+)$/.exec(e.gen?.generator ?? '');
    const tool = m?.[1] ?? null;
    return tool && `../composites/${tool}.ts` in compositeModules ? tool : null;
  }
  function toolForKind(kindId: string): string | null {
    for (const g of byKind[kindId]?.generators ?? []) {
      if (typeof g.id === 'string' && g.id.startsWith('composite:')) {
        const tool = g.id.slice('composite:'.length);
        if (`../composites/${tool}.ts` in compositeModules) return tool;
      }
    }
    return null;
  }

  // ---------- the map (tree↔map merge, M1) ----------
  // The map lives BESIDE the tree: 🗺 Map swaps the page for the world map,
  // the tree stays. Clicking an anchored tree node while the map is open
  // pans to it; clicking a pin opens its page; "+ Add here" mints a page
  // anchored to that hex.
  let mapMode = false;
  let map: MapHandle | null = null;

  interface PlaneAnchor { entityId: string; x: number; y: number; tier: string; icon?: string; promoted?: boolean }
  interface PlaneRec {
    id: string; name: string; unit?: string; orientation?: string;
    terrain?: Record<string, unknown>;
    anchors?: PlaneAnchor[];
    routes?: Array<{ id: string; kind: string; pts: Array<[number, number]> }>;
    biomePaint?: Record<string, string>;
    claims?: Record<string, string[]>;
  }
  function surfacePlane(w: WorldDoc, create = false): PlaneRec | null {
    const planes = (w.planes ??= []) as PlaneRec[];
    if (!planes.length) {
      if (!create) return null;
      // Pinning the terrain dials at first map open keeps this world stable
      // even if the app's defaults change later (drift policy, CONTRACTS §5).
      planes.push({
        id: 'p_surface', name: 'The Surface', unit: 'ft', orientation: 'pointy',
        terrain: { landform: 'continents', continents: 3, waterPct: 55, climate: 'temperate' },
        anchors: [],
      });
    }
    return planes[0] ?? null;
  }
  const anchorOf = (id: string) =>
    WORLD ? (surfacePlane(WORLD)?.anchors ?? []).find((a) => a.entityId === id) : undefined;

  /** All anchors on this entity or anything filed under it. */
  function descendantAnchors(id: string): Array<{ x: number; y: number }> {
    const anchors = WORLD ? (surfacePlane(WORLD)?.anchors ?? []) : [];
    // Index by entity first: this walks every descendant, and a linear .find()
    // per node made a big realm (~1,400 children) cost ~1 s per page open.
    // First-match wins, matching the .find() this replaced.
    const byEntity = new Map<string, { x: number; y: number }>();
    for (const a of anchors) if (!byEntity.has(a.entityId)) byEntity.set(a.entityId, a);
    const out: Array<{ x: number; y: number }> = [];
    return withKidIdx(() => {
      const walk = (eid: string): void => {
        const a = byEntity.get(eid);
        if (a) out.push(a);
        for (const c of childrenOf(eid)) if (!c.deleted) walk(c.id);
      };
      walk(id);
      return out;
    });
  }
  const hasMapPresence = (id: string): boolean => !!anchorOf(id) || descendantAnchors(id).length > 0;

  /** Where does a page created at (x, y) file? Under the claiming crown's
   *  lands if a kingdom holds that hex, else under the continent, else root. */
  function politicalParentAt(x: number, y: number): string | undefined {
    if (!WORLD) return undefined;
    const plane = surfacePlane(WORLD);
    const claims = (plane as unknown as { claims?: Record<string, string[]> })?.claims ?? {};
    const circ = Number((plane?.terrain as Record<string, unknown> | undefined)?.circumFt ?? EARTH_CIRCUM_FT);
    // Same lattice as the creation-time filing above: the shared pointToHex —
    // the hand-rolled cube-round that used to live here is exactly the copy
    // hexgrid.ts's header warns will drift.
    const xn = ((x % circ) + circ) % circ;
    const [rq, rr] = pointToHex(CLAIM_HEX_FT.world, xn, y);
    const addr = claimAddr('world', rq, rr);
    for (const [owner, addrs] of Object.entries(claims)) {
      if (!addrs.includes(addr)) continue;
      const crown = E()[owner];
      if (!crown || crown.deleted) continue;
      // Browser-built claims are keyed by the region itself — take it directly.
      // Only the legacy faction-keyed form needs the name match, and two
      // same-named regions can misfile through it.
      if (crown.kind === 'region') return crown.id;
      const lands = Object.values(E()).find((e2) => e2.kind === 'region' && !e2.deleted && e2.name === crown.name);
      if (lands) return lands.id;
    }
    return Object.values(E()).find((e2) => (e2.tags ?? []).includes('continent') && !e2.deleted)?.id;
  }

  /** Jump the open map to an entity: its own pin at the logical tier zoom,
   *  or — for containers like regions — fit all its pinned descendants. */
  function focusOnMap(id: string): boolean {
    if (!map) return false;
    if (anchorOf(id)) { map.focusEntity(id); return true; }
    const pts = descendantAnchors(id);
    if (!pts.length) return false;
    const xs = pts.map((p) => p.x), ys = pts.map((p) => p.y);
    const cx = (Math.min(...xs) + Math.max(...xs)) / 2;
    const cy = (Math.min(...ys) + Math.max(...ys)) / 2;
    const span = Math.max(Math.max(...xs) - Math.min(...xs), Math.max(...ys) - Math.min(...ys), 200000);
    map.focusBounds(cx, cy, span * 1.6);
    return true;
  }

  // what "+ Add here" creates, by the tier of the tapped hex
  const TIER_KIND: Record<string, string> = { world: 'region', region: 'settlement', locale: 'landmark' };

  // ---------- the Add Here dialog (owner, batch 32) ----------
  // "a window of options to pick from including custom and icon picker; if a
  // type, can still pick icons and random generate from that type's tables"
  const ADD_KINDS: Array<{ id: string; label: string }> = [
    { id: 'settlement', label: 'Settlement' },
    { id: 'landmark', label: 'Landmark' },
    { id: 'building', label: 'Building' },
    { id: 'region', label: 'Region' },
    { id: 'person', label: 'Person' },
    { id: 'note', label: 'Custom…' },
  ];
  const ICON_CHOICES: Record<string, string[]> = {
    settlement: ['town', 'village', 'city', 'port', 'waterborne'],
    landmark: ['ruin', 'dungeon', 'lair', 'cave', 'formation', 'tower', 'temple', 'camp', 'mine', 'bridge'],
    building: ['tavern', 'shop', 'temple', 'tower'],
    region: [],
    person: [],
    note: Object.keys(ANCHOR_ICON),
  };
  async function addHereDialog(x: number, y: number, hexLabel: string, biome: string): Promise<void> {
    if (!WORLD) return;
    const tier = hexLabel.split(':')[0] ?? 'region';
    const onWater = biome === 'water' || biome === 'deep';
    const overlay = document.createElement('div');
    overlay.className = 'wd-adddlg';
    overlay.innerHTML = `<div class="wd-adddlg-card">
      <h3>New at ${esc(hexLabel)} · ${esc(biome)}${onWater ? ' <span class="wd-water">(open water — will be waterborne)</span>' : ''}</h3>
      <label>What is it? <select id="adKind">${ADD_KINDS.map((k) => `<option value="${k.id}">${k.label}</option>`).join('')}</select></label>
      <div class="wd-iconrow" id="adIcons"></div>
      <label class="wd-namerow">Name <input id="adName" placeholder="Name it — or roll one">
        <button class="wd-btn" id="adRoll" title="Random generate from this type's tables">🎲</button></label>
      <div class="wd-dlgbtns">
        <button class="wd-btn" id="adCreate"><b>Create</b></button>
        <button class="wd-btn" id="adCancel">Cancel</button>
      </div></div>`;
    document.body.appendChild(overlay);
    const $$ = (id: string) => overlay.querySelector<HTMLElement>('#' + id)!;
    const kindSel = $$('adKind') as unknown as HTMLSelectElement;
    const nameIn = $$('adName') as unknown as HTMLInputElement;
    kindSel.value = TIER_KIND[tier] ?? 'landmark';
    let pickedIcon = '';
    let rolled: { metaId: string; blocks: Block[]; path: string; locked?: Record<string, string> } | null = null;
    function renderIcons(): void {
      const kind = kindSel.value;
      const opts = ICON_CHOICES[kind] ?? [];
      pickedIcon = onWater && kind === 'settlement' ? 'waterborne' : opts[0] ?? '';
      $$('adIcons').innerHTML = opts.length
        ? opts.map((ic) => `<button type="button" class="wd-iconbtn${ic === pickedIcon ? ' on' : ''}" data-ic="${ic}" title="${ic}">${ANCHOR_ICON[ic] ?? '📍'}</button>`).join('')
        : `<span class="ghostnote">pin uses the ${esc(byKind[kind]?.label ?? kind)} glyph</span>`;
      $$('adIcons').querySelectorAll<HTMLButtonElement>('[data-ic]').forEach((b) =>
        b.addEventListener('click', () => {
          pickedIcon = b.dataset.ic!;
          $$('adIcons').querySelectorAll('[data-ic]').forEach((o) => o.classList.toggle('on', o === b));
        }));
      const hasTables = !!toolForKind(kind) || kind === 'region';
      ($$('adRoll') as unknown as HTMLButtonElement).style.display = hasTables ? '' : 'none';
      rolled = null;
    }
    kindSel.addEventListener('change', renderIcons);
    renderIcons();
    $$('adRoll').addEventListener('click', async () => {
      const kind = kindSel.value;
      if (kind === 'region') { // regions name themselves like the geography does
        nameIn.value = geoName('region', `${WORLD!.seed}/adhoc:georegion:${rid('', 6)}`);
        rolled = null;
        return;
      }
      const tool = toolForKind(kind);
      if (!tool) return;
      const path = `${WORLD!.seed}/adhoc:here:${kind}:${rid('', 6)}`;
      const run = await runComposite(tool, path, {
        ...ctxFor(tool, politicalParentAt(x, y), path),
        ...(tool === 'landmark' ? { biome } : {}),
      });
      if (!run) return;
      rolled = { ...run, path };
      nameIn.value = extractName(run.blocks, byKind[kind]?.label ?? kind);
    });
    const close = () => overlay.remove();
    $$('adCancel').addEventListener('click', close);
    overlay.addEventListener('click', (ev) => { if (ev.target === overlay) close(); });
    $$('adCreate').addEventListener('click', () => {
      if (!WORLD) return;
      const kind = kindSel.value;
      const name = nameIn.value.trim();
      if (!name) { nameIn.focus(); return; }
      const ne = rolled
        ? blocksToEntity(rolled.metaId, rolled.path, rolled.blocks, name)
        : newEntity(kind, name);
      ne.kind = kind;
      if (ne.name !== name) { ne.name = name; markOverride(ne, 'name'); }
      if (rolled?.locked && Object.keys(rolled.locked).length && ne.gen) ne.gen.opts = rolled.locked;
      if (onWater) (ne.tags ??= []).push('waterborne');
      ne.parentId = politicalParentAt(x, y); // file under the claiming crown
      WORLD.entities[ne.id] = ne;
      const plane = surfacePlane(WORLD, true);
      const icon = onWater ? 'waterborne' : pickedIcon;
      (plane!.anchors ??= []).push({ entityId: ne.id, x, y, tier, ...(icon ? { icon } : {}) });
      save();
      // a hand-placed settlement re-forges the road network to reach it (batch 73)
      if (kind === 'settlement') scheduleRoadRebuild();
      close();
      navigate(ne.id);
    });
    nameIn.focus();
  }

  /** A settlement plan should know the water it sits by (the Azgaar lesson:
   *  semantic facts, not geometry, are the handoff). Coast = open water
   *  within ~a footprint of the pin; river = a traced river route passing
   *  by. Derived at first descend and frozen into the generator opts. */
  function waterFactAt(entityId: string): { water?: 'river' | 'coast' } {
    const a = anchorOf(entityId);
    if (!a) return {};
    for (let i = 0; i < 8; i++) {
      const ang = (i / 8) * Math.PI * 2;
      const b = biomeAtXY(a.x + Math.cos(ang) * 4000, a.y + Math.sin(ang) * 4000);
      if (b === 'water' || b === 'deep') return { water: 'coast' };
    }
    const plane = surfacePlane(WORLD!);
    for (const r of plane?.routes ?? []) {
      if (r.kind !== 'river') continue;
      for (const [px, py] of r.pts) {
        if (Math.abs(px - a.x) < 5000 && Math.abs(py - a.y) < 5000) return { water: 'river' };
      }
    }
    return {};
  }

  /** The roads that actually reach this settlement on the world map become
   *  its city GATES (LAYERED-SPACES R1): you enter the city by the road you
   *  travelled. Each incident road route is sampled ~a city-radius out and
   *  its bearing quantized to a compass side; the set of sides is frozen
   *  into the generator opts at first descend, exactly like the water fact.
   *  Roadless pins / standalone cities return nothing → the overview keeps
   *  its random gates. */
  function roadApproachesAt(entityId: string): { gates?: string } {
    const a = anchorOf(entityId);
    if (!a) return {};
    const plane = surfacePlane(WORLD!);
    const NEAR = 9000, OUT = 14000; // ft: touches the pin; sampled a city-radius out
    const sides = new Set<string>();
    for (const r of plane?.routes ?? []) {
      if (r.kind !== 'road' && r.kind !== 'highway' && r.kind !== 'dirt') continue;
      const pts = r.pts;
      if (pts.length < 2) continue;
      let ni = -1, nd = Infinity;
      for (let i = 0; i < pts.length; i++) {
        const d = Math.hypot(pts[i]![0] - a.x, pts[i]![1] - a.y);
        if (d < nd) { nd = d; ni = i; }
      }
      if (nd > NEAR) continue; // this road doesn't reach the city
      const dir = (pts.length - 1 - ni) >= ni ? 1 : -1; // walk the longer way out
      let bx = pts[ni]![0], by = pts[ni]![1], acc = 0;
      for (let i = ni + dir; i >= 0 && i < pts.length; i += dir) {
        acc += Math.hypot(pts[i]![0] - bx, pts[i]![1] - by);
        bx = pts[i]![0]; by = pts[i]![1];
        if (acc >= OUT) break;
      }
      const dx = bx - a.x, dy = by - a.y; // plane: +x east, +y south
      if (Math.abs(dx) < 500 && Math.abs(dy) < 500) continue;
      sides.add(Math.abs(dx) >= Math.abs(dy) ? (dx > 0 ? 'e' : 'w') : (dy > 0 ? 's' : 'n'));
    }
    if (!sides.size) return {};
    return { gates: ['n', 'e', 's', 'w'].filter((s) => sides.has(s)).join('') };
  }

  /** Descend into an entity's interior: find-or-generate its site, save,
   *  open the editor overlay. Shared by the page 🏰 button and the map
   *  peek card's Enter. */
  function enterInterior(entityId: string, z = 0): void {
    if (!WORLD) return;
    const e = E()[entityId];
    if (!e) return;
    const kind = spaceKindFor(e, anchorOf(e.id)?.icon);
    if (!kind) return;
    const site = ensureGeneratedSite(WORLD, e, kind, anchorOf(e.id)?.icon, { ...waterFactAt(e.id), ...roadApproachesAt(e.id) });
    save();
    openSiteOverlay(site.id, z);
  }

  // Deep links (LAYERED-SPACES §3): the overlay's site (and floor) ride the
  // hash — `#e_…/map/s:<siteId>/fl:<z>` — so a ward three layers down is a
  // shareable address. Never fights the map-viewport hash (`#map=…`).
  function writeOverlayHash(siteId: string, z: number): void {
    if (!WORLD || location.hash.startsWith('#map=')) return;
    let root = siteById(WORLD, siteId);
    for (let i = 0; root?.parentSiteId && i < 8; i++) root = siteById(WORLD, root.parentSiteId);
    if (!root) return;
    const sub = root.id === siteId ? '' : `/s:${siteId}`;
    history.replaceState(null, '', `#${root.entityId}/map${sub}${z ? `/fl:${z}` : ''}`);
  }
  const ENTITY_HASH = /^(e_[^/]+)\/map(?:\/s:(s_[a-z0-9]+))?(?:\/fl:(-?\d+))?$/;

  // ---------- the interior map overlay (nested-spaces epic, slice 3) ----------
  // Descending into a landmark/building/settlement opens its site — the
  // square-grid battle map — full-screen over the wiki. The editor writes
  // straight into WORLD.planes[].sites and calls save(); "back" returns to
  // the page untouched.
  let siteHandle: SiteHandle | null = null;
  function closeSiteOverlay(): void {
    // drop the /map/s: suffix so the hash goes back to the plain page link
    const m = ENTITY_HASH.exec(location.hash.slice(1));
    if (m) history.replaceState(null, '', `#${m[1]}`);
    siteHandle?.destroy();
    siteHandle = null;
    $('siteOverlay')?.remove();
  }
  function openSiteOverlay(siteId: string, z = 0): void {
    if (!WORLD) return;
    let overlay = $('siteOverlay');
    if (!overlay) {
      overlay = document.createElement('div');
      overlay.id = 'siteOverlay';
      document.body.appendChild(overlay);
    }
    siteHandle?.destroy();
    const site = siteById(WORLD, siteId);
    const owner = site ? E()[site.entityId] : undefined;
    writeOverlayHash(siteId, z);
    siteHandle = mountSite(overlay, WORLD, siteId, {
      onDirty: () => save(),
      onExit: () => closeSiteOverlay(),
      onOpenSite: (sid) => openSiteOverlay(sid),
      initialZ: z,
      onNavigate: (sid, fz) => writeOverlayHash(sid, fz),
      // a pinned cell's page opens in the wiki (the prize leads somewhere)
      onSelectEntity: (id) => { closeSiteOverlay(); navigate(id); },
      // a keyed area's bound room text: `blockId` or `blockId#Section Label`
      resolveBlock: (ref) => {
        const [bid, section] = ref.split('#');
        const b = (owner?.body ?? []).find((x) => x.id === bid) as
          | { text?: unknown; sections?: Array<{ label?: unknown; text?: unknown; type?: string; pairs?: Array<{ key?: string; value?: string }> }> }
          | undefined;
        if (!b) return null;
        if (!section) return typeof b.text === 'string' ? b.text : null;
        // labelled sections match by label; B187+ rooms are label-less
        // keyValue sections referenced by their first pair key
        const s = (b.sections ?? []).find((x) => x.label === section || x.pairs?.[0]?.key === section);
        if (!s) return null;
        if (typeof s.text === 'string') return s.text;
        if (s.pairs) return s.pairs.map((p) => `${p.key}: ${p.value}`).join('\n');
        return null;
      },
      // 💰 on a cell: the hoard composite mints a real page (deterministic
      // from the cell's seed), childed under the site's owner
      rollHoard: async (seed) => {
        if (!WORLD) return null;
        const run = await runComposite('hoard', seed);
        if (!run) return null;
        const ne = blocksToEntity(run.metaId, seed, run.blocks, 'Treasure Hoard', owner?.id);
        WORLD.entities[ne.id] = ne;
        save();
        return ne;
      },
      playerView,
      title: owner?.name,
    });
  }

  function setMapMode(on: boolean): void {
    mapMode = on;
    $('page')?.classList.toggle('mapoff', on);
    $('mapHost')?.classList.toggle('on', on);
    const btn = $('mapBtn');
    if (btn) btn.textContent = on ? '📖 Pages' : '🗺 Map';
    if (on) void remountMap();
    else { map?.destroy(); map = null; }
  }
  async function remountMap(): Promise<void> {
    const host = $('mapHost');
    if (!host || !WORLD) return;
    const hadPlane = (WORLD.planes ?? []).length > 0;
    const plane = surfacePlane(WORLD, true);
    // a real-Earth world reads its coastline from the baked grid — load it before
    // the first paint so it never flashes as open ocean
    if ((plane?.terrain as { landform?: string } | undefined)?.landform === 'earth') await ensureEarthGrid();
    if (!hadPlane) save();
    if (plane) lastWaterSig = worldWaterSig(plane); // baseline: only later water paint re-traces rivers
    map?.destroy();
    map = mountMap(host, WORLD, {
      onSelectEntity(id) { navigate(id); },
      onClaimsEdited() {
        save(); // painted borders persist (M2)
        // if the terrain paint added/removed water, re-trace the rivers (batch 73)
        const plane = surfacePlane(WORLD!);
        if (plane) { const sig = worldWaterSig(plane); if (sig !== lastWaterSig) { lastWaterSig = sig; scheduleRiverRebuild(); } }
      },
      onAdvanceDays(days) { shiftDay(days); }, // the march takes real time
      onAddHere(x, y, hexLabel, biome) {
        if (!WORLD) return;
        void addHereDialog(x, y, hexLabel, biome);
      },
      canEnter(id) {
        const e2 = E()[id];
        return !!e2 && !e2.deleted && !!spaceKindFor(e2, anchorOf(id)?.icon);
      },
      onEnterSite(id) { enterInterior(id); },
      async onMaterializeGhost(g) {
        if (!WORLD) return;
        const isSettlement = 'cls' in g;
        // the ghost knows where it stands: crown law for settlements, the
        // ground underfoot for landmarks (ancestor context, batch 20)
        const ctx: Record<string, string> = isSettlement
          ? { government: lawOfTheLand(politicalParentAt(g.x, g.y)),
              // the page agrees with the ghost that promised it (batch 26); the
              // biome grounds the node type and abandoned is generated as empty
              // from the start rather than bolted on afterward (batch 76)
              size: (g as { cls: string }).cls, population: String((g as { pop: number }).pop),
              biome: biomeAtXY(g.x, g.y), abandoned: (g as { abandoned?: boolean }).abandoned ? '1' : '' }
          : { biome: biomeAtXY(g.x, g.y) };
        const run = await runComposite(isSettlement ? 'settlement' : 'landmark', g.seedPath, ctx);
        if (!run) return;
        const ne = blocksToEntity(run.metaId, g.seedPath, run.blocks, isSettlement ? g.cls : g.kind);
        ne.id = g.gid; // materialization keeps the ghost's contract id
        // the ghost's promise survives rerolls: node type, scale, biome (batch 93 machinery)
        if (run.locked && Object.keys(run.locked).length && ne.gen) ne.gen.opts = run.locked;
        ne.parentId = politicalParentAt(g.x, g.y); // file under the claiming crown
        const plane = surfacePlane(WORLD, true);
        if (isSettlement) {
          ne.kind = 'settlement';
          ne.tags = [g.cls === 'hamlet' ? 'village' : g.cls];
          ne.fields = { ...(ne.fields ?? {}), population: g.abandoned ? 0 : g.pop };
          if (g.abandoned) {
            // the composite already generated this as an empty place (batch 76);
            // just tag and label it here
            ne.tags.push('abandoned');
            ne.name = `${ne.name} (abandoned)`;
          } else {
            // a living settlement earns its dirt track — if the road is near
            // enough (the 20-mile isolation rule applies to ghosts too)
            const routes = (plane as unknown as { routes?: Array<{ kind?: string; pts: Array<[number, number]> }> }).routes ?? [];
            let best: [number, number] | null = null, bestD = Infinity;
            for (const rt of routes) {
              if (rt.kind === 'river' || rt.kind === 'seaRoute') continue; // you can't pave onto a river
              for (let i = 0; i < rt.pts.length; i += 3) {
                const [px2, py2] = rt.pts[i]!;
                const d = Math.hypot(px2 - g.x, py2 - g.y);
                if (d < bestD) { bestD = d; best = [px2, py2]; }
              }
            }
            if (best && bestD <= 20 * 5280 && g.pop >= 250) {
              ((plane as unknown as { routes: Array<{ id: string; kind: string; pts: Array<[number, number]> }> }).routes ??= [])
                .push({ id: 'rt_gen' + rid('', 6), kind: 'dirt', pts: [[Math.round(g.x), Math.round(g.y)], best] });
            }
          }
        } else {
          ne.kind = 'landmark';
          ne.tags = [g.kind];
        }
        WORLD.entities[ne.id] = ne;
        (plane!.anchors ??= []).push({
          entityId: ne.id, x: g.x, y: g.y, tier: 'region',
          icon: isSettlement ? (g.abandoned ? 'ruin' : g.cls === 'town' ? 'town' : 'village') : g.kind,
        });
        save();
        // a new living settlement re-forges the road network to reach it (batch 73)
        if (isSettlement && !g.abandoned) scheduleRoadRebuild();
        navigate(ne.id);
      },
    });
    if (current) focusOnMap(current);
  }
  $('mapBtn')?.addEventListener('click', () => {
    if (!WORLD) { alert('Create or load a world first.'); return; }
    setMapMode(!mapMode);
  });

  // ---------- shell ----------
  // One index build shared by the tree and the page — both only read entities.
  function rerender(): void { withKidIdx(() => { renderTree(); renderPage(); }); }
  function navigate(id: string | null): void {
    if (mapMode) setMapMode(false);
    creatingWorld = false;
    current = id;
    editingBlock = null;
    addingKind = null;
    // open just this spot in the tree (owner, item #5) — unfolds the ancestors,
    // un-hides a locked region if the page lives inside one, and renderTree
    // scrolls it into view. Reached from a tree click, a search hit, a link, a
    // mention or a #hash, so the tree always shows where you actually are.
    if (id) {
      // drop the search too: picking a hit means "take me there", and leaving
      // the query set re-rendered the flat hit list instead of the hierarchy,
      // so the revealed path was never actually shown
      if (searchQuery) {
        searchQuery = '';
        const sb = $('treeSearch') as HTMLInputElement | null;
        if (sb) sb.value = '';
      }
      revealPath(id);
    }
    history.replaceState(null, '', id ? `#${id}` : location.pathname);
    rerender();
  }

  // ---------- the calendar (Phase D, batch 31) ----------
  // Twelve 30-day months, a 360-day year — the classic tabletop calendar.
  // world.calendar = { day } (absolute day counter, 0 = 1 Deepwinter Y1);
  // month names are per-world overridable later.
  const MONTHS = ['Deepwinter', 'Thawmarch', 'Seedfall', 'Rainmoot', 'Blossomtide', 'Highsun',
    'Goldenreach', 'Emberwane', 'Harvestmoon', 'Mistfall', 'Frostmarch', 'Longnight'];
  const SEASONS = ['winter', 'winter', 'spring', 'spring', 'spring', 'summer', 'summer', 'summer', 'autumn', 'autumn', 'autumn', 'winter'];
  const SEASON_GLYPH: Record<string, string> = { winter: '❄', spring: '🌱', summer: '☀', autumn: '🍂' };
  type Cal = { day: number };
  function calOf(): Cal | null {
    if (!WORLD) return null;
    const w = WORLD as unknown as { calendar?: Cal };
    w.calendar ??= { day: 0 };
    if (typeof w.calendar.day !== 'number' || !Number.isFinite(w.calendar.day)) w.calendar.day = 0;
    return w.calendar;
  }
  function fmtWorldDate(day: number): string {
    const y = Math.floor(day / 360) + 1;
    const m = Math.floor((day % 360) / 30);
    const dom = (day % 30) + 1;
    return `${SEASON_GLYPH[SEASONS[m]!]} ${dom} ${MONTHS[m]}, Year ${y}`;
  }
  /** Inverse of fmtWorldDate, tolerantly: needs a month name; day-of-month and
   *  "Year N" default to 1. Returns null when no month is recognizable, so a
   *  freeform phrase ("sometime in spring") stays undated rather than wrong. */
  function parseWorldDate(s: string): number | null {
    const low = s.toLowerCase();
    const mIdx = MONTHS.findIndex((m) => low.includes(m.toLowerCase()));
    if (mIdx < 0) return null;
    const dm = /(\d+)\s+[A-Za-z]/.exec(s);
    const ym = /year\s+(\d+)/i.exec(s);
    const dom = dm ? Number(dm[1]) : 1;
    const y = ym ? Number(ym[1]) : 1;
    if (!(dom >= 1 && dom <= 30) || !(y >= 1)) return null;
    return (y - 1) * 360 + mIdx * 30 + (dom - 1);
  }
  function refreshDateChip(): void {
    const btn = $('dateBtn');
    const chip = $('dateChip');
    if (!btn || !chip) return;
    const cal = calOf();
    chip.style.display = cal ? '' : 'none';
    if (cal) btn.textContent = fmtWorldDate(cal.day);
  }
  function shiftDay(delta: number): void {
    const cal = calOf();
    if (!cal) return;
    cal.day = Math.max(0, cal.day + delta);
    save();
    refreshDateChip();
  }
  $('dayFwd')?.addEventListener('click', () => shiftDay(1));
  $('dayBack')?.addEventListener('click', () => shiftDay(-1));
  $('weekFwd')?.addEventListener('click', () => shiftDay(10));
  $('dateBtn')?.addEventListener('click', () => {
    const cal = calOf();
    if (!cal) return;
    const cur = `${(cal.day % 30) + 1} ${Math.floor((cal.day % 360) / 30) + 1} ${Math.floor(cal.day / 360) + 1}`;
    const raw = prompt('Set the date — day month year (numbers, 30-day months, 12-month years):', cur);
    if (!raw) return;
    const m = /^\s*(\d+)\s+(\d+)\s+(\d+)\s*$/.exec(raw);
    if (!m) { alert('Use three numbers: day month year, e.g. "14 9 3".'); return; }
    const dom = Math.min(30, Math.max(1, Number(m[1])));
    const mon = Math.min(12, Math.max(1, Number(m[2])));
    const yr = Math.max(1, Number(m[3]));
    cal.day = (yr - 1) * 360 + (mon - 1) * 30 + (dom - 1);
    save();
    refreshDateChip();
  });

  // the timeline (Phase D, batch 34): every event with a stamped day,
  // sorted; the clock's NOW line divides what happened from what looms
  $('timelineBtn')?.addEventListener('click', () => {
    const cal = calOf();
    if (!cal || !WORLD) return;
    const dated: Array<{ day: number; e: EntityRecord }> = [];
    const undated: EntityRecord[] = [];
    for (const en of Object.values(E())) {
      if (en.deleted || en.kind !== 'event') continue;
      const d = (en.fields as Record<string, unknown> | undefined)?.whenDay;
      if (typeof d === 'number') dated.push({ day: d, e: en });
      else undated.push(en);
    }
    dated.sort((a, b) => a.day - b.day);
    const row = (day: number, en: EntityRecord) =>
      `<div class="wd-tlrow${day > cal.day ? ' wd-future' : ''}"><span class="wd-tldate">${esc(fmtWorldDate(day))}</span>` +
      `<a href="#${en.id}" data-tl="${en.id}">${esc(en.name)}</a></div>`;
    const past = dated.filter((x) => x.day <= cal.day).map((x) => row(x.day, x.e)).join('');
    const future = dated.filter((x) => x.day > cal.day).map((x) => row(x.day, x.e)).join('');
    const overlay = document.createElement('div');
    overlay.className = 'wd-adddlg';
    overlay.innerHTML = `<div class="wd-adddlg-card wd-tl">
      <h3>🕰 The Timeline</h3>
      ${past || '<div class="ghostnote">nothing recorded yet — stamp events with 📅</div>'}
      <div class="wd-tlnow">— ${esc(fmtWorldDate(cal.day))} · today —</div>
      ${future || '<div class="ghostnote">nothing looms… yet</div>'}
      ${undated.length ? `<div class="ghostnote">${undated.length} undated event${undated.length > 1 ? 's' : ''} (open them and 📅 stamp)</div>` : ''}
      <div class="wd-dlgbtns"><button class="wd-btn" id="tlClose">Close</button></div></div>`;
    document.body.appendChild(overlay);
    overlay.addEventListener('click', (ev) => { if (ev.target === overlay) overlay.remove(); });
    overlay.querySelector('#tlClose')?.addEventListener('click', () => overlay.remove());
    overlay.querySelectorAll<HTMLAnchorElement>('[data-tl]').forEach((a) =>
      a.addEventListener('click', (ev) => {
        ev.preventDefault();
        overlay.remove();
        navigate(a.dataset.tl!);
      }));
  });

  // prefetch the generators a GM reaches for first (PERF.md P1): materialising a
  // map ghost or adding a place rolls a settlement/landmark/NPC, each of which
  // lazy-loads its registry chunk (settlement 0.5 MB, npc-block 1.3 MB…). Warm
  // those on idle once a world is open so the first roll doesn't stall on a fetch.
  let generatorsPrefetched = false;
  function prefetchGenerators(): void {
    if (generatorsPrefetched) return;
    generatorsPrefetched = true;
    const warm = (): void => {
      for (const tool of ['settlement', 'landmark', 'npc-block']) {
        compositeModules[`../composites/${tool}.ts`]?.().catch(() => {});
        compositeRegistries[`../generators/registries/${tool}.json`]?.().catch(() => {});
      }
    };
    const ric = (window as { requestIdleCallback?: (cb: () => void) => void }).requestIdleCallback;
    if (ric) ric(warm); else setTimeout(warm, 1200);
  }

  async function openWorld(id: string | null): Promise<void> {
    WORLD = id ? (await getWorld(id)) ?? null : null;
    if (WORLD) localStorage.setItem(ACTIVE_KEY, WORLD.id);
    else localStorage.removeItem(ACTIVE_KEY);
    loadTreeState();
    current = null;
    await renderChrome();
    rerender();
    refreshDateChip();
    refreshPartyComp();
    if (mapMode) { if (WORLD) remountMap(); else setMapMode(false); }
    if (WORLD) prefetchGenerators();
  }

  document.addEventListener('click', (ev) => {
    const tg = (ev.target as HTMLElement).closest?.('[data-toggle]') as HTMLElement | null;
    if (tg) {
      const id = tg.dataset.toggle ?? '';
      if (expanded.has(id)) expanded.delete(id); else expanded.add(id);
      saveTreeState();
      renderTree();
      return;
    }
    // lock a region away to the Hidden shelf / bring it back
    const hd = (ev.target as HTMLElement).closest?.('[data-hide]') as HTMLElement | null;
    if (hd) {
      ev.preventDefault(); ev.stopPropagation();
      const id = hd.dataset.hide ?? '';
      hidden.add(id); expanded.delete(id);
      saveTreeState(); renderTree();
      return;
    }
    const sh = (ev.target as HTMLElement).closest?.('[data-show]') as HTMLElement | null;
    if (sh) {
      ev.preventDefault(); ev.stopPropagation();
      hidden.delete(sh.dataset.show ?? '');
      saveTreeState(); renderTree();
      return;
    }
    const t = (ev.target as HTMLElement).closest('a[data-id], .node[data-id]') as HTMLElement | null;
    if (t) {
      ev.preventDefault();
      const id = t.dataset.id ?? null;
      // map open + the page (or its children) live somewhere → jump there
      // at the logical zoom instead of leaving the map
      if (mapMode && id && focusOnMap(id)) {
        current = id;
        renderTree();
      } else navigate(id);
    }
  });
  ($('playerView') as HTMLInputElement).addEventListener('change', (ev) => {
    playerView = (ev.target as HTMLInputElement).checked;
    editingBlock = null; addingKind = null;
    if (playerView && current && E()[current]?.deleted) current = null;
    refreshPartyComp();
    rerender();
  });
  ($('worldSel') as HTMLSelectElement).addEventListener('change', (ev) => {
    void openWorld((ev.target as HTMLSelectElement).value || null);
  });
  // ---------- party composition control (batch 94) ----------
  function setupPartyComp(): void {
    const lv = $('partyLevel') as HTMLSelectElement | null;
    const sz = $('partySize') as HTMLSelectElement | null;
    if (!lv || !sz) return;
    if (!lv.options.length) {
      lv.innerHTML = Array.from({ length: 20 }, (_, i) => `<option value="${i + 1}">Lv ${i + 1}</option>`).join('');
      sz.innerHTML = Array.from({ length: 8 }, (_, i) => `<option value="${i + 1}">×${i + 1}</option>`).join('');
      const onChange = (): void => {
        if (!WORLD) return;
        WORLD.settings = { ...(WORLD.settings ?? {}), party: { level: Number(lv.value), size: Number(sz.value) } };
        save();
      };
      lv.addEventListener('change', onChange);
      sz.addEventListener('change', onChange);
    }
    refreshPartyComp();
  }
  function refreshPartyComp(): void {
    const lv = $('partyLevel') as HTMLSelectElement | null;
    const sz = $('partySize') as HTMLSelectElement | null;
    const wrap = $('partyComp');
    if (!lv || !sz || !wrap) return;
    wrap.style.display = WORLD && !playerView ? '' : 'none'; // GM tool; hidden in Player View
    const p = partyComp();
    lv.value = String(p.level);
    sz.value = String(p.size);
  }
  $('newWorldBtn')?.addEventListener('click', () => {
    if (mapMode) setMapMode(false);
    creatingWorld = true;
    current = null;
    renderPage();
  });
  $('exampleBtn')?.addEventListener('click', async () => {
    // always pull the freshly-shipped fixture, never a cached copy — the file is
    // rebaked as the demo evolves, and clicking this is an explicit "give me the
    // current example" (it overwrites the stored copy in IndexedDB).
    const res = await fetch('/labs/earth.example.json', { cache: 'reload' });
    const doc: unknown = await res.json();
    if (!looksLikeWorld(doc)) { alert('Example failed to load.'); return; }
    await putWorld(doc);
    await openWorld(doc.id);
  });
  ($('importFile') as HTMLInputElement).addEventListener('change', async (ev) => {
    const file = (ev.target as HTMLInputElement).files?.[0];
    if (!file) return;
    try {
      const doc: unknown = JSON.parse(await file.text());
      if (!looksLikeWorld(doc)) { alert('That file does not look like an Everdeep world.'); return; }
      const existing = await getWorld(doc.id);
      if (existing) {
        // MERGE is the default (queue #38): one person, two devices, one
        // world — pages from both sides survive, colliding edits keep the
        // newer side and file the other in the conflict inbox
        if (confirm(`A world “${existing.name}” with this id already exists.\n\nOK — MERGE the file into it: pages from both copies survive; where both edited the same page, the newer edit wins and the other is kept in the conflict inbox.\nCancel — choose replace instead.`)) {
          const r = mergeWorlds(existing, doc);
          await putWorldRaw(r.world);
          await openWorld(doc.id);
          alert(`Merged: ${r.added} page(s) united across the two copies, ${r.collided} conflicting edit(s)${r.collided ? ' — the losing versions are in the world’s conflict inbox' : ''}.`);
          return;
        }
        if (!confirm('REPLACE your local copy with the file? (Cancel keeps your local copy untouched.)')) return;
      }
      await putWorld(doc);
      await openWorld(doc.id);
    } finally {
      (ev.target as HTMLInputElement).value = '';
    }
  });
  $('exportBtn')?.addEventListener('click', () => {
    if (!WORLD) return;
    const blob = new Blob([JSON.stringify(WORLD, null, 2)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `${WORLD.name || 'world'}.json`;
    a.click();
    URL.revokeObjectURL(a.href);
  });
  $('deleteWorldBtn')?.addEventListener('click', async () => {
    if (!WORLD) return;
    if (!confirm(`Delete the whole world “${WORLD.name}” from this browser? Export first if you want a copy.`)) return;
    await deleteWorld(WORLD.id);
    const rest = await listWorlds();
    await openWorld(rest[0]?.id ?? null);
  });
  const setDriveStatus = (msg: string) => { const el = $('driveStatus'); if (el) el.textContent = msg; };
  $('driveSaveBtn')?.addEventListener('click', async () => {
    try {
      setDriveStatus('Saving…');
      await initSheetStore(); // hydrate the mirror or we back up an EMPTY sheet store
      const result = await saveToDrive(await buildBackup(loadSheetStore()));
      setDriveStatus(`✓ backed up ${new Date(result.modifiedTime).toLocaleTimeString()}`);
    } catch (err) {
      setDriveStatus('Drive save failed — connect on first use, or see /sheet/.');
      console.error(err);
    }
  });
  $('driveLoadBtn')?.addEventListener('click', async () => {
    try {
      setDriveStatus('Checking Drive…');
      const backup = await loadFromDrive();
      if (!backup) { setDriveStatus('No Drive backup yet — ☁ Backup first.'); return; }
      const incoming = parseBackup(backup.json);
      if (!incoming.worlds.length && !incoming.sheets) { setDriveStatus('Backup contains nothing restorable.'); return; }
      if (!confirm(`Restore from Drive backup saved ${new Date(backup.modifiedTime).toLocaleString()}? Worlds with newer local edits are kept; sheets are only restored from /sheet/.`)) { setDriveStatus(''); return; }
      const res = await restoreWorlds(incoming.worlds);
      setDriveStatus(`✓ ${res.restored} world(s) restored${res.skippedOlder ? `, ${res.skippedOlder} kept (local newer)` : ''}.`);
      const worlds = await listWorlds();
      await openWorld(WORLD?.id ?? worlds[0]?.id ?? null);
    } catch (err) {
      setDriveStatus('Drive load failed.');
      console.error(err);
    }
  });

  $('addRootBtn')?.addEventListener('click', async () => {
    if (!WORLD) { alert('Create or load a world first.'); return; }
    const name = prompt('Name the new top-level region:');
    if (!name?.trim()) return;
    const ne = newEntity('region', name.trim());
    WORLD.entities[ne.id] = ne;
    save();
    navigate(ne.id);
  });
  ($('treeSearch') as HTMLInputElement | null)?.addEventListener('input', (ev) => {
    searchQuery = (ev.target as HTMLInputElement).value;
    renderTree();
  });

  // ---------- the tree's width (owner, item #16) ----------
  // Realm names got long and the padlock crowded them, in a pane frozen at
  // 250px. So: drag the rule to any width, double-click it to fit the longest
  // name on show, or fold the tree away and give the page the whole screen.
  // Both settings persist — this is furniture, and furniture stays put.
  const NAV_KEY = 'stb:everdeep:nav';
  const NAV_MIN = 150, NAV_MAX = 720;
  const main = document.querySelector<HTMLElement>('.wd-main')!;
  const navEl = $('nav'), grip = $('navGrip'), navShow = $('navShow'), navMin = $('navMin');
  let navW = 250, navFolded = false;

  function applyNav(): void {
    main.style.setProperty('--navw', `${navW}px`);
    navEl?.classList.toggle('min', navFolded);
    grip?.classList.toggle('min', navFolded);
    if (navShow) navShow.hidden = !navFolded;
    // the map canvas re-fits itself: mountMap keeps a ResizeObserver on its host
  }
  function saveNav(): void {
    try { localStorage.setItem(NAV_KEY, JSON.stringify({ w: navW, folded: navFolded })); } catch { /* private mode */ }
  }
  try {
    const st = JSON.parse(localStorage.getItem(NAV_KEY) ?? '{}') as { w?: number; folded?: boolean };
    if (typeof st.w === 'number') navW = Math.min(NAV_MAX, Math.max(NAV_MIN, st.w));
    navFolded = st.folded === true;
  } catch { /* defaults are fine */ }
  applyNav();

  const foldNav = (on: boolean): void => { navFolded = on; applyNav(); saveNav(); };
  navMin?.addEventListener('click', () => foldNav(true));
  navShow?.addEventListener('click', () => foldNav(false));

  grip?.addEventListener('pointerdown', (ev) => {
    ev.preventDefault();
    grip.classList.add('dragging');
    grip.setPointerCapture(ev.pointerId);
    const x0 = ev.clientX, w0 = navW;
    const move = (m: PointerEvent) => {
      navW = Math.min(NAV_MAX, Math.max(NAV_MIN, w0 + m.clientX - x0));
      applyNav();
    };
    const up = () => {
      grip.classList.remove('dragging');
      grip.removeEventListener('pointermove', move);
      grip.removeEventListener('pointerup', up);
      saveNav();
    };
    grip.addEventListener('pointermove', move);
    grip.addEventListener('pointerup', up);
  });
  // double-click: measure what's actually rendered and fit it, so you don't
  // have to hunt for the width by hand
  grip?.addEventListener('dblclick', () => {
    let widest = 0;
    document.querySelectorAll<HTMLElement>('#tree .nm').forEach((nm) => {
      // the row's own left edge tells us how deep it is nested
      const indent = nm.getBoundingClientRect().left - (navEl?.getBoundingClientRect().left ?? 0);
      widest = Math.max(widest, indent + nm.scrollWidth);
    });
    if (!widest) return;
    navW = Math.min(NAV_MAX, Math.max(NAV_MIN, Math.ceil(widest) + 34)); // + lock column and padding
    applyNav();
    saveNav();
  });
  // hover tooltips on entity links: name · kind · where it lives (free —
  // World Anvil charges for this)
  document.addEventListener('mouseover', (ev) => {
    const a = (ev.target as HTMLElement).closest?.('a[data-id]') as HTMLElement | null;
    if (!a || a.title) return;
    const e = E()[a.dataset.id ?? ''];
    if (!e) return;
    const crumb = crumbFor(e);
    const firstLine = (e.body ?? []).map((b) => String(b.text ?? '')).find((t) => t.trim());
    a.title = `${e.name} · ${e.kind}${crumb ? `\nin ${crumb}` : ''}${firstLine ? `\n${firstLine.replace(/\{@e [^}|]+\|?([^}]*)\}/g, '$1').slice(0, 140)}` : ''}`;
  });
  window.addEventListener('hashchange', () => {
    // "#e_…/map" (the generator pages' floor-plan link) descends on arrival;
    // "/s:<siteId>/fl:<z>" goes deeper — straight into a nested sub-site
    const raw = location.hash.slice(1);
    const hm = ENTITY_HASH.exec(raw);
    const id = hm ? hm[1]! : raw;
    if (E()[id]) {
      navigate(id);
      if (hm) {
        const z = hm[3] ? Number(hm[3]) : 0;
        if (hm[2] && WORLD && siteById(WORLD, hm[2])) openSiteOverlay(hm[2], z);
        else enterInterior(id, z);
      }
    }
  });

  setupPartyComp();
  void (async () => {
    const worlds = await listWorlds();
    const remembered = localStorage.getItem(ACTIVE_KEY);
    let pick = worlds.find((w) => w.id === remembered)?.id ?? worlds[0]?.id ?? null;
    // deep link: #e_… may live in a different world — find its home; a
    // "/map" suffix additionally descends into the interior once open, and
    // "/s:<siteId>/fl:<z>" lands in a nested sub-site on a chosen floor
    const rawHash = location.hash.slice(1);
    const bm = ENTITY_HASH.exec(rawHash);
    const hashId = bm ? bm[1]! : rawHash;
    if (hashId.startsWith('e_')) {
      const all = await getAllWorlds();
      const home = all.find((w) => hashId in (w.entities ?? {}));
      if (home) pick = home.id;
    }
    await openWorld(pick);
    if (E()[hashId]) {
      navigate(hashId);
      if (bm) {
        const z = bm[3] ? Number(bm[3]) : 0;
        if (bm[2] && WORLD && siteById(WORLD, bm[2])) openSiteOverlay(bm[2], z);
        else enterInterior(hashId, z);
      }
    }
    if (hashId.startsWith('map=')) setMapMode(true); // shared viewport link
  })();
</script>
