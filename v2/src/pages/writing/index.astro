---
import Base from '../../layouts/Base.astro';
import ToolCatalog, { type CatalogTool } from '../../components/ToolCatalog.astro';
import type { GeneratorConfig } from '../../engine/types';
import type { CompositeModule } from '../../engine/composite';

const genModules = import.meta.glob<GeneratorConfig>('../../generators/*.json', { eager: true, import: 'default' });
const compModules = import.meta.glob<CompositeModule>('../../composites/*.ts', { eager: true });
const slugOf = (id: string) => id.split('/')[1]!;

const tools: CatalogTool[] = [
  ...Object.values(compModules)
    .map(({ meta }) => meta)
    .filter((m) => m.pillar === 'writing')
    .map((m) => ({ href: `/writing/${slugOf(m.id)}/`, title: m.title, blurb: m.description, builder: true })),
  ...Object.values(genModules)
    .filter((c) => c.pillar === 'writing')
    .map((c) => ({ href: `/writing/${slugOf(c.id)}/`, title: c.title, blurb: c.description ?? '', builder: false })),
  // Standalone island page (not a generator/composite module) added by hand:
  {
    href: '/writing/inspiration/',
    title: 'Inspiration Deck',
    blurb:
      'Draw a word card — character, mood, or detail — to spark a scene. Pin the keepers to your sheet.',
    builder: false,
  },
].sort((a, b) => a.title.localeCompare(b.title));
---

<Base title="Writing" description="Prompts, challenges, and unblockers for writers.">
  <h1>Writing</h1>
  <p class="lede">
    Tools for writers: prompts to start from, timed challenges to push through, and
    unblockers for when the page won't move. Every result can be pinned to a sheet —
    a story bible is just a sheet.
  </p>

  <ToolCatalog tools={tools} placeholder="Filter writing tools…" />
</Base>

<style>
  .lede {
    max-width: 44rem;
    color: var(--color-ink-muted);
  }
</style>
