---
import Base from '../../layouts/Base.astro';
import type { GeneratorConfig } from '../../engine/types';
import type { CompositeModule } from '../../engine/composite';

const modules = import.meta.glob<GeneratorConfig>('../../generators/*.json', { eager: true, import: 'default' });
const compModules = import.meta.glob<CompositeModule>('../../composites/*.ts', { eager: true });

const tools = [
  ...Object.values(modules)
    .filter((c) => c.pillar === 'writing')
    .map((c) => ({ href: `/writing/${c.id.split('/')[1]}/`, title: c.title, blurb: c.description ?? '' })),
  ...Object.values(compModules)
    .map(({ meta }) => meta)
    .filter((m) => m.pillar === 'writing')
    .map((m) => ({ href: `/writing/${m.id.split('/')[1]}/`, title: m.title, blurb: m.description })),
].sort((a, b) => a.title.localeCompare(b.title));
---

<Base title="Writing" description="Prompts, challenges, and unblockers for writers.">
  <h1>Writing</h1>
  <p>
    Tools for writers: prompts to start from, timed challenges to push through, and
    unblockers for when the page won't move. Every result can be pinned to a sheet —
    a story bible is just a sheet.
  </p>

  <div class="tools">
    {
      tools.map((t) => (
        <a class="card tool" href={t.href}>
          <h2>{t.title}</h2>
          <p>{t.blurb}</p>
        </a>
      ))
    }
  </div>

  <h2>Coming here</h2>
  <ul>
    <li>Detail &amp; shine card decks — a draw-a-card deck for scene and character sparks</li>
  </ul>
</Base>

<style>
  .tools {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    margin-block: var(--space-8);
  }

  .tool {
    text-decoration: none;
    color: var(--color-ink);
    display: grid;
    gap: var(--space-3);
    align-content: start;
  }

  .tool:hover {
    border-color: var(--color-accent);
  }

  .tool h2 {
    color: var(--color-accent);
  }
</style>
