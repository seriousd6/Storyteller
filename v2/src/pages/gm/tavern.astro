---
import Base from '../../layouts/Base.astro';
import Generator from '../../components/Generator.astro';
import type { GeneratorConfig } from '../../engine/types';
import rawConfig from '../../generators/tavern.json';

const config = rawConfig as GeneratorConfig;
---

<Base title="Tavern Generator" description="Roll up a complete fantasy tavern: name, atmosphere, menu, entertainment, rumors, and trouble.">
  <h1>Tavern</h1>
  <p>{config.description}</p>
  <Generator config={config} />
  <p class="credits">
    Content adapted from community lists on
    <a href="https://www.reddit.com/r/d100/">r/d100</a>,
    <a href="https://www.reddit.com/r/BehindTheTables/">r/BehindTheTables</a>, and
    <a href="https://www.reddit.com/r/DnDBehindTheScreen/">r/DnDBehindTheScreen</a>.
    Name generator originally by Seriousd6.
  </p>
</Base>

<style>
  .credits {
    margin-top: var(--space-8);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }
</style>
