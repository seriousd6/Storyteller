---
import Base from '../../layouts/Base.astro';
import Generator from '../../components/Generator.astro';
import type { GeneratorConfig } from '../../engine/types';
import rawConfig from '../../generators/tavern.json';

const config = rawConfig as GeneratorConfig;
---

<Base title="Tavern Generator" description="Roll up a complete fantasy tavern: name, atmosphere, menu, entertainment, rumors, and trouble.">
  <h1>Tavern</h1>
  <p>{config.description}</p>
  <Generator config={config} />
</Base>
