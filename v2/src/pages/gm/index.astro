---
import Base from '../../layouts/Base.astro';
import type { GeneratorConfig } from '../../engine/types';

const modules = import.meta.glob<GeneratorConfig>('../../generators/*.json', { eager: true, import: 'default' });
const tools = Object.values(modules)
  .filter((c) => c.pillar === 'gm')
  .sort((a, b) => a.title.localeCompare(b.title))
  .map((c) => ({ href: `/gm/${c.id.split('/')[1]}/`, title: c.title, blurb: c.description ?? '' }));
---

<Base title="GM Prep" description="Random tables and printable prep sheets for game masters.">
  <h1>GM Prep</h1>
  <p>
    Roll on curated community tables, reroll any piece on its own, and pin what
    you like for the printable Sheet Builder.
  </p>

  <div class="tools">
    {
      tools.map((t) => (
        <a class="card tool" href={t.href}>
          <h2>{t.title}</h2>
          <p>{t.blurb}</p>
        </a>
      ))
    }
  </div>
</Base>

<style>
  .tools {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    margin-block: var(--space-8);
  }

  .tool {
    text-decoration: none;
    color: var(--color-ink);
    display: grid;
    gap: var(--space-3);
    align-content: start;
  }

  .tool:hover {
    border-color: var(--color-accent);
  }

  .tool h2 {
    color: var(--color-accent);
  }
</style>
