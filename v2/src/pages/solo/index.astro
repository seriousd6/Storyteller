---
import Base from '../../layouts/Base.astro';
import ToolCatalog, { type CatalogTool } from '../../components/ToolCatalog.astro';
import type { GeneratorConfig } from '../../engine/types';
import type { CompositeModule } from '../../engine/composite';

const genModules = import.meta.glob<GeneratorConfig>('../../generators/*.json', { eager: true, import: 'default' });
const compModules = import.meta.glob<CompositeModule>('../../composites/*.ts', { eager: true });
const slugOf = (id: string) => id.split('/')[1]!;

const tools: CatalogTool[] = [
  ...Object.values(compModules)
    .map(({ meta }) => meta)
    .filter((m) => m?.pillar === 'solo')
    .map((m) => ({ href: `/solo/${slugOf(m.id)}/`, title: m.title, blurb: m.description, builder: true })),
  ...Object.values(genModules)
    .filter((c) => c.pillar === 'solo')
    .map((c) => ({ href: `/solo/${slugOf(c.id)}/`, title: c.title, blurb: c.description ?? '', builder: false })),
].sort((a, b) => a.title.localeCompare(b.title));
---

<Base title="Solo Play" description="Companion tools for solo tabletop RPGs.">
  <h1>Solo Play</h1>
  <p class="lede">
    Tools for playing tabletop RPGs without a GM. Ask the oracle, pin every
    answer to a sheet, and the Sheet Builder becomes your adventure journal.
  </p>

  <ToolCatalog tools={tools} placeholder="Filter solo tools…" />
</Base>

<style>
  .lede {
    max-width: 44rem;
    color: var(--color-ink-muted);
  }
</style>
