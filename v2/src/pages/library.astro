---
import Base from '../layouts/Base.astro';
---

<Base title="Library" description="Every document you've made — sheets, worlds, and your own roll tables — on one shelf." hideTray appShell>
  <div class="library-page">
    <div class="library-inner">
      <header class="library-head no-print">
        <h1>Library</h1>
        <span class="head-spacer"></span>
        <input data-lib-search type="search" placeholder="Search by name or contents…" aria-label="Search documents" />
        <select data-lib-filter aria-label="Filter by document type">
          <option value="">All types</option>
          <option value="sheet">📄 Sheets</option>
          <option value="world">🌍 Worlds</option>
          <option value="brew">🍺 My tables</option>
        </select>
        <a class="btn btn-primary" href="/sheet/">＋ New sheet</a>
      </header>
      <p class="library-sub">
        Everything you've made, in one place — click a card to open it. Sheets
        open in the <a href="/sheet/">Sheet Builder</a>, worlds in the
        <a href="/world/">World</a> wiki; your tables live in the Sheet
        Builder's 🍺 panel.
      </p>
      <div class="library-grid" data-lib-grid aria-live="polite"></div>
      <p class="library-empty" data-lib-empty hidden>
        Nothing here yet. Pin 📌 results from any generator, start a sheet
        <a href="/sheet/">from a template</a>, or generate a <a href="/world/">world</a>.
      </p>
    </div>
  </div>
</Base>

<script>
  import { docTypes, toggleSheetTemplate, type DocMeta, type DocTypeDef } from '../engine/docRegistry';
  import { SHEET_EVENT } from '../engine/sheetStore';
  import { BREW_EVENT } from '../engine/brewStore';

  const $ = <T extends HTMLElement = HTMLElement>(sel: string) => document.querySelector<T>(sel)!;
  const grid = $('[data-lib-grid]');
  const emptyEl = $('[data-lib-empty]');
  const searchEl = $<HTMLInputElement>('[data-lib-search]');
  const filterEl = $<HTMLSelectElement>('[data-lib-filter]');

  const defs = new Map<string, DocTypeDef>(docTypes.map((d) => [d.type, d]));
  let docs: DocMeta[] = [];

  function card(doc: DocMeta): HTMLElement {
    const def = defs.get(doc.type)!;
    const el = document.createElement('article');
    el.className = `lib-card lib-${doc.type}`;
    el.setAttribute('data-doc', `${doc.type}:${doc.id}`);

    // the card IS the document — click anywhere (except a control) to open
    el.tabIndex = 0;
    const open = () => void def.open(doc.id).then((url) => (location.href = url));
    el.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('button, a')) return;
      open();
    });
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && e.target === el) open();
    });

    const head = document.createElement('p');
    head.className = 'lib-card-head';
    const name = document.createElement('b');
    name.textContent = `${def.icon} ${doc.name}`;
    head.appendChild(name);
    if (doc.kind) {
      const chip = document.createElement('span');
      chip.className = 'lib-chip';
      chip.textContent = doc.kind;
      head.appendChild(chip);
    }
    if (doc.genre) {
      const chip = document.createElement('span');
      chip.className = 'lib-chip lib-chip-genre';
      chip.textContent = doc.genre;
      chip.title = 'This sheet pins its own genre theme';
      head.appendChild(chip);
    }
    el.appendChild(head);

    const detail = document.createElement('p');
    detail.className = 'lib-detail';
    detail.textContent = doc.detail;
    el.appendChild(detail);

    if (def.thumb) {
      const thumb = document.createElement('div');
      thumb.className = 'lib-thumb';
      el.prepend(thumb); // the picture leads, like any documents home
      void def.thumb(doc.id).then((inner) => {
        if (inner) thumb.appendChild(inner);
        else thumb.remove();
      });
    }

    const actions = document.createElement('p');
    actions.className = 'lib-actions no-print';
    const openBtn = document.createElement('button');
    openBtn.type = 'button';
    openBtn.className = 'btn';
    openBtn.textContent = 'Open';
    openBtn.addEventListener('click', () => {
      void def.open(doc.id).then((url) => (location.href = url));
    });
    actions.appendChild(openBtn);
    if (def.duplicate) {
      const dupBtn = document.createElement('button');
      dupBtn.type = 'button';
      dupBtn.className = 'btn';
      dupBtn.textContent = '⧉ Duplicate';
      dupBtn.addEventListener('click', () => void def.duplicate!(doc.id).then(refresh));
      actions.appendChild(dupBtn);
    }
    if (doc.type === 'sheet') {
      const tmplBtn = document.createElement('button');
      tmplBtn.type = 'button';
      tmplBtn.className = 'btn';
      tmplBtn.textContent = doc.template ? '★ Templated' : '☆ Template';
      tmplBtn.title = doc.template
        ? 'Remove from the "New from template" gallery'
        : 'Add this sheet to the "New from template" gallery as your own boilerplate';
      tmplBtn.addEventListener('click', () => void toggleSheetTemplate(doc.id).then(refresh));
      actions.appendChild(tmplBtn);
    }
    if (def.remove) {
      const rmBtn = document.createElement('button');
      rmBtn.type = 'button';
      rmBtn.className = 'btn';
      rmBtn.textContent = doc.type === 'sheet' ? '🗑 Trash' : '✕ Delete';
      rmBtn.addEventListener('click', () => {
        const warning =
          doc.type === 'sheet'
            ? `Move "${doc.name}" to the trash? (restorable for 30 days on /sheet/)`
            : `Delete "${doc.name}"? This cannot be undone.`;
        if (!confirm(warning)) return;
        void def.remove!(doc.id).then(refresh);
      });
      actions.appendChild(rmBtn);
    }
    el.appendChild(actions);
    return el;
  }

  function render(): void {
    const q = searchEl.value.trim().toLowerCase();
    const type = filterEl.value;
    const shown = docs.filter(
      (d) =>
        (!type || d.type === type) &&
        (!q || d.name.toLowerCase().includes(q) || d.haystack?.includes(q)),
    );
    grid.replaceChildren(...shown.map(card));
    emptyEl.hidden = docs.length > 0;
  }

  async function refresh(): Promise<void> {
    const lists = await Promise.all(docTypes.map((d) => d.list().catch(() => [] as DocMeta[])));
    docs = lists.flat();
    render();
  }

  searchEl.addEventListener('input', render);
  filterEl.addEventListener('change', render);
  window.addEventListener(SHEET_EVENT, () => void refresh());
  window.addEventListener(BREW_EVENT, () => void refresh());
  void refresh();
</script>

<style>
  /* the documents home: a desk, one header row, the grid */
  .library-page {
    background: var(--color-surface-sunken);
    min-height: calc(100vh - 4rem);
    padding: var(--space-6) var(--space-4) var(--space-10);
  }

  .library-inner {
    max-width: 72rem;
    margin-inline: auto;
  }

  .library-head {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .library-head h1 {
    font-size: var(--text-2xl);
    color: var(--color-statblock);
    margin: 0;
  }

  .head-spacer {
    flex: 1;
  }

  .library-head input,
  .library-head select {
    font: inherit;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: inherit;
  }

  .library-head input {
    min-width: 17rem;
  }

  .library-sub {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    max-width: 52rem;
    margin-block: var(--space-2) var(--space-5);
  }

  .library-empty {
    color: var(--color-ink-muted);
  }
</style>

<style is:global>
  /* cards are runtime-rendered */
  .library-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: var(--space-3);
  }

  .lib-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    cursor: pointer;
    transition: box-shadow 120ms ease, transform 120ms ease, border-color 120ms ease;
  }

  .lib-card:hover,
  .lib-card:focus-visible {
    border-color: var(--color-accent);
    box-shadow: 0 6px 20px rgb(0 0 0 / 0.12);
    transform: translateY(-2px);
    outline: none;
  }

  /* controls surface when you consider a card; a touch screen keeps them */
  .lib-actions {
    opacity: 0;
    transition: opacity 120ms ease;
    margin-top: auto; /* pin to the card's foot — no floating gap above */
  }

  .lib-card:hover .lib-actions,
  .lib-card:focus-within .lib-actions {
    opacity: 1;
  }

  @media (hover: none) {
    .lib-actions {
      opacity: 1;
    }
  }

  .lib-card-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin: 0;
  }

  .lib-card-head b {
    color: var(--color-statblock);
  }

  .lib-chip {
    font-size: var(--text-sm);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 999px;
    padding: 0 var(--space-2);
    white-space: nowrap;
  }

  .lib-detail {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    margin: 0;
  }

  .lib-actions {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
    margin: 0;
  }

  .lib-actions .btn {
    padding: 2px var(--space-2);
    font-size: var(--text-sm);
  }

  /* a scaled-down real render of the sheet's first blocks */
  .lib-thumb {
    height: 7.5rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface-sunken);
    position: relative;
  }

  .lib-thumb::after {
    /* fade the cut-off bottom */
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 2rem;
    background: linear-gradient(transparent, var(--color-surface-sunken));
  }

  .lib-thumb-inner {
    transform: scale(0.55);
    transform-origin: top left;
    width: 181%;
    padding: var(--space-2);
    pointer-events: none; /* a thumbnail is a picture, not a control panel */
  }
</style>
