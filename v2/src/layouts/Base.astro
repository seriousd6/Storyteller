---
import '../styles/global.css';
import SheetTray from '../components/SheetTray.astro';

interface Props {
  title: string;
  description?: string;
  hideTray?: boolean;
  /** og:type — 'website' for most pages, 'article' where it fits. */
  ogType?: string;
  /** Social-card image, resolved against the site origin. */
  image?: string;
  /** Keep a page out of the index (e.g. thin utility routes). */
  noindex?: boolean;
  /** App-shell mode (workspace pages like /sheet/ and /library/): the page
   *  is an editor, not an article — full-bleed main, no marketing footer. */
  appShell?: boolean;
}

const {
  title,
  description = 'Generators and printable prep sheets for game masters, solo players, and writers.',
  hideTray = false,
  ogType = 'website',
  image = '/og-image.svg',
  noindex = false,
  appShell = false,
} = Astro.props;

// Absolute URLs for canonical + social cards. Astro.site is set in the config;
// the fallback keeps `astro dev` and any preview build from throwing.
const site = Astro.site ?? new URL('https://storytellertoolbox.com');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;
const fullTitle = `${title} · Storyteller Toolbox`;

// One WebSite node on every page — gives search a stable name/description and
// (via SearchAction) advertises the in-site search so results can deep-link it.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Storyteller Toolbox',
  url: site.href,
  description:
    'Free tabletop RPG generators and printable prep sheets — random NPCs, taverns, loot, encounters, oracles, and writing prompts for GMs, solo players, and writers.',
};

const nav = [
  { href: '/world/', label: 'World' },
  { href: '/spaces/', label: 'Spaces' },
  { href: '/gm/', label: 'GM Prep' },
  { href: '/solo/', label: 'Solo Play' },
  { href: '/writing/', label: 'Writing' },
  { href: '/sheet/', label: 'Sheet Builder' },
  { href: '/library/', label: 'Library' },
];

const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#6d28d9" />
    <title>{fullTitle}</title>

    <!-- Open Graph / Twitter: links shared to Discord & Reddit render as cards -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Storyteller Toolbox" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      // Apply saved theme + genre before paint to avoid a flash. Genre
      // (PLAN.md §15) is a second axis: fantasy is the default tokens
      // (no attribute), sci-fi/horror are token packs behind [data-genre].
      const saved = localStorage.getItem('theme');
      if (saved === 'light' || saved === 'dark') {
        document.documentElement.dataset.theme = saved;
      }
      const genre = localStorage.getItem('stb:genre');
      if (genre === 'scifi' || genre === 'horror') {
        document.documentElement.dataset.genre = genre;
      }
    </script>
    {
      /* Offline shell (PLAN.md §21.7) — production builds only, so `astro
         dev` never fights a stale cache. e2e runs the built site and IS
         covered (tests/pwa.spec.ts). */
      import.meta.env.PROD && (
        <script is:inline>
          if ('serviceWorker' in navigator) {
            addEventListener('load', () => navigator.serviceWorker.register('/sw.js'));
          }
        </script>
      )
    }
  </head>
  <body class:list={[{ 'app-shell': appShell }]}>
    <header class="site-header no-print">
      <div class="container header-row">
        <a class="brand" href="/">
          <img src="/favicon.svg" alt="" width="28" height="28" />
          <span>Storyteller Toolbox</span>
        </a>
        <nav aria-label="Main">
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a href={item.href} aria-current={path.startsWith(item.href) ? 'page' : undefined}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <select id="genre-pick" class="btn" aria-label="Genre theme" title="Genre theme — recolors the whole site; individual sheets can pin their own">
          <option value="fantasy">Fantasy</option>
          <option value="scifi">Sci-fi</option>
          <option value="horror">Horror</option>
        </select>
        <button id="theme-toggle" class="btn" type="button" aria-label="Toggle color theme">◐</button>
      </div>
    </header>

    <main class:list={[{ container: !appShell }]}>
      <slot />
    </main>

    {!hideTray && <SheetTray />}

    <script>
      // Drive auto-sync courier (PLAN.md §13): boots on EVERY page so every
      // creation point — a pin, a world edit, a brew save — schedules a sync.
      // No-op until the user opts in from the /sheet/ pill.
      import { startSyncIfEnabled } from '../engine/sync';
      startSyncIfEnabled();
    </script>

    <footer class="site-footer">
      <div class="container">
        <p>
          Built on the creativity of the tabletop community —
          <a href="/about/">about &amp; attributions</a> ·
          <a href="/privacy/">privacy</a> ·
          <a href="/terms/">terms</a> ·
          Made by <a href="https://www.reddit.com/user/seriousd6/">u/seriousd6</a>
        </p>
      </div>
    </footer>

    <script>
      // Genre picker (PLAN.md §15): sets [data-genre] + persists; the packs'
      // CSS does the rest. Routed through the engine so pickers elsewhere
      // (the image fade picker) hear the change.
      import { setSiteGenre, siteGenre, isGenre } from '../engine/genres';
      const pick = document.getElementById('genre-pick') as HTMLSelectElement | null;
      if (pick) {
        pick.value = siteGenre();
        pick.addEventListener('change', () => {
          if (isGenre(pick.value)) setSiteGenre(pick.value);
        });
      }
    </script>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const root = document.documentElement;
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const current = root.dataset.theme ?? (systemDark ? 'dark' : 'light');
        const next = current === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>

    <style>
      .site-header {
        background: var(--color-surface);
        border-bottom: 1px solid var(--color-border);
      }

      .header-row {
        display: flex;
        align-items: center;
        gap: var(--space-6);
        padding-block: var(--space-3);
        flex-wrap: wrap;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-family: var(--font-display);
        font-size: var(--text-lg);
        font-weight: 700;
        color: var(--color-ink);
        text-decoration: none;
      }

      nav ul {
        display: flex;
        gap: var(--space-4);
        list-style: none;
        padding: 0;
        flex-wrap: wrap;
      }

      nav a {
        color: var(--color-ink-muted);
        text-decoration: none;
        padding-block: var(--space-1);
      }

      nav a:hover {
        color: var(--color-ink);
      }

      nav a[aria-current='page'] {
        color: var(--color-accent);
        font-weight: 600;
        border-bottom: 2px solid var(--color-accent);
      }

      #genre-pick {
        margin-left: auto;
      }

      main {
        flex: 1;
        padding-block: var(--space-8);
      }

      .site-footer {
        background: var(--color-surface-sunken);
        border-top: 1px solid var(--color-border);
        padding-block: var(--space-6);
        font-size: var(--text-sm);
        color: var(--color-ink-muted);
      }

      /* App shell (workspace pages): the document IS the page. The main
         column goes full-bleed so the editor owns its own layout, and the
         marketing footer stays on marketing pages. */
      body.app-shell main {
        max-width: none;
        padding: 0;
      }

      body.app-shell .site-footer {
        display: none;
      }
    </style>
  </body>
</html>
