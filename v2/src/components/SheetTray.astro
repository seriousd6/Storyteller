---
// The always-visible worksheet tray: shows the active sheet on every page,
// supports drag-to-reorder and remove, and links to the full Sheet Builder.
---

<aside class="tray no-print" data-tray hidden>
  <button class="tray-toggle btn" data-tray-toggle type="button" aria-expanded="false" title="Show / hide the worksheet">
    📋 <span data-tray-count>0</span>
  </button>
  <div class="tray-panel" data-tray-panel hidden>
    <header class="tray-head">
      <strong data-tray-name>Sheet</strong>
      <span class="tray-head-actions">
        <a href="/sheet/" title="Open the full Sheet Builder">Edit ↗</a>
        <button class="tray-dismiss" data-tray-dismiss type="button" aria-label="Hide the worksheet tray" title="Hide the tray — a small tab brings it back">✕</button>
      </span>
    </header>
    <p class="tray-hint">Drag to reorder · pin 📌 from any generator</p>
    <ol class="tray-list" data-tray-list></ol>
    <p class="tray-empty" data-tray-empty>Nothing pinned yet.</p>
  </div>
</aside>
<button class="tray-restore btn no-print" data-tray-restore type="button" hidden title="Show the worksheet tray">
  📋 <span data-tray-restore-count>0</span>
</button>

<script>
  import { initSheetStore, loadStore, saveStore, getActive, SHEET_EVENT } from '../engine/sheetStore';
  import type { Block } from '../engine/types';
  import { enableDragReorder, moveItem } from '../engine/dragList';

  await initSheetStore(); // IndexedDB-backed since PLAN.md §8 — hydrate the mirror first

  const SOURCE = 'tray';
  const COLLAPSE_KEY = 'stb:tray:open';
  const DISMISS_KEY = 'stb:tray:dismissed';

  const root = document.querySelector<HTMLElement>('[data-tray]');
  const restore = document.querySelector<HTMLButtonElement>('[data-tray-restore]');
  if (root && restore) {
    const toggle = root.querySelector<HTMLButtonElement>('[data-tray-toggle]')!;
    const panel = root.querySelector<HTMLElement>('[data-tray-panel]')!;
    const list = root.querySelector<HTMLElement>('[data-tray-list]')!;
    const nameEl = root.querySelector<HTMLElement>('[data-tray-name]')!;
    const countEl = root.querySelector<HTMLElement>('[data-tray-count]')!;
    const emptyEl = root.querySelector<HTMLElement>('[data-tray-empty]')!;
    const dismissBtn = root.querySelector<HTMLButtonElement>('[data-tray-dismiss]')!;
    const restoreCount = restore.querySelector<HTMLElement>('[data-tray-restore-count]')!;

    const blockText = (b: Block): string => {
      switch (b.type) {
        case 'title':
          return b.text;
        case 'paragraph':
          return b.label ? `${b.label}: ${b.text}` : b.text;
        case 'keyValue':
          return b.pairs.map((p) => `${p.key}: ${p.value}`).join(' · ');
        case 'list':
          return `${b.label ?? 'List'} (${b.items.length})`;
        case 'table':
          return `${b.label ?? 'Table'} (${b.rows.length} rows)`;
        case 'statblock':
          return b.name;
        case 'rollTable':
          return `🎲 ${b.title ?? b.ref}`;
        case 'pageBreak':
          return '✂ page break';
        case 'tracker':
          return `${b.label}: ${b.current}${b.max !== undefined ? `/${b.max}` : ''}`;
        case 'statGrid':
          return b.stats.map((s) => `${s.label} ${s.value}`).join(' · ');
        case 'actions':
          return `⚔ ${b.title ?? `${b.items.length} action(s)`}`;
        case 'image':
          return `🖼 ${b.caption ?? (b.assetId ? 'image' : b.portrait ? 'portrait' : 'empty image slot')}`;
        case 'columns':
          return `⫴ columns (${b.columns.reduce((n, c) => n + c.length, 0)} block(s))`;
        case 'entityRef':
          return `🌍 world entity`;
        case 'choice':
          return `${b.label}: ${b.value}`;
        case 'choiceList':
          return `${b.label} (${b.values.length})`;
        case 'profGrid':
          return `☑ ${b.label ?? 'Proficiencies'} (${b.items.length})`;
      }
    };

    function render() {
      const store = loadStore();
      const sheet = getActive(store);
      nameEl.textContent = sheet.name;
      countEl.textContent = String(sheet.blocks.length);
      restoreCount.textContent = String(sheet.blocks.length);
      emptyEl.hidden = sheet.blocks.length > 0;
      list.replaceChildren(
        ...sheet.blocks.map((block, i) => {
          const li = document.createElement('li');
          li.className = 'tray-item';
          li.draggable = true;
          const grip = document.createElement('span');
          grip.className = 'tray-grip';
          grip.textContent = '⠿';
          const text = document.createElement('span');
          text.className = 'tray-text';
          text.textContent = blockText(block);
          text.title = blockText(block);
          const remove = document.createElement('button');
          remove.type = 'button';
          remove.className = 'tray-remove';
          remove.textContent = '✕';
          remove.title = 'Remove from sheet';
          remove.setAttribute('aria-label', 'Remove from sheet');
          remove.addEventListener('click', () => {
            const s = loadStore();
            getActive(s).blocks.splice(i, 1);
            saveStore(s, SOURCE);
            render();
          });
          li.append(grip, text, remove);
          return li;
        }),
      );
    }

    enableDragReorder(list, '.tray-item', (from, to) => {
      const store = loadStore();
      moveItem(getActive(store).blocks, from, to);
      saveStore(store, SOURCE);
      render();
    });

    const setOpen = (open: boolean, persist = true) => {
      panel.hidden = !open;
      toggle.setAttribute('aria-expanded', String(open));
      if (persist) localStorage.setItem(COLLAPSE_KEY, open ? '1' : '0');
    };
    toggle.addEventListener('click', () => setOpen(panel.hidden));

    // Full dismiss: hide the whole tray (toggle and all), leaving only a small
    // restore tab in the corner. The pinned sheet is untouched — this is just
    // getting the floating UI out of the way.
    const setDismissed = (dismissed: boolean, persist = true) => {
      root.hidden = dismissed;
      restore.hidden = !dismissed;
      if (persist) localStorage.setItem(DISMISS_KEY, dismissed ? '1' : '0');
    };
    dismissBtn.addEventListener('click', () => setDismissed(true));
    restore.addEventListener('click', () => {
      setDismissed(false);
      setOpen(true); // bring it back already open so the sheet is right there
    });

    // Debounced: SHEET_EVENT fires on every keystroke in the Sheet Builder,
    // and a full parse+rebuild of the tray per keystroke is real jank on a
    // large sheet. One render shortly after the burst settles is the same UX.
    let renderT = 0;
    window.addEventListener(SHEET_EVENT, ((e: CustomEvent) => {
      if (e.detail?.source === SOURCE) return;
      clearTimeout(renderT);
      renderT = window.setTimeout(render, 120);
    }) as EventListener);

    // Small screens always start collapsed so the tray never sits on top of
    // generator controls; the toggle still opens it (and remembers nothing
    // it wasn't told to).
    const stored = localStorage.getItem(COLLAPSE_KEY);
    const small = window.matchMedia('(max-width: 900px)').matches;
    setOpen(small ? false : stored !== null ? stored === '1' : window.innerWidth >= 1200, false);
    render();
    // Respect a prior full-dismiss: until the user restores it, only the tab shows.
    setDismissed(localStorage.getItem(DISMISS_KEY) === '1', false);
  }
</script>

<style is:global>
  /* Tray items are runtime-rendered — global styles, scoped under .tray */
  .tray {
    position: fixed;
    right: var(--space-4);
    bottom: var(--space-4);
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
  }

  /* display:flex above would override the UA [hidden] rule on full dismiss. */
  .tray[hidden] {
    display: none;
  }

  .tray-toggle {
    box-shadow: var(--shadow);
    font-size: var(--text-base);
  }

  .tray-head-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .tray-dismiss {
    border: none;
    background: none;
    color: var(--color-ink-muted);
    cursor: pointer;
    font-size: var(--text-sm);
    line-height: 1;
    padding: 2px 5px;
    border-radius: var(--radius);
  }

  .tray-dismiss:hover {
    color: var(--color-accent);
    background: var(--color-bg);
  }

  /* The restore tab that remains after a full dismiss. */
  .tray-restore {
    position: fixed;
    right: var(--space-4);
    bottom: var(--space-4);
    z-index: 50;
    box-shadow: var(--shadow);
    font-size: var(--text-base);
    opacity: 0.8;
  }

  .tray-restore:hover {
    opacity: 1;
  }

  /* .btn sets display, which would override the UA [hidden] rule — restore it. */
  .tray-restore[hidden] {
    display: none;
  }

  .tray-panel {
    width: min(19rem, calc(100vw - 2 * var(--space-4)));
    max-height: min(60vh, 34rem);
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: var(--space-3);
  }

  /* Same [hidden]-vs-display trap as .tray and .tray-restore above. Without
     this the collapse toggle (and the small-screen default-closed) never
     actually hides the panel — it just sits over the page. */
  .tray-panel[hidden] {
    display: none;
  }

  .tray-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-2);
  }

  .tray-head strong {
    color: var(--color-statblock);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tray-hint {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin-block: var(--space-1) var(--space-2);
  }

  .tray-list {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-y: auto;
    display: grid;
    gap: var(--space-1);
  }

  .tray-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    cursor: grab;
  }

  .tray-item.dragging {
    opacity: 0.5;
    border-style: dashed;
  }

  .tray-grip {
    color: var(--color-ink-muted);
    cursor: grab;
  }

  .tray-text {
    flex: 1;
    font-size: var(--text-sm);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tray-remove {
    border: none;
    background: none;
    color: var(--color-ink-muted);
    cursor: pointer;
    padding: 0 var(--space-1);
  }

  .tray-remove:hover {
    color: var(--color-accent);
  }

  .tray-empty {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  /* On small screens keep the open panel short so page content stays reachable. */
  @media (max-width: 900px) {
    .tray-panel {
      max-height: 40vh;
    }
  }
</style>
