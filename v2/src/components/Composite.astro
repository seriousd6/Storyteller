---
// UI for composite generators: option dropdowns, one Generate button, a
// sheet-styled preview of the emitted blocks, and add-to-sheet. Optionally a
// countdown timer (meta.timer) and a caption note (meta.note).
import WorldSavePanel from './WorldSavePanel.astro';
import type { CompositeMeta } from '../engine/composite';

interface Props {
  meta: CompositeMeta;
}

const { meta } = Astro.props;
---

<section class="composite" data-composite>
  <script type="application/json" data-meta is:inline set:html={JSON.stringify(meta)} />

  <div class="gen-toolbar no-print">
    {
      meta.options.map((opt) => (
        <label class="opt">
          {opt.label}
          <select data-opt={opt.id}>
            {opt.choices.map((choice) => (
              <option value={choice.value} selected={choice.value === opt.default}>
                {choice.label}
              </option>
            ))}
          </select>
          <small class="opt-note" data-opt-note={opt.id}></small>
        </label>
      ))
    }
    <button class="btn btn-primary" data-generate type="button">🎲 Generate</button>
    <button class="btn" data-add type="button">📌 {meta.addLabel}</button>
    <button class="btn" data-copy type="button" title="Copy the result to your clipboard">📋 Copy</button>
    <button class="btn" data-link type="button" title="Copy a link that reproduces this exact result">🔗 Link</button>
    <button class="btn" data-full-page type="button" title="Open this build as an editable, printable page in the Sheet Builder — carrying these dials, so you can add or remove sections and reroll">📄 Full page →</button>
    <button class="btn" data-save-world type="button" title="Save this result as a page in one of your worlds">🌍 Save to world</button>
  </div>

  <WorldSavePanel />

  {meta.note && <p class="composite-note no-print">{meta.note}</p>}

  {
    meta.timer && (
      <div class="timer no-print" data-timer data-timer-opt={meta.timer}>
        <span class="timer-clock" data-timer-clock>00:00</span>
        <button class="btn btn-primary" data-timer-start type="button">▶ Start</button>
        <button class="btn" data-timer-reset type="button">↺ Reset</button>
      </div>
    )
  }

  <div class="preview" data-preview aria-live="polite"></div>
  <p class="preview-hint no-print">
    Generate until it sings, then pin it — the result lands on your worksheet as an
    editable block you can rearrange and print from the Sheet Builder.
  </p>
</section>

<script>
  import { randomSeed } from '../engine/rng';
  import { addBlockToActive } from '../engine/sheetStore';
  import { renderBlockStatic } from '../engine/blockRender';
  import type { CompositeMeta, CompositeModule } from '../engine/composite';
  import type { Block, Table, TableRegistry } from '../engine/types';
  import { getWorld } from '../engine/worldStore';
  import { wireWorldSave } from '../everdeep/worldSave';
  import { buildPortraitSVG, defaultRecipe, knownRace } from '../everdeep/portraits';

  const modules = import.meta.glob<CompositeModule>('../composites/*.ts');
  const registries = import.meta.glob<Record<string, Table>>('../generators/registries/*.json', {
    import: 'default',
  });

  async function setup(root: HTMLElement) {
    const metaEl = root.querySelector('script[data-meta]');
    if (!metaEl?.textContent) return;
    const meta: CompositeMeta = JSON.parse(metaEl.textContent);
    const tool = meta.id.split('/')[1];

    const loadModule = modules[`../composites/${tool}.ts`];
    const loadRegistry = registries[`../generators/registries/${tool}.json`];
    if (!loadModule || !loadRegistry) {
      console.error(`Missing module or registry for "${meta.id}" — run npm run registries`);
      return;
    }
    const [mod, registry] = await Promise.all([loadModule(), loadRegistry()]);
    const { build } = mod;
    const lockOpts = (mod as { lockOpts?: (t: TableRegistry, s: string, o: Record<string, string>) => Record<string, string> }).lockOpts;
    const tables: TableRegistry = new Map(Object.entries(registry));

    const preview = root.querySelector<HTMLElement>('[data-preview]')!;
    const selects = [...root.querySelectorAll<HTMLSelectElement>('select[data-opt]')];

    // Dependent dials: a composite can recompute a dial's choices / disabled
    // state / note from the current selections (e.g. the subclass list follows
    // the chosen class and unlocks at the class's subclass level). Applied on
    // load and before every generate. Most composites define no refineOptions.
    const refineOptions = mod.refineOptions;
    const escAttr = (s: string) => s.replace(/&/g, '&amp;').replace(/"/g, '&quot;');
    const escHtmlOpt = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;');
    function applyRefine(desired?: Record<string, string>): void {
      if (!refineOptions) return;
      const cur: Record<string, string> = {};
      for (const s of selects) cur[s.dataset.opt!] = s.value;
      const refined = refineOptions(cur);
      for (const sel of selects) {
        const spec = refined[sel.dataset.opt!];
        if (!spec) continue;
        if (spec.choices) {
          const want = desired?.[sel.dataset.opt!] ?? sel.value;
          sel.innerHTML = spec.choices
            .map((c) => `<option value="${escAttr(c.value)}">${escHtmlOpt(c.label)}</option>`)
            .join('');
          if ([...sel.options].some((o) => o.value === want)) sel.value = want;
        }
        if (spec.disabled !== undefined) sel.disabled = spec.disabled;
        const note = root.querySelector<HTMLElement>(`[data-opt-note="${sel.dataset.opt}"]`);
        if (note) note.textContent = spec.note ?? '';
      }
    }

    let blocks: Block[] = [];
    let seed = '';
    let lastOpts: Record<string, string> = {};
    // Per-part reroll counters: key `${topIdx}:${sectionIdx | 'name' | 'whole'}`
    // → nonce. Rerolling one part re-runs build() with a salted seed and swaps
    // in only that part, so the rest of the page stays put. Persisted in the
    // hash so a shared link reproduces a partially-rerolled page exactly.
    let nonces: Record<string, number> = {};
    // Locked parts: key → the seed that produced the value to KEEP. "Generate"
    // rerolls everything except locked parts, which are re-derived from their
    // frozen seed (so a locked piece survives a fresh seed and reproduces from a
    // shared link). Locking a piece supersedes any reroll nonce on it.
    let locks: Record<string, string> = {};

    // Share URLs: a composite result is fully determined by (seed, options, the
    // per-part reroll nonces, the locks), so mirror them all into the hash.
    function writeHash() {
      const params = new URLSearchParams();
      params.set('seed', seed);
      for (const sel of selects) if (sel.value) params.set(sel.dataset.opt!, sel.value);
      if (Object.keys(nonces).length) params.set('rr', JSON.stringify(nonces));
      if (Object.keys(locks).length) params.set('lk', JSON.stringify(locks));
      history.replaceState(null, '', '#' + params.toString());
    }
    function readShared():
      | { seed: string; opts: Record<string, string>; nonces: Record<string, number>; locks: Record<string, string> }
      | null {
      const raw = location.hash.replace(/^#/, '');
      if (!raw) return null;
      const params = new URLSearchParams(raw);
      const s = params.get('seed');
      if (!s) return null;
      const opts: Record<string, string> = {};
      for (const sel of selects) {
        const v = params.get(sel.dataset.opt!);
        if (v !== null) opts[sel.dataset.opt!] = v;
      }
      const parse = <T,>(p: string): T | Record<string, never> => {
        try {
          const raw2 = params.get(p);
          return raw2 ? (JSON.parse(raw2) as T) : {};
        } catch {
          return {}; // malformed reroll/lock state — ignore, fall back to the base roll
        }
      };
      return { seed: s, opts, nonces: parse<Record<string, number>>('rr'), locks: parse<Record<string, string>>('lk') };
    }
    const shared = readShared();

    // ── Per-part reroll ────────────────────────────────────────────────────
    // The label a section is matched by across rerolls — stable enough to find
    // "the same" section in a freshly-salted build (keyValue → its first key,
    // statblock → its name), else we fall back to position.
    type Labelled = { label?: string };
    const sectionLabel = (b: Block): string | null =>
      (b as Labelled).label ??
      (b.type === 'statblock' ? b.name : b.type === 'keyValue' ? (b.pairs[0]?.key ?? null) : null);

    // A reroll target, encoded as a stable key for the nonce map + share hash.
    // Forms: `${t}:name`, `${t}:whole`, `${t}:s${sec}`, `${t}:s${sec}:i${item}`
    // (an item of a list SECTION), `${t}:i${item}` (an item of a top-level list
    // block). A bare `${t}:${n}` still reads as a section, for links shared
    // before the `s`-prefix landed.
    type Target =
      | { t: number; k: 'name' }
      | { t: number; k: 'whole' }
      | { t: number; k: 'sec'; sec: number }
      | { t: number; k: 'secItem'; sec: number; item: number }
      | { t: number; k: 'topItem'; item: number };

    function targetKey(tg: Target): string {
      switch (tg.k) {
        case 'name': return `${tg.t}:name`;
        case 'whole': return `${tg.t}:whole`;
        case 'sec': return `${tg.t}:s${tg.sec}`;
        case 'secItem': return `${tg.t}:s${tg.sec}:i${tg.item}`;
        case 'topItem': return `${tg.t}:i${tg.item}`;
      }
    }
    function parseKey(key: string): Target | null {
      const p = key.split(':');
      const t = Number(p[0]);
      if (Number.isNaN(t)) return null;
      const a = p[1] ?? '';
      if (a === 'name') return { t, k: 'name' };
      if (a === 'whole') return { t, k: 'whole' };
      if (a.startsWith('i')) return { t, k: 'topItem', item: Number(a.slice(1)) };
      const sec = a.startsWith('s') ? Number(a.slice(1)) : Number(a);
      if (Number.isNaN(sec)) return null;
      const b = p[2] ?? '';
      if (b.startsWith('i')) return { t, k: 'secItem', sec, item: Number(b.slice(1)) };
      return { t, k: 'sec', sec };
    }

    /** The value for a target from a build: a block, a name/item string, or null
     *  if the shape doesn't fit. Sections are matched by label first (survives
     *  reordering / variable structure), then by index. */
    function valueFor(from: Block[], tg: Target): Block | string | null {
      const ft = from[tg.t];
      if (!ft) return null;
      if (tg.k === 'whole') return ft;
      if (tg.k === 'name') return ft.type === 'statblock' ? ft.name : null;
      if (tg.k === 'topItem') return ft.type === 'list' ? (ft.items[tg.item] ?? null) : null;
      if (ft.type !== 'statblock') return null;
      const curTop = blocks[tg.t];
      const cur = curTop && curTop.type === 'statblock' ? curTop.sections[tg.sec] : undefined;
      const label = cur ? sectionLabel(cur) : null;
      const sec = (label ? ft.sections.find((s) => sectionLabel(s) === label) : undefined) ?? ft.sections[tg.sec];
      if (!sec) return null;
      if (tg.k === 'sec') return sec;
      return sec.type === 'list' ? (sec.items[tg.item] ?? null) : null;
    }
    function applyValue(tg: Target, value: Block | string): void {
      const top = blocks[tg.t];
      if (tg.k === 'whole') { blocks[tg.t] = value as Block; return; }
      if (tg.k === 'topItem') { if (top?.type === 'list' && tg.item < top.items.length) top.items[tg.item] = value as string; return; }
      if (top?.type !== 'statblock') return;
      if (tg.k === 'name') { top.name = value as string; return; }
      if (tg.sec >= top.sections.length) return; // structure shrank (variable page) — skip
      if (tg.k === 'sec') { top.sections[tg.sec] = value as Block; return; }
      const sec = top.sections[tg.sec];
      if (sec?.type === 'list' && tg.item < sec.items.length) sec.items[tg.item] = value as string;
    }
    const asText = (v: Block | string | null): string => (v == null ? '' : typeof v === 'string' ? v : JSON.stringify(v));

    /** Reroll one target: bump its nonce and swap in the salted build's version,
     *  trying a few nonces so a click that lands the same text keeps looking. */
    function rerollTarget(tg: Target): void {
      const key = targetKey(tg);
      const from = nonces[key] ?? 0;
      const before = asText(valueFor(blocks, tg));
      let chosen: { n: number; v: Block | string } | null = null;
      for (let i = 0; i < 5; i++) {
        const n = from + 1 + i;
        const v = valueFor(build(tables, `${seed}#rr:${key}:${n}`, lastOpts), tg);
        if (v == null) continue;
        if (!chosen) chosen = { n, v };
        if (asText(v) !== before) {
          chosen = { n, v };
          break;
        }
      }
      if (!chosen) return;
      nonces[key] = chosen.n;
      applyValue(tg, chosen.v);
      // a locked part stays locked, now on the NEW value
      if (locks[key]) locks[key] = `${seed}#rr:${key}:${chosen.n}`;
      renderPreview();
      writeHash();
    }

    // The seed that currently produces a target's value — its reroll salt if
    // rerolled, else the base seed. What a lock freezes.
    const sourceSeed = (key: string): string => (nonces[key] ? `${seed}#rr:${key}:${nonces[key]}` : seed);
    /** Lock (pin) a target so "Generate" keeps it, or unlock it. */
    function toggleLock(tg: Target): void {
      const key = targetKey(tg);
      if (locks[key]) delete locks[key];
      else locks[key] = sourceSeed(key);
      renderPreview();
      writeHash();
    }

    function iconButton(onClick: () => void, title: string, cls: string): HTMLButtonElement {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = `${cls} no-print`; // glyph via CSS ::before so it stays out of Copy's innerText
      b.title = title;
      b.setAttribute('aria-label', title);
      b.addEventListener('click', (e) => {
        e.stopPropagation();
        onClick();
      });
      return b;
    }

    // Mount the 🎲 + 🔒 pair at the corner of a name/section/block, and mark the
    // host as locked so the whole piece reads as pinned.
    function mountControls(host: HTMLElement, tg: Target, what: string): void {
      const key = targetKey(tg);
      const locked = !!locks[key];
      host.classList.add('rr-host');
      host.classList.toggle('rr-locked', locked);
      const group = document.createElement('span');
      group.className = 'rr-controls no-print';
      group.appendChild(iconButton(() => rerollTarget(tg), `Reroll ${what}`, 'rr-btn'));
      const lock = iconButton(() => toggleLock(tg), locked ? `Locked — “Generate” keeps ${what}` : `Lock ${what} so “Generate” keeps it`, `rr-lock${locked ? ' is-locked' : ''}`);
      lock.setAttribute('aria-pressed', String(locked));
      group.appendChild(lock);
      host.appendChild(group);
    }

    // A trailing 🎲 on each <li>, so one gem / name / rumor / monster rerolls on
    // its own — not the whole list.
    function addItemButtons(sectionEl: HTMLElement, target: (item: number) => Target): void {
      [...sectionEl.querySelectorAll('li')].forEach((li, k) => {
        li.classList.add('rr-item-host');
        li.appendChild(iconButton(() => rerollTarget(target(k)), 'Reroll this item', 'rr-item'));
      });
    }

    // Draw the blocks with 🎲 + 🔒 on the name and every section (and on any
    // non-statblock top-level block), plus a per-item 🎲 inside every list, then
    // re-sketch the portrait if present.
    function renderPreview(): void {
      const nodes: HTMLElement[] = [];
      blocks.forEach((block, topIdx) => {
        const el = renderBlockStatic(block);
        if (block.type === 'statblock') {
          const h3 = el.querySelector('h3') as HTMLElement | null;
          if (h3) mountControls(h3, { t: topIdx, k: 'name' }, 'the name');
          const sectionEls = [...el.children].filter((c) => c.classList.contains('b')) as HTMLElement[];
          block.sections.forEach((section, j) => {
            const sEl = sectionEls[j];
            if (!sEl) return;
            mountControls(sEl, { t: topIdx, k: 'sec', sec: j }, 'this section');
            if (section.type === 'list') addItemButtons(sEl, (item) => ({ t: topIdx, k: 'secItem', sec: j, item }));
          });
        } else {
          mountControls(el, { t: topIdx, k: 'whole' }, 'this');
          if (block.type === 'list') addItemButtons(el, (item) => ({ t: topIdx, k: 'topItem', item }));
        }
        nodes.push(el);
      });
      preview.replaceChildren(...nodes);
      maybePortrait();
    }

    // If the result names a race, sketch the face to go with it — the portrait
    // is seeded by the same roll, so this person keeps this face.
    function maybePortrait(): void {
      const txt = JSON.stringify(blocks);
      const m =
        /Race:\s*([A-Za-z -]+?)\s*(?:\(\s*(male|female)\s*\))?\s*\./.exec(txt) ??
        /"meta":"([A-Za-z -]+?)(?:\s*\(\s*(male|female)\s*\))?\s*(?:·|")/.exec(txt);
      const race = m ? knownRace(m[1]) : null;
      if (!race) return;
      const card = document.createElement('div');
      card.className = 'npc-portrait';
      card.innerHTML = buildPortraitSVG(defaultRecipe(seed, race, (m![2] as 'male' | 'female') ?? null), seed);
      card.style.cssText = 'float:right;width:138px;background:#faf6ea;border:1px solid #d8d0bc;border-radius:9px;padding:4px;box-shadow:1px 2px 5px #0002;transform:rotate(0.8deg);margin:0 0 10px 14px;';
      const svgEl = card.querySelector('svg');
      if (svgEl) {
        svgEl.style.display = 'block';
        svgEl.style.width = '100%';
        svgEl.style.height = 'auto';
      }
      const faceBtn = document.createElement('button');
      faceBtn.type = 'button';
      faceBtn.className = 'no-print';
      faceBtn.textContent = '🎲 new face';
      faceBtn.style.cssText = 'display:block;width:100%;margin-top:3px;font-size:11px;padding:2px 4px;cursor:pointer;';
      faceBtn.addEventListener('click', () => {
        const salt = seed + '/face:' + Math.random().toString(36).slice(2, 8);
        card.querySelector('svg')?.remove();
        faceBtn.insertAdjacentHTML('beforebegin', buildPortraitSVG(defaultRecipe(salt, race!, (m![2] as 'male' | 'female') ?? null), salt));
        const sv = card.querySelector('svg');
        if (sv) {
          sv.style.display = 'block';
          sv.style.width = '100%';
          sv.style.height = 'auto';
        }
      });
      card.appendChild(faceBtn);
      preview.prepend(card);
    }

    function generate(fixedSeed?: string, opt: { keepNonces?: boolean; keepLocks?: boolean } = {}): void {
      seed = fixedSeed ?? randomSeed();
      const opts: Record<string, string> = {};
      for (const sel of selects) opts[sel.dataset.opt!] = sel.value;
      lastOpts = opts;
      if (!opt.keepNonces) nonces = {};
      if (!opt.keepLocks) locks = {};
      blocks = build(tables, seed, opts);
      // Reproduce persisted per-part rerolls (shared links), on the current seed.
      for (const key of Object.keys(nonces)) {
        const tg = parseKey(key);
        if (!tg) continue;
        const v = valueFor(build(tables, `${seed}#rr:${key}:${nonces[key]}`, opts), tg);
        if (v != null) applyValue(tg, v);
      }
      // Then overlay locked parts, re-derived from their own frozen seed — so a
      // locked piece survives a fresh seed and a shared link reproduces it.
      for (const key of Object.keys(locks)) {
        const tg = parseKey(key);
        if (!tg) continue;
        const v = valueFor(build(tables, locks[key]!, opts), tg);
        if (v != null) applyValue(tg, v);
      }
      renderPreview();
      writeHash();
    }

    // "Generate" rerolls everything EXCEPT locked parts; changing an option is a
    // fresh configuration, so it clears the locks (and rerolls).
    root.querySelector('[data-generate]')?.addEventListener('click', () => generate(undefined, { keepLocks: true }));
    // A change may reshape dependent dials (subclass follows class) before the reroll.
    for (const sel of selects) sel.addEventListener('change', () => { applyRefine(); generate(); });

    // Size to the active world's party (batch 94): if the GM has set a party
    // composition on their open world, an Encounter or Hoard rolled here defaults
    // to it — level, headcount, and (for hoards) the matching challenge tier —
    // so the fight and its loot fit the table. The GM can still override.
    // A shared link is authoritative — skip party sizing so it reproduces exactly.
    if (!shared) void applyPartyDefaults(meta.id, selects, () => generate());

    setupTimer(root, selects);

    root.querySelector('[data-add]')?.addEventListener('click', (ev) => {
      if (!blocks.length) return;
      for (const block of blocks) {
        const copy: Block = structuredClone(block);
        copy.id = `pin-${randomSeed()}`;
        copy.source = { generator: meta.id, seed };
        addBlockToActive(copy);
      }
      const btn = ev.currentTarget as HTMLButtonElement;
      const original = btn.textContent;
      btn.textContent = '✓ Added';
      setTimeout(() => (btn.textContent = original), 900);
    });

    root.querySelector('[data-copy]')?.addEventListener('click', (ev) => {
      // Copy the prose only — drop the reroll/portrait buttons from the text.
      const clone = preview.cloneNode(true) as HTMLElement;
      clone.querySelectorAll('button').forEach((b) => b.remove());
      const text = clone.innerText.trim();
      if (!text) return;
      const btn = ev.currentTarget as HTMLButtonElement;
      const original = btn.textContent;
      void navigator.clipboard
        ?.writeText(text)
        .then(() => {
          btn.textContent = '✓ Copied';
          setTimeout(() => (btn.textContent = original), 900);
        })
        .catch(() => {});
    });

    root.querySelector('[data-link]')?.addEventListener('click', (ev) => {
      const btn = ev.currentTarget as HTMLButtonElement;
      const original = btn.textContent;
      void navigator.clipboard
        ?.writeText(location.href)
        .then(() => {
          btn.textContent = '✓ Link copied';
          setTimeout(() => (btn.textContent = original), 1200);
        })
        .catch(() => {});
    });

    // Lift the current build into the Sheet Builder as an editable one-pager
    // (GENERATORS-AS-ONEPAGERS.md §3.2/§3.3): carry the seed and the dials so
    // /sheet/ rebuilds it identically, then it's a full document — add/remove
    // sections, reroll, print. (Per-part rerolls done here aren't carried; the
    // base build for these dials + seed is what opens.)
    root.querySelector('[data-full-page]')?.addEventListener('click', () => {
      const params = new URLSearchParams();
      params.set('template', meta.id);
      params.set('seed', seed);
      for (const sel of selects) if (sel.value) params.set(sel.dataset.opt!, sel.value);
      location.href = `/sheet/?${params.toString()}`;
    });

    // Save this result as a permanent page in one of the user's worlds —
    // the generation→wiki bridge (Everdeep Phase B). Shared with the slot
    // pages since batch B of the GM/solo audit: one implementation, two islands.
    wireWorldSave(root, {
      generatorId: meta.id,
      fallbackName: meta.title,
      getBlocks: () => blocks,
      getSeed: () => seed,
      // the options this page was rolled WITH survive its future rerolls
      // (batch 93 machinery): a Fishing Village saved to a world stays one
      getLockedOpts: () => lockOpts?.(tables, seed, lastOpts),
    });

    if (shared) {
      for (const sel of selects) {
        const v = shared.opts[sel.dataset.opt!];
        if (v != null && [...sel.options].some((o) => o.value === v)) sel.value = v;
      }
      // Repopulate dependent dials from the shared class/level, then select the
      // shared subclass value (which the base meta options didn't yet contain).
      applyRefine(shared.opts);
      nonces = shared.nonces ?? {};
      locks = shared.locks ?? {};
      generate(shared.seed, { keepNonces: true, keepLocks: true });
    } else {
      applyRefine();
      generate();
    }
  }

  // Size the Encounter/Hoard tools to the active world's party (batch 94). Reads
  // the party composition the GM set on their open world and pre-selects level,
  // headcount, and the matching hoard challenge tier; then re-rolls so the first
  // result already fits. Silent no-op for other tools or when no party is set.
  const ACTIVE_WORLD_KEY = 'stb:everdeep:activeWorld';
  async function applyPartyDefaults(metaId: string, selects: HTMLSelectElement[], generate: () => void) {
    if (metaId !== 'gm/encounter' && metaId !== 'gm/hoard') return;
    const id = localStorage.getItem(ACTIVE_WORLD_KEY);
    if (!id) return;
    const world = await getWorld(id);
    const party = world?.settings?.party;
    if (!party) return;
    const level = Math.min(20, Math.max(1, party.level ?? 3));
    const size = Math.min(8, Math.max(1, party.size ?? 4));
    const set = (opt: string, value: string): boolean => {
      const sel = selects.find((s) => s.dataset.opt === opt);
      if (!sel || ![...sel.options].some((o) => o.value === value)) return false;
      sel.value = value;
      return true;
    };
    let changed = false;
    if (metaId === 'gm/encounter') {
      changed = set('level', String(level)) || changed;
      changed = set('size', String(size)) || changed;
    } else {
      const tier = level <= 4 ? '0-4' : level <= 10 ? '5-10' : level <= 16 ? '11-16' : '17+';
      changed = set('tier', tier) || changed;
    }
    if (changed) generate();
  }

  // Countdown timer for timed exercises (writing challenge). Reads its minutes
  // from the select whose id matches meta.timer.
  function setupTimer(root: HTMLElement, selects: HTMLSelectElement[]) {
    const timer = root.querySelector<HTMLElement>('[data-timer]');
    if (!timer) return;
    const optId = timer.dataset.timerOpt!;
    const source = selects.find((s) => s.dataset.opt === optId);
    const clock = timer.querySelector<HTMLElement>('[data-timer-clock]')!;
    let remaining = 0;
    let handle: ReturnType<typeof setInterval> | null = null;

    const minutes = () => Math.max(1, parseInt(source?.value ?? '10', 10) || 10);
    const paint = () => {
      const m = Math.floor(remaining / 60);
      const s = remaining % 60;
      clock.textContent = `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      timer.classList.toggle('timer-done', remaining === 0 && handle === null);
    };
    const stop = () => {
      if (handle) clearInterval(handle);
      handle = null;
    };
    const reset = () => {
      stop();
      remaining = minutes() * 60;
      paint();
    };
    const startBtn = timer.querySelector<HTMLButtonElement>('[data-timer-start]')!;
    startBtn.addEventListener('click', () => {
      if (handle) {
        stop();
        startBtn.textContent = '▶ Resume';
        return;
      }
      if (remaining === 0) remaining = minutes() * 60;
      startBtn.textContent = '❚❚ Pause';
      handle = setInterval(() => {
        remaining = Math.max(0, remaining - 1);
        paint();
        if (remaining === 0) {
          stop();
          startBtn.textContent = '▶ Start';
          timer.classList.add('timer-done');
        }
      }, 1000);
    });
    timer.querySelector('[data-timer-reset]')?.addEventListener('click', () => {
      reset();
      startBtn.textContent = '▶ Start';
    });
    source?.addEventListener('change', () => {
      if (!handle) reset();
    });
    reset();
  }

  document.querySelectorAll<HTMLElement>('[data-composite]').forEach(setup);
</script>

