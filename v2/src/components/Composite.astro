---
// UI for composite generators: option dropdowns, one Generate button, a
// sheet-styled preview of the emitted blocks, and add-to-sheet. Optionally a
// countdown timer (meta.timer) and a caption note (meta.note).
import type { CompositeMeta } from '../engine/composite';

interface Props {
  meta: CompositeMeta;
}

const { meta } = Astro.props;
---

<section class="composite" data-composite>
  <script type="application/json" data-meta is:inline set:html={JSON.stringify(meta)} />

  <div class="gen-toolbar no-print">
    {
      meta.options.map((opt) => (
        <label class="opt">
          {opt.label}
          <select data-opt={opt.id}>
            {opt.choices.map((choice) => (
              <option value={choice.value} selected={choice.value === opt.default}>
                {choice.label}
              </option>
            ))}
          </select>
        </label>
      ))
    }
    <button class="btn btn-primary" data-generate type="button">🎲 Generate</button>
    <button class="btn" data-add type="button">📌 {meta.addLabel}</button>
    <button class="btn" data-save-world type="button" title="Save this result as a page in one of your worlds">🌍 Save to world</button>
  </div>

  <div class="world-save no-print" data-world-save hidden>
    <label>World <select data-world-pick></select></label>
    <label>Inside <select data-parent-pick></select></label>
    <button class="btn btn-primary" data-world-confirm type="button">Save page</button>
    <button class="btn" data-world-cancel type="button">✕</button>
    <span class="world-save-status" data-world-status aria-live="polite"></span>
  </div>

  <style>
    .world-save {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin: 8px 0;
      padding: 8px 12px;
      border: 1px dashed #8886;
      border-radius: 8px;
      font-size: 0.9rem;
    }
    .world-save label { display: flex; gap: 6px; align-items: center; }
    .world-save-status { font-size: 0.85rem; opacity: 0.85; }
  </style>

  {meta.note && <p class="composite-note no-print">{meta.note}</p>}

  {
    meta.timer && (
      <div class="timer no-print" data-timer data-timer-opt={meta.timer}>
        <span class="timer-clock" data-timer-clock>00:00</span>
        <button class="btn btn-primary" data-timer-start type="button">▶ Start</button>
        <button class="btn" data-timer-reset type="button">↺ Reset</button>
      </div>
    )
  }

  <div class="preview" data-preview aria-live="polite"></div>
  <p class="preview-hint no-print">
    Generate until it sings, then pin it — the result lands on your worksheet as an
    editable block you can rearrange and print from the Sheet Builder.
  </p>
</section>

<script>
  import { randomSeed } from '../engine/rng';
  import { addBlockToActive } from '../engine/sheetStore';
  import { renderBlockStatic } from '../engine/blockRender';
  import type { CompositeMeta, CompositeModule } from '../engine/composite';
  import type { Block, Table, TableRegistry } from '../engine/types';
  import { listWorlds, getWorld, putWorld } from '../engine/worldStore';
  import { blocksToEntity, kindForGenerator } from '../everdeep/adapters';
  import REGISTRY from '../everdeep/registry.json';

  const modules = import.meta.glob<CompositeModule>('../composites/*.ts');
  const registries = import.meta.glob<Record<string, Table>>('../generators/registries/*.json', {
    import: 'default',
  });

  async function setup(root: HTMLElement) {
    const metaEl = root.querySelector('script[data-meta]');
    if (!metaEl?.textContent) return;
    const meta: CompositeMeta = JSON.parse(metaEl.textContent);
    const tool = meta.id.split('/')[1];

    const loadModule = modules[`../composites/${tool}.ts`];
    const loadRegistry = registries[`../generators/registries/${tool}.json`];
    if (!loadModule || !loadRegistry) {
      console.error(`Missing module or registry for "${meta.id}" — run npm run registries`);
      return;
    }
    const [{ build }, registry] = await Promise.all([loadModule(), loadRegistry()]);
    const tables: TableRegistry = new Map(Object.entries(registry));

    const preview = root.querySelector<HTMLElement>('[data-preview]')!;
    const selects = [...root.querySelectorAll<HTMLSelectElement>('select[data-opt]')];
    let blocks: Block[] = [];
    let seed = '';

    function generate() {
      seed = randomSeed();
      const opts: Record<string, string> = {};
      for (const sel of selects) opts[sel.dataset.opt!] = sel.value;
      blocks = build(tables, seed, opts);
      preview.replaceChildren(...blocks.map((b) => renderBlockStatic(b)));
    }

    root.querySelector('[data-generate]')?.addEventListener('click', generate);
    for (const sel of selects) sel.addEventListener('change', generate);

    setupTimer(root, selects);

    root.querySelector('[data-add]')?.addEventListener('click', (ev) => {
      if (!blocks.length) return;
      for (const block of blocks) {
        const copy: Block = structuredClone(block);
        copy.id = `pin-${randomSeed()}`;
        copy.source = { generator: meta.id, seed };
        addBlockToActive(copy);
      }
      const btn = ev.currentTarget as HTMLButtonElement;
      const original = btn.textContent;
      btn.textContent = '✓ Added';
      setTimeout(() => (btn.textContent = original), 900);
    });

    // Save this result as a permanent page in one of the user's worlds —
    // the generation→wiki bridge (Everdeep Phase B).
    const savePanel = root.querySelector<HTMLElement>('[data-world-save]');
    const worldPick = root.querySelector<HTMLSelectElement>('[data-world-pick]');
    const parentPick = root.querySelector<HTMLSelectElement>('[data-parent-pick]');
    const saveStatus = root.querySelector<HTMLElement>('[data-world-status]');
    const esc = (s: string) => s.replace(/</g, '&lt;');
    // parents legal for this generator's kind, per the registry containment rules
    const savedKind = kindForGenerator(meta.id);
    const canHold = new Set(
      REGISTRY.kinds.filter((k) => (k.childKinds ?? []).includes(savedKind)).map((k) => k.id),
    );
    const iconOf = (kind: string) => REGISTRY.kinds.find((k) => k.id === kind)?.icon ?? '';
    async function fillParents(): Promise<void> {
      if (!worldPick?.value || !parentPick) return;
      const world = await getWorld(worldPick.value);
      const options = Object.values(world?.entities ?? {})
        .filter((en) => !en.deleted && canHold.has(en.kind))
        .sort((a, b) => a.name.localeCompare(b.name))
        .map((en) => `<option value="${en.id}">${iconOf(en.kind)} ${esc(en.name)}</option>`);
      parentPick.innerHTML = `<option value="">— top level —</option>` + options.join('');
    }
    root.querySelector('[data-save-world]')?.addEventListener('click', async () => {
      if (!blocks.length || !savePanel || !worldPick) return;
      const worlds = await listWorlds();
      if (!worlds.length) {
        window.location.href = '/world/';
        return;
      }
      worldPick.innerHTML = worlds
        .map((w) => `<option value="${w.id}">${esc(w.name)}</option>`)
        .join('');
      await fillParents();
      if (saveStatus) saveStatus.textContent = `saves a new ${savedKind} page`;
      savePanel.hidden = false;
    });
    worldPick?.addEventListener('change', () => void fillParents());
    root.querySelector('[data-world-cancel]')?.addEventListener('click', () => {
      if (savePanel) savePanel.hidden = true;
    });
    root.querySelector('[data-world-confirm]')?.addEventListener('click', async () => {
      if (!blocks.length || !worldPick?.value) return;
      const world = await getWorld(worldPick.value);
      if (!world) return;
      const entity = blocksToEntity(meta.id, seed, blocks, meta.title, parentPick?.value || undefined);
      world.entities[entity.id] = entity;
      await putWorld(world);
      if (saveStatus) {
        const home = parentPick?.value ? world.entities[parentPick.value]?.name : world.name;
        saveStatus.innerHTML =
          `✓ Saved — <a href="/world/#${entity.id}">open “${esc(entity.name)}” in ${esc(home ?? world.name)}</a>`;
      }
    });

    generate();
  }

  // Countdown timer for timed exercises (writing challenge). Reads its minutes
  // from the select whose id matches meta.timer.
  function setupTimer(root: HTMLElement, selects: HTMLSelectElement[]) {
    const timer = root.querySelector<HTMLElement>('[data-timer]');
    if (!timer) return;
    const optId = timer.dataset.timerOpt!;
    const source = selects.find((s) => s.dataset.opt === optId);
    const clock = timer.querySelector<HTMLElement>('[data-timer-clock]')!;
    let remaining = 0;
    let handle: ReturnType<typeof setInterval> | null = null;

    const minutes = () => Math.max(1, parseInt(source?.value ?? '10', 10) || 10);
    const paint = () => {
      const m = Math.floor(remaining / 60);
      const s = remaining % 60;
      clock.textContent = `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      timer.classList.toggle('timer-done', remaining === 0 && handle === null);
    };
    const stop = () => {
      if (handle) clearInterval(handle);
      handle = null;
    };
    const reset = () => {
      stop();
      remaining = minutes() * 60;
      paint();
    };
    const startBtn = timer.querySelector<HTMLButtonElement>('[data-timer-start]')!;
    startBtn.addEventListener('click', () => {
      if (handle) {
        stop();
        startBtn.textContent = '▶ Resume';
        return;
      }
      if (remaining === 0) remaining = minutes() * 60;
      startBtn.textContent = '❚❚ Pause';
      handle = setInterval(() => {
        remaining = Math.max(0, remaining - 1);
        paint();
        if (remaining === 0) {
          stop();
          startBtn.textContent = '▶ Start';
          timer.classList.add('timer-done');
        }
      }, 1000);
    });
    timer.querySelector('[data-timer-reset]')?.addEventListener('click', () => {
      reset();
      startBtn.textContent = '▶ Start';
    });
    source?.addEventListener('change', () => {
      if (!handle) reset();
    });
    reset();
  }

  document.querySelectorAll<HTMLElement>('[data-composite]').forEach(setup);
</script>

<style>
  .gen-toolbar {
    display: flex;
    align-items: end;
    gap: var(--space-3);
    margin-block: var(--space-6);
    flex-wrap: wrap;
  }

  .opt {
    display: grid;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }

  .opt select {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-ink);
    font-size: var(--text-base);
  }

  .preview-hint {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    max-width: 40rem;
    margin-top: var(--space-4);
  }

  .composite-note {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    font-style: italic;
    margin-block: var(--space-3);
    max-width: 42rem;
  }

  .timer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-block: var(--space-4);
    flex-wrap: wrap;
  }

  .timer-clock {
    font-size: 2rem;
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    color: var(--color-ink);
    min-width: 4.5ch;
  }

  .timer-done .timer-clock {
    color: var(--color-accent);
  }
</style>

<style is:global>
  /* Preview blocks are runtime-rendered — global styles, scoped under .composite */
  .composite .preview {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: var(--space-6) var(--space-8);
    max-width: 46rem;
  }

  .composite .preview h2,
  .composite .preview h3 {
    color: var(--color-statblock);
  }

  .composite .preview .b {
    margin-block: var(--space-3);
  }

  .composite .preview .b-rule {
    height: 3px;
    background: var(--color-statblock-rule);
    clip-path: polygon(0 0, 100% 0, 99% 100%, 1% 100%);
    margin-block: var(--space-2) var(--space-3);
  }

  .composite .preview .b-label {
    font-style: italic;
    color: var(--color-statblock);
  }

  .composite .preview table {
    border-collapse: collapse;
  }

  .composite .preview th,
  .composite .preview td {
    border: 1px solid var(--color-border);
    padding: var(--space-1) var(--space-2);
    text-align: left;
  }

  @media print {
    .composite .preview {
      border: none;
      box-shadow: none;
      padding: 0;
      max-width: none;
    }
  }
</style>
