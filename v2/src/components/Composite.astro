    border-radius: 9px; padding: 4px; box-shadow: 1px 2px 5px #0002; transform: rotate(0.8deg); margin: 0 0 10px 14px; }
  .preview :global(.npc-portrait svg) { display: block; width: 100%; height: auto; }

  /* Per-part controls: a 🎲 (reroll) + 🔒 (lock) sit at the corner of the name
     and each section, so you can reroll one piece — or pin it so "Generate"
     keeps it — without touching the rest. Subtle by default (usable on touch,
     where there is no hover), full on hover/focus. Plain selectors — this whole
     block is already `is:global`, so a nested :global() would emit an invalid
     selector and the rules would be dropped. */
  .composite .preview .rr-host { position: relative; }
  /* Every host reserves the controls' corner, not just the name — without
     this the buttons sit ON the first line of a paragraph section and the
     text underneath them is unreadable. */
  .composite .preview .rr-host { padding-right: 3.8rem; }
  .composite .preview .rr-controls {
    position: absolute;
    top: 4px;
    right: 4px;
    display: inline-flex;
    gap: 3px;
  }
  .composite .preview .rr-btn,
  .composite .preview .rr-lock {
    min-width: 1.6rem;
    padding: 2px 5px;
    font-size: 0.85em;
    line-height: 1.4;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-ink-muted);
    cursor: pointer;
    opacity: 0.35;
