---
import WorldSavePanel from './WorldSavePanel.astro';
import type { GeneratorConfig, SlotConfig } from '../engine/types';

interface Props {
  config: GeneratorConfig;
}

const { config } = Astro.props;
// id for the mobile ⚙️ disclosure checkbox (same pattern as Composite.astro)
const moreId = `more-${config.id.replace(/\//g, '-')}`;

// ── One-page-sheet layout (presentation only — the slot LIST stays the seed
// contract; engine/generatorTemplate walks config.slots, never config.page) ──
// A config's `page` hints pick a lead (the big serif heading), a sub (the
// italic line under it), and named sections. Un-hinted configs still get the
// sheet: a slot literally named `name` leads (the same promotion the derived
// one-pager makes), and everything else flows into one adaptive-column band.
const byId = new Map(config.slots.map((s) => [s.id, s]));
const page = config.page ?? {};
const leadSlot = byId.get(page.lead ?? '') ?? byId.get('name');
const subSlot = byId.get(page.sub ?? '');

interface RenderSection {
  title?: string;
  columns?: boolean;
  slots: SlotConfig[];
}
const placed = new Set<string>();
if (leadSlot) placed.add(leadSlot.id);
if (subSlot) placed.add(subSlot.id);
const sections: RenderSection[] = (page.sections ?? []).map((sec) => ({
  title: sec.title,
  columns: sec.columns,
  slots: sec.slots.map((id) => byId.get(id)).filter((s): s is SlotConfig => !!s && !placed.has(s.id)),
}));
for (const sec of sections) for (const s of sec.slots) placed.add(s.id);
// Anything the hints forgot still renders — a new slot must never be silently
// invisible (the ToolCatalog orphan rule, applied to sheets).
const rest = config.slots.filter((s) => !placed.has(s.id));
if (rest.length) sections.push({ title: sections.length ? 'More' : undefined, columns: true, slots: rest });
---

<section class="generator" data-generator>
  <script type="application/json" data-config is:inline set:html={JSON.stringify(config)} />

  <!-- One status region for the whole panel: a single announcement on reroll /
       "Roll everything", instead of every slot being its own live region and
       firing ~22 announcements at once. -->
  <p class="sr-only" data-status aria-live="polite"></p>

  <div class="gen-toolbar no-print">
    <input type="checkbox" class="gen-more-box" id={moreId} />
    <button class="btn btn-primary" data-roll-all type="button">🎲 Roll everything</button>
    <label class="btn gen-more" for={moreId} data-more>⚙️ Tools</label>
    <div class="gen-extra">
      <button class="btn" data-copy-all type="button" title="Copy the whole result to your clipboard">📋 Copy</button>
      <button class="btn" data-link type="button" title="Copy a link that reproduces this exact set of rolls">🔗 Link</button>
      <button
        class="btn"
        data-full-page
        type="button"
        title="Open this result as an editable, printable page in the Sheet Builder — the same rolls, now a full document you can trim, reroll, and print."
      >
        📄 Full page →
      </button>
      <button class="btn" data-save-world type="button" title="Save this result as a page in one of your worlds">🌍 Save to world</button>
      <p class="gen-hint">
        The page below is one rollable sheet. Every underlined fragment is its own
        roll — click it to reroll just that piece. Hover a field for its 🎲 lock
        and pin controls; share the link to hand someone this exact page, or open
        it in the Sheet Builder to trim, reroll, and print.
      </p>
    </div>
  </div>

  <WorldSavePanel />

  <article class="sheet-page">
    {
      (leadSlot || subSlot) && (
        <header class="sheet-head">
          <div class="sheet-head-text">
            {leadSlot && (
              <div class="entry lead" data-slot={leadSlot.id} data-template={leadSlot.template}>
                <p class="entry-line">
                  <span class="slot-label sr-only">{leadSlot.label}</span>
                  <span class="slot-value" data-value>…</span>
                </p>
                <span class="slot-actions no-print">
                  <button class="act" data-reroll type="button" title={`Reroll ${leadSlot.label}`} aria-label={`Reroll ${leadSlot.label}`}>🎲</button>
                  <button class="act" data-lock type="button" title="Lock (skip on Roll everything)" aria-pressed="false" aria-label={`Lock ${leadSlot.label}`}>🔓</button>
                  <button class="act" data-pin type="button" title="Pin for the Sheet Builder" aria-label={`Pin ${leadSlot.label}`}>📌</button>
                  <button class="act" data-copy type="button" title="Copy to clipboard" aria-label={`Copy ${leadSlot.label}`}>📋</button>
                </span>
              </div>
            )}
            {subSlot && (
              <div class="entry sub" data-slot={subSlot.id} data-template={subSlot.template}>
                <p class="entry-line">
                  <span class="slot-label sr-only">{subSlot.label}</span>
                  <span class="slot-value" data-value>…</span>
                </p>
                <span class="slot-actions no-print">
                  <button class="act" data-reroll type="button" title={`Reroll ${subSlot.label}`} aria-label={`Reroll ${subSlot.label}`}>🎲</button>
                  <button class="act" data-lock type="button" title="Lock (skip on Roll everything)" aria-pressed="false" aria-label={`Lock ${subSlot.label}`}>🔓</button>
                  <button class="act" data-pin type="button" title="Pin for the Sheet Builder" aria-label={`Pin ${subSlot.label}`}>📌</button>
                  <button class="act" data-copy type="button" title="Copy to clipboard" aria-label={`Copy ${subSlot.label}`}>📋</button>
                </span>
              </div>
            )}
          </div>
          <!-- the NPC portrait mounts here at runtime, in the head's end column -->
        </header>
      )
    }
    {(leadSlot || subSlot) && <div class="sheet-rule" />}

    {
      sections.map((sec) => (
        <section class="sheet-sec">
          {sec.title && <h3 class="sec-head">{sec.title}</h3>}
          <div class:list={['sec-body', { cols: sec.columns }]}>
            {sec.slots.map((slot) => (
              <div class="entry" data-slot={slot.id} data-template={slot.template} data-render={slot.render}>
                <p class="entry-line">
                  <span class="slot-label">{slot.label}</span>
                  <span class="slot-value" data-value>…</span>
                </p>
                <span class="slot-actions no-print">
                  <button class="act" data-reroll type="button" title={`Reroll ${slot.label}`} aria-label={`Reroll ${slot.label}`}>🎲</button>
                  <button class="act" data-lock type="button" title="Lock (skip on Roll everything)" aria-pressed="false" aria-label={`Lock ${slot.label}`}>🔓</button>
                  <button class="act" data-pin type="button" title="Pin for the Sheet Builder" aria-label={`Pin ${slot.label}`}>📌</button>
                  <button class="act" data-copy type="button" title="Copy to clipboard" aria-label={`Copy ${slot.label}`}>📋</button>
                </span>
              </div>
            ))}
          </div>
        </section>
      ))
    }
  </article>
</section>

<script>
  import { randomSeed } from '../engine/rng';
  import { resolveTemplate, rerollNode, nodeText } from '../engine/roll';
  import type { RenderNode, CountNode, PickNode, RollNode } from '../engine/roll';
  import { slotSeeds } from '../engine/generatorTemplate';
  import { addBlockToActive } from '../engine/sheetStore';
  import { wireWorldSave } from '../everdeep/worldSave';
  import type { Block, GeneratorConfig, ParagraphBlock, StatblockBlock, Table, TableRegistry } from '../engine/types';

  // Per-generator registries: each tool's transitive table closure is its own
  // lazy chunk (built by scripts/gen-registries.mjs), so a page downloads only
  // the tables it can actually roll.
  const registries = import.meta.glob<Record<string, Table>>('../generators/registries/*.json', {
    import: 'default',
  });

  /** Render a node tree; every random node is a hoverable, rerollable fragment.
   *  Depth drives the underline tint so separately rerollable pieces read apart. */
  function renderNode(node: RenderNode, tables: TableRegistry, depth = 0): Node {
    if (node.kind === 'text') return document.createTextNode(node.text);

    const span = document.createElement('span');
    span.className = 'frag';
    span.dataset.depth = String(depth % 4);
    const sourceName =
      node.kind === 'count' ? 'Number' : node.kind === 'pick' ? 'Choice' : (node as RollNode).tableTitle;
    span.title = `${sourceName} — click to reroll this piece`;
    span.setAttribute('role', 'button');
    span.tabIndex = 0;

    if (node.kind === 'roll') {
      // a var-defining roll advertises its name so rerolls can harvest the
      // line's live bindings from the DOM (values reflect prior rerolls)
      if ((node as RollNode).varName) span.dataset.var = (node as RollNode).varName;
      for (const child of node.children) span.appendChild(renderNode(child, tables, depth + 1));
    } else {
      span.textContent = nodeText(node);
    }

    const reroll = (ev: Event) => {
      ev.stopPropagation();
      // the slot's text no longer matches its seed — a pin or share link
      // can't honestly claim to reproduce it (same caveat composites carry)
      const slotEl = span.closest<HTMLElement>('[data-slot]');
      if (slotEl) slotEl.dataset.diverged = '1';
      const bindings = new Map<string, string>();
      span.closest('[data-value]')?.querySelectorAll<HTMLElement>('[data-var]').forEach((el) => {
        if (el !== span && el.dataset.var) bindings.set(el.dataset.var, el.textContent ?? '');
      });
      const fresh = rerollNode(node as CountNode | PickNode | RollNode, tables, bindings);
      span.replaceWith(renderNode(fresh, tables, depth));
      // layout hints (wide entries, the stat card) re-derive from the new text
      slotEl?.dispatchEvent(new CustomEvent('stb:fragged', { bubbles: true }));
    };
    span.addEventListener('click', reroll);
    span.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter' || ev.key === ' ') {
        ev.preventDefault();
        reroll(ev);
      }
    });

    return span;
  }

  // ── The humanoid stat card ────────────────────────────────────────────────
  // A statblock slot's canonical value is one compact TEXT line
  // ("Guard (CR 1/8) — AC 16 (…) · HP 11 (…) · … · STR 13 DEX 12 …"), which is
  // what pin/copy/save-to-world/one-pager carry. On the sheet it renders as a
  // proper stat card. Parse, don't trust position: vitals are the AC/HP/Speed
  // parts, the abilities part is the one with all six scores, the rest are
  // skills/attacks/traits lines.
  const ABILITY_RE = /\b(STR|DEX|CON|INT|WIS|CHA)\s+(\d+)\b/g;
  function statCard(text: string): HTMLElement | null {
    const dash = text.indexOf('—');
    if (dash < 0) return null;
    const title = text.slice(0, dash).trim();
    const parts = text
      .slice(dash + 1)
      .split('·')
      .map((s) => s.trim())
      .filter(Boolean);
    const vitals: { k: string; v: string }[] = [];
    const abilities: { k: string; v: number }[] = [];
    const notes: string[] = [];
    for (const p of parts) {
      const abs = [...p.matchAll(ABILITY_RE)];
      if (abs.length === 6) {
        for (const a of abs) abilities.push({ k: a[1], v: Number(a[2]) });
        continue;
      }
      const vm = /^(AC|HP|Speed)\s+(.+)$/.exec(p);
      if (vm) vitals.push({ k: vm[1], v: vm[2] });
      else notes.push(p);
    }
    if (abilities.length !== 6) return null;

    const card = document.createElement('div');
    card.className = 'stat-card';
    // the raw line stays in the DOM (screen readers, copy, tests); the card is
    // its visual double
    card.setAttribute('aria-hidden', 'true');

    const name = document.createElement('div');
    name.className = 'stat-card-name';
    const tm = /^(.*?)\s*\((CR [^)]+)\)$/.exec(title);
    name.textContent = tm ? tm[1] : title;
    if (tm) {
      const cr = document.createElement('span');
      cr.className = 'stat-card-cr';
      cr.textContent = tm[2];
      name.appendChild(cr);
    }
    card.appendChild(name);

    if (vitals.length) {
      const row = document.createElement('div');
      row.className = 'stat-vitals';
      for (const { k, v } of vitals) {
        const cell = document.createElement('span');
        const b = document.createElement('b');
        b.textContent = k;
        cell.append(b, ` ${v}`);
        row.appendChild(cell);
      }
      card.appendChild(row);
    }

    // Reuse the Block Kit's statGrid look (global .b-statGrid CSS) so the
    // roller's ability boxes are pixel-identical to the character sheet's —
    // one visual language for a stat block, whichever surface built it (§7 P4).
    const gridWrap = document.createElement('div');
    gridWrap.className = 'b-statGrid';
    const grid = document.createElement('div');
    grid.className = 'statgrid';
    gridWrap.appendChild(grid);
    for (const { k, v } of abilities) {
      const box = document.createElement('span');
      box.className = 'stat-box';
      const label = document.createElement('span');
      label.className = 'stat-label';
      label.textContent = k;
      const value = document.createElement('span');
      value.className = 'stat-value';
      value.textContent = String(v);
      const mod = Math.floor((v - 10) / 2);
      const sub = document.createElement('span');
      sub.className = 'stat-sub';
      sub.textContent = (mod >= 0 ? '+' : '−') + Math.abs(mod);
      box.append(label, value, sub);
      grid.appendChild(box);
    }
    card.appendChild(gridWrap);

    for (const note of notes) {
      const line = document.createElement('div');
      line.className = 'stat-note';
      line.textContent = note;
      card.appendChild(line);
    }
    return card;
  }

  async function setup(root: HTMLElement) {
    const configEl = root.querySelector('script[data-config]');
    if (!configEl?.textContent) return;
    const config: GeneratorConfig = JSON.parse(configEl.textContent);

    const status = root.querySelector<HTMLElement>('[data-status]');
    const announce = (msg: string) => { if (status) status.textContent = msg; };
    const labelOf = (el: HTMLElement) =>
      config.slots.find((s) => s.id === el.dataset.slot)?.label ?? 'Field';

    const tool = config.id.split('/')[1];
    const loadRegistry = registries[`../generators/registries/${tool}.json`];
    if (!loadRegistry) {
      console.error(`No registry for generator "${config.id}" — run npm run registries`);
      return;
    }
    const tables: TableRegistry = new Map(Object.entries(await loadRegistry()));

    /** Re-derive an entry's presentation from its current text: wide entries
     *  span a columns band, and a statblock slot rebuilds its stat card. The
     *  single choke point for both rollSlot() and fragment rerolls. */
    function decorate(el: HTMLElement) {
      const out = el.querySelector<HTMLElement>('[data-value]');
      if (!out) return;
      const text = out.textContent ?? '';
      if (el.closest('.sec-body')?.classList.contains('cols')) {
        el.classList.toggle('wide', text.length > 130);
      }
      if (el.dataset.render === 'statblock') {
        el.querySelector('.stat-card')?.remove();
        const card = statCard(text);
        el.classList.toggle('has-card', !!card);
        if (card) el.appendChild(card);
      }
    }
    root.addEventListener('stb:fragged', (e) => {
      const el = e.target;
      if (el instanceof HTMLElement) decorate(el);
    });

    // a face for the roll: when a race slot names someone, sketch them —
    // updates on every roll AND on fragment rerolls inside the slot
    const raceSlot = root.querySelector<HTMLElement>('[data-slot="race"]');
    let portraitBox: HTMLElement | null = null;
    let sketchBox: HTMLElement | null = null;
    let faceSalt = '';
    async function updatePortrait() {
      if (!raceSlot) return;
      const text = raceSlot.querySelector('[data-value]')?.textContent ?? '';
      const m = /Race:\s*([A-Za-z -]+?)\s*(?:\(\s*(male|female)\s*\))?\s*\./.exec(text);
      if (!m) return;
      const { buildPortraitSVG, defaultRecipe, knownRace } = await import('../everdeep/portraits');
      const race = knownRace(m[1]);
      if (!race) return;
      if (!portraitBox || !sketchBox) {
        portraitBox = document.createElement('div');
        portraitBox.className = 'npc-portrait';
        // the card must CONTAIN its button — as a sibling the button once
        // rendered as its own full-width row (pinned by rollers e2e)
        sketchBox = document.createElement('div');
        portraitBox.appendChild(sketchBox);
        // reroll the LOOK only — the rolled race and gender hold
        const faceBtn = document.createElement('button');
        faceBtn.type = 'button';
        faceBtn.textContent = '🎲 new face';
        faceBtn.style.cssText = 'display:block;width:100%;margin-top:3px;font-size:11px;padding:2px 4px;cursor:pointer;';
        faceBtn.addEventListener('click', () => { faceSalt = Math.random().toString(36).slice(2, 8); void updatePortrait(); });
        portraitBox.appendChild(faceBtn);
        // the sheet head's end column is the portrait's home; a page whose
        // race slot sits in the body just floats it at the page corner
        const head = root.querySelector<HTMLElement>('.sheet-head');
        (head ?? raceSlot.parentElement)?.appendChild(portraitBox);
      }
      const pSeed = (raceSlot.dataset.seed ?? text) + (faceSalt ? '/face:' + faceSalt : '');
      sketchBox.innerHTML = buildPortraitSVG(defaultRecipe(pSeed, race, (m[2] as 'male' | 'female') ?? null), pSeed);
      const svgEl = sketchBox.querySelector('svg');
      if (svgEl) { svgEl.style.display = 'block'; svgEl.style.width = '100%'; svgEl.style.height = 'auto'; }
    }
    if (raceSlot) new MutationObserver(() => void updatePortrait()).observe(raceSlot, { childList: true, subtree: true, characterData: true });

    // ── The page seed model (GM/solo audit, batch B) ──────────────────────
    // One page seed; every slot rolls from slotSeeds() — the SAME derivation
    // /sheet/?template=&seed= fills the one-pager with — so 📄 Full page and
    // 🔗 Link both reproduce exactly what's on screen. A hand-rerolled slot
    // gets its own seed, carried in the `ov` hash param. (Fragment-level
    // rerolls inside a slot aren't captured — the composite's caveat too.)
    let pageSeed = '';
    let derived = new Map<string, string>();
    let overrides: Record<string, string> = {};

    function writeHash(): void {
      const params = new URLSearchParams();
      params.set('seed', pageSeed);
      if (Object.keys(overrides).length) params.set('ov', JSON.stringify(overrides));
      history.replaceState(null, '', '#' + params.toString());
    }
    function readShared(): { seed: string; ov: Record<string, string> } | null {
      const raw = location.hash.replace(/^#/, '');
      if (!raw) return null;
      const params = new URLSearchParams(raw);
      const s = params.get('seed');
      if (!s) return null;
      let ov: Record<string, string> = {};
      try {
        ov = JSON.parse(params.get('ov') ?? '{}') as Record<string, string>;
      } catch {
        ov = {}; // malformed override state — fall back to the base derivation
      }
      return { seed: s, ov };
    }

    function rollSlot(el: HTMLElement, seed: string) {
      el.dataset.seed = seed;
      delete el.dataset.diverged;
      const nodes = resolveTemplate(el.dataset.template ?? '', tables, seed);
      const out = el.querySelector<HTMLElement>('[data-value]');
      if (!out) return;
      out.replaceChildren(...nodes.map((n) => renderNode(n, tables)));
      decorate(el);
    }

    const shared = readShared();
    pageSeed = shared?.seed ?? randomSeed();
    overrides = shared?.ov ?? {};
    derived = slotSeeds(config, pageSeed);

    for (const el of root.querySelectorAll<HTMLElement>('[data-slot]')) {
      const lockBtn = el.querySelector<HTMLButtonElement>('[data-lock]');

      el.querySelector('[data-reroll]')?.addEventListener('click', () => {
        const fresh = randomSeed();
        overrides[el.dataset.slot!] = fresh;
        rollSlot(el, fresh);
        writeHash();
        announce(`${labelOf(el)}: ${el.querySelector('[data-value]')?.textContent ?? ''}`);
      });

      lockBtn?.addEventListener('click', () => {
        const locked = el.dataset.locked === 'true';
        el.dataset.locked = String(!locked);
        lockBtn.textContent = locked ? '🔓' : '🔒';
        lockBtn.setAttribute('aria-pressed', String(!locked));
      });

      el.querySelector('[data-pin]')?.addEventListener('click', (ev) => {
        const slotId = el.dataset.slot;
        const slot = config.slots.find((s) => s.id === slotId);
        const text = el.querySelector('[data-value]')?.textContent ?? '';
        if (!slot || !text || text === '…') return;
        const block: ParagraphBlock = {
          type: 'paragraph',
          label: slot.label,
          text,
          id: `pin-${randomSeed()}`,
          // a fragment-rerolled slot's seed no longer reproduces its text —
          // record no seed rather than a lying one
          source: { generator: `${config.id}#${slot.id}`, seed: el.dataset.diverged ? undefined : el.dataset.seed },
        };
        addBlockToActive(block);
        const btn = ev.currentTarget as HTMLButtonElement;
        btn.textContent = '✓';
        setTimeout(() => (btn.textContent = '📌'), 900);
      });

      el.querySelector('[data-copy]')?.addEventListener('click', (ev) => {
        const text = el.querySelector('[data-value]')?.textContent ?? '';
        if (!text || text === '…') return;
        const btn = ev.currentTarget as HTMLButtonElement;
        void navigator.clipboard
          ?.writeText(text)
          .then(() => {
            btn.textContent = '✓';
            setTimeout(() => (btn.textContent = '📋'), 900);
          })
          .catch(() => {});
      });

      rollSlot(el, overrides[el.dataset.slot!] ?? derived.get(el.dataset.slot!) ?? pageSeed);
    }
    writeHash();

    root.querySelector('[data-roll-all]')?.addEventListener('click', () => {
      pageSeed = randomSeed();
      derived = slotSeeds(config, pageSeed);
      const kept: Record<string, string> = {};
      let n = 0;
      for (const el of root.querySelectorAll<HTMLElement>('[data-slot]')) {
        const id = el.dataset.slot!;
        if (el.dataset.locked === 'true') {
          // a locked slot keeps its roll — its seed rides on as an override
          // of the fresh page seed
          if (el.dataset.seed) kept[id] = el.dataset.seed;
        } else {
          rollSlot(el, derived.get(id) ?? pageSeed);
          n++;
        }
      }
      overrides = kept;
      writeHash();
      announce(`Rolled ${n} field${n === 1 ? '' : 's'}.`);
    });

    root.querySelector('[data-copy-all]')?.addEventListener('click', (ev) => {
      const lines: string[] = [];
      for (const el of root.querySelectorAll<HTMLElement>('[data-slot]')) {
        const value = el.querySelector('[data-value]')?.textContent ?? '';
        if (value && value !== '…') lines.push(`${labelOf(el)}: ${value}`);
      }
      if (!lines.length) return;
      const btn = ev.currentTarget as HTMLButtonElement;
      const original = btn.textContent;
      void navigator.clipboard
        ?.writeText(`${config.title}\n\n${lines.join('\n')}`)
        .then(() => {
          btn.textContent = '✓ Copied';
          setTimeout(() => (btn.textContent = original), 900);
        })
        .catch(() => {});
    });

    root.querySelector('[data-link]')?.addEventListener('click', (ev) => {
      const btn = ev.currentTarget as HTMLButtonElement;
      const original = btn.textContent;
      void navigator.clipboard
        ?.writeText(location.href)
        .then(() => {
          btn.textContent = '✓ Link copied';
          setTimeout(() => (btn.textContent = original), 1200);
        })
        .catch(() => {});
    });

    // Open in the Sheet Builder CARRYING the rolls: instantiate() fills the
    // derived one-pager from `${seed}:${n}` — the very seeds this page rolled
    // from — so what opens is what you see. (Slots hand-rerolled here ride
    // only on this page's own link, not through the template bridge.)
    root.querySelector('[data-full-page]')?.addEventListener('click', () => {
      const params = new URLSearchParams();
      params.set('template', config.id);
      params.set('seed', pageSeed);
      location.href = `/sheet/?${params.toString()}`;
    });

    // Save to a world as a permanent page: the same statblock shape the
    // derived one-pager uses — name slot as the page name, the rest as
    // sections — so the wiki page reads like the sheet would.
    function currentBlocks(): Block[] {
      const sections: StatblockBlock['sections'] = [];
      let name = config.title;
      let hasName = false;
      for (const el of root.querySelectorAll<HTMLElement>('[data-slot]')) {
        const slot = config.slots.find((s) => s.id === el.dataset.slot);
        const text = el.querySelector('[data-value]')?.textContent?.trim() ?? '';
        if (!slot || !text || text === '…') continue;
        if (slot.id === 'name') {
          name = text;
          hasName = true;
        } else {
          sections.push({ type: 'paragraph', label: slot.label, text });
        }
      }
      if (!sections.length && !hasName) return [];
      const sb: StatblockBlock = {
        type: 'statblock',
        name,
        ...(hasName ? { meta: config.title } : {}),
        sections,
      };
      return [sb];
    }
    wireWorldSave(root, {
      generatorId: config.id,
      fallbackName: config.title,
      getBlocks: currentBlocks,
      getSeed: () => pageSeed,
      genPrefix: 'generator',
    });
  }

  document.querySelectorAll<HTMLElement>('[data-generator]').forEach(setup);
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .gen-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-block: var(--space-4);
    flex-wrap: wrap;
  }

  .gen-hint {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    max-width: 40rem;
  }

  /* Mobile ⚙️ disclosure — the same pattern (and reasons) as Composite.astro:
     the state box never renders, the wrapper dissolves on desktop, and at
     phone widths the rolls come first with the tools behind ⚙️ (batch F). */
  .gen-more-box {
    display: none;
  }
  .gen-extra {
    display: contents;
  }
  .gen-more {
    display: none;
  }

  @media (max-width: 40rem) {
    .gen-toolbar {
      align-items: stretch;
      margin-block: var(--space-4);
    }
    .gen-toolbar > [data-roll-all] {
      flex: 1 1 auto;
    }
    .gen-more {
      display: inline-flex;
      align-items: center;
    }
    .gen-extra {
      display: none;
      flex: 1 1 100%;
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-2);
    }
    .gen-more-box:checked ~ .gen-extra {
      display: flex;
    }
  }

  /* ── The sheet: one designed, rollable page ─────────────────────────── */
  .sheet-page {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: var(--space-6) var(--space-8);
    max-width: 50rem;
  }

  .sheet-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-4);
    align-items: start;
  }

  .sheet-head-text {
    display: grid;
    gap: var(--space-1);
    align-content: start;
  }

  .sheet-rule {
    height: 3px;
    background: var(--color-statblock-rule);
    clip-path: polygon(0 0, 100% 0, 99% 100%, 1% 100%);
    margin-block: var(--space-2) var(--space-3);
  }

  .sec-head {
    font-family: var(--font-display);
    font-variant: small-caps;
    letter-spacing: 0.04em;
    font-weight: 600;
    color: var(--color-statblock);
    font-size: var(--text-lg);
    margin: var(--space-4) 0 var(--space-2);
    padding-bottom: 2px;
    border-bottom: 1px solid var(--color-statblock-rule);
  }

  .sec-body {
    display: grid;
    gap: var(--space-2) var(--space-6);
  }

  .sec-body.cols {
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
  }

  /* an entry whose text runs long spans the whole band (set at runtime) */
  .sec-body.cols :global(.entry.wide) {
    grid-column: 1 / -1;
  }

  /* ── Entries: run-in "Label. Value" lines, statblock style ──────────── */
  .entry {
    position: relative;
  }

  .entry-line {
    margin: 0;
  }

  .slot-label {
    font-weight: 700;
    font-style: italic;
    color: var(--color-statblock);
  }

  .slot-label::after {
    content: '. ';
  }

  .entry[data-locked='true'] {
    background: color-mix(in srgb, var(--color-accent) 7%, transparent);
    border-radius: var(--radius);
  }

  .entry.lead :global(.slot-value) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-statblock);
  }

  .entry.sub :global(.slot-value) {
    font-style: italic;
    color: var(--color-ink-muted);
  }

  /* Per-field controls in the composites' rr-controls manner, but with zero
     footprint: invisible until the field is hovered or focused, then a
     solid-backed strip over the line's end. Opacity only — never
     `pointer-events: none`, which breaks hit-testing for anything that probes
     before hovering (Playwright's actionability check, some ATs); a mouse is
     always hovering by the time it clicks, so invisible-but-clickable is safe.
     Touch devices, which can't hover, keep the strip faintly visible. */
  .slot-actions {
    position: absolute;
    top: -3px;
    right: 0;
    display: inline-flex;
    gap: 2px;
    opacity: 0;
    background: var(--color-surface);
    border-radius: var(--radius);
    box-shadow: 0 0 0 4px var(--color-surface);
    transition: opacity 0.12s ease;
  }

  .entry:hover .slot-actions,
  .entry:focus-within .slot-actions,
  .entry[data-locked='true'] .slot-actions {
    opacity: 1;
  }

  @media (hover: none) {
    .slot-actions {
      opacity: 0.45;
    }
  }

  .slot-actions .act {
    min-width: 1.5rem;
    padding: 1px 4px;
    font-size: 0.8em;
    line-height: 1.4;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-ink-muted);
    cursor: pointer;
  }

  .slot-actions .act:hover {
    border-color: var(--color-accent);
  }

  .entry[data-locked='true'] .slot-actions [data-lock] {
    opacity: 1;
    border-color: var(--color-accent);
  }

  /* a statblock entry hides its raw line behind the card (still in the DOM
     for copy/pin/screen readers); parse failure leaves the text visible */
  .entry.has-card .entry-line {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 40rem) {
    .sheet-page {
      padding: var(--space-4);
    }

    .entry {
      padding-right: 0;
    }

    .slot-actions {
      position: static;
      display: flex;
      justify-content: flex-end;
      opacity: 0.45;
    }
  }

  @media print {
    .sheet-page {
      border: none;
      box-shadow: none;
      padding: 0;
      max-width: none;
    }
  }
</style>

<style is:global>
  /* Fragments are created at runtime, so these styles must be global.
     Each nesting depth gets its own underline tint, and nested borders stack
     (child line above parent line), so separately rerollable pieces are
     visible before you ever hover. */
  .frag {
    --frag-color: var(--color-accent);
    cursor: pointer;
    border-bottom: 1px dotted var(--frag-color);
    padding-bottom: 1px;
    border-radius: 2px;
  }

  .frag[data-depth='1'] { --frag-color: #0d9488; }
  .frag[data-depth='2'] { --frag-color: #d97706; }
  .frag[data-depth='3'] { --frag-color: #db2777; }

  :root[data-theme='dark'] .frag[data-depth='1'],
  :root:not([data-theme='light']) .frag[data-depth='1'] { --frag-color: #2dd4bf; }
  :root[data-theme='dark'] .frag[data-depth='2'],
  :root:not([data-theme='light']) .frag[data-depth='2'] { --frag-color: #fbbf24; }
  :root[data-theme='dark'] .frag[data-depth='3'],
  :root:not([data-theme='light']) .frag[data-depth='3'] { --frag-color: #f472b6; }

  @media (prefers-color-scheme: light) {
    :root:not([data-theme='dark']) .frag[data-depth='1'] { --frag-color: #0d9488; }
    :root:not([data-theme='dark']) .frag[data-depth='2'] { --frag-color: #d97706; }
    :root:not([data-theme='dark']) .frag[data-depth='3'] { --frag-color: #db2777; }
  }

  /* Fallback for browsers without :has(): hovered chain gets a solid line. */
  .frag:hover {
    border-bottom-style: solid;
  }

  /* Precise highlight: ONLY the innermost fragment under the cursor — the one
     a click will actually reroll — gets the background wash. */
  .frag:hover:not(:has(.frag:hover)),
  .frag:focus-visible {
    background: color-mix(in srgb, var(--frag-color) 18%, transparent);
    border-bottom-width: 2px;
    padding-bottom: 0;
  }

  @media print {
    .frag {
      border-bottom: none;
    }
  }

  /* The portrait card mounts in the sheet head's end column at runtime. */
  .generator .npc-portrait {
    width: 138px;
    justify-self: end;
    background: #faf6ea;
    border: 1px solid #d8d0bc;
    border-radius: 9px;
